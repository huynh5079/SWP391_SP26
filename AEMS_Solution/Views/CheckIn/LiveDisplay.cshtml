@{
    Layout = null;
    var eventId = ViewBag.EventId as string;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AEMS - Live Welcome Display</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="~/images/aems-logo.png" />
    
    <style>
        :root {
            --primary-accent: #6366f1;
            --secondary-accent: #a855f7;
            --primary-gradient: linear-gradient(135deg, var(--primary-accent) 0%, var(--secondary-accent) 100%);
            --glass-bg: rgba(15, 23, 42, 0.4);
            --glass-border: rgba(255, 255, 255, 0.1);
        }

        body, html {
            height: 100%;
            margin: 0;
            overflow: hidden;
            font-family: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif;
            background-color: #020617;
            color: #fff;
        }

        .background-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(rgba(2, 6, 23, 0.8), rgba(2, 6, 23, 0.95)), 
                        url('@(string.IsNullOrEmpty(ViewBag.ThumbnailUrl as string) ? "https://images.unsplash.com/photo-1492684223066-81342ee5ff30?q=80&w=2070&auto=format&fit=crop" : ViewBag.ThumbnailUrl)');
            background-size: cover;
            background-position: center;
            filter: blur(80px); /* Tăng độ mờ để làm nền mượt hơn */
            transform: scale(1.2);
            z-index: -1;
            transition: background-image 1.5s ease-in-out;
        }

        .main-wrapper {
            height: 100vh;
            display: flex;
            flex-direction: column;
            position: relative;
            z-index: 1;
        }

        /* Branding Top-Left */
        .branding-header {
            position: absolute;
            top: 3rem;
            left: 3rem;
            display: flex;
            align-items: center;
            gap: 1.5rem;
            z-index: 10;
        }

        .brand-logo-container {
            width: 80px;
            height: 80px;
            background: var(--primary-gradient);
            padding: 4px;
            border-radius: 20px;
            box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .brand-logo-container img {
            width: 100%;
            height: 100%;
            border-radius: 17px;
            object-fit: cover;
            display: block;
        }

        .brand-info h4 {
            font-size: 1.5rem;
            font-weight: 700;
            margin: 0;
            letter-spacing: -0.02em;
        }

        .brand-info span {
            font-size: 0.9rem;
            color: #94a3b8;
            letter-spacing: 0.05em;
        }

        /* Content Center */
        .central-view {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            padding: 0 10%;
        }

        .default-hero {
            text-align: center;
            max-width: 1200px;
        }

        .welcome-hint {
            font-size: 1.25rem;
            color: var(--secondary-accent);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.3em;
            margin-bottom: 1.5rem;
            display: block;
        }

        .event-title-main {
            font-size: 4.5rem;
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: 2rem;
            background: linear-gradient(to right, #ffffff, #94a3b8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Welcome Card */
        .welcome-card-glass {
            background: var(--glass-bg);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border: 1px solid var(--glass-border);
            border-radius: 40px;
            padding: 5rem;
            width: 100%;
            max-width: 1000px;
            display: none; /* Trạng thái ẩn mặc định */
            flex-direction: column;
            align-items: center;
            box-shadow: 0 50px 100px -20px rgba(0, 0, 0, 0.5);
            animation-duration: 0.6s;
        }

        .avatar-glow {
            width: 160px;
            height: 160px;
            border-radius: 50%;
            padding: 8px;
            background: var(--primary-gradient);
            position: relative;
            margin-bottom: 2rem;
        }

        .avatar-glow img {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
            border: 6px solid #020617;
        }

        .user-salutation {
            font-size: 2rem;
            color: #94a3b8;
            font-weight: 400;
            margin-bottom: 0.5rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .user-fullname {
            font-size: clamp(3rem, 8vw, 6rem); /* Tự động co giãn theo độ dài tên */
            font-weight: 800;
            line-height: 1;
            margin-bottom: 2rem;
            text-align: center;
        }

        .event-welcome-text {
            font-size: 1.5rem;
            color: #64748b;
        }

        .emoji-heart {
            font-size: 3.5rem;
            margin-top: 1rem;
            display: block;
        }

        /* Status & Footer */
        .connection-status {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.9rem;
            color: #475569;
            margin-top: 2rem;
        }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #22c55e;
            box-shadow: 0 0 10px #22c55e;
            animation: pulse-green 2s infinite;
        }

        @@keyframes pulse-green {
            0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7); }
            70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(34, 197, 94, 0); }
            100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
        }

        .footer-tag {
            position: absolute;
            bottom: 3rem;
            width: 100%;
            text-align: center;
            font-size: 0.75rem;
            letter-spacing: 0.5em;
            color: #334155;
            text-transform: uppercase;
        }
    </style>
</head>
<body>
    <div class="background-overlay" id="bg-overlay"></div>

    <div class="main-wrapper">
        <!-- Branding Corner -->
        <header class="branding-header">
            <div class="brand-logo-container">
                <img src="~/images/aems-logo.png" alt="AEMS Logo" />
            </div>
            <div class="brand-info">
                <h4>@(string.IsNullOrEmpty(ViewBag.EventTitle as string) ? "AEMS" : "Event Center")</h4>
                <span>LIVE CHECK-IN CONCIERGE</span>
            </div>
        </header>

        <!-- Default State -->
        <div id="default-view" class="default-state">
            <h1 class="display-3 fw-bold mb-2">Chào mừng đến với sự kiện 🎉</h1>
            @if (!string.IsNullOrEmpty(ViewBag.EventTitle as string))
            {
                <h2 class="display-5 fw-bold mb-4" style="color: #a5b4fc;">@ViewBag.EventTitle</h2>
            }
            <p class="lead text-muted">
                <span class="status-dot"></span> Sẵn sàng chào đón khách tham dự
            </p>
        </div>

        <!-- Welcome Card (Dynamic) -->
        <div id="welcome-card" class="welcome-card animate__animated d-flex flex-column align-items-center">
            <img id="display-avatar" src="" class="user-avatar" alt="Avatar" style="display: none;" />
            <div class="welcome-text">Chào mừng</div>
            <div id="display-name" class="user-name text-center">...</div>
            <div class="welcome-text text-center">đến với sự kiện <span class="emoji-float d-inline-block mt-2">🫶</span></div>
        </div>

        <footer class="footer-tag">
            Powered by AEMS Solutions &middot; Digital Concierge 2026
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <script>
        const eventId = '@eventId';
        const defaultView = document.getElementById('default-view');
        const welcomeCard = document.getElementById('welcome-card');
        const displayName = document.getElementById('display-name');
        const displayAvatar = document.getElementById('display-avatar');
        const avatarContainer = document.getElementById('avatar-container');
        const statusText = document.getElementById('conn-text');
        const bgOverlay = document.getElementById('bg-overlay');

        // Slideshow Engine
        const imageUrlsRaw = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ImageUrls ?? new List<string>()));
        const imageUrls = Array.isArray(imageUrlsRaw) && imageUrlsRaw.length > 0 ? imageUrlsRaw : [];
        
        if (imageUrls.length > 1) {
            let imgIdx = 0;
            setInterval(() => {
                imgIdx = (imgIdx + 1) % imageUrls.length;
                bgOverlay.style.backgroundImage = `linear-gradient(rgba(2, 6, 23, 0.8), rgba(2, 6, 23, 0.95)), url('${imageUrls[imgIdx]}')`;
            }, 10000);
        }

        // Realtime Connection
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hub/v1/notification")
            .withAutomaticReconnect()
            .build();

        async function start() {
            try {
                await connection.start();
                statusText.innerText = 'Đã kết nối với hệ thống';
                await connection.invoke("JoinEventGroup", eventId);
            } catch (err) {
                statusText.innerText = 'Đang thử kết nối lại...';
                setTimeout(start, 5000);
            }
        };

        connection.on("ReceiveCheckIn", (receivedEventId, fullName, message, avatarUrl) => {
            if (receivedEventId === eventId) {
                triggerWelcomeAnimation(fullName, avatarUrl);
            }
        });

        let currentTimeout = null;

        function triggerWelcomeAnimation(name, avatarUrl) {
            if (currentTimeout) clearTimeout(currentTimeout);

            displayName.innerText = name;
            
            if (avatarUrl) {
                displayAvatar.src = avatarUrl;
                avatarContainer.style.display = 'block';
            } else {
                avatarContainer.style.display = 'none';
            }
            
            // Hide Idle, Show Welcome
            defaultView.classList.remove('animate__fadeIn');
            defaultView.classList.add('animate__fadeOut');
            
            setTimeout(() => {
                defaultView.style.display = 'none';
                welcomeCard.style.display = 'flex';
                welcomeCard.classList.remove('animate__zoomOut');
                welcomeCard.classList.add('animate__zoomIn');
            }, 400);

            // Revert to Idle after 8 seconds
            currentTimeout = setTimeout(() => {
                welcomeCard.classList.remove('animate__zoomIn');
                welcomeCard.classList.add('animate__zoomOut');
                
                setTimeout(() => {
                    welcomeCard.style.display = 'none';
                    defaultView.style.display = 'block';
                    defaultView.classList.remove('animate__fadeOut');
                    defaultView.classList.add('animate__fadeIn');
                }, 600);
            }, 8000);
        }

        start();
    </script>
</body>
</html>
