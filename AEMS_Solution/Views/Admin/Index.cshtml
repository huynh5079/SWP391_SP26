@model AEMS_Solution.Models.Admin.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    // Layout = "_Layout"; // Configured in _ViewStart
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Hello, Admin!</h1>
            <p class="text-muted small">Here's what's happening with your system today.</p>
        </div>
        <div>
            <a href="@Url.Action("Index", "UserManagement")" class="btn btn-sm btn-primary shadow-sm me-2 mb-2">
                <i class="bi bi-people"></i> Manage Users
            </a>
            <a href="@Url.Action("Index", "Topic")" class="btn btn-sm btn-secondary shadow-sm me-2 mb-2">
                <i class="bi bi-tags"></i> Manage Topics
            </a>
            <a href="@Url.Action("Index", "Location")" class="btn btn-sm btn-success shadow-sm me-2 mb-2">
                <i class="bi bi-geo-alt"></i> Manage Locations
            </a>
            <a href="@Url.Action("Index", "Department")" class="btn btn-sm btn-dark shadow-sm me-2 mb-2">
                <i class="bi bi-buildings"></i> Manage Departments
            </a>
            <a href="@Url.Action("Index", "AdminNotification")" class="btn btn-sm btn-info text-white shadow-sm me-2 mb-2">
                <i class="bi bi-bell"></i> Manage Notifications
            </a>
            <a href="@Url.Action("Create", "AdminNotification")" class="btn btn-sm btn-warning shadow-sm me-2 mb-2">
                <i class="bi bi-megaphone"></i> Broadcast
            </a>
            <a href="@Url.Action("Index", "SystemLog")" class="btn btn-sm btn-outline-primary shadow-sm mb-2">
                <i class="bi bi-activity"></i> View System Logs
            </a>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row g-3 mb-4">
        <!-- Errors Today Card -->
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-danger shadow h-100 py-2 cursor-pointer" onclick="location.href='@Url.Action("Index", "SystemLog")'" style="border-left: 4px solid #dc3545; cursor: pointer;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">
                                System Errors (Today)
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalErrorsToday</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-exclamation-octagon display-6 text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Users Card -->
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2 cursor-pointer" onclick="location.href='@Url.Action("Index", "UserManagement")'" style="border-left: 4px solid #4e73df; cursor: pointer;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                Total Users
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalUsers</div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-people display-6 text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Total Students Card -->
        <div class="col-xl-3 col-md-6 mb-4">
             <div class="card border-left-info shadow h-100 py-2" style="border-left: 4px solid #36b9cc;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                             <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                Students
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalStudents</div>
                        </div>
                         <div class="col-auto">
                            <i class="bi bi-mortarboard display-6 text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Total Staff Card -->
        <div class="col-xl-3 col-md-6 mb-4">
             <div class="card border-left-success shadow h-100 py-2" style="border-left: 4px solid #1cc88a;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                             <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                Staff
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalStaff</div>
                        </div>
                         <div class="col-auto">
                            <i class="bi bi-person-badge display-6 text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Charts Row -->
    <div class="row">
        <!-- Error Trend Chart -->
        <div class="col-lg-8 mb-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                     <h6 class="m-0 font-weight-bold text-primary">System Errors (Last 7 Days)</h6>
                </div>
                <div class="card-body">
                    <div class="chart-area" style="position: relative; height: 300px; width: 100%;">
                         <canvas id="errorTrendChart"></canvas>
                    </div>
                     <small class="text-muted mt-2 d-block text-center fst-italic">Click on chart to view details</small>
                </div>
            </div>
        </div>
        
        <!-- User Distribution Chart -->
         <div class="col-lg-4 mb-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                     <h6 class="m-0 font-weight-bold text-primary">User Distribution</h6>
                </div>
                <div class="card-body">
                     <div class="chart-pie pt-4 pb-2" style="position: relative; height: 260px; width: 100%;">
                         <canvas id="userDistChart"></canvas>
                     </div>
                </div>
            </div>
         </div>
    </div>
</div>

@section Scripts {
    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        // --- Data ---
        var trendLabels = @Html.Raw(Json.Serialize(Model.ErrorTrendLabels));
        var trendData = @Html.Raw(Json.Serialize(Model.ErrorTrendData));
        
        var userLabels = @Html.Raw(Json.Serialize(Model.UserDistribution.Keys));
        var userData = @Html.Raw(Json.Serialize(Model.UserDistribution.Values));

        // --- Error Trend Chart (Line) ---
        var ctxTrend = document.getElementById("errorTrendChart").getContext('2d');
        var errorTrendChart = new Chart(ctxTrend, {
            type: 'line',
            data: {
                labels: trendLabels,
                datasets: [{
                    label: "System Errors",
                    lineTension: 0.3,
                    backgroundColor: "rgba(220, 53, 69, 0.05)",
                    borderColor: "rgba(220, 53, 69, 1)",
                    pointRadius: 3,
                    pointBackgroundColor: "rgba(220, 53, 69, 1)",
                    pointBorderColor: "rgba(220, 53, 69, 1)",
                    pointHoverRadius: 3,
                    pointHoverBackgroundColor: "rgba(220, 53, 69, 1)",
                    pointHoverBorderColor: "rgba(220, 53, 69, 1)",
                    pointHitRadius: 10,
                    pointBorderWidth: 2,
                    data: trendData,
                }],
            },
            options: {
                maintainAspectRatio: false,
                layout: { padding: { left: 10, right: 25, top: 25, bottom: 0 } },
                scales: {
                    x: { grid: { display: false, drawBorder: false }, ticks: { maxTicksLimit: 7 } },
                    y: { ticks: { maxTicksLimit: 5, padding: 10, callback: function(value) { return value; } }, grid: { color: "rgb(234, 236, 244)", zeroLineColor: "rgb(234, 236, 244)", drawBorder: false, borderDash: [2], zeroLineBorderDash: [2] } },
                },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: "rgb(255,255,255)",
                        bodyColor: "#858796",
                        titleMarginBottom: 10,
                        titleColor: '#6e707e',
                        titleFont: { size: 14 },
                        borderColor: '#dddfeb',
                        borderWidth: 1,
                        xPadding: 15,
                        yPadding: 15,
                        displayColors: false,
                        intersect: false,
                        mode: 'index',
                        caretPadding: 10,
                    }
                },
                onClick: (e) => {
                     window.location.href = '@Url.Action("Index", "SystemLog")';
                }
            }
        });

        // --- User Distribution Chart (Doughnut) ---
        var ctxUser = document.getElementById("userDistChart").getContext('2d');
        var userDistChart = new Chart(ctxUser, {
            type: 'doughnut',
            data: {
                labels: userLabels,
                datasets: [{
                    data: userData,
                    backgroundColor: ['#36b9cc', '#1cc88a', '#4e73df'],
                    hoverBackgroundColor: ['#2c9faf', '#17a673', '#2e59d9'],
                    hoverBorderColor: "rgba(234, 236, 244, 1)",
                }],
            },
            options: {
                maintainAspectRatio: false,
                plugins: {
                    tooltip: {
                        backgroundColor: "rgb(255,255,255)",
                        bodyColor: "#858796",
                        borderColor: '#dddfeb',
                        borderWidth: 1,
                        xPadding: 15,
                        yPadding: 15,
                        displayColors: false,
                        caretPadding: 10,
                    },
                     legend: { position: 'bottom' },
                },
                cutout: '70%',
                onClick: (e, activeElements) => {
                     // Redirect to User Management if exists, else do nothing (or show alert)
                     // window.location.href = '@Url.Action("Index", "UserManagement")'; 
                     // Assuming Controller is Admin and action is UserManagement (or similar)
                     // Since UserManagement controller is not explicitly defined in request, checking context...
                     // Can redirect to Student/Organizer Index based on slice clicked? Too complex for now.
                     // Just nice-to-have.
                }
            },
        });
    </script>
}
