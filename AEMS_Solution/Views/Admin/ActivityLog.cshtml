@model DataAccess.Entities.PaginationResult<DataAccess.Entities.UserActivityLog>
@{
    ViewData["Title"] = "System Activity Logs";
    Layout = "_AdminLayout";
}

<style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.75);
        --glass-border: rgba(255, 255, 255, 0.4);
        --indigo-gradient: linear-gradient(135deg, #6366f1 0%, #4338ca 100%);
        --executive-card-shadow: 0 15px 35px rgba(0, 0, 0, 0.05);
    }

    body {
        background: #f8fafc;
        font-family: 'Inter', -apple-system, sans-serif;
    }

    .ex-card {
        background: var(--glass-bg);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        box-shadow: var(--executive-card-shadow);
        overflow: hidden;
        transition: transform 0.3s ease;
    }

    .ex-header-gradient {
        background: var(--indigo-gradient);
        color: white;
        padding: 2.5rem 2rem;
        border-radius: 0 0 40px 40px;
        margin-bottom: -20px;
        position: relative;
        z-index: 1;
    }

    .table-ex {
        background: transparent;
    }

    .table-ex thead th {
        background: #f1f5f9;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.725rem;
        letter-spacing: 0.05em;
        color: #64748b;
        border: none;
        padding: 1.25rem 1rem;
    }

    .table-ex tbody tr {
        border-bottom: 1px solid #f1f5f9;
        transition: background 0.2s ease;
    }

    .table-ex tbody tr:hover {
        background: rgba(99, 102, 241, 0.03);
    }

    .action-badge {
        padding: 0.5rem 1rem;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .badge-create { background: #dcfce7; color: #15803d; }
    .badge-update { background: #fef9c3; color: #854d0e; }
    .badge-delete { background: #fee2e2; color: #b91c1c; }
    .badge-other  { background: #e0e7ff; color: #4338ca; }

    .user-avatar {
        width: 36px;
        height: 36px;
        border-radius: 12px;
        object-fit: cover;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    }

    .user-initial {
        width: 36px;
        height: 36px;
        border-radius: 12px;
        background: var(--indigo-gradient);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1rem;
    }

    .pagination-ex .page-link {
        border: none;
        border-radius: 10px;
        margin: 0 4px;
        font-weight: 600;
        color: #64748b;
        transition: all 0.2s;
    }

    .pagination-ex .page-item.active .page-link {
        background: var(--indigo-gradient) !important;
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.4);
    }

    .filter-pill {
        background: white !border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 0.6rem 1.25rem;
        font-size: 0.9rem;
        transition: all 0.2s;
    }

    .filter-pill:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
        outline: none;
    }

    .btn-clean {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        border: 1px solid rgba(239, 68, 68, 0.2);
        padding: 0.6rem 1.25rem;
        border-radius: 14px;
        font-weight: 700;
        transition: all 0.2s;
    }

    .btn-clean:hover {
        background: #ef4444;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(239, 68, 68, 0.3);
    }
</style>

<div class="ex-header-gradient shadow-lg">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="fw-800 mb-2" style="font-size: 2.25rem; letter-spacing: -0.03em;">Activity Intelligence</h1>
            <p class="mb-0 opacity-75">Monitoring system integrity and administrative workflow in real-time.</p>
        </div>
        <div>
            <form asp-action="DeleteOldLogs" method="post" id="cleanupForm">
                <button type="button" onclick="confirmCleanup()" class="btn-clean">
                    <i class="bi bi-shield-slash me-2"></i> Purge History
                </button>
            </form>
        </div>
    </div>
</div>

<div class="container-fluid px-4" style="margin-top: 40px; position: relative; z-index: 2;">
    <!-- Filters Row -->
    <div class="ex-card mb-4 p-4">
        <form method="get" class="row g-3">
            <div class="col-md-6">
                <div class="position-relative">
                    <i class="bi bi-search position-absolute text-muted" style="left: 1.25rem; top: 50%; transform: translateY(-50%);"></i>
                    <input type="text" name="search" class="filter-pill w-100 ps-5" placeholder="Search activities, users, or targets..." value="@Context.Request.Query["search"]">
                </div>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn w-100 py-2 fw-bold text-white shadow-sm" style="background: #0f172a; border-radius: 14px;">
                    Search Insights
                </button>
            </div>
            <div class="col-md-4 text-end">
                <div class="text-muted small fw-bold">COUNT: @Model.Data.Count() RECORD(S)</div>
            </div>
        </form>
    </div>

    <!-- Data Table -->
    <div class="ex-card mb-5">
        <div class="table-responsive">
            <table class="table table-ex align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Actor</th>
                        <th>Action Protocol</th>
                        <th style="min-width: 400px;">Outcome & Context</th>
                        <th class="text-end pe-4">Timestamp</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model.Data)
                    {
                        var badgeClass = log.ActionType.ToString().Contains("Create") ? "badge-create" :
                                         log.ActionType.ToString().Contains("Update") ? "badge-update" :
                                         log.ActionType.ToString().Contains("Delete") ? "badge-delete" : "badge-other";
                        
                        var icon = log.ActionType.ToString().Contains("Create") ? "bi-plus-circle-fill" :
                                   log.ActionType.ToString().Contains("Update") ? "bi-pencil-fill" :
                                   log.ActionType.ToString().Contains("Delete") ? "bi-trash3-fill" : "bi-lightning-charge-fill";

                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    @if (!string.IsNullOrEmpty(log.User?.AvatarUrl))
                                    {
                                        <img src="@log.User.AvatarUrl" class="user-avatar" alt="Avatar">
                                    }
                                    else
                                    {
                                        <div class="user-initial">
                                            @(log.User?.FullName?.Substring(0, 1).ToUpper() ?? "S")
                                        </div>
                                    }
                                    <div>
                                        <div class="fw-bold text-dark">@(log.User?.FullName ?? "System")</div>
                                        <div class="text-muted small">#@(log.UserId?.Substring(0, 8) ?? "root")</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="action-badge @badgeClass">
                                    <i class="bi @icon"></i>
                                    @log.ActionType
                                </span>
                            </td>
                            <td>
                                <div class="text-dark fw-medium" style="line-height: 1.5;">@log.Description</div>
                                @if (!string.IsNullOrEmpty(log.TargetId))
                                {
                                    <div class="text-muted mt-1" style="font-size: 0.75rem;">
                                        <i class="bi bi-hash"></i> Target Reference: <span class="badge bg-light text-dark fw-normal">@log.TargetId</span>
                                    </div>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="fw-bold text-indigo-900">@log.CreatedAt.ToString("HH:mm:ss")</div>
                                <div class="text-muted small">@log.CreatedAt.ToString("dd MMM yyyy")</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="card-footer bg-white border-top py-4 px-4 hstack justify-content-between">
            <div class="text-muted small fw-600">
                Page <span class="text-dark">@Model.PageNumber</span> of <span class="text-dark">@Model.TotalPages</span>
            </div>
            <nav>
                <ul class="pagination pagination-ex mb-0">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link shadow-none" href="@Url.Action("ActivityLog", new { page = Model.PageNumber - 1, search = Context.Request.Query["search"] })">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        if (i == 1 || i == Model.TotalPages || (i >= Model.PageNumber - 2 && i <= Model.PageNumber + 2))
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link shadow-none" href="@Url.Action("ActivityLog", new { page = i, search = Context.Request.Query["search"] })">@i</a>
                            </li>
                        }
                    }

                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link shadow-none" href="@Url.Action("ActivityLog", new { page = Model.PageNumber + 1, search = Context.Request.Query["search"] })">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmCleanup() {
            Swal.fire({
                title: 'Purge Activity Records?',
                text: "All operational logs older than 30 days will be permanently removed from high-speed storage.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Confirm Purge',
                cancelButtonText: 'Cancel',
                background: '#ffffff',
                borderRadius: '24px'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('cleanupForm').submit();
                }
            })
        }
    </script>
}
