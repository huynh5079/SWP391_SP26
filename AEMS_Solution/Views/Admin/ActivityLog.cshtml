@model DataAccess.Entities.PaginationResult<DataAccess.Entities.UserActivityLog>
@{
    ViewData["Title"] = "System Activity Logs";
    Layout = "_AdminLayout";
}

<div class="row mb-4 animate-fade-in">
    <div class="col-md-8">
        <h2 class="fw-800 text-indigo-900 mb-1">System Activity Logs</h2>
        <p class="text-muted">Track administrative actions and system-wide user interactions.</p>
    </div>
    <div class="col-md-4 text-md-end d-flex align-items-center justify-content-md-end">
        <form asp-action="DeleteOldLogs" method="post" onsubmit="return confirm('Are you sure you want to clean up logs older than 30 days?');">
            <button type="submit" class="btn btn-outline-danger shadow-sm py-2 px-4" style="border-radius: 10px; font-weight: 600;">
                <i class="bi bi-trash3-fill me-2"></i> Clean Up Old Logs
            </button>
        </form>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 12px; background-color: #f0fdf4; color: #15803d;">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card border-0 shadow-sm animate-fade-in animate-delay-1" style="border-radius: 20px; overflow: hidden;">
    <div class="card-header bg-white border-bottom py-3 px-4">
        <form method="get" class="row g-3">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0" style="border-radius: 10px 0 0 10px;"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="search" class="form-control bg-light border-start-0 py-2" placeholder="Search by description or user..." value="@Context.Request.Query["search"]" style="border-radius: 0 10px 10px 0;">
                </div>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100 py-2" style="border-radius: 10px; font-weight: 600; background: linear-gradient(135deg, #6366f1, #4f46e5); border: none;">Apply Filters</button>
            </div>
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted" style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;">
                    <tr>
                        <th class="ps-4 py-3">Timestamp</th>
                        <th class="py-3">User</th>
                        <th class="py-3">Action</th>
                        <th class="py-3" style="min-width: 300px;">Description</th>
                    </tr>
                </thead>
                <tbody style="font-size: 0.85rem;">
                    @foreach (var log in Model.Data)
                    {
                        <tr>
                            <td class="ps-4 text-muted">@log.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle bg-indigo-100 text-indigo-700 d-flex align-items-center justify-content-center me-2" style="width: 28px; height: 28px; background-color: #e0e7ff; color: #4338ca; font-size: 0.7rem; font-weight: 700;">
                                        @(log.User?.FullName?.Substring(0, 1).ToUpper() ?? "?")
                                    </div>
                                    <span class="fw-600">@(log.User?.FullName ?? "System")</span>
                                </div>
                            </td>
                            <td>
                                <span class="badge rounded-pill @(log.ActionType.ToString().Contains("CREATE") ? "bg-success-soft" : log.ActionType.ToString().Contains("DELETE") ? "bg-danger-soft" : "bg-primary-soft")" 
                                      style="font-size: 0.65rem; padding: 0.4em 0.8em; font-weight: 700; @(log.ActionType.ToString().Contains("CREATE") ? "background-color: #dcfce7; color: #166534;" : log.ActionType.ToString().Contains("DELETE") ? "background-color: #fee2e2; color: #991b1b;" : "background-color: #e0e7ff; color: #3730a3;")">
                                    @log.ActionType
                                </span>
                            </td>
                            <td class="text-indigo-950">@log.Description</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white border-top py-3 px-4">
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm justify-content-end mb-0">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link border-0 shadow-none text-indigo-600" href="@Url.Action("ActivityLog", new { page = Model.PageNumber - 1, search = Context.Request.Query["search"] })">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link border-0 shadow-none @(i == Model.PageNumber ? "bg-indigo-600 text-white" : "text-indigo-600")" 
                           href="@Url.Action("ActivityLog", new { page = i, search = Context.Request.Query["search"] })" 
                           style="@(i == Model.PageNumber ? "background-color: #4f46e5 !important; border-radius: 6px;" : "border-radius: 6px;")">@i</a>
                    </li>
                }
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link border-0 shadow-none text-indigo-600" href="@Url.Action("ActivityLog", new { page = Model.PageNumber + 1, search = Context.Request.Query["search"] })">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>

@section Scripts {
    <style>
        .fw-800 { font-weight: 800; }
        .fw-600 { font-weight: 600; }
        .text-indigo-900 { color: #1e1b4b; }
        .text-indigo-950 { color: #14113d; }
        .animate-fade-in { animation: fadeIn 0.5s ease-out; }
        .animate-delay-1 { animation-delay: 0.1s; }
        
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
}
