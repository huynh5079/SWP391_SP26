@model AEMS_Solution.Models.Organizer.BudgetProposal.BudgetProposalViewModel
@using DataAccess.Enum

@{
    var (badgeClass, badgeIcon) = Model.Status switch
    {
        ProposalStatusEnum.Draft => ("bg-secondary", "bi-pencil"),
        ProposalStatusEnum.Approved => ("bg-success", "bi-check-circle"),
        ProposalStatusEnum.Rejected => ("bg-danger", "bi-x-circle"),
        _ => ("bg-warning text-dark", "bi-hourglass-split")
    };
}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
            <div>
                <h5 class="fw-bold mb-1">@Model.Title</h5>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="text-muted small mb-2">@Model.Description</p>
                }
                <span class="badge @badgeClass fs-6 px-3 py-2">
                    <i class="bi @badgeIcon me-1"></i>@Model.Status
                </span>
            </div>

            <div class="d-flex gap-2 flex-wrap">

                
                @if (Model.CanSend)
                {
                    <form asp-action="SubmitForApproval"
                          asp-controller="BudgetProposal"
                          method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="proposalId" value="@Model.ProposalId" />
                        <input type="hidden" name="eventId" value="@Model.EventId" />
                        <button type="submit" class="btn btn-primary fw-semibold"
                                onclick="return confirm('Gửi Proposal lên Approver duyệt?')">
                            <i class="bi bi-send me-1"></i> Gửi duyệt
                        </button>
                    </form>
                }

                
                @if (Model.CanEditProposal)
                {
                    <button class="btn btn-warning fw-semibold"
                            data-bs-toggle="modal" data-bs-target="#modalEditProposal">
                        <i class="bi bi-pencil me-1"></i> Chỉnh sửa
                    </button>
                    <form asp-action="DeleteProposal" asp-controller="BudgetProposal"
                          method="post" class="d-inline"
                          onsubmit="return confirm('Xóa Proposal này? Hành động không thể hoàn tác.')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="proposalId" value="@Model.ProposalId" />
                        <input type="hidden" name="eventId" value="@Model.EventId" />
                        <button type="submit" class="btn btn-danger fw-semibold">
                            <i class="bi bi-trash me-1"></i> Xóa
                        </button>
                    </form>
                }

               
                @if (Model.CanApprove)
                {
                    <button class="btn btn-success fw-semibold"
                            data-bs-toggle="modal" data-bs-target="#modalApprove">
                        <i class="bi bi-check-lg me-1"></i> Duyệt
                    </button>
                    <button class="btn btn-danger fw-semibold"
                            data-bs-toggle="modal" data-bs-target="#modalReject">
                        <i class="bi bi-x-lg me-1"></i> Từ chối
                    </button>
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Note))
        {
            <div class="alert alert-light border mt-3 mb-0 small">
                <i class="bi bi-chat-left-text me-1 text-muted"></i>
                <strong>Ghi chú:</strong> @Model.Note
            </div>
        }

        @if (Model.ApprovedAt.HasValue)
        {
            <div class="text-muted small mt-2">
                <i class="bi bi-person-check me-1"></i>
                Xử lý bởi <strong>@Model.ApprovedBy</strong>
                lúc @Model.ApprovedAt.Value.ToString("HH:mm dd/MM/yyyy")
            </div>
        }
    </div>
</div>