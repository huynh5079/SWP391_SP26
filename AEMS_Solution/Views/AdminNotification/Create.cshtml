@using BusinessLogic.DTOs.System
@using DataAccess.Enum
@model BroadcastNotificationDto

@{
    ViewData["Title"] = "Gửi thông báo hệ thống";
    Layout = "~/Views/Shared/_Layout.cshtml"; 
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class='bx bx-broadcast'></i> Soạn thông báo toàn hệ thống</h4>
        </div>
        <div class="card-body">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form asp-action="Create" asp-controller="AdminNotification" method="post" id="broadcastForm">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-bold">Tiêu đề thông báo <span class="text-danger">*</span></label>
                    <input asp-for="Title" class="form-control" placeholder="VD: Bảo trì hệ thống đêm nay" required />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Message" class="form-label fw-bold">Nội dung <span class="text-danger">*</span></label>
                    <textarea asp-for="Message" class="form-control" rows="4" placeholder="Nhập chi tiết thông báo..." required></textarea>
                    <span asp-validation-for="Message" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Đố tượng nhận <span class="text-danger">*</span></label>
                    
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" asp-for="TargetGroup" value="AllSystem" id="targetAll" onclick="toggleTargetFields()" checked>
                        <label class="form-check-label" for="targetAll">
                            Gửi cho toàn bộ User trong hệ thống
                        </label>
                    </div>

                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" asp-for="TargetGroup" value="ByRole" id="targetRole" onclick="toggleTargetFields()">
                        <label class="form-check-label" for="targetRole">
                            Gửi theo Role cụ thể
                        </label>
                        <div class="mt-2 ms-4 d-none" id="roleSelectWrapper">
                            <select asp-for="TargetRole" class="form-select w-50" asp-items="Html.GetEnumSelectList<RoleEnum>()">
                                <option value="">-- Chọn Role --</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" asp-for="TargetGroup" value="SpecificEmail" id="targetEmail" onclick="toggleTargetFields()">
                        <label class="form-check-label" for="targetEmail">
                            Gửi cho cá nhân qua Email đăng nhập
                        </label>
                        <div class="mt-2 ms-4 d-none" id="emailInputWrapper">
                            <input asp-for="SpecificEmail" type="email" class="form-control w-50" placeholder="VD: student@fpt.edu.vn" />
                            <span asp-validation-for="SpecificEmail" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary px-4" onclick="return confirmAction(event, 'Xác nhận gửi thông báo tới các đối tượng đã chọn?')">
                        <i class='bx bx-send'></i> Gửi thông báo
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function toggleTargetFields() {
            var targetType = document.querySelector('input[name="TargetGroup"]:checked').value;
            
            document.getElementById('roleSelectWrapper').classList.add('d-none');
            document.getElementById('emailInputWrapper').classList.add('d-none');

            if (targetType === 'ByRole') {
                document.getElementById('roleSelectWrapper').classList.remove('d-none');
            } else if (targetType === 'SpecificEmail') {
                document.getElementById('emailInputWrapper').classList.remove('d-none');
            }
        }
        
        // Run once on load to establish correct state if validation fails and postbacks
        document.addEventListener("DOMContentLoaded", function () {
            toggleTargetFields();
        });
    </script>
}
