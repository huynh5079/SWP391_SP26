@model BusinessLogic.DTOs.Authentication.Register.RegisterStaffRequestDto
@{
    ViewData["Title"] = "Tạo tài khoản Nhân viên/Ban tổ chức";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3 mb-0 text-gray-800">Tạo Mới Người Dùng Từ Hệ Thống</h2>
        <a asp-action="Index" class="btn btn-sm btn-secondary shadow-sm">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Thông tin tài khoản</h6>
                </div>
                <div class="card-body">
                    <form asp-action="CreateStaff" method="post">
                        @Html.AntiForgeryToken()
                        
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i> Vui lòng kiểm tra lại thông tin nhập.
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label">Chọn Vai Trò <span class="text-danger">*</span></label>
                            <select asp-for="RoleName" class="form-select">
                                <option value="Organizer">Ban tổ chức (Organizer)</option>
                                <option value="Approver">Người duyệt sự kiện (Approver)</option>
                                <option value="Admin">Quản trị viên (Admin)</option>
                            </select>
                            <span asp-validation-for="RoleName" class="text-danger"></span>
                            <small class="text-muted d-block mt-1">Lưu ý: Nếu chọn Quản trị viên, mã nhân viên và chức vụ sẽ chỉ lưu thông tin như Staff bình thường.</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email <span class="text-danger">*</span></label>
                            <input asp-for="Email" class="form-control" placeholder="example@domain.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">Mật khẩu khởi tạo <span class="text-danger">*</span></label>
                            <input asp-for="Password" type="text" class="form-control" placeholder="Mật khẩu ít nhất 6 ký tự" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        
                        <hr class="my-4">
                        <h6 class="font-weight-bold text-primary mb-3">Thông tin hồ sơ</h6>

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label">Họ và tên <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn A" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="StaffCode" class="form-label">Mã số nhân viên (Mã BTC) <span class="text-danger">*</span></label>
                            <input asp-for="StaffCode" class="form-control" placeholder="STF12345" />
                            <span asp-validation-for="StaffCode" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label">Số điện thoại</label>
                            <input asp-for="Phone" class="form-control" placeholder="0123456789" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Position" class="form-label">Chức vụ / Vị trí <span class="text-danger">*</span></label>
                            <input asp-for="Position" class="form-control" placeholder="Ví dụ: Giảng viên, Trưởng câu lạc bộ" />
                            <span asp-validation-for="Position" class="text-danger"></span>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg">Tạo Tài Khoản</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
