@model DataAccess.Entities.PaginationResult<BusinessLogic.DTOs.User.UserListDto>
@using DataAccess.Enum
@{
    ViewData["Title"] = "User Management";
    if (User.IsInRole("Admin")) Layout = "_AdminLayout";
    else if (User.IsInRole("Organizer") || User.IsInRole("Staff")) Layout = "_Organizerlayout";
    else Layout = "_Approvallayout";

    // ── Helpers ────────────────────────────────────────────────────────────────
    string RoleColor(string r) => r switch {
        "Admin"     => "#ef4444", "Organizer" => "#3b82f6",
        "Approver"  => "#a855f7", "Student"   => "#22c55e",
        _           => "#64748b"
    };
    string RoleBg(string r) => r switch {
        "Admin"     => "#fee2e2", "Organizer" => "#dbeafe",
        "Approver"  => "#f3e8ff", "Student"   => "#dcfce7",
        _           => "#f1f5f9"
    };
    string RoleIcon(string r) => r switch {
        "Admin"     => "bi-shield-lock-fill",
        "Organizer" => "bi-person-workspace",
        "Approver"  => "bi-patch-check-fill",
        "Student"   => "bi-mortarboard-fill",
        _           => "bi-person-fill"
    };

    string GetInitials(string? name) {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var p = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return (p.Length == 1 ? $"{p[0][0]}" : $"{p[0][0]}{p[^1][0]}").ToUpper();
    }
    string AvatarBg(string? name) {
        var colors = new[]{"#6366f1","#8b5cf6","#ec4899","#f59e0b","#10b981","#3b82f6","#ef4444","#14b8a6"};
        return string.IsNullOrEmpty(name) ? colors[0] : colors[Math.Abs(name.GetHashCode()) % colors.Length];
    }
    string ToLocalDt(DateTime? v) => v?.ToString("yyyy-MM-ddTHH:mm:ss") ?? "";

    // Stat numbers
    int totalUsers    = Model.TotalCount;
    int activeCount   = Model.Data?.Count(u => u.Status == UserStatusEnum.Active && u.IsBanned != true) ?? 0;
    int bannedCount   = Model.Data?.Count(u => u.IsBanned == true) ?? 0;
    int inactiveCount = Model.Data?.Count(u => u.Status != UserStatusEnum.Active && u.IsBanned != true) ?? 0;
}

<style>
/* ============================================================
   USER MANAGEMENT — ULTRA PREMIUM REDESIGN
   Prefix: um2-
============================================================ */
@@keyframes um2-fadein  { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:none} }
@@keyframes um2-card-in { from{opacity:0;transform:translateY(8px) scale(.97)} to{opacity:1;transform:none} }
@@keyframes um2-row-in  { from{opacity:0;transform:translateX(-8px)} to{opacity:1;transform:none} }
@@keyframes um2-pulse-g { 0%,100%{box-shadow:0 0 0 0 rgba(34,197,94,.4)} 50%{box-shadow:0 0 0 8px rgba(34,197,94,0)} }
@@keyframes um2-pulse-r { 0%,100%{box-shadow:0 0 0 0 rgba(239,68,68,.4)} 50%{box-shadow:0 0 0 8px rgba(239,68,68,0)} }
@@keyframes um2-avatar  { from{transform:scale(.5) rotate(-15deg);opacity:0} to{transform:none;opacity:1} }

:root {
    --um2-primary: #6366f1;
    --um2-violet:  #8b5cf6;
    --um2-radius:  16px;
    --um2-shadow:  0 4px 24px rgba(99,102,241,.09);
    --um2-border:  #e0e7ff;
    --um2-text:    #1e1b4b;
    --um2-muted:   #64748b;
    --um2-card:    #ffffff;
}

.um2-page { background: #f0f2ff; min-height: 100vh; padding: 0 0 3rem; animation: um2-fadein .4s ease both; border-radius:12px; overflow:hidden;}

/* ── HERO ── */
.um2-hero {
    background: linear-gradient(130deg,#0f172a 0%,#1e1b4b 35%,#312e81 70%,#4c1d95 100%);
    padding: 2rem 2.5rem 2rem; position: relative; overflow: hidden;
    box-shadow: 0 6px 32px rgba(15,23,42,.3);
    animation: um2-card-in .4s ease both;
}
.um2-hero::before {
    content:""; position:absolute; right:-80px; top:-80px;
    width:280px; height:280px; border-radius:50%;
    background:rgba(255,255,255,.03); pointer-events:none;
}
.um2-hero::after {
    content:""; position:absolute; left:-50px; bottom:-60px;
    width:180px; height:180px; border-radius:50%;
    background:rgba(139,92,246,.07); pointer-events:none;
}
.um2-hero-icon {
    width:62px; height:62px; border-radius:18px;
    background:rgba(255,255,255,.14); backdrop-filter:blur(6px);
    display:flex; align-items:center; justify-content:center;
    font-size:1.9rem; color:#fff; flex-shrink:0;
    box-shadow:0 4px 16px rgba(0,0,0,.2);
}
.um2-hero-title { font-size:1.75rem; font-weight:900; color:#fff; letter-spacing:-.04em; }
.um2-hero-sub   { color:rgba(255,255,255,.55); font-size:.87rem; margin-top:.12rem; }
.um2-hero-chip  {
    display:inline-flex; align-items:center; gap:.3rem; font-size:.71rem;
    color:rgba(255,255,255,.5);
    background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.18);
    padding:.23rem .7rem; border-radius:20px; margin-top:.4rem;
}
.um2-kpis  { display:flex; gap:1.6rem; flex-wrap:wrap; align-items:center; }
.um2-kpi-v { font-size:1.4rem; font-weight:900; color:#fff; line-height:1; }
.um2-kpi-l { font-size:.6rem; font-weight:700; color:rgba(255,255,255,.4); text-transform:uppercase; letter-spacing:.08em; }
.um2-sep   { width:1px; height:40px; background:rgba(255,255,255,.13); flex-shrink:0; }

/* Hero buttons */
.um2-hero-btn {
    display:inline-flex; align-items:center; gap:.35rem;
    font-size:.82rem; font-weight:800; padding:.6rem 1.2rem;
    border-radius:30px; border:none; cursor:pointer; text-decoration:none; transition:all .18s;
}
.um2-hbtn-white { background:#fff; color:#6366f1; box-shadow:0 2px 10px rgba(0,0,0,.15); }
.um2-hbtn-white:hover { transform:translateY(-2px); box-shadow:0 6px 18px rgba(0,0,0,.2); color:#4f46e5; }
.um2-hbtn-glass { background:rgba(255,255,255,.13); color:#fff; border:1.5px solid rgba(255,255,255,.28); }
.um2-hbtn-glass:hover { background:rgba(255,255,255,.22); color:#fff; }

/* ── STAT CARDS ── */
.um2-stats {
    display:grid; grid-template-columns:repeat(4,1fr); gap:1rem;
    padding: 1.4rem 2.5rem 0; max-width:100%;
}
@@media(max-width:900px){ .um2-stats{grid-template-columns:repeat(2,1fr);} }
@@media(max-width:540px){ .um2-stats{grid-template-columns:1fr;} }

.um2-stat {
    background:var(--um2-card); border-radius:var(--um2-radius);
    border:1px solid var(--um2-border); box-shadow:var(--um2-shadow);
    padding:1.1rem 1.2rem; position:relative; overflow:hidden;
    transition:transform .2s,box-shadow .2s; animation:um2-card-in .38s ease both;
}
.um2-stat:hover { transform:translateY(-4px); box-shadow:0 14px 32px rgba(99,102,241,.14); }
.um2-stat-bar { height:3px; border-radius:2px; margin-bottom:.85rem; transition:width .3s; }
.um2-stat-top { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:.6rem; }
.um2-stat-icon { width:44px; height:44px; border-radius:13px; display:flex; align-items:center; justify-content:center; font-size:1.15rem; }
.um2-stat-badge{ font-size:.63rem; font-weight:800; padding:.18rem .5rem; border-radius:20px; }
.um2-stat-lbl  { font-size:.62rem; font-weight:800; color:#94a3b8; text-transform:uppercase; letter-spacing:.07em; margin-bottom:.15rem; }
.um2-stat-val  { font-size:2rem; font-weight:900; color:var(--um2-text); line-height:1; }
.um2-stat-sub  { font-size:.7rem; color:#94a3b8; margin-top:.12rem; }

/* ── CONTENT AREA ── */
.um2-content { padding: 1.2rem 2.5rem 0; }

/* ── FILTER CARD ── */
.um2-filter {
    background:var(--um2-card); border-radius:var(--um2-radius);
    border:1px solid var(--um2-border); box-shadow:var(--um2-shadow);
    padding:1.2rem 1.5rem; margin-bottom:1.2rem;
    animation:um2-card-in .38s .06s ease both;
}
.um2-filter-label { font-size:.63rem; font-weight:800; color:#94a3b8; text-transform:uppercase; letter-spacing:.07em; margin-bottom:.5rem; }
.um2-filter-grid { display:grid; grid-template-columns:1fr 200px 200px auto; gap:.8rem; align-items:end; }
@@media(max-width:960px){ .um2-filter-grid{grid-template-columns:1fr 1fr;} }
@@media(max-width:540px){ .um2-filter-grid{grid-template-columns:1fr;} }

.um2-input, .um2-select {
    width:100%; background:#fafbff; border:1.5px solid var(--um2-border);
    border-radius:10px; padding:.6rem 1rem; font-size:.87rem; outline:none;
    transition:border-color .2s,box-shadow .2s; font-family:inherit; color:var(--um2-text);
}
.um2-search-wrap { position:relative; }
.um2-search-wrap i { position:absolute; left:13px; top:50%; transform:translateY(-50%); color:#94a3b8; font-size:.85rem; }
.um2-search-wrap .um2-input { padding-left:2.4rem; }
.um2-input:focus,.um2-select:focus { border-color:var(--um2-primary); box-shadow:0 0 0 3px rgba(99,102,241,.12); }

.um2-filter-btn {
    display:inline-flex; align-items:center; gap:.4rem;
    font-size:.85rem; font-weight:800; padding:.62rem 1.3rem;
    border-radius:10px; border:none; cursor:pointer;
    background:linear-gradient(135deg,#6366f1,#8b5cf6); color:#fff;
    transition:all .18s; box-shadow:0 3px 12px rgba(99,102,241,.3);
    white-space:nowrap;
}
.um2-filter-btn:hover { transform:translateY(-1px); box-shadow:0 5px 18px rgba(99,102,241,.4); }
.um2-reset-btn {
    display:inline-flex; align-items:center; gap:.3rem;
    font-size:.83rem; font-weight:700; padding:.62rem .9rem;
    border-radius:10px; border:1.5px solid var(--um2-border);
    background:#f8faff; color:var(--um2-muted); text-decoration:none; transition:all .15s;
}
.um2-reset-btn:hover { background:#e0e7ff; color:var(--um2-primary); }

/* Filter tags */
.um2-filter-tags { display:flex; flex-wrap:wrap; gap:.4rem; margin-top:.65rem; }
.um2-ftag {
    display:inline-flex; align-items:center; gap:.28rem;
    font-size:.69rem; font-weight:700; padding:.2rem .6rem; border-radius:20px;
    background:#ede9fe; color:#6d28d9; border:1px solid #c4b5fd; cursor:pointer; transition:all .15s;
    text-decoration:none;
}
.um2-ftag:hover { background:#6366f1; color:#fff; border-color:#6366f1; }

/* ── TABLE CARD ── */
.um2-card {
    background:var(--um2-card); border-radius:var(--um2-radius);
    border:1px solid var(--um2-border); box-shadow:var(--um2-shadow);
    overflow:hidden; margin-bottom:2rem;
    animation:um2-card-in .4s .1s ease both;
}
.um2-card-header {
    padding:.95rem 1.5rem; border-bottom:1px solid #f1f5f9;
    display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:.5rem;
}
.um2-card-title { font-size:.9rem; font-weight:800; color:var(--um2-text); }
.um2-card-sub   { font-size:.74rem; color:var(--um2-muted); margin-top:.05rem; }
.um2-card-pill  {
    font-size:.73rem; font-weight:800; padding:.2rem .65rem; border-radius:20px;
    background:#ede9fe; color:#6d28d9; border:1px solid #c4b5fd;
}

/* ── TABLE ── */
.um2-table { width:100%; border-collapse:collapse; }
.um2-table thead th {
    background:#f8fafc; font-size:.62rem; font-weight:800;
    text-transform:uppercase; letter-spacing:.08em; color:#94a3b8;
    padding:.78rem 1.1rem; border-bottom:1px solid #f1f5f9; white-space:nowrap;
}
.um2-table thead th:first-child { padding-left:1.5rem; }
.um2-table thead th:last-child  { padding-right:1.5rem; text-align:right; }
.um2-table tbody tr {
    border-bottom:1px solid #f8fafc; transition:background .12s;
    animation:um2-row-in .28s ease both;
}
.um2-table tbody tr:last-child { border-bottom:none; }
.um2-table tbody tr:hover { background:#f5f3ff !important; }
.um2-table tbody td { padding:.9rem 1.1rem; vertical-align:middle; font-size:.87rem; }
.um2-table tbody td:first-child { padding-left:1.5rem; }
.um2-table tbody td:last-child  { padding-right:1.5rem; text-align:right; }

/* ── AVATAR ── */
.um2-avatar-wrap { display:flex; align-items:center; gap:.8rem; }
.um2-avatar {
    width:38px; height:38px; border-radius:50%; object-fit:cover;
    flex-shrink:0; font-size:.78rem; font-weight:800;
    display:flex; align-items:center; justify-content:center;
    color:#fff; position:relative;
    animation:um2-avatar .3s ease both;
    box-shadow:0 2px 8px rgba(0,0,0,.12);
}
.um2-avatar img { width:100%; height:100%; border-radius:50%; object-fit:cover; }
.um2-status-dot {
    position:absolute; bottom:1px; right:1px;
    width:10px; height:10px; border-radius:50%; border:2px solid #fff; flex-shrink:0;
}
.um2-user-name  { font-weight:700; color:#0f172a; font-size:.88rem; max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.um2-user-email { font-size:.75rem; color:#64748b; margin-top:.05rem; max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

/* ── ROLE PILL ── */
.um2-role {
    display:inline-flex; align-items:center; gap:.28rem;
    font-size:.7rem; font-weight:800; padding:.22rem .65rem;
    border-radius:20px; text-transform:uppercase; letter-spacing:.04em;
}

/* ── STATUS PILL ── */
.um2-status {
    display:inline-flex; align-items:center; gap:.35rem;
    font-size:.75rem; font-weight:700; padding:.28rem .72rem; border-radius:20px;
}
.um2-status-dot-inner { width:6px; height:6px; border-radius:50%; flex-shrink:0; }

/* ── ACTION BUTTONS ── */
.um2-actions { display:flex; gap:.35rem; align-items:center; justify-content:flex-end; }
.um2-btn-action {
    width:32px; height:32px; border-radius:9px; border:1.5px solid #e2e8f0;
    background:#f8fafc; display:inline-flex; align-items:center; justify-content:center;
    font-size:.82rem; cursor:pointer; transition:all .15s; text-decoration:none; color:#64748b;
}
.um2-btn-action:hover { transform:translateY(-1px); }
.um2-btn-action.view:hover  { background:#eff6ff; border-color:#bfdbfe; color:#3b82f6; }
.um2-btn-action.lock:hover  { background:#fee2e2; border-color:#fca5a5; color:#ef4444; }
.um2-btn-action.timed:hover { background:#fef3c7; border-color:#fde68a; color:#d97706; }
.um2-btn-action.unlock:hover{ background:#f0fdf4; border-color:#86efac; color:#16a34a; }

/* ── PAGINATION ── */
.um2-pag {
    display:flex; align-items:center; justify-content:space-between;
    padding:.9rem 1.5rem; border-top:1px solid #f1f5f9; flex-wrap:wrap; gap:.5rem;
}
.um2-pag-info { font-size:.78rem; color:var(--um2-muted); font-weight:600; }
.um2-pag-btns { display:flex; gap:.28rem; }
.um2-pbt {
    display:inline-flex; align-items:center; justify-content:center;
    width:34px; height:34px; border-radius:9px; font-size:.8rem; font-weight:700;
    text-decoration:none; border:1.5px solid var(--um2-border); color:var(--um2-muted);
    background:#fff; transition:all .15s;
}
.um2-pbt:hover   { background:#f5f3ff; border-color:#c4b5fd; color:var(--um2-primary); }
.um2-pbt.active  { background:var(--um2-primary); color:#fff; border-color:var(--um2-primary); }
.um2-pbt.disabled{ opacity:.4; pointer-events:none; }

/* ── EMPTY STATE ── */
.um2-empty { text-align:center; padding:4rem 1rem; }
.um2-empty-icon {
    width:80px; height:80px; border-radius:50%;
    background:linear-gradient(135deg,#ede9fe,#c4b5fd);
    display:flex; align-items:center; justify-content:center;
    font-size:2.2rem; color:#6d28d9; margin:0 auto .9rem;
}
.um2-empty h4 { font-size:1.1rem; font-weight:800; color:#374151; margin-bottom:.35rem; }
.um2-empty p  { font-size:.87rem; color:var(--um2-muted); max-width:320px; margin:0 auto; }

/* ── TOAST ── */
.um2-toast {
    display:flex; align-items:center; gap:.7rem;
    border-radius:12px; border:none; padding:.9rem 1.25rem;
    font-size:.9rem; font-weight:600; margin:0 2.5rem 1rem;
}

/* ── MODAL ── */
.um2-modal .modal-content {
    border:none; border-radius:20px;
    box-shadow:0 20px 60px rgba(0,0,0,.18); overflow:hidden;
}
.um2-modal .modal-header {
    background:linear-gradient(130deg,#1e1b4b,#4c1d95);
    border:none; padding:1.2rem 1.5rem;
}
.um2-modal .modal-title { color:#fff; font-weight:900; font-size:1rem; }
.um2-modal .btn-close   { filter:invert(1); }
.um2-modal .modal-body  { padding:1.4rem 1.5rem; background:#fafbff; }
.um2-modal .modal-footer{ background:#fff; border-top:1px solid #f1f5f9; padding:.9rem 1.5rem; }
</style>

<div class="um2-page">

    @* ════════════ ALERT TOASTS ════════════ *@
    @if (TempData["Success"] != null)
    {
        <div class="um2-toast" style="background:#f0fdf4;color:#15803d;border:1px solid #86efac;margin-top:1rem;">
            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="um2-toast" style="background:#fef2f2;color:#dc2626;border:1px solid #fca5a5;margin-top:1rem;">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
        </div>
    }

    @* ════════════ HERO HEADER ════════════ *@
    <div class="um2-hero">
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1.2rem;">
            <div style="display:flex;align-items:center;gap:1.1rem;">
                <div class="um2-hero-icon"><i class="bi bi-people-fill"></i></div>
                <div>
                    <h1 class="um2-hero-title">User Management</h1>
                    <p class="um2-hero-sub">Quản trị, phân quyền và kiểm soát tài khoản hệ thống.</p>
                    <div style="display:flex;gap:.45rem;flex-wrap:wrap;margin-top:.35rem;">
                        <span class="um2-hero-chip"><i class="bi bi-calendar3"></i> @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
                        <span class="um2-hero-chip"><i class="bi bi-database"></i> @totalUsers tài khoản trong DB</span>
                        <span class="um2-hero-chip" style="color:#86efac;border-color:rgba(34,197,94,.3);background:rgba(34,197,94,.1);">
                            <i class="bi bi-circle-fill" style="font-size:.38rem;"></i> Live
                        </span>
                    </div>
                </div>
            </div>
            <div style="display:flex;flex-direction:column;gap:.85rem;align-items:flex-end;">
                <a asp-action="CreateStaff" class="um2-hero-btn um2-hbtn-white">
                    <i class="bi bi-person-plus-fill"></i> Tạo Tài Khoản Mới
                </a>
                <div class="um2-kpis">
                    <div class="text-center">
                        <div class="um2-kpi-v">@totalUsers</div>
                        <div class="um2-kpi-l">Tổng</div>
                    </div>
                    <div class="um2-sep"></div>
                    <div class="text-center">
                        <div class="um2-kpi-v" style="color:#86efac;">@activeCount</div>
                        <div class="um2-kpi-l">Hoạt động</div>
                    </div>
                    <div class="um2-sep"></div>
                    <div class="text-center">
                        <div class="um2-kpi-v" style="color:#fca5a5;">@bannedCount</div>
                        <div class="um2-kpi-l">Bị khóa</div>
                    </div>
                    <div class="um2-sep"></div>
                    <div class="text-center">
                        <div class="um2-kpi-v">@Model.TotalPages</div>
                        <div class="um2-kpi-l">Trang</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ════════════ STAT CARDS ════════════ *@
    <div class="um2-stats">
        <div class="um2-stat" style="animation-delay:.04s;">
            <div class="um2-stat-bar" style="width:40px;background:#6366f1;"></div>
            <div class="um2-stat-top">
                <div class="um2-stat-icon" style="background:#ede9fe;color:#6d28d9;"><i class="bi bi-people-fill"></i></div>
                <span class="um2-stat-badge" style="background:#ede9fe;color:#6d28d9;">Total</span>
            </div>
            <div class="um2-stat-lbl">Tổng Tài Khoản</div>
            <div class="um2-stat-val" style="color:#6d28d9;" id="um2c-total">@totalUsers</div>
            <div class="um2-stat-sub">Trong toàn hệ thống</div>
        </div>
        <div class="um2-stat @(activeCount > 0 ? "" : "")" style="animation-delay:.07s;">
            <div class="um2-stat-bar" style="width:40px;background:#22c55e;"></div>
            <div class="um2-stat-top">
                <div class="um2-stat-icon" style="background:#dcfce7;color:#15803d;"><i class="bi bi-person-check-fill"></i></div>
                <span class="um2-stat-badge" style="background:#dcfce7;color:#15803d;">Active</span>
            </div>
            <div class="um2-stat-lbl">Đang Hoạt Động</div>
            <div class="um2-stat-val" style="color:#15803d;" id="um2c-active">@activeCount</div>
            <div class="um2-stat-sub">@(totalUsers > 0 ? (activeCount * 100 / totalUsers) : 0)% tổng hệ thống</div>
        </div>
        <div class="um2-stat @(bannedCount > 0 ? "" : "")" style="animation-delay:.10s;">
            <div class="um2-stat-bar" style="width:40px;background:#ef4444;"></div>
            <div class="um2-stat-top">
                <div class="um2-stat-icon" style="background:#fee2e2;color:#b91c1c;"><i class="bi bi-shield-x-fill"></i></div>
                @if (bannedCount > 0)
                { <span class="um2-stat-badge" style="background:#fee2e2;color:#b91c1c;">⚠ Locked</span> }
                else
                { <span class="um2-stat-badge" style="background:#dcfce7;color:#15803d;">✓ None</span> }
            </div>
            <div class="um2-stat-lbl">Bị Khoá</div>
            <div class="um2-stat-val" style="color:@(bannedCount > 0 ? "#b91c1c" : "#15803d");" id="um2c-banned">@bannedCount</div>
            <div class="um2-stat-sub">Tài khoản bị hạn chế</div>
        </div>
        <div class="um2-stat" style="animation-delay:.13s;">
            <div class="um2-stat-bar" style="width:40px;background:#f59e0b;"></div>
            <div class="um2-stat-top">
                <div class="um2-stat-icon" style="background:#fef3c7;color:#92400e;"><i class="bi bi-person-dash-fill"></i></div>
                <span class="um2-stat-badge" style="background:#fef3c7;color:#92400e;">Inactive</span>
            </div>
            <div class="um2-stat-lbl">Không Hoạt Động</div>
            <div class="um2-stat-val" style="color:#92400e;" id="um2c-inactive">@inactiveCount</div>
            <div class="um2-stat-sub">Trên trang hiện tại</div>
        </div>
    </div>

    @* ════════════ CONTENT ════════════ *@
    <div class="um2-content" style="padding-top:1.2rem;">

        @* ── Filter Bar ── *@
        <div class="um2-filter">
            <div class="um2-filter-label"><i class="bi bi-funnel-fill me-1"></i>Bộ lọc & Tìm kiếm</div>
            <form asp-action="Index" method="get" id="um2FilterForm">
                <div class="um2-filter-grid">
                    <div>
                        <div class="um2-filter-label" style="margin-bottom:.3rem;">Tìm kiếm</div>
                        <div class="um2-search-wrap">
                            <i class="bi bi-search"></i>
                            <input type="text" name="searchTerm" class="um2-input"
                                   placeholder="Tên hoặc email..."
                                   value="@ViewBag.SearchTerm" id="um2SearchInput" />
                        </div>
                    </div>
                    <div>
                        <div class="um2-filter-label" style="margin-bottom:.3rem;">Vai Trò</div>
                        <select name="role" class="um2-select" id="um2RoleSelect">
                            <option value="">— Tất cả vai trò —</option>
                            @foreach (var opt in new[]{"Student","Organizer","Approver","Staff","Admin"})
                            {
                                if (ViewBag.Role?.ToString() == opt)
                                { <option value="@opt" selected>@opt</option> }
                                else
                                { <option value="@opt">@opt</option> }
                            }
                        </select>
                    </div>
                    <div>
                        <div class="um2-filter-label" style="margin-bottom:.3rem;">Trạng Thái</div>
                        <select name="status" class="um2-select" id="um2StatusSelect">
                            <option value="">— Tất cả trạng thái —</option>
                            @foreach (var s in Html.GetEnumSelectList<UserStatusEnum>())
                            {
                                if (ViewBag.Status?.ToString() == s.Value)
                                { <option value="@s.Value" selected>@s.Text</option> }
                                else
                                { <option value="@s.Value">@s.Text</option> }
                            }
                        </select>
                    </div>
                    <div style="display:flex;gap:.4rem;align-items:center;">
                        <button type="submit" class="um2-filter-btn">
                            <i class="bi bi-funnel-fill"></i> Lọc
                        </button>
                        <a asp-action="Index" class="um2-reset-btn" title="Xóa bộ lọc">
                            <i class="bi bi-x-circle"></i>
                        </a>
                    </div>
                </div>
                @* Active filter tags *@
                @if (!string.IsNullOrEmpty(ViewBag.SearchTerm?.ToString()) || ViewBag.Role != null || ViewBag.Status != null)
                {
                    <div class="um2-filter-tags">
                        @if (!string.IsNullOrEmpty(ViewBag.SearchTerm?.ToString()))
                        {
                            <a href="@Url.Action("Index","UserManagement", new{role=ViewBag.Role, status=ViewBag.Status})" class="um2-ftag">
                                <i class="bi bi-search"></i> "@ViewBag.SearchTerm" <i class="bi bi-x ms-1"></i>
                            </a>
                        }
                        @if (ViewBag.Role != null)
                        {
                            <a href="@Url.Action("Index","UserManagement", new{searchTerm=ViewBag.SearchTerm, status=ViewBag.Status})" class="um2-ftag">
                                <i class="bi bi-person-fill"></i> Role: @ViewBag.Role <i class="bi bi-x ms-1"></i>
                            </a>
                        }
                        @if (ViewBag.Status != null)
                        {
                            <a href="@Url.Action("Index","UserManagement", new{searchTerm=ViewBag.SearchTerm, role=ViewBag.Role})" class="um2-ftag">
                                <i class="bi bi-circle-fill" style="font-size:.4rem;"></i> Status: @ViewBag.Status <i class="bi bi-x ms-1"></i>
                            </a>
                        }
                        <a asp-action="Index" class="um2-ftag" style="background:#fee2e2;color:#b91c1c;border-color:#fca5a5;">
                            <i class="bi bi-x-octagon"></i> Xóa tất cả
                        </a>
                    </div>
                }
            </form>
        </div>

        @* ── Table Card ── *@
        <div class="um2-card">
            <div class="um2-card-header">
                <div>
                    <div class="um2-card-title"><i class="bi bi-table me-1" style="color:#6366f1;"></i>Danh sách Tài khoản</div>
                    <div class="um2-card-sub">
                        Trang @Model.PageNumber / @Model.TotalPages
                        @if (!string.IsNullOrEmpty(ViewBag.SearchTerm?.ToString()))
                        { <text>· Lọc theo "<strong>@ViewBag.SearchTerm</strong>"</text> }
                    </div>
                </div>
                <span class="um2-card-pill">@totalUsers tài khoản</span>
            </div>

            <div class="table-responsive">
                <table class="um2-table">
                    <thead>
                        <tr>
                            <th style="width:44px;">#</th>
                            <th>Người dùng</th>
                            <th>Vai trò</th>
                            <th>Ngày tạo</th>
                            <th>Trạng thái</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Data != null && Model.Data.Any())
                        {
                            int rowIdx = (Model.PageNumber - 1) * Model.PageSize + 1;
                            foreach (var user in Model.Data)
                            {
                                bool isBanned   = user.IsBanned == true;
                                bool isActive   = user.Status == UserStatusEnum.Active && !isBanned;
                                string dotColor = isBanned ? "#ef4444" : isActive ? "#22c55e" : "#94a3b8";
                                string statusLabel = isBanned ? "Đã khóa" : isActive ? "Hoạt động" : "Inactive";
                                string statusBg    = isBanned ? "#fee2e2" : isActive ? "#f0fdf4" : "#f8fafc";
                                string statusFg    = isBanned ? "#b91c1c" : isActive ? "#15803d" : "#64748b";
                                string rowBg       = isBanned ? "rgba(239,68,68,.02)" : "transparent";
                                <tr style="background:@rowBg;animation-delay:@(rowIdx * 28)ms;">
                                    <td style="color:#94a3b8;font-weight:800;font-size:.75rem;">@rowIdx</td>
                                    <td>
                                        <div class="um2-avatar-wrap">
                                            <div class="um2-avatar" style="background:@AvatarBg(user.FullName);">
                                                @if (!string.IsNullOrEmpty(user.AvatarUrl))
                                                {
                                                    <img src="@user.AvatarUrl" alt="@user.FullName"
                                                         onerror="this.style.display='none';this.parentElement.textContent='@GetInitials(user.FullName)';" />
                                                }
                                                else
                                                {
                                                    @GetInitials(user.FullName)
                                                }
                                                <span class="um2-status-dot" style="background:@dotColor;" title="@statusLabel"></span>
                                            </div>
                                            <div>
                                                <div class="um2-user-name">@user.FullName</div>
                                                <div class="um2-user-email">@user.Email</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="um2-role"
                                              style="background:@RoleBg(user.RoleName);color:@RoleColor(user.RoleName);">
                                            <i class="bi @RoleIcon(user.RoleName)" style="font-size:.65rem;"></i>
                                            @user.RoleName
                                        </span>
                                    </td>
                                    <td style="color:#64748b;font-size:.82rem;white-space:nowrap;">
                                        @(user.CreatedAt.HasValue ? user.CreatedAt.Value.ToString("dd/MM/yyyy") : "—")
                                    </td>
                                    <td>
                                        <div>
                                            <span class="um2-status" style="background:@statusBg;color:@statusFg;">
                                                <span class="um2-status-dot-inner" style="background:@dotColor;"></span>
                                                @statusLabel
                                            </span>
                                            @if (user.ReactivateAt.HasValue && isBanned)
                                            {
                                                <div style="font-size:.7rem;color:#94a3b8;margin-top:.2rem;">
                                                    Mở lúc: @user.ReactivateAt.Value.ToString("dd/MM/yyyy HH:mm")
                                                </div>
                                                <div style="font-size:.7rem;color:#6d28d9;font-weight:700;"
                                                     class="um2-countdown" data-reactivate-at="@ToLocalDt(user.ReactivateAt)"></div>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div class="um2-actions">
                                            <a asp-action="Detail" asp-route-id="@user.Id"
                                               class="um2-btn-action view" title="Xem chi tiết">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            @if (isBanned)
                                            {
                                                <form asp-action="Unban" asp-route-id="@user.Id" method="post" style="display:inline;"
                                                      onsubmit="return confirm('Mở khóa tài khoản @Html.Raw(user.FullName?.Replace("'", "\\'"))?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="um2-btn-action unlock" title="Mở khóa">
                                                        <i class="bi bi-unlock-fill"></i>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <button type="button" class="um2-btn-action lock um2-open-lock"
                                                        title="Khóa thủ công"
                                                        data-lock-mode="manual"
                                                        data-bs-toggle="modal" data-bs-target="#um2LockModal"
                                                        data-user-id="@user.Id" data-user-name="@user.FullName"
                                                        data-reactivate-at="@ToLocalDt(user.ReactivateAt)">
                                                    <i class="bi bi-lock-fill"></i>
                                                </button>
                                                <button type="button" class="um2-btn-action timed um2-open-lock"
                                                        title="Khóa theo thời gian"
                                                        data-lock-mode="timed"
                                                        data-bs-toggle="modal" data-bs-target="#um2LockModal"
                                                        data-user-id="@user.Id" data-user-name="@user.FullName"
                                                        data-reactivate-at="@ToLocalDt(user.ReactivateAt)">
                                                    <i class="bi bi-clock-history"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                                rowIdx++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6">
                                    <div class="um2-empty">
                                        <div class="um2-empty-icon"><i class="bi bi-person-slash"></i></div>
                                        <h4>Không tìm thấy người dùng</h4>
                                        <p>
                                            @if (!string.IsNullOrEmpty(ViewBag.SearchTerm?.ToString()) || ViewBag.Role != null || ViewBag.Status != null)
                                            { <text>Không có tài khoản nào phù hợp với bộ lọc hiện tại.</text> }
                                            else
                                            { <text>Hệ thống chưa có tài khoản nào.</text> }
                                        </p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Pagination *@
            @if (Model.TotalPages > 1)
            {
                int ws = 5, hw = 2;
                int sp = Math.Max(1, Model.PageNumber - hw);
                int ep = Math.Min(Model.TotalPages, sp + ws - 1);
                if (ep - sp + 1 < ws) sp = Math.Max(1, ep - ws + 1);

                <div class="um2-pag">
                    <div class="um2-pag-info">
                        Hiển thị <strong>@((Model.PageNumber-1)*Model.PageSize+1)–@Math.Min(Model.PageNumber*Model.PageSize,Model.TotalCount)</strong>
                        trong <strong>@Model.TotalCount</strong> tài khoản
                    </div>
                    <div class="um2-pag-btns">
                        @if (Model.PageNumber > 1)
                        {
                            <a href="@Url.Action("Index","UserManagement", new{pageNumber=1,searchTerm=ViewBag.SearchTerm,role=ViewBag.Role,status=ViewBag.Status})" class="um2-pbt" title="Đầu"><i class="bi bi-chevron-double-left"></i></a>
                            <a href="@Url.Action("Index","UserManagement", new{pageNumber=Model.PageNumber-1,searchTerm=ViewBag.SearchTerm,role=ViewBag.Role,status=ViewBag.Status})" class="um2-pbt"><i class="bi bi-chevron-left"></i></a>
                        }
                        else
                        {
                            <span class="um2-pbt disabled"><i class="bi bi-chevron-double-left"></i></span>
                            <span class="um2-pbt disabled"><i class="bi bi-chevron-left"></i></span>
                        }
                        @for (int pg = sp; pg <= ep; pg++)
                        {
                            if (pg == Model.PageNumber)
                            { <span class="um2-pbt active">@pg</span> }
                            else
                            { <a href="@Url.Action("Index","UserManagement", new{pageNumber=pg,searchTerm=ViewBag.SearchTerm,role=ViewBag.Role,status=ViewBag.Status})" class="um2-pbt">@pg</a> }
                        }
                        @if (Model.PageNumber < Model.TotalPages)
                        {
                            <a href="@Url.Action("Index","UserManagement", new{pageNumber=Model.PageNumber+1,searchTerm=ViewBag.SearchTerm,role=ViewBag.Role,status=ViewBag.Status})" class="um2-pbt"><i class="bi bi-chevron-right"></i></a>
                            <a href="@Url.Action("Index","UserManagement", new{pageNumber=Model.TotalPages,searchTerm=ViewBag.SearchTerm,role=ViewBag.Role,status=ViewBag.Status})" class="um2-pbt" title="Cuối"><i class="bi bi-chevron-double-right"></i></a>
                        }
                        else
                        {
                            <span class="um2-pbt disabled"><i class="bi bi-chevron-right"></i></span>
                            <span class="um2-pbt disabled"><i class="bi bi-chevron-double-right"></i></span>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@* ════════════ LOCK MODAL ════════════ *@
<div class="modal fade um2-modal" id="um2LockModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="um2LockForm" asp-action="Ban" method="post"
                  onsubmit="return confirm('Bạn có chắc muốn khóa tài khoản này?');">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="um2LockTitle">
                        <i class="bi bi-lock-fill me-2" style="color:#fca5a5;"></i>Khóa tài khoản
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="um2LockId"   name="Id" />
                    <input type="hidden" name="Status" value="Inactive" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Người dùng</label>
                        <input type="text" id="um2LockName" class="form-control form-control-sm rounded-3 bg-light" readonly />
                    </div>
                    <div class="d-none mb-2" id="um2TimedWrapper">
                        <label class="form-label fw-semibold small">Mở khóa tự động sau</label>
                        <div class="row g-2">
                            <div class="col-4"><label class="form-label small text-muted">Năm</label><input type="number" id="um2LkY" class="form-control form-control-sm rounded-3" min="0" placeholder="0" /></div>
                            <div class="col-4"><label class="form-label small text-muted">Tháng</label><input type="number" id="um2LkM" class="form-control form-control-sm rounded-3" min="0" placeholder="0" /></div>
                            <div class="col-4"><label class="form-label small text-muted">Ngày</label><input type="number" id="um2LkD" class="form-control form-control-sm rounded-3" min="0" placeholder="0" /></div>
                            <div class="col-4"><label class="form-label small text-muted">Giờ</label><input type="number" id="um2LkH" class="form-control form-control-sm rounded-3" min="0" placeholder="0" /></div>
                            <div class="col-4"><label class="form-label small text-muted">Phút</label><input type="number" id="um2LkMn" class="form-control form-control-sm rounded-3" min="0" placeholder="0" /></div>
                            <div class="col-4"><label class="form-label small text-muted">Giây</label><input type="number" id="um2LkS" class="form-control form-control-sm rounded-3" min="0" placeholder="0" /></div>
                        </div>
                        <input type="hidden" id="um2LkReactivate" name="ReactivateAt" />
                    </div>
                    <div class="alert alert-warning py-2 px-3 small mt-3 mb-0 rounded-3" id="um2LkPreview">
                        Khóa thủ công — chỉ mở khi Admin mở khóa.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger rounded-pill px-4">
                        <i class="bi bi-lock-fill me-2"></i>Xác nhận khóa
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
    // ── Counter animations ──────────────────────────────────────────────────
    [
        {id:'um2c-total',   val:@totalUsers},
        {id:'um2c-active',  val:@activeCount},
        {id:'um2c-banned',  val:@bannedCount},
        {id:'um2c-inactive',val:@inactiveCount},
    ].forEach(c => {
        const el = document.getElementById(c.id);
        if (!el || c.val === 0) return;
        let cur = 0, step = Math.max(1, Math.ceil(c.val / 28));
        const t = setInterval(() => {
            cur = Math.min(cur + step, c.val);
            el.textContent = cur;
            if (cur >= c.val) clearInterval(t);
        }, 38);
    });

    // ── Lock Modal ──────────────────────────────────────────────────────────
    const pad = v => String(v).padStart(2,'0');
    const fmt = d => `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
    const fmtD = d => `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;

    const elId    = document.getElementById('um2LockId');
    const elName  = document.getElementById('um2LockName');
    const elTitle = document.getElementById('um2LockTitle');
    const elWrap  = document.getElementById('um2TimedWrapper');
    const elPrev  = document.getElementById('um2LkPreview');
    const elReact = document.getElementById('um2LkReactivate');
    const Y=document.getElementById('um2LkY'), M=document.getElementById('um2LkM'),
          D=document.getElementById('um2LkD'), H=document.getElementById('um2LkH'),
          Mn=document.getElementById('um2LkMn'), S=document.getElementById('um2LkS');
    let mode = 'manual';

    const calcReact = () => {
        const y=+Y.value||0,m=+M.value||0,d=+D.value||0,h=+H.value||0,mn=+Mn.value||0,s=+S.value||0;
        if (![y,m,d,h,mn,s].some(v=>v>0)) { elReact.value=''; elPrev.textContent='Ít nhất 1 trường phải > 0.'; return; }
        const dt = new Date();
        dt.setFullYear(dt.getFullYear()+y); dt.setMonth(dt.getMonth()+m); dt.setDate(dt.getDate()+d);
        dt.setHours(dt.getHours()+h); dt.setMinutes(dt.getMinutes()+mn); dt.setSeconds(dt.getSeconds()+s);
        elReact.value = fmt(dt);
        elPrev.textContent = `Tự mở khóa lúc: ${fmtD(dt)}`;
    };

    const setMode = (m, reactAt='') => {
        mode = m;
        if (m === 'timed') {
            elTitle.innerHTML = '<i class="bi bi-clock-history me-2" style="color:#fbbf24;"></i>Khóa theo thời gian';
            elWrap.classList.remove('d-none');
            elReact.required = true;
            if (reactAt) {
                const dt = new Date(reactAt);
                if (!isNaN(dt)) { Y.value=dt.getFullYear();M.value=dt.getMonth()+1;D.value=dt.getDate();H.value=dt.getHours();Mn.value=dt.getMinutes();S.value=dt.getSeconds(); }
                calcReact();
            } else { elPrev.textContent='Nhập thời gian khóa.'; }
        } else {
            elTitle.innerHTML = '<i class="bi bi-lock-fill me-2" style="color:#fca5a5;"></i>Khóa thủ công';
            elWrap.classList.add('d-none');
            elReact.required = false; elReact.value = '';
            elPrev.textContent = 'Khóa thủ công — chỉ mở khi Admin mở khóa.';
        }
    };

    document.querySelectorAll('.um2-open-lock').forEach(btn => {
        btn.addEventListener('click', () => {
            elId.value   = btn.dataset.userId;
            elName.value = btn.dataset.userName;
            setMode(btn.dataset.lockMode, btn.dataset.reactivateAt||'');
        });
    });
    [Y,M,D,H,Mn,S].forEach(el => el?.addEventListener('input', calcReact));
    document.getElementById('um2LockForm')?.addEventListener('submit', e => {
        if (mode==='timed' && !elReact.value) { e.preventDefault(); elPrev.textContent='Ít nhất 1 trường phải > 0.'; }
    });
    setMode('manual');

    // ── Countdown for locked accounts ───────────────────────────────────────
    const cds = document.querySelectorAll('.um2-countdown');
    const tick = el => {
        const at = new Date(el.dataset.reactivateAt);
        const rem = at - Date.now();
        if (isNaN(at)) { el.textContent=''; return; }
        if (rem <= 0)  { el.textContent='Đang chờ tự mở khóa...'; return; }
        const ts = Math.floor(rem/1000), dy=Math.floor(ts/86400),
              hr=Math.floor((ts%86400)/3600), mn=Math.floor((ts%3600)/60), sc=ts%60;
        el.textContent = `Còn: ${dy>0?dy+'d ':'' }${pad(hr)}:${pad(mn)}:${pad(sc)}`;
    };
    cds.forEach(el => { tick(el); setInterval(()=>tick(el),1000); });
})();
</script>
}
