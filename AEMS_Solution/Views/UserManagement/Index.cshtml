@model DataAccess.Entities.PaginationResult<BusinessLogic.DTOs.User.UserListDto>
@using DataAccess.Enum
@{
    ViewData["Title"] = "User Management";
    if (User.IsInRole("Admin")) Layout = "_AdminLayout";
    else if (User.IsInRole("Organizer") || User.IsInRole("Staff")) Layout = "_Organizerlayout";
    else Layout = "_Approvallayout";

    // ── Helpers ────────────────────────────────────────────────────────────────
    string RoleColor(string r) => r switch {
        "Admin"     => "#ef4444", "Organizer" => "#3b82f6",
        "Approver"  => "#a855f7", "Student"   => "#22c55e",
        _           => "#64748b"
    };
    string RoleBg(string r) => r switch {
        "Admin"     => "#fee2e2", "Organizer" => "#dbeafe",
        "Approver"  => "#f3e8ff", "Student"   => "#dcfce7",
        _           => "#f1f5f9"
    };
    string RoleIcon(string r) => r switch {
        "Admin"     => "bi-shield-lock-fill",
        "Organizer" => "bi-person-workspace",
        "Approver"  => "bi-patch-check-fill",
        "Student"   => "bi-mortarboard-fill",
        _           => "bi-person-fill"
    };

    string GetInitials(string? name) {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var p = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return (p.Length == 1 ? $"{p[0][0]}" : $"{p[0][0]}{p[^1][0]}").ToUpper();
    }
    string AvatarBg(string? name) {
        var colors = new[]{"#6366f1","#8b5cf6","#ec4899","#f59e0b","#10b981","#3b82f6","#ef4444","#14b8a6"};
        return string.IsNullOrEmpty(name) ? colors[0] : colors[Math.Abs(name.GetHashCode()) % colors.Length];
    }
    string ToLocalDt(DateTime? v) => v?.ToString("yyyy-MM-ddTHH:mm:ss") ?? "";

    // Stat numbers
    int totalUsers    = Model.TotalCount;
    int activeCount   = Model.Data?.Count(u => u.Status == UserStatusEnum.Active && u.IsBanned != true) ?? 0;
    int bannedCount   = Model.Data?.Count(u => u.IsBanned == true) ?? 0;
    int inactiveCount = Model.Data?.Count(u => u.Status != UserStatusEnum.Active && u.IsBanned != true) ?? 0;
}

<style>
    /* ============================================================
       USER MANAGEMENT PAGE — PREMIUM DESIGN
    ============================================================ */
    :root {
        --um-primary:      #1e40af;
        --um-primary-light:#3b82f6;
        --um-bg:           #f8fafc;
        --um-card-bg:      #ffffff;
        --um-border:       #e2e8f0;
        --um-text:         #0f172a;
        --um-muted:        #64748b;
        --um-radius:       14px;
        --um-shadow:       0 4px 24px rgba(0,0,0,.04);
        --um-focus-ring:   0 0 0 3px rgba(59,130,246,.2);
    }

    .um-page-wrapper {
        background: transparent;
        min-height: auto;
        padding: 0;
    }

    /* ── Page header ── */
    .um-page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .um-page-header h1 {
        font-size: 2rem;
        font-weight: 800;
        color: var(--um-text);
        margin-bottom: .3rem;
        letter-spacing: -.02em;
    }

    .um-page-header p {
        color: var(--um-muted);
        font-size: .9rem;
        margin: 0;
    }

    .um-create-btn {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%);
        color: #fff;
        font-weight: 700;
        font-size: .9rem;
        padding: .7rem 1.6rem;
        border-radius: 50px;
        text-decoration: none;
        border: none;
        box-shadow: 0 4px 14px rgba(30,64,175,.28);
        transition: all .22s;
        white-space: nowrap;
    }

    .um-create-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(30,64,175,.35);
        color: #fff;
    }

    /* ── Filter Card ── */
    .um-filter-card {
        background: var(--um-card-bg);
        border-radius: var(--um-radius);
        border: 1px solid var(--um-border);
        box-shadow: var(--um-shadow);
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .um-filter-label {
        font-size: .72rem;
        font-weight: 800;
        letter-spacing: .07em;
        text-transform: uppercase;
        color: var(--um-muted);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .um-filter-grid {
        display: grid;
        grid-template-columns: 1fr 220px 220px auto;
        gap: 1rem;
        align-items: end;
    }

    @@media (max-width: 992px) {
        .um-filter-grid { grid-template-columns: 1fr 1fr; }
    }

    @@media (max-width: 576px) {
        .um-filter-grid { grid-template-columns: 1fr; }
    }

    .um-filter-field-label {
        font-size: .78rem;
        font-weight: 600;
        color: var(--um-text);
        margin-bottom: .35rem;
        display: block;
    }

    .um-filter-input,
    .um-filter-select {
        width: 100%;
        padding: .65rem 1rem;
        border: 1px solid var(--um-border);
        border-radius: 10px;
        font-size: .88rem;
        color: var(--um-text);
        background: #f8fafc;
        transition: all .18s;
        outline: none;
    }

    .um-filter-input:focus,
    .um-filter-select:focus {
        background: #fff;
        border-color: var(--um-primary-light);
        box-shadow: var(--um-focus-ring);
    }

    .um-search-wrapper {
        position: relative;
    }

    .um-search-wrapper i {
        position: absolute;
        top: 50%;
        left: .85rem;
        transform: translateY(-50%);
        color: #94a3b8;
        font-size: .85rem;
        pointer-events: none;
    }

    .um-search-wrapper .um-filter-input {
        padding-left: 2.35rem;
    }

    .um-filter-btn {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        padding: .65rem 1.4rem;
        border-radius: 10px;
        font-size: .88rem;
        font-weight: 700;
        border: none;
        background: linear-gradient(135deg, #1e40af, #3b82f6);
        color: #fff;
        cursor: pointer;
        transition: all .18s;
        box-shadow: 0 3px 10px rgba(59,130,246,.25);
        white-space: nowrap;
    }

    .um-filter-btn:hover {
        opacity: .92;
        transform: translateY(-1px);
    }

    .um-filter-reset {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .65rem 1rem;
        border-radius: 10px;
        font-size: .85rem;
        font-weight: 600;
        border: 1px solid var(--um-border);
        background: #f8fafc;
        color: var(--um-muted);
        cursor: pointer;
        transition: all .18s;
        text-decoration: none;
        margin-left: .5rem;
    }

    .um-filter-reset:hover {
        background: #e2e8f0;
        color: var(--um-text);
    }

    /* ── Main Table Card ── */
    .um-table-card {
        background: var(--um-card-bg);
        border-radius: var(--um-radius);
        border: 1px solid var(--um-border);
        box-shadow: var(--um-shadow);
        overflow: hidden;
        margin-bottom: 1.5rem;
    }

    .um-table-card-header {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: .75rem;
    }

    .um-table-section-label {
        font-size: .7rem;
        font-weight: 800;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: #94a3b8;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .um-count-pill {
        background: #f1f5f9;
        color: #64748b;
        font-size: .7rem;
        font-weight: 700;
        padding: .15rem .55rem;
        border-radius: 20px;
    }

    /* ── Main Table ── */
    .um-table {
        width: 100%;
        border-collapse: collapse;
    }

    .um-table thead tr th {
        background: #f8fafc;
        font-size: .68rem;
        font-weight: 800;
        letter-spacing: .07em;
        text-transform: uppercase;
        color: #94a3b8;
        padding: .8rem 1.25rem;
        border-bottom: 1px solid #f1f5f9;
        white-space: nowrap;
    }

    .um-table tbody tr {
        border-bottom: 1px solid #f8fafc;
        transition: background .12s;
    }

    .um-table tbody tr:last-child { border-bottom: none; }

    .um-table tbody tr:hover { background: #fafbff; }

    .um-table tbody td {
        padding: .95rem 1.25rem;
        vertical-align: middle;
        font-size: .9rem;
        color: var(--um-text);
    }

    /* ── Avatar ── */
    .um-avatar-wrap {
        display: flex;
        align-items: center;
        gap: .85rem;
    }

    .um-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
        font-size: .78rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        letter-spacing: .03em;
        position: relative;
    }

    .um-avatar img {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
    }

    .um-avatar-initials {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: .78rem;
        font-weight: 800;
        color: #fff;
        flex-shrink: 0;
    }

    .um-status-dot {
        position: absolute;
        bottom: 1px;
        right: 1px;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        border: 2px solid #fff;
    }

    .um-avatar-meta {
        min-width: 0;
    }

    .um-user-name {
        font-weight: 700;
        color: #0f172a;
        font-size: .9rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 220px;
    }

    .um-user-email {
        font-size: .78rem;
        color: #64748b;
        margin-top: .1rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 220px;
    }

    /* ── Role Badge ── */
    .um-role-badge {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        padding: .25rem .75rem;
        border-radius: 20px;
        font-size: .72rem;
        font-weight: 800;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    /* ── Status Badge ── */
    .um-status-badge {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .3rem .7rem;
        border-radius: 20px;
        font-size: .78rem;
        font-weight: 700;
    }

    .um-status-badge .dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .um-status-active  { background: #f0fdf4; color: #16a34a; }
    .um-status-active  .dot { background: #22c55e; }

    .um-status-banned  { background: #fef2f2; color: #dc2626; }
    .um-status-banned  .dot { background: #ef4444; }

    .um-status-inactive { background: #f8fafc; color: #64748b; }
    .um-status-inactive .dot { background: #94a3b8; }

    /* ── Action Buttons ── */
    .um-actions {
        display: flex;
        gap: .4rem;
        align-items: center;
    }

    .um-action-btn {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: .82rem;
        cursor: pointer;
        transition: all .15s;
        text-decoration: none;
        color: #64748b;
    }

    .um-action-btn:hover { transform: translateY(-1px); }

    .um-action-btn.view:hover      { background: #eff6ff; border-color: #bfdbfe; color: #3b82f6; }
    .um-action-btn.lock:hover      { background: #fee2e2; border-color: #fca5a5; color: #ef4444; }
    .um-action-btn.lock-timed:hover { background: #fef3c7; border-color: #fde68a; color: #d97706; }
    .um-action-btn.unlock:hover    { background: #f0fdf4; border-color: #86efac; color: #16a34a; }

    /* ── Pagination ── */
    .um-pagination {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        border-top: 1px solid #f1f5f9;
        flex-wrap: wrap;
        gap: .75rem;
    }

    .um-page-info {
        font-size: .82rem;
        color: #64748b;
    }

    .um-page-info strong { color: #0f172a; }

    .um-page-nav {
        display: flex;
        align-items: center;
        gap: .35rem;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .um-page-nav a,
    .um-page-nav span {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 600;
        border: 1px solid transparent;
        color: #0f172a;
        text-decoration: none;
        transition: all .15s;
        background: transparent;
    }

    .um-page-nav a:hover        { background: #f1f5f9; border-color: #e2e8f0; }
    .um-page-nav .active a,
    .um-page-nav .active span   { background: #1e40af; color: #fff; border-color: #1e40af; }
    .um-page-nav .disabled a,
    .um-page-nav .disabled span { color: #cbd5e1; pointer-events: none; }

    .um-page-nav .ellipsis span { cursor: default; color: #94a3b8; }

    /* ── Stat Cards ── */
    .um-stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-top: 1.5rem;
    }

    @@media (max-width: 768px) {
        .um-stats-grid { grid-template-columns: 1fr; }
    }

    .um-stat-card {
        background: var(--um-card-bg);
        border-radius: var(--um-radius);
        border: 1px solid var(--um-border);
        box-shadow: var(--um-shadow);
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
    }

    .um-stat-card::after {
        content: '';
        position: absolute;
        top: -30px;
        right: -30px;
        width: 100px;
        height: 100px;
        border-radius: 50%;
        opacity: .06;
        background: var(--stat-color, #1e40af);
    }

    .um-stat-label {
        font-size: .7rem;
        font-weight: 800;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: .5rem;
    }

    .um-stat-value {
        font-size: 2rem;
        font-weight: 900;
        color: var(--um-text);
        line-height: 1;
        margin-bottom: .4rem;
    }

    .um-stat-sub {
        font-size: .78rem;
        color: #64748b;
        margin: 0;
    }

    .um-stat-trend {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        font-size: .75rem;
        font-weight: 700;
        padding: .15rem .5rem;
        border-radius: 20px;
    }

    .um-stat-trend.up   { background: #f0fdf4; color: #16a34a; }
    .um-stat-trend.warn { background: #fff7ed; color: #d97706; }

    /* ── Empty state ── */
    .um-empty {
        text-align: center;
        padding: 3rem 1rem;
        color: #94a3b8;
    }

    .um-empty i     { font-size: 2.5rem; display: block; margin-bottom: .75rem; }
    .um-empty p     { font-size: .88rem; margin: 0; }

    /* ── Alert toasts ── */
    .um-toast {
        border-radius: 12px;
        border: none;
        padding: .9rem 1.25rem;
        font-size: .9rem;
        font-weight: 600;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: .65rem;
    }

    /* ── Lock modal ── */
    .um-modal .modal-content {
        border-radius: 18px;
        border: none;
        box-shadow: 0 20px 60px rgba(0,0,0,.15);
    }

    .um-modal .modal-header { border-bottom: none; padding: 1.5rem 1.5rem .75rem; }
    .um-modal .modal-body   { padding: .75rem 1.5rem 1.25rem; }
    .um-modal .modal-footer { border-top: 1px solid #f1f5f9; padding: 1rem 1.5rem 1.25rem; }
    /* ── Staggered Row Animations ── */
    .um-table tbody tr { animation: um-row-in 0.4s ease both; }
    @@keyframes um-row-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }
    
    .um-table tbody tr:nth-child(1)  { animation-delay: .05s; }
    .um-table tbody tr:nth-child(2)  { animation-delay: .08s; }
    .um-table tbody tr:nth-child(3)  { animation-delay: .11s; }
    .um-table tbody tr:nth-child(4)  { animation-delay: .14s; }
    .um-table tbody tr:nth-child(5)  { animation-delay: .17s; }
    .um-table tbody tr:nth-child(6)  { animation-delay: .20s; }
    .um-table tbody tr:nth-child(7)  { animation-delay: .23s; }
    .um-table tbody tr:nth-child(8)  { animation-delay: .26s; }
    .um-table tbody tr:nth-child(9)  { animation-delay: .29s; }
    .um-table tbody tr:nth-child(10) { animation-delay: .32s; }
</style>

<div class="um-page-wrapper animate-fade-in">
    <div class="container-fluid p-0">

        @* Alerts *@
        @if (TempData["Success"] != null)
        {
            <div class="um-toast alert-success shadow-sm">
                <i class="bi bi-check-circle-fill text-success"></i>
                @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="um-toast alert-danger shadow-sm">
                <i class="bi bi-exclamation-triangle-fill text-danger"></i>
                @TempData["Error"]
            </div>
        }

        @* Header *@
        <div class="um-page-header">
            <div>
                <h1>User Management</h1>
                <p>Project management and authorization of system users.</p>
            </div>
            <a asp-action="CreateStaff" class="um-create-btn animate-fade-in animate-delay-1">
                <i class="bi bi-person-plus-fill"></i> Create New Account
            </a>
        </div>

        @* ── Filter Card ── *@
        <div class="um-filter-card animate-fade-in animate-delay-2">
            <div class="um-filter-label">
                <i class="bi bi-funnel-fill"></i> Filter &amp; Search
            </div>
            <form asp-action="Index" method="get" id="filterForm">
                <div class="um-filter-grid">
                    <div>
                        <label class="um-filter-field-label">SEARCH</label>
                        <div class="um-search-wrapper">
                            <i class="bi bi-search"></i>
                            <input type="text"
                                   name="searchTerm"
                                   class="um-filter-input"
                                   placeholder="Name or email..."
                                   value="@ViewBag.SearchTerm" />
                        </div>
                    </div>
                    <div>
                        <label class="um-filter-field-label">ROLE</label>
                        <select name="role" class="um-filter-select">
                            <option value="">All roles</option>
                            <option value="Student"   selected="@(ViewBag.Role?.ToString() == "Student"   ? "selected" : null)">Student</option>
                            <option value="Organizer" selected="@(ViewBag.Role?.ToString() == "Organizer" ? "selected" : null)">Organizer</option>
                            <option value="Approver"  selected="@(ViewBag.Role?.ToString() == "Approver"  ? "selected" : null)">Approver</option>
                            <option value="Staff"     selected="@(ViewBag.Role?.ToString() == "Staff"     ? "selected" : null)">Staff</option>
                            <option value="Admin"     selected="@(ViewBag.Role?.ToString() == "Admin"     ? "selected" : null)">Admin</option>
                        </select>
                    </div>
                    <div>
                        <label class="um-filter-field-label">STATUS</label>
                        <select name="status" class="um-filter-select">
                            <option value="">All statuses</option>
                            @foreach (var s in Html.GetEnumSelectList<UserStatusEnum>())
                            {
                                if (ViewBag.Status?.ToString() == s.Text)
                                { <option value="@s.Text" selected>@s.Text</option> }
                                else
                                { <option value="@s.Text">@s.Text</option> }
                            }
                        </select>
                    </div>

                    <div style="display:flex; gap:.5rem; align-items:center;">
                        <button type="submit" class="um-filter-btn">
                            <i class="bi bi-search"></i> Filter Results
                        </button>
                        <a asp-action="Index" class="um-filter-reset" title="Reset">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </a>
                    </div>
                </div>
                @* Active filter tags *@
                @if (!string.IsNullOrEmpty(ViewBag.SearchTerm?.ToString()) || ViewBag.Role != null || ViewBag.Status != null)
                {
                    <div class="um2-filter-tags">
                        @if (!string.IsNullOrEmpty(ViewBag.SearchTerm?.ToString()))
                        {
                            <a href="@Url.Action("Index","UserManagement", new{role=ViewBag.Role, status=ViewBag.Status})" class="um2-ftag">
                                <i class="bi bi-search"></i> "@ViewBag.SearchTerm" <i class="bi bi-x ms-1"></i>
                            </a>
                        }
                        @if (ViewBag.Role != null)
                        {
                            <a href="@Url.Action("Index","UserManagement", new{searchTerm=ViewBag.SearchTerm, status=ViewBag.Status})" class="um2-ftag">
                                <i class="bi bi-person-fill"></i> Role: @ViewBag.Role <i class="bi bi-x ms-1"></i>
                            </a>
                        }
                        @if (ViewBag.Status != null)
                        {
                            <a href="@Url.Action("Index","UserManagement", new{searchTerm=ViewBag.SearchTerm, role=ViewBag.Role})" class="um2-ftag">
                                <i class="bi bi-circle-fill" style="font-size:.4rem;"></i> Status: @ViewBag.Status <i class="bi bi-x ms-1"></i>
                            </a>
                        }
                        <a asp-action="Index" class="um2-ftag" style="background:#fee2e2;color:#b91c1c;border-color:#fca5a5;">
                            <i class="bi bi-x-octagon"></i> Xóa tất cả
                        </a>
                    </div>
                }
            </form>
        </div>

        @* ── Users Table Card ── *@
        <div class="um-table-card animate-fade-in animate-delay-3">
            <div class="um-table-card-header">
                <div class="um-table-section-label">
                    <i class="bi bi-people-fill"></i>
                    Users
                    <span class="um-count-pill">@Model.TotalCount</span>
                </div>
                <div style="font-size:.8rem; color:#94a3b8;">
                    Page @Model.PageNumber / @Model.TotalPages
                    &nbsp;•&nbsp;
                    Showing @((Model.PageNumber - 1) * Model.PageSize + 1)–@Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount)
                    of @Model.TotalCount users
                </div>
                <span class="um2-card-pill">@totalUsers tài khoản</span>
            </div>

            <div class="table-responsive">
                <table class="um2-table">
                    <thead>
                        <tr>
                            <th style="width:56px; text-align:center;">Avatar</th>
                            <th>User</th>
                            <th>Role</th>
                            <th>Created At</th>
                            <th>Status</th>
                            <th style="text-align:right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Data != null && Model.Data.Any())
                        {
                            int rowIdx = (Model.PageNumber - 1) * Model.PageSize + 1;
                            foreach (var user in Model.Data)
                            {
                                bool isBanned   = user.IsBanned == true;
                                bool isActive   = user.Status == UserStatusEnum.Active && !isBanned;
                                bool isInactive = user.Status != UserStatusEnum.Active && !isBanned;

                                string statusClass = isBanned ? "um-status-banned"
                                                   : isActive ? "um-status-active"
                                                   : "um-status-inactive";

                                string statusLabel = isBanned   ? "Locked"
                                                   : isActive   ? "Active"
                                                   : "Inactive";

                               string dotStatusColor = isBanned ? "#ef4444"
                                                      : isActive ? "#22c55e"
                                                      : "#94a3b8";
                                <tr class="animate-fade-in">
                                    @* Avatar *@
                                    <td style="text-align:center;">
                                        <div style="position:relative; display:inline-flex;">
                                            @if (!string.IsNullOrEmpty(user.AvatarUrl))
                                            {
                                                <img src="@user.AvatarUrl"
                                                     alt="@user.FullName"
                                                     class="um-avatar"
                                                     onerror="this.style.display='none'; this.nextElementSibling.style.display='inline-flex';" />
                                                <span class="um-avatar-initials"
                                                      style="display:none; background:@AvatarBg(user.FullName);">
                                                    @GetInitials(user.FullName)
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="um-avatar-initials" style="background:@AvatarBg(user.FullName);">
                                                    @GetInitials(user.FullName)
                                                </span>
                                            }
                                            <span class="um2-status-dot" style="background:@dotStatusColor;" title="@statusLabel"></span>
                                        </div>
                                    </td>
                                    @* User Info *@
                                    <td>
                                        <div style="display:flex; flex-direction:column; gap:0.25rem;">
                                            <div class="um2-user-name">@user.FullName</div>
                                            <div class="um2-user-email">@user.Email</div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="um2-role"
                                              style="background:@RoleBg(user.RoleName);color:@RoleColor(user.RoleName);">
                                            <i class="bi @RoleIcon(user.RoleName)" style="font-size:.65rem;"></i>
                                            @user.RoleName
                                        </span>
                                    </td>
                                    <td style="color:#64748b;font-size:.82rem;white-space:nowrap;">
                                        @(user.CreatedAt.HasValue ? user.CreatedAt.Value.ToString("dd/MM/yyyy") : "—")
                                    </td>
                                    <td>
                                        @{
                                            string displayStatusBg = isBanned ? "#fef2f2" : isActive ? "#f0fdf4" : "#f1f5f9";
                                            string displayStatusFg = isBanned ? "#991b1b" : isActive ? "#166534" : "#475569";
                                        }
                                        <div>
                                            <span class="um2-status" style="background:@displayStatusBg;color:@displayStatusFg;">
                                                <span class="um2-status-dot-inner" style="background:@dotStatusColor;"></span>
                                                @statusLabel
                                            </span>
                                            @if (user.ReactivateAt.HasValue && isBanned)
                                            {
                                                <div style="font-size:.72rem; color:#94a3b8; margin-top:.25rem;">
                                                    Unlock at: @user.ReactivateAt.Value.ToString("dd/MM/yyyy HH:mm")
                                                </div>
                                                <div style="font-size:.7rem;color:#6d28d9;font-weight:700;"
                                                     class="lock-countdown" data-reactivate-at="@ToLocalDt(user.ReactivateAt)"></div>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div class="um-actions" style="justify-content:flex-end;">
                                            @* View Detail *@
                                            <a asp-action="Detail"
                                               asp-route-id="@user.Id"
                                               class="um-action-btn view"
                                               title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            @if (isBanned)
                                            {
                                                @* Unlock Button *@
                                                <form asp-action="Unban"
                                                      asp-route-id="@user.Id"
                                                      method="post"
                                                      style="display:inline;"
                                                      onsubmit="return confirmAction(event,'Unlock account for @Html.Raw(user.FullName.Replace("'","\\'")));">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit"
                                                            class="um-action-btn unlock"
                                                            title="Unlock Account">
                                                        <i class="bi bi-unlock-fill"></i>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                @* Lock Manual *@
                                                <button type="button"
                                                        class="um-action-btn lock open-lock-modal"
                                                        title="Manual Lock"
                                                        data-lock-mode="manual"
                                                        data-bs-toggle="modal" data-bs-target="#um2LockModal"
                                                        data-user-id="@user.Id" data-user-name="@user.FullName"
                                                        data-reactivate-at="@ToLocalDt(user.ReactivateAt)">
                                                    <i class="bi bi-lock-fill"></i>
                                                </button>

                                                @* Lock Timed *@
                                                <button type="button"
                                                        class="um-action-btn lock-timed open-lock-modal"
                                                        title="Timed Lock"
                                                        data-lock-mode="timed"
                                                        data-bs-toggle="modal" data-bs-target="#um2LockModal"
                                                        data-user-id="@user.Id" data-user-name="@user.FullName"
                                                        data-reactivate-at="@ToLocalDt(user.ReactivateAt)">
                                                    <i class="bi bi-clock-history"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                                rowIdx++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6">
                                    <div class="um-empty">
                                        <i class="bi bi-person-slash"></i>
                                        <p>No matching users found.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Pagination *@
            @if (Model.TotalPages > 1)
            {
                int ws = 5, hw = 2;
                int sp = Math.Max(1, Model.PageNumber - hw);
                int ep = Math.Min(Model.TotalPages, sp + ws - 1);
                if (ep - sp + 1 < ws) sp = Math.Max(1, ep - ws + 1);

                <div class="um-pagination">
                    <div class="um-page-info">
                        Showing <strong>@((Model.PageNumber - 1) * Model.PageSize + 1)–@Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount)</strong>
                        of <strong>@Model.TotalCount</strong> users
                    </div>

                    <ul class="um-page-nav">
                        <li class="@(!Model.HasPreviousPage ? "disabled" : "")">
                            <a asp-action="Index"
                               asp-route-pageNumber="@(Model.PageNumber - 1)"
                               asp-route-searchTerm="@ViewBag.SearchTerm"
                               asp-route-role="@ViewBag.Role"
                               asp-route-status="@ViewBag.Status"
                               title="Previous Page">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @if (sp > 1)
                        {
                            <a href="@Url.Action("Index","UserManagement", new{pageNumber=1,searchTerm=ViewBag.SearchTerm,role=ViewBag.Role,status=ViewBag.Status})" class="um2-pbt" title="Đầu"><i class="bi bi-chevron-double-left"></i></a>
                            <a href="@Url.Action("Index","UserManagement", new{pageNumber=Model.PageNumber-1,searchTerm=ViewBag.SearchTerm,role=ViewBag.Role,status=ViewBag.Status})" class="um2-pbt"><i class="bi bi-chevron-left"></i></a>
                        }
                        else
                        {
                            <span class="um2-pbt disabled"><i class="bi bi-chevron-double-left"></i></span>
                            <span class="um2-pbt disabled"><i class="bi bi-chevron-left"></i></span>
                        }
                        @for (int pg = sp; pg <= ep; pg++)
                        {
                            if (pg == Model.PageNumber)
                            { <span class="um2-pbt active">@pg</span> }
                            else
                            { <a href="@Url.Action("Index","UserManagement", new{pageNumber=pg,searchTerm=ViewBag.SearchTerm,role=ViewBag.Role,status=ViewBag.Status})" class="um2-pbt">@pg</a> }
                        }

                        <li class="@(!Model.HasNextPage ? "disabled" : "")">
                            <a asp-action="Index"
                               asp-route-pageNumber="@(Model.PageNumber + 1)"
                               asp-route-searchTerm="@ViewBag.SearchTerm"
                               asp-route-role="@ViewBag.Role"
                               asp-route-status="@ViewBag.Status"
                               title="Next Page">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </div>
            }
        </div>

        @* ── Stat Cards ── *@
        <div class="um-stats-grid">
            <div class="um-stat-card animate-fade-in animate-delay-1" style="--stat-color:#1e40af; border-top: 3px solid #1e40af;">
                <div class="um-stat-label">Total Users</div>
                <div class="um-stat-value">@Model.TotalCount.ToString("N0")</div>
                <span class="um-stat-trend up"><i class="bi bi-graph-up-arrow"></i> Registered in system</span>
            </div>

            <div class="um-stat-card animate-fade-in animate-delay-2" style="--stat-color:#22c55e; border-top: 3px solid #22c55e;">
                <div class="um-stat-label">Active Users</div>
                <div class="um-stat-value" style="color:#16a34a;">@activeCount</div>
                <p class="um-stat-sub">
                    Ratio: @(Model.TotalCount > 0 ? (activeCount * 100 / Model.TotalCount) : 0)% of total system
                </p>
            </div>

            <div class="um-stat-card animate-fade-in animate-delay-3" style="--stat-color:#ef4444; border-top: 3px solid #ef4444;">
                <div class="um-stat-label">Banned Users</div>
                <div class="um-stat-value" style="color:#dc2626;">@bannedCount</div>
                <p class="um-stat-sub">Requires review: @bannedCount accounts</p>
            </div>
        </div>

    </div>
</div>

@* ════════════ LOCK MODAL ════════════ *@
<div class="modal fade um2-modal" id="um2LockModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="lockUserForm" asp-action="Ban" method="post" onsubmit="return confirmAction(event, 'Are you sure you want to lock this account?');">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <div>
                        <h5 class="modal-title fw-bold text-danger" id="lockModalTitle">
                            <i class="bi bi-lock-fill me-2"></i>Lock Account
                        </h5>
                        <p class="text-muted small mb-0">This action will prevent the user from logging in.</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="um2LockId"   name="Id" />
                    <input type="hidden" name="Status" value="Inactive" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">User</label>
                        <input type="text" id="lockUserName" class="form-control form-control-sm rounded-3 bg-light" readonly />
                    </div>

                    <div class="mb-2 d-none" id="lockReactivateAtWrapper">
                        <label class="form-label fw-semibold small">Auto-unlock after</label>
                        <div class="row g-2">
                            <div class="col-4">
                                <label class="form-label small text-muted">Years</label>
                                <input type="number" id="lockYear" class="form-control form-control-sm rounded-3" min="0" placeholder="0" />
                            </div>
                            <div class="col-4">
                                <label class="form-label small text-muted">Months</label>
                                <input type="number" id="lockMonth" class="form-control form-control-sm rounded-3" min="0" placeholder="0" />
                            </div>
                            <div class="col-4">
                                <label class="form-label small text-muted">Days</label>
                                <input type="number" id="lockDay" class="form-control form-control-sm rounded-3" min="0" placeholder="0" />
                            </div>
                            <div class="col-4">
                                <label class="form-label small text-muted">Hours</label>
                                <input type="number" id="lockHour" class="form-control form-control-sm rounded-3" min="0" placeholder="0" />
                            </div>
                            <div class="col-4">
                                <label class="form-label small text-muted">Minutes</label>
                                <input type="number" id="lockMinute" class="form-control form-control-sm rounded-3" min="0" placeholder="0" />
                            </div>
                            <div class="col-4">
                                <label class="form-label small text-muted">Seconds</label>
                                <input type="number" id="lockSecond" class="form-control form-control-sm rounded-3" min="0" placeholder="0" />
                            </div>
                        </div>
                        <input type="hidden" id="um2LkReactivate" name="ReactivateAt" />
                    </div>

                    <div class="alert alert-warning py-2 px-3 small mt-3 mb-0 rounded-3" id="lockReactivatePreview">
                        Manual lock will only be opened when the admin unlocks it.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger rounded-pill px-4">
                        <i class="bi bi-lock-fill me-2"></i>Confirm Lock
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
    // ── Counter animations 
    [
        {id:'um2c-total',   val:@totalUsers},
        {id:'um2c-active',  val:@activeCount},
        {id:'um2c-banned',  val:@bannedCount},
        {id:'um2c-inactive',val:@inactiveCount},
    ].forEach(c => {
        const el = document.getElementById(c.id);
        if (!el || c.val === 0) return;
        let cur = 0, step = Math.max(1, Math.ceil(c.val / 28));
        const t = setInterval(() => {
            cur = Math.min(cur + step, c.val);
            el.textContent = cur;
            if (cur >= c.val) clearInterval(t);
        }, 38);
    });

    // ── Lock Modal
    const pad = v => String(v).padStart(2,'0');
    const fmt = d => `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
    const fmtD = d => `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;

    const lockUserId = document.getElementById('um2LockId');
    const lockUserName = document.getElementById('lockUserName');
    const lockModalTitle = document.getElementById('lockModalTitle');
    const lockReactivateAtWrapper = document.getElementById('lockReactivateAtWrapper');
    const lockReactivatePreview = document.getElementById('lockReactivatePreview');
    const lockReactivateAt = document.getElementById('um2LkReactivate');
    const lockUserForm = document.getElementById('lockUserForm');

    const lockYear = document.getElementById('lockYear');
    const lockMonth = document.getElementById('lockMonth');
    const lockDay = document.getElementById('lockDay');
    const lockHour = document.getElementById('lockHour');
    const lockMinute = document.getElementById('lockMinute');
    const lockSecond = document.getElementById('lockSecond');

    let currentLockMode = 'manual';

    const updateTimedLockValue = () => {
        const years = +lockYear.value || 0;
        const months = +lockMonth.value || 0;
        const days = +lockDay.value || 0;
        const hours = +lockHour.value || 0;
        const minutes = +lockMinute.value || 0;
        const seconds = +lockSecond.value || 0;

        const vals = [years, months, days, hours, minutes, seconds];
        if (vals.some(v => isNaN(v) || v < 0)) {
            lockReactivateAt.value = '';
            lockReactivatePreview.textContent = 'Values must be greater than or equal to 0.';
            return;
        }
        if (!vals.some(v => v > 0)) {
            lockReactivateAt.value = '';
            lockReactivatePreview.textContent = 'At least one field must be greater than 0.';
            return;
        }
        const unlockAt = new Date();
        unlockAt.setFullYear(unlockAt.getFullYear() + years);
        unlockAt.setMonth(unlockAt.getMonth() + months);
        unlockAt.setDate(unlockAt.getDate() + days);
        unlockAt.setHours(unlockAt.getHours() + hours);
        unlockAt.setMinutes(unlockAt.getMinutes() + minutes);
        unlockAt.setSeconds(unlockAt.getSeconds() + seconds);
        lockReactivateAt.value = fmt(unlockAt);
        lockReactivatePreview.textContent = `Account will auto-unlock at ${fmtD(unlockAt)}.`;
    };

    const applyLockMode = (mode, reactivateAtValue = '') => {
        currentLockMode = mode;
        if (mode === 'timed') {
            lockModalTitle.innerHTML = '<i class="bi bi-clock-history me-2 text-warning"></i>Timed Lock Account';
            lockReactivateAtWrapper.classList.remove('d-none');
            lockReactivateAt.required = true;
            if (reactivateAtValue) {
                const dt = new Date(reactivateAtValue);
                if (!isNaN(dt)) {
                    lockYear.value = lockMonth.value = lockDay.value = lockHour.value = lockMinute.value = lockSecond.value = '';
                }
            } else {
                lockYear.value = lockMonth.value = lockDay.value = lockHour.value = lockMinute.value = lockSecond.value = '';
            }
            updateTimedLockValue();
            if (!lockReactivateAt.value) lockReactivatePreview.textContent = 'Enter duration values below.';
            return;
        }
        lockModalTitle.innerHTML = '<i class="bi bi-lock-fill me-2 text-danger"></i>Manual Lock Account';
        lockReactivateAtWrapper.classList.add('d-none');
        lockReactivateAt.required = false;
        lockReactivateAt.value = '';
        lockReactivatePreview.textContent = 'Manual lock will remain in effect until manually unlocked.';
    };

    const lockModalButtons = document.querySelectorAll('.open-lock-modal');
    lockModalButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            lockUserId.value = btn.dataset.userId;
            lockUserName.value = btn.dataset.userName;
            applyLockMode(btn.dataset.lockMode, btn.dataset.reactivateAt || '');
        });
    });

    [lockYear, lockMonth, lockDay, lockHour, lockMinute, lockSecond].forEach(el => {
        el?.addEventListener('input', updateTimedLockValue);
    });

    lockUserForm?.addEventListener('submit', e => {
        if (currentLockMode === 'timed' && !lockReactivateAt.value) {
            e.preventDefault();
            lockReactivatePreview.textContent = 'At least one field must be greater than 0.';
        }
    });

    applyLockMode('manual');

    // ─── Countdown Timers for locked accounts
    const countdownElements = document.querySelectorAll('.lock-countdown');
    const updateCountdown = el => {
        const unlockAt  = new Date(el.dataset.reactivateAt);
        const remaining = unlockAt.getTime() - Date.now();
        if (isNaN(unlockAt.getTime())) { el.textContent = ''; return; }
        if (remaining <= 0) { el.textContent = 'Waiting for auto-unlock...'; return; }
        const totalSec = Math.floor(remaining / 1000);
        const d = Math.floor(totalSec / 86400);
        const h = Math.floor((totalSec % 86400) / 3600);
        const m = Math.floor((totalSec % 3600) / 60);
        const s = totalSec % 60;
        el.textContent = `Remaining: ${d > 0 ? d + 'd ' : ''}${pad(h)}:${pad(m)}:${pad(s)}`;
    };
    countdownElements.forEach(el => {
        updateCountdown(el);
        setInterval(() => updateCountdown(el), 1000);
    });
})();

// ─── Confirm wrapper
function confirmAction(event, message) {
    if (!confirm(message)) { event.preventDefault(); return false; }
    return true;
}
</script>
}
