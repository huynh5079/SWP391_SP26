@model BusinessLogic.DTOs.User.UserDetailDto
@{
    ViewData["Title"] = "User Details";
    if (User.IsInRole("Admin")) Layout = "_AdminLayout";
    else if (User.IsInRole("Organizer") || User.IsInRole("Staff")) Layout = "_Organizerlayout";
    else Layout = "_Approvallayout";

    string ToDateTimeLocalValue(DateTime? value) => value?.ToString("yyyy-MM-ddTHH:mm:ss") ?? string.Empty;
}

<div class="container-fluid py-4 animate-fade-in">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary me-3 rounded-pill px-3 shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Back
        </a>
        <h2 class="h3 mb-0 fw-bold text-gray-800">Profile: @Model.FullName</h2>
    </div>

    <div class="row">
        @* Left Column: Profile Card *@
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0 rounded-4 animate-fade-in animate-delay-1 sticky-top" style="top: 2rem; z-index: 10;">
                <div class="card-body text-center p-4">
                    <div class="position-relative d-inline-block mb-3">
                        <img src="@(string.IsNullOrEmpty(Model.AvatarUrl) ? "https://ui-avatars.com/api/?name=" + Model.FullName : Model.AvatarUrl)" 
                             alt="@Model.FullName" 
                             class="rounded-circle shadow-sm border border-light"
                             style="width: 150px; height: 150px; object-fit: cover;">
                        <span class="position-absolute bottom-0 end-0 p-2 bg-white rounded-circle shadow-sm border" style="transform: translate(-10%, -10%);">
                            <i class="bi bi-patch-check-fill text-primary"></i>
                        </span>
                    </div>
                    
                    <h5 class="fw-bold mb-1">@Model.FullName</h5>
                    <p class="text-muted small mb-3">@Model.Email</p>
                    
                    <div class="mb-4">
                        <span class="badge rounded-pill bg-light text-primary border border-primary px-3 py-2 me-1">@Model.RoleName</span>
                        <span class="badge rounded-pill @(Model.Status == DataAccess.Enum.UserStatusEnum.Active ? "bg-success" : "bg-danger") px-3 py-2">
                            @(Model.Status?.ToString() ?? "Unknown")
                        </span>
                        @if(Model.IsBanned == true)
                        {
                            <span class="badge rounded-pill bg-dark px-3 py-2 mt-2 d-block mx-auto w-50">BANNED</span>
                        }
                    </div>

                    <div class="mb-4">
                        <button type="button" class="btn btn-primary w-100 rounded-pill py-2 shadow-sm mb-2" data-open-chat-user="@Model.Id" style="background: linear-gradient(135deg, #6366f1, #8b5cf6); border: none;">
                            <i class="bi bi-chat-dots-fill me-2"></i> Nhắn tin
                        </button>
                    </div>

                     @if (Model.ReactivateAt.HasValue && Model.Status == DataAccess.Enum.UserStatusEnum.Inactive)
                     {
                          <div class="alert alert-warning text-start border-0 shadow-sm rounded-3 p-3 mb-4">
                              <div class="small fw-bold mb-1"><i class="bi bi-clock-history me-1"></i> Unlock at:</div>
                              <div class="small">@Model.ReactivateAt.Value.ToString("dd/MM/yyyy HH:mm")</div>
                              <div class="text-primary fw-bold mt-2 lock-countdown" data-reactivate-at="@Model.ReactivateAt.Value.ToString("yyyy-MM-ddTHH:mm:ss")"></div>
                          </div>
                     }

                     @if (Model.IsBanned == true)
                     {
                          <form asp-action="Unban" asp-route-id="@Model.Id" method="post" onsubmit="return confirmAction(event, 'Confirm unlock account?');">
                              @Html.AntiForgeryToken()
                              <button type="submit" class="btn btn-success w-100 rounded-pill py-2 shadow-sm">
                                  <i class="bi bi-unlock-fill me-2"></i> Unlock Account
                              </button>
                          </form>
                     }
                     else
                     {
                          <div class="border-top pt-4 mt-2">
                              <form id="detailLockForm" asp-action="Ban" method="post" onsubmit="return confirmAction(event, 'Confirm lock account?');">
                                  @Html.AntiForgeryToken()
                                  <input type="hidden" name="Id" value="@Model.Id" />
                                  <input type="hidden" name="Status" value="Inactive" />

                                   <div class="mb-3 text-start">
                                       <label for="detailLockType" class="form-label fw-bold small text-muted">LOCK TYPE</label>
                                       <select id="detailLockType" class="form-select form-select-sm rounded-3">
                                           <option value="manual">Manual Lock</option>
                                           <option value="timed">Timed Lock</option>
                                       </select>
                                   </div>

                                   <div class="mb-3 text-start d-none" id="detailReactivateAtWrapper">
                                       <label class="form-label fw-bold small text-muted">AUTO-UNLOCK AT</label>
                                       <div class="row g-2">
                                           <div class="col-4">
                                               <input type="number" id="detailLockYear" class="form-control form-control-sm rounded-3" min="0" placeholder="Year" />
                                           </div>
                                           <div class="col-4">
                                               <input type="number" id="detailLockMonth" class="form-control form-control-sm rounded-3" min="0" placeholder="Month" />
                                           </div>
                                           <div class="col-4">
                                               <input type="number" id="detailLockDay" class="form-control form-control-sm rounded-3" min="0" placeholder="Day" />
                                           </div>
                                           <div class="col-4">
                                               <input type="number" id="detailLockHour" class="form-control form-control-sm rounded-3" min="0" placeholder="Hour" />
                                           </div>
                                           <div class="col-4">
                                               <input type="number" id="detailLockMinute" class="form-control form-control-sm rounded-3" min="0" placeholder="Min" />
                                           </div>
                                           <div class="col-4">
                                               <input type="number" id="detailLockSecond" class="form-control form-control-sm rounded-3" min="0" placeholder="Sec" />
                                           </div>
                                       </div>
                                       <input type="hidden" id="detailReactivateAt" name="ReactivateAt" value="@ToDateTimeLocalValue(Model.ReactivateAt)" />
                                   </div>

                                   <div class="alert alert-secondary py-2 px-3 small border-0 mb-3" id="detailLockPreview" style="font-size: .75rem;">
                                       Manual lock will only be opened when the admin unlocks it.
                                   </div>

                                  <button type="submit" class="btn btn-danger w-100 rounded-pill py-2 shadow-sm">
                                      <i class="bi bi-lock-fill me-2"></i> Lock Account
                                  </button>
                              </form>
                          </div>
                     }
                </div>
            </div>
        </div>

        @* Right Column: Info Cards *@
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4 animate-fade-in animate-delay-2 mb-4">
                <div class="card-header bg-white py-3 border-bottom border-light">
                    <h6 class="m-0 font-weight-bold text-primary"><i class="bi bi-info-circle me-2"></i>Detailed Information</h6>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-sm-6">
                            <label class="small text-muted fw-bold d-block mb-1">SYSTEM ID</label>
                            <div class="text-break text-dark fw-medium">@Model.Id</div>
                        </div>
                        <div class="col-sm-6">
                            <label class="small text-muted fw-bold d-block mb-1">JOINED DATE</label>
                            <div class="text-dark fw-medium">@(Model.CreatedAt.HasValue ? Model.CreatedAt.Value.ToString("dd/MM/yyyy HH:mm") : "-")</div>
                        </div>
                        <div class="col-sm-6">
                            <label class="small text-muted fw-bold d-block mb-1">PHONE NUMBER</label>
                            <div class="text-dark fw-medium">@(string.IsNullOrEmpty(Model.Phone) ? "Not updated" : Model.Phone)</div>
                        </div>
                        <div class="col-sm-6">
                            <label class="small text-muted fw-bold d-block mb-1">GOOGLE ID</label>
                            <div class="text-break text-muted small">@(string.IsNullOrEmpty(Model.GoogleId) ? "-" : Model.GoogleId)</div>
                        </div>

                        <div class="col-12"><hr class="my-2 opacity-25"></div>

                        @if (!string.IsNullOrEmpty(Model.StudentCode))
                        {
                            <div class="col-sm-6">
                                <label class="small text-muted fw-bold d-block mb-1">STUDENT CODE</label>
                                <div class="h5 text-primary fw-bold mb-0">@Model.StudentCode</div>
                            </div>
                            <div class="col-sm-6">
                                <label class="small text-muted fw-bold d-block mb-1">DEPARTMENT / FACULTY</label>
                                <div class="text-dark fw-medium">@Model.DepartmentName</div>
                            </div>
                            <div class="col-sm-6">
                                <label class="small text-muted fw-bold d-block mb-1">CURRENT SEMESTER</label>
                                <div class="text-dark fw-medium">@Model.CurrentSemester</div>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(Model.StaffCode))
                        {
                            <div class="col-sm-6">
                                <label class="small text-muted fw-bold d-block mb-1">STAFF CODE</label>
                                <div class="h5 text-primary fw-bold mb-0">@Model.StaffCode</div>
                            </div>
                            <div class="col-sm-6">
                                <label class="small text-muted fw-bold d-block mb-1">DEPARTMENT</label>
                                <div class="text-dark fw-medium">@Model.DepartmentName</div>
                            </div>
                            <div class="col-sm-6">
                                <label class="small text-muted fw-bold d-block mb-1">POSITION</label>
                                <div class="text-dark fw-medium">@Model.Position</div>
                            </div>
                        }
                        else
                        {
                            <div class="col-12 text-muted fst-italic">
                                <i class="bi bi-info-circle me-1"></i> No additional profile information (Student/Staff profile).
                            </div>
                        }
                    </div>
                </div>
            </div>
            
            @* Placeholder for Activity Log or other info *@
            <div class="card shadow-sm border-0 rounded-4 animate-fade-in animate-delay-3">
                <div class="card-body p-5 text-center text-muted">
                    <i class="bi bi-journal-text mb-3 d-block" style="font-size: 2.5rem; opacity: .3;"></i>
                    <p class="mb-0">Activity log for this user will be displayed here in a future update.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const countdownElements = document.querySelectorAll('.lock-countdown');
            const detailLockForm = document.getElementById('detailLockForm');
            const detailLockType = document.getElementById('detailLockType');
            const detailReactivateAtWrapper = document.getElementById('detailReactivateAtWrapper');
            const detailLockYear = document.getElementById('detailLockYear');
            const detailLockMonth = document.getElementById('detailLockMonth');
            const detailLockDay = document.getElementById('detailLockDay');
            const detailLockHour = document.getElementById('detailLockHour');
            const detailLockMinute = document.getElementById('detailLockMinute');
            const detailLockSecond = document.getElementById('detailLockSecond');
            const detailReactivateAt = document.getElementById('detailReactivateAt');
            const detailLockPreview = document.getElementById('detailLockPreview');
            const pad = value => value.toString().padStart(2, '0');
            const formatDateTimeLocal = value => `${value.getFullYear()}-${pad(value.getMonth() + 1)}-${pad(value.getDate())}T${pad(value.getHours())}:${pad(value.getMinutes())}:${pad(value.getSeconds())}`;
            const formatDateTimeDisplay = value => `${value.getFullYear()}-${pad(value.getMonth() + 1)}-${pad(value.getDate())} ${pad(value.getHours())}:${pad(value.getMinutes())}:${pad(value.getSeconds())}`;
            let currentDetailLockMode = 'manual';

            const setDetailTimedInputs = value => {
                if (!detailLockYear || !detailLockMonth || !detailLockDay || !detailLockHour || !detailLockMinute || !detailLockSecond) {
                    return;
                }

                detailLockYear.value = '';
                detailLockMonth.value = '';
                detailLockDay.value = '';
                detailLockHour.value = '';
                detailLockMinute.value = '';
                detailLockSecond.value = '';
            };

            const updateDetailLockSchedule = () => {
                if (!detailLockType || !detailReactivateAtWrapper || !detailReactivateAt || !detailLockPreview
                    || !detailLockYear || !detailLockMonth || !detailLockDay || !detailLockHour || !detailLockMinute || !detailLockSecond) {
                    return;
                }

                if (detailLockType.value === 'timed') {
                    const years = Number.parseInt(detailLockYear.value || '0', 10);
                    const months = Number.parseInt(detailLockMonth.value || '0', 10);
                    const days = Number.parseInt(detailLockDay.value || '0', 10);
                    const hours = Number.parseInt(detailLockHour.value || '0', 10);
                    const minutes = Number.parseInt(detailLockMinute.value || '0', 10);
                    const seconds = Number.parseInt(detailLockSecond.value || '0', 10);

                    if ([years, months, days, hours, minutes, seconds].some(value => Number.isNaN(value) || value < 0)) {
                        detailReactivateAt.value = '';
                        detailLockPreview.textContent = 'Values must be greater than or equal to 0.';
                        return;
                    }

                    if (![years, months, days, hours, minutes, seconds].some(value => value > 0)) {
                        detailReactivateAt.value = '';
                        detailLockPreview.textContent = 'At least one field must be greater than 0.';
                        return;
                    }

                    const unlockAt = new Date();
                    unlockAt.setFullYear(unlockAt.getFullYear() + years);
                    unlockAt.setMonth(unlockAt.getMonth() + months);
                    unlockAt.setDate(unlockAt.getDate() + days);
                    unlockAt.setHours(unlockAt.getHours() + hours);
                    unlockAt.setMinutes(unlockAt.getMinutes() + minutes);
                    unlockAt.setSeconds(unlockAt.getSeconds() + seconds);

                    detailReactivateAt.value = formatDateTimeLocal(unlockAt);
                    detailLockPreview.textContent = `Account will auto-unlock at ${formatDateTimeDisplay(unlockAt)}.`;
                    return;
                }

                detailReactivateAtWrapper.classList.add('d-none');
                setDetailTimedInputs('');
                detailReactivateAt.value = '';
                detailLockPreview.textContent = 'Manual lock will only be opened when the admin unlocks it.';
            };

            const applyDetailLockMode = mode => {
                if (!detailReactivateAtWrapper || !detailReactivateAt || !detailLockPreview) {
                    return;
                }

                currentDetailLockMode = mode;

                if (mode === 'timed') {
                    detailReactivateAtWrapper.classList.remove('d-none');
                    detailReactivateAt.required = true;
                    setDetailTimedInputs('');
                    detailReactivateAt.value = '';
                    detailLockPreview.textContent = 'Enter values in years, months, days, hours, minutes, seconds.';
                    return;
                }

                detailReactivateAtWrapper.classList.add('d-none');
                detailReactivateAt.required = false;
                setDetailTimedInputs('');
                detailReactivateAt.value = '';
                detailLockPreview.textContent = 'Manual lock will only be opened when the admin unlocks it.';
            };

            const updateCountdown = element => {
                const unlockAt = new Date(element.dataset.reactivateAt);
                const remaining = unlockAt.getTime() - Date.now();

                if (Number.isNaN(unlockAt.getTime())) {
                    element.textContent = '';
                    return;
                }

                if (remaining <= 0) {
                    element.textContent = 'Waiting for auto-unlock...';
                    return;
                }

                const totalSeconds = Math.floor(remaining / 1000);
                const days = Math.floor(totalSeconds / 86400);
                const hours = Math.floor((totalSeconds % 86400) / 3600);
                const minutes = Math.floor((totalSeconds % 3600) / 60);
                const seconds = totalSeconds % 60;
                const dayText = days > 0 ? `${days}d ` : '';
                element.textContent = `Remaining: ${dayText}${pad(hours)}:${pad(minutes)}:${pad(seconds)}`;
            };

            countdownElements.forEach(element => {
                updateCountdown(element);
                window.setInterval(() => updateCountdown(element), 1000);
            });

            detailLockType?.addEventListener('change', event => applyDetailLockMode(event.target.value));
            [detailLockYear, detailLockMonth, detailLockDay, detailLockHour, detailLockMinute, detailLockSecond].forEach(input => {
                input?.addEventListener('input', updateDetailLockSchedule);
            });

            detailLockForm?.addEventListener('submit', event => {
                if (currentDetailLockMode === 'timed' && !detailReactivateAt.value) {
                    event.preventDefault();
                    detailLockPreview.textContent = 'At least one field must be greater than 0.';
                }
            });

            applyDetailLockMode('manual');
        })();
        
        function confirmAction(event, message) {
            if (!confirm(message)) { event.preventDefault(); return false; }
            return true;
        }
    </script>
}
            </div>
        </div>
    </div>
</div>
