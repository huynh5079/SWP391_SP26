            </div>
            <div class="tbe-fill-bar-mini">
                <div class="tbe-fill-bar-mini-inner" style="width:@Model.FillPercent%;"></div>
            </div>
        </div>
    </div>

    @* â”€â”€ Stats Strip â”€â”€ *@
    <div class="tbe-stats-grid">
        <div class="tbe-stat">
            <div class="tbe-stat-icon" style="background:#ede9fe;">
                <i class="bi bi-ticket-perforated-fill" style="color:#6d28d9;"></i>
            </div>
            <div>
                <div class="tbe-stat-label">Total Tickets</div>
                <div class="tbe-stat-value" style="color:#6d28d9;">@Model.TotalTickets</div>
            </div>
        </div>
        <div class="tbe-stat">
            <div class="tbe-stat-icon" style="background:#dcfce7;">
                <i class="bi bi-check-circle-fill" style="color:#16a34a;"></i>
            </div>
            <div>
                <div class="tbe-stat-label">Checked In</div>
                <div class="tbe-stat-value" style="color:#16a34a;">@Model.CheckedIn</div>
            </div>
        </div>
        <div class="tbe-stat">
            <div class="tbe-stat-icon" style="background:#dbeafe;">
                <i class="bi bi-clock-fill" style="color:#1d4ed8;"></i>
            </div>
            <div>
                <div class="tbe-stat-label">Registered</div>
                <div class="tbe-stat-value" style="color:#1d4ed8;">@Model.Registered</div>
            </div>
        </div>
        <div class="tbe-stat">
            <div class="tbe-stat-icon" style="background:#fee2e2;">
                <i class="bi bi-x-circle-fill" style="color:#dc2626;"></i>
            </div>
            <div>
                <div class="tbe-stat-label">Cancelled</div>
                <div class="tbe-stat-value" style="color:#dc2626;">@Model.Cancelled</div>
            </div>
        </div>
        <div class="tbe-stat">
            <div class="tbe-stat-icon" style="background:#fef3c7;">
                <i class="bi bi-person-badge-fill" style="color:#d97706;"></i>
            </div>
            <div>
                <div class="tbe-stat-label">Remaining</div>
                <div class="tbe-stat-value" style="color:#d97706;">@Model.RemainingSeats</div>
            </div>
        </div>
    </div>

    @* â”€â”€ Search + Status filter â”€â”€ *@
    <div class="tbe-filter-bar">
        <form method="get" asp-controller="Organizer" asp-action="TicketsByEvent" style="display:contents;">
            <input type="hidden" name="eventId" value="@Model.EventId" />

            @* Search *@
            <div class="tbe-search-wrap">
                <i class="bi bi-search"></i>
                <input type="text" name="search" value="@Model.Search"
                       id="tbeSearchInput"
                       class="tbe-search-input"
                       placeholder="Search by student name or ticket codeâ€¦"
                       oninput="tbeLiveFilter()" />
            </div>

                        @* Status dropdown - plain HTML to avoid RZ1031 *@
            <select name="status" class="tbe-status-select" onchange="this.form.submit()">
                <option value="">All Statuses</option>
                <option value="Registered">Registered</option>
                <option value="CheckedIn">Checked In</option>
                <option value="Used">Used</option>
                <option value="Cancelled">Cancelled</option>
            </select>

            <button type="submit" class="tbe-btn tbe-btn-filter">
                <i class="bi bi-funnel-fill"></i> Filter
            </button>

            @if (!string.IsNullOrWhiteSpace(Model.Search) || !string.IsNullOrWhiteSpace(Model.StatusFilter))
            {
                <a asp-controller="Organizer" asp-action="TicketsByEvent"
                   asp-route-eventId="@Model.EventId"
                   class="tbe-btn tbe-btn-ghost">
                    <i class="bi bi-x-circle"></i> Clear
                </a>
            }
        </form>
        <span class="tbe-result-count">
            <strong id="tbeVisCount">@tickets.Count</strong> / @tickets.Count ticket(s)
        </span>
    </div>

    @* â”€â”€ Table card â”€â”€ *@
    <div class="tbe-table-card">
        <div class="tbe-table-header">
            <div class="tbe-table-label">
                <i class="bi bi-list-ul"></i> Ticket List
                <span class="tbe-count-chip" id="tbeChipCount">@tickets.Count ticket(s)</span>
            </div>
            <div style="font-size:.78rem; color:#94a3b8;">
                @if (!string.IsNullOrWhiteSpace(Model.Search) || !string.IsNullOrWhiteSpace(Model.StatusFilter))
                {
                    <span>
                        Filtered
                        @if (!string.IsNullOrWhiteSpace(Model.Search)) { <text>by "<strong style="color:#6366f1;">@Model.Search</strong>"</text> }
                        @if (!string.IsNullOrWhiteSpace(Model.StatusFilter)) { <text>Â· Status: <strong style="color:#6366f1;">@Model.StatusFilter</strong></text> }
                    </span>
                }
                else
                {
                    <span>All tickets</span>
                }
            </div>
        </div>

        @if (!tickets.Any())
        {
            <div class="tbe-empty">
                <div class="tbe-empty-icon"><i class="bi bi-ticket-perforated"></i></div>
                <h3>No Tickets Found</h3>
                <p>
                    @if (!string.IsNullOrWhiteSpace(Model.Search) || !string.IsNullOrWhiteSpace(Model.StatusFilter))
                    {
                        <text>No tickets match the current filters. Try clearing the search.</text>
                    }
                    else
                    {
                        <text>No tickets have been registered for this event yet.</text>
                    }
                </p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="tbe-table" id="tbeTable">
                    <colgroup>
                        <col style="width:50px;" />
                        <col />
                        <col style="width:160px;" />
                        <col style="width:120px;" />
                        <col style="width:160px;" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Student</th>
                            <th>Ticket Code</th>
                            <th>Status</th>
                            <th>Check-In Time</th>
                        </tr>
                    </thead>
                    <tbody id="tbeTableBody">
                        @{int rowNum = 1;}
                        @foreach (var ticket in tickets)
                        {
                            var avatarColor = GetAvatarColor(ticket.StudentName);
                            var initials    = GetInitials(ticket.StudentName);

                            <tr class="tbe-ticket-row"
                                data-name="@ticket.StudentName.ToLower()"
                                data-code="@(ticket.TicketCode ?? "").ToLower()">

                                @* # â”€â”€ *@
                                <td>
                                    <span style="font-size:.75rem; color:#94a3b8; font-weight:700;">@rowNum</span>
                                </td>

                                @* Student â”€â”€ *@
                                <td>
                                    <div class="tbe-student-cell">
                                        <div class="tbe-student-avatar" style="background:@avatarColor;">
                                            @initials
                                        </div>
                                        <div>
                                            <div class="tbe-student-name">@ticket.StudentName</div>
                                            <div class="tbe-student-id">ID: @ticket.StudentId[..Math.Min(10,ticket.StudentId.Length)]â€¦</div>
                                        </div>
                                    </div>
                                </td>

                                @* Ticket Code â”€â”€ *@
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(ticket.TicketCode))
                                    {
                                        <span class="tbe-ticket-code">@ticket.TicketCode</span>
                                    }
                                    else
                                    {
                                        <span class="tbe-ticket-code empty">â€”</span>
                                    }
                                </td>

                                @* Status â”€â”€ *@
                                <td>
                                    <span class="tbe-status-pill @StatusClass(ticket.Status)">
                                        <i class="bi @StatusIcon(ticket.Status)" style="font-size:.65rem;"></i>
                                        @ticket.Status
                                    </span>
                                </td>

                                @* Check-In Time â”€â”€ *@
                                <td>
                                    @if (ticket.CheckInTime.HasValue)
                                    {
                                        <div class="tbe-checkin">
                                            <strong>@ticket.CheckInTime.Value.ToString("dd/MM/yyyy")</strong>
                                            <span style="color:#94a3b8; font-size:.76rem;">@ticket.CheckInTime.Value.ToString("HH:mm")</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span style="color:#cbd5e1; font-size:.82rem; font-style:italic;">Not checked in</span>
                                    }
                                </td>
                            </tr>
                            rowNum++;
                        }
                    </tbody>
                </table>
            </div>

            @* â”€â”€ Summary footer â”€â”€ *@
            <div class="tbe-footer">
                <div>
                    Showing <strong id="tbeFooterCount">@tickets.Count</strong> / <strong>@tickets.Count</strong> ticket(s)
                    &nbsp;Â·&nbsp; <strong>@Model.CheckedIn</strong> checked in
                    &nbsp;Â·&nbsp; <strong>@Model.Registered</strong> registered
                    &nbsp;Â·&nbsp; <strong>@Model.Cancelled</strong> cancelled
                </div>
                <div>
                    Fill rate: <strong style="color:@FillColor(Model.FillPercent);">@Model.FillPercent.ToString("0.0")%</strong>
                    &nbsp;Â·&nbsp; Remaining: <strong>@Model.RemainingSeats</strong>
                </div>
            </div>
        }
    </div>

</div>
</div>

@section Scripts {
    <script>
    document.addEventListener('DOMContentLoaded', function () {

        // â”€â”€ Live client-side filter (name + ticket code) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
        window.tbeLiveFilter = function () {
            const query    = (document.getElementById('tbeSearchInput')?.value ?? '').toLowerCase().trim();
            const rows     = document.querySelectorAll('#tbeTableBody .tbe-ticket-row');
            const chip     = document.getElementById('tbeChipCount');
            const visCount = document.getElementById('tbeVisCount');
            const footer   = document.getElementById('tbeFooterCount');
            let visible    = 0;

            rows.forEach(function (row) {
                const name = row.getAttribute('data-name') || '';
                const code = row.getAttribute('data-code') || '';
                const show = !query || name.includes(query) || code.includes(query);
                row.classList.toggle('tbe-filtered-out', !show);
                if (show) visible++;
            });

            if (chip)     chip.textContent    = visible + ' ticket(s)';
            if (visCount) visCount.textContent = visible;
            if (footer)   footer.textContent   = visible;
        };

        // â”€â”€ Auto-run in case browser pre-fills â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
        tbeLiveFilter();

        // â”€â”€ Row hover â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
        document.querySelectorAll('.tbe-ticket-row').forEach(function (row) {
            row.addEventListener('mouseenter', function () {
                this.style.transition = 'background .12s';
            });
        });

        // â”€â”€ Toast auto-dismiss â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
        document.querySelectorAll('.tbe-toast').forEach(function (t) {
            setTimeout(function () {
                t.style.transition = 'opacity .4s, transform .4s';
                t.style.opacity    = '0';
                t.style.transform  = 'translateY(-6px)';
                setTimeout(function () { t.remove(); }, 420);
            }, 5000);
        });

    });
    </script>
}

