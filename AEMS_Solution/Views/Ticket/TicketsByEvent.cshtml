@* ============================================================
   Views/Ticket/TicketsByEvent.cshtml
   â”€â”€ Individual ticket records for a single event â”€â”€
   Populated by OrganizerController.TicketsByEvent()
   Team TODO: ensure the controller's _unitOfWork.Tickets query
   is wired to the correct repository / service.
============================================================ *@
@model AEMS_Solution.Models.Organizer.Manage.TicketsByEventViewModel
@using DataAccess.Enum
@{
    ViewData["Title"] = "Tickets â€“ " + Model.EventTitle;
    Layout = "_Organizerlayout";

    var tickets = Model.Tickets ?? new List<AEMS_Solution.Models.Organizer.Manage.TicketListItemVm>();

    // â”€â”€ Status helpers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    string StatusClass(TicketStatusEnum s) => s switch
    {
        TicketStatusEnum.CheckedIn  => "tbe-status-checkedin",
        TicketStatusEnum.Registered => "tbe-status-registered",
        TicketStatusEnum.Cancelled  => "tbe-status-cancelled",
        TicketStatusEnum.Used       => "tbe-status-used",
        _                           => "tbe-status-registered"
    };
    string StatusIcon(TicketStatusEnum s) => s switch
    {
        TicketStatusEnum.CheckedIn  => "bi-check-circle-fill",
        TicketStatusEnum.Registered => "bi-ticket-perforated-fill",
        TicketStatusEnum.Cancelled  => "bi-x-circle-fill",
        TicketStatusEnum.Used       => "bi-patch-check-fill",
        _                           => "bi-ticket-perforated-fill"
    };

    // â”€â”€ Avatar colour from student name hash â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    string GetAvatarColor(string? name)
    {
        var palette = new[] {
            "#6366f1","#8b5cf6","#ec4899","#f59e0b",
            "#10b981","#3b82f6","#ef4444","#14b8a6","#f97316","#a855f7"
        };
        if (string.IsNullOrEmpty(name)) return palette[0];
        return palette[Math.Abs(name.GetHashCode()) % palette.Length];
    }
    string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 1
            ? parts[0][0].ToString().ToUpper()
            : $"{parts[0][0]}{parts[^1][0]}".ToUpper();
    }

    // â”€â”€ Fill-rate colour â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    string FillColor(double pct) =>
        pct >= 90 ? "#ef4444" : pct >= 60 ? "#f59e0b" : "#22c55e";

    // Status options for the dropdown filter
    var statusOptions = new[] {
        ("", "All Statuses"),
        ("Registered",  "Registered"),
        ("CheckedIn",   "Checked In"),
        ("Used",        "Used"),
        ("Cancelled",   "Cancelled")
    };
}

<style>
