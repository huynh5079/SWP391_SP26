        <span>@Model.EventTitle</span>
    </div>

    @* â”€â”€ Header â”€â”€ *@
    <div class="tbe-header">
        <div>
            <h1 class="tbe-header-title">
                <div class="tbe-header-icon"><i class="bi bi-ticket-perforated-fill"></i></div>
                Ticket Details
            </h1>
            <p class="tbe-header-sub">Individual ticket records for this event.</p>
