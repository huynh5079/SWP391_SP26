            <a asp-controller="Organizer" asp-action="Manage"
               asp-route-operation="manageticket"
               class="tbe-btn tbe-btn-ghost">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    @* â”€â”€ Event summary card â”€â”€ *@
    <div class="tbe-event-card">
        <div class="tbe-event-card-icon"><i class="bi bi-calendar2-event-fill"></i></div>
        <div style="flex:1; min-width:0;">
            <div class="tbe-event-card-title">@Model.EventTitle</div>
            <div class="tbe-event-card-detail">
                <span><i class="bi bi-ticket-perforated"></i> @Model.TotalTickets / @Model.MaxCapacity sold</span>
                <span><i class="bi bi-check-circle"></i> @Model.CheckedIn checked in</span>
                <span><i class="bi bi-hourglass-split"></i> @Model.RemainingSeats seats left</span>
