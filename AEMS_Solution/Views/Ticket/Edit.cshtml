@model AEMS_Solution.Models.Organizer.Manage.UpdateTicketViewModel
@using DataAccess.Enum
@{
    ViewData["Title"] = "Edit Ticket";
    Layout = "_Organizerlayout";
}

<div class="container mt-4">
    <h2>Edit Ticket</h2>
    <form asp-controller="Ticket" asp-action="Edit" method="post" class="mt-3">
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(false, "", new { @class = "text-danger" })
        <input asp-for="TicketId" type="hidden" />

        <div class="mb-3">
            <label class="form-label">Event</label>
            <input value="@Model.EventName" class="form-control" disabled />
        </div>

        <div class="mb-3">
            <label class="form-label">Student</label>
            <input value="@Model.StudentName" class="form-control" disabled />
        </div>

        <div class="mb-3">
            <label asp-for="TicketCode" class="form-label"></label>
            <input asp-for="TicketCode" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Status" class="form-label"></label>
            <select asp-for="Status" asp-items="Html.GetEnumSelectList<TicketStatusEnum>()" class="form-select"></select>
        </div>

        <div class="mb-3">
            <label asp-for="CheckInTime" class="form-label"></label>
            <input asp-for="CheckInTime" type="datetime-local" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary">Update</button>
        <a asp-controller="Ticket" asp-action="Index" class="btn btn-secondary">Back</a>
    </form>
</div>
