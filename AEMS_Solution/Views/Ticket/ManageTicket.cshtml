@model AEMS_Solution.Models.Organizer.Manage.ManageTicketViewModel
@{
    ViewData["Title"] = "Manage Tickets";
    Layout = "_Organizerlayout";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Manage Tickets</h2>
        <span class="badge bg-primary fs-6">Total sold: @Model.TotalSoldTickets</span>
    </div>

    <form method="get" asp-controller="Organizer" asp-action="Manage" class="row g-2 mb-3">
        <input type="hidden" name="operation" value="manageticket" />
        <div class="col-md-5">
            <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search event title..." />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-outline-primary">Search</button>
        </div>
    </form>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-bordered table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Event</th>
                        <th>Start</th>
                        <th>End</th>
                        <th class="text-center">Sold</th>
                        <th class="text-center">Capacity</th>
                        <th class="text-center">Remaining</th>
                        <th class="text-center">Fill %</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Events.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-3">No events found.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var e in Model.Events)
                        {
                            <tr>
                                <td>
                                    <a asp-controller="Organizer" asp-action="Manage" asp-route-operation="detailevent" asp-route-id="@e.EventId" class="text-decoration-none fw-semibold">
                                        @e.EventTitle
                                    </a>
                                </td>
                                <td>@e.StartTime.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@e.EndTime.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-center">@e.SoldTickets</td>
                                <td class="text-center">@e.MaxCapacity</td>
                                <td class="text-center">@e.RemainingSeats</td>
                                <td class="text-center">@e.FillPercent%</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
