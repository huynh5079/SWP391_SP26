@using DataAccess.Enum
@model AEMS_Solution.Models.Organizer.Manage.EventParticipantsViewModel
@{
    ViewData["Title"] = "Người tham gia - " + Model.EventTitle;
    Layout = "_OrganizerLayout";
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="Manage" asp-route-operation="detail" asp-route-id="@Model.EventId" class="btn btn-outline-secondary me-3">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-action="Index">Dashboard</a></li>
                    <li class="breadcrumb-item"><a asp-action="Manage" asp-route-operation="myevents">Sự kiện của tôi</a></li>
                    <li class="breadcrumb-item"><a asp-action="Manage" asp-route-operation="detail" asp-route-id="@Model.EventId">Chi tiết</a></li>
                    <li class="breadcrumb-item active">Người tham gia</li>
                </ol>
            </nav>
            <h2 class="h4 mb-0">Quản lý người tham gia</h2>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
            <div class="row align-items-center">
                <div class="col">
                    <h5 class="mb-0">Danh sách đăng ký (@Model.Participants.Count)</h5>
                    <p class="text-muted small mb-0">Sự kiện: <strong>@Model.EventTitle</strong></p>
                </div>
                <div class="col-auto d-flex gap-2">
                    <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addParticipantModal">
                        <i class="bi bi-person-plus me-1"></i>Thêm người tham gia
                    </button>
                    <a href="@Url.Action("LiveDisplay", "CheckIn", new { eventId = Model.EventId })" target="_blank" class="btn btn-sm btn-outline-success" title="Mở màn hình chào mừng sự kiện">
                        <i class="bi bi-display me-1"></i>Màn hình Welcome
                    </a>
                    <button class="btn btn-sm btn-outline-primary" onclick="window.print()">
                        <i class="bi bi-printer me-1"></i>In danh sách
                    </button>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Họ tên / MSSV</th>
                            <th>Mã vé</th>
                            <th>Email</th>
                            <th>Trạng thái</th>
                            <th>Check-in</th>
                            <th>Check-out</th>
                            <th class="text-end pe-4">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Participants == null || !Model.Participants.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="bi bi-people d-block display-4 mb-3"></i>
                                        <p>Chưa có ai đăng ký tham gia sự kiện này.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var p in Model.Participants)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar avatar-sm bg-primary text-white rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 0.8rem;">
                                                @(p.FullName.Length > 0 ? p.FullName[0].ToString().ToUpper() : "?")
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">@p.FullName</div>
                                                <div class="text-muted small">@p.StudentCode</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <code class="text-primary small">@p.TicketCode</code>
                                    </td>
                                    <td><span class="text-muted small">@p.Email</span></td>
                                    <td>
                                        @{
                                            var badgeClass = p.Status switch
                                            {
                                                TicketStatusEnum.Registered => "bg-info-subtle text-info border-info",
                                                TicketStatusEnum.CheckedIn => "bg-warning-subtle text-warning border-warning",
                                                TicketStatusEnum.Used => "bg-success-subtle text-success border-success",
                                                TicketStatusEnum.Cancelled => "bg-danger-subtle text-danger border-danger",
                                                _ => "bg-secondary-subtle"
                                            };
                                            var statusText = p.Status switch
                                            {
                                                TicketStatusEnum.Registered => "Đã đăng ký",
                                                TicketStatusEnum.CheckedIn => "Đã Check-in",
                                                TicketStatusEnum.Used => "Đã Checkout",
                                                TicketStatusEnum.Cancelled => "Đã hủy",
                                                _ => p.Status.ToString()
                                            };
                                        }
                                        <span class="badge border @badgeClass">@statusText</span>
                                    </td>
                                    <td>
                                        @if (p.CheckInTime.HasValue)
                                        {
                                            <div class="text-dark small">@p.CheckInTime.Value.ToString("HH:mm")</div>
                                            <div class="text-muted" style="font-size: 0.7rem;">@p.CheckInTime.Value.ToString("dd/MM/yyyy")</div>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">--:--</span>
                                        }
                                    </td>
                                    <td>
                                        @if (p.CheckOutTime.HasValue)
                                        {
                                            <div class="text-dark small">@p.CheckOutTime.Value.ToString("HH:mm")</div>
                                            <div class="text-muted" style="font-size: 0.7rem;">@p.CheckOutTime.Value.ToString("dd/MM/yyyy")</div>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">--:--</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="d-flex justify-content-end gap-2">
                                            @if (p.Status != TicketStatusEnum.Cancelled)
                                            {
                                                <!-- Resend Email -->
                                                <form asp-action="ResendTicket" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="ticketId" value="@p.TicketId" />
                                                    <input type="hidden" name="eventId" value="@Model.EventId" />
                                                    <button type="submit" class="btn btn-sm btn-outline-info" title="Gửi lại email vé">
                                                        <i class="bi bi-envelope"></i>
                                                    </button>
                                                </form>

                                                <!-- Cancel Ticket -->
                                                <form asp-action="CancelTicket" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="ticketId" value="@p.TicketId" />
                                                    <input type="hidden" name="eventId" value="@Model.EventId" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Hủy vé" onclick="return confirm('Bạn có chắc chắn muốn hủy vé của @p.FullName?')">
                                                        <i class="bi bi-x-circle"></i>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-muted small italic">N/A</span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Add Participant -->
<div class="modal fade" id="addParticipantModal" tabindex="-1" aria-labelledby="addParticipantModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="addParticipantModalLabel">Thêm người tham gia thủ công</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="ManualRegister" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="eventId" value="@Model.EventId" />
                <input type="hidden" name="userId" id="selectedUserId" required />

                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tìm kiếm sinh viên (Email hoặc Tên)</label>
                        <div class="position-relative">
                            <input type="text" id="userSearchInput" class="form-control" placeholder="Nhập email hoặc tên..." autocomplete="off">
                            <div id="searchResultList" class="list-group position-absolute w-100 shadow-sm d-none" style="z-index: 1050; max-height: 200px; overflow-y: auto;">
                                <!-- Results will be injected here -->
                            </div>
                        </div>
                        <div id="selectedUserDisplay" class="mt-2 d-none">
                            <div class="alert alert-info py-2 px-3 mb-0 d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="bi bi-person-check-fill me-2"></i>
                                    <span id="selectedUserName" class="fw-bold"></span>
                                    <div class="small text-muted" id="selectedUserEmail"></div>
                                </div>
                                <button type="button" class="btn-close btn-sm" onclick="clearUserSelection()"></button>
                            </div>
                        </div>
                    </div>
                    <div class="alert alert-warning small">
                        <i class="bi bi-exclamation-triangle-fill me-1"></i>
                        Hệ thống sẽ tạo vé mới và gửi email xác nhận kèm mã QR cho sinh viên này.
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary" id="btnSubmitRegistration" disabled>Xác nhận đăng ký</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('userSearchInput');
            const resultList = document.getElementById('searchResultList');
            const selectedUserId = document.getElementById('selectedUserId');
            const selectedUserDisplay = document.getElementById('selectedUserDisplay');
            const selectedUserName = document.getElementById('selectedUserName');
            const selectedUserEmail = document.getElementById('selectedUserEmail');
            const btnSubmit = document.getElementById('btnSubmitRegistration');

            let timeout = null;

            searchInput.addEventListener('input', function() {
                clearTimeout(timeout);
                const q = this.value.trim();
                
                if (q.length < 2) {
                    resultList.classList.add('d-none');
                    return;
                }

                timeout = setTimeout(() => {
                    fetch(`/api/v1/lookup/users?q=${encodeURIComponent(q)}`)
                        .then(res => res.json())
                        .then(data => {
                            if (data.isSuccess && data.data) {
                                renderResults(data.data);
                            }
                        });
                }, 300);
            });

            function renderResults(users) {
                resultList.innerHTML = '';
                if (users.length === 0) {
                    resultList.innerHTML = '<div class="list-group-item text-muted">Không tìm thấy người dùng</div>';
                } else {
                    users.forEach(user => {
                        const item = document.createElement('a');
                        item.href = '#';
                        item.className = 'list-group-item list-group-item-action';
                        item.innerHTML = `
                            <div class="fw-bold">${user.fullName}</div>
                            <div class="small text-muted">${user.email} (${user.role})</div>
                        `;
                        item.addEventListener('click', (e) => {
                            e.preventDefault();
                            selectUser(user);
                        });
                        resultList.appendChild(item);
                    });
                }
                resultList.classList.remove('d-none');
            }

            function selectUser(user) {
                selectedUserId.value = user.id;
                selectedUserName.textContent = user.fullName;
                selectedUserEmail.textContent = user.email;
                
                selectedUserDisplay.classList.remove('d-none');
                searchInput.value = '';
                resultList.classList.add('d-none');
                btnSubmit.disabled = false;
            }

            window.clearUserSelection = function() {
                selectedUserId.value = '';
                selectedUserDisplay.classList.add('d-none');
                btnSubmit.disabled = true;
            };

            // Close results when clicking outside
            document.addEventListener('click', function(e) {
                if (!searchInput.contains(e.target) && !resultList.contains(e.target)) {
                    resultList.classList.add('d-none');
                }
            });
        });
    </script>
}

<style>
    .avatar { flex-shrink: 0; }
    .bg-info-subtle { background-color: #e0f7fa !important; }
    .text-info { color: #00acc1 !important; }
    .border-info { border-color: #b2ebf2 !important; }
    .bg-warning-subtle { background-color: #fff8e1 !important; }
    .text-warning { color: #fbc02d !important; }
    .border-warning { border-color: #fff1c1 !important; }
    .bg-success-subtle { background-color: #e8f5e9 !important; }
    .text-success { color: #2e7d32 !important; }
    .border-success { border-color: #c8e6c9 !important; }
    .bg-danger-subtle { background-color: #ffebee !important; }
    .text-danger { color: #d32f2f !important; }
    .border-danger { border-color: #ffcdd2 !important; }
    .italic { font-style: italic; }
</style>
