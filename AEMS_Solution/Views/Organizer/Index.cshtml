@model AEMS_Solution.Models.Organizer.OrganizerDashboardViewModel
@using DataAccess.Enum
@{
    ViewData["Title"] = "Organizer Dashboard";
    Layout = "_OrganizerLayout";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Ban Tổ Chức - Bảng Điều Khiển</h1>
            <p class="text-muted small">Quản lý sự kiện và theo dõi hđ sắp tới</p>
        </div>

        <div class="d-flex gap-2">
            <a asp-controller="Organizer" asp-action="Manage" asp-route-operation="create" class="btn btn-sm btn-primary shadow-sm">
                <i class="bi bi-plus-circle"></i> Create Event
            </a>
            <a asp-controller="Organizer" asp-action="Manage" asp-route-operation="myevents" class="btn btn-sm btn-outline-primary shadow-sm">
                <i class="bi bi-calendar-event"></i> My Events
            </a>
            <a asp-controller="Organizer" asp-action="Manage" asp-route-operation="myeventsdelete" class="btn btn-sm btn-outline-primary shadow-sm">
                <i class="bi bi-calendar-event"></i> Event allready delete
            </a>
        </div>
    </div>

    <!-- Stats Cards Row -->
    <div class="row mb-4">
        <!-- Total Events -->
        <div class="col-md-3 mb-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-muted small text-uppercase fw-bold mb-1">Tổng Sự Kiện</p>
                            <h3 class="mb-0 text-primary">@Model.Stats.TotalEvents</h3>
                        </div>
                        <div class="bg-primary bg-opacity-10 p-3 rounded">
                            <i class="bi bi-calendar-check text-primary" style="font-size: 1.5rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Upcoming Events -->
        <div class="col-md-3 mb-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-muted small text-uppercase fw-bold mb-1">Sắp Tới</p>
                            <h3 class="mb-0 text-info">@Model.Stats.UpcomingEvents</h3>
                        </div>
                        <div class="bg-info bg-opacity-10 p-3 rounded">
                            <i class="bi bi-clock-history text-info" style="font-size: 1.5rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Registrations Today -->
        <div class="col-md-3 mb-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-muted small text-uppercase fw-bold mb-1">Đăng Ký Hôm Nay</p>
                            <h3 class="mb-0 text-success">@Model.RegistrationsToday</h3>
                        </div>
                        <div class="bg-success bg-opacity-10 p-3 rounded">
                            <i class="bi bi-person-check text-success" style="font-size: 1.5rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Draft Events -->
        <div class="col-md-3 mb-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-muted small text-uppercase fw-bold mb-1">Nháp</p>
                            <h3 class="mb-0 text-warning">@Model.Stats.DraftEvents</h3>
                        </div>
                        <div class="bg-warning bg-opacity-10 p-3 rounded">
                            <i class="bi bi-file-text text-warning" style="font-size: 1.5rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Deposit Collected Card -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="text-muted small text-uppercase fw-bold mb-1">Tiền Đặt Cọc Thu Được Tháng Này</p>
                            <h2 class="mb-0 text-danger">@Model.DepositCollectedThisMonth.ToString("C")</h2>
                        </div>
                        <div class="bg-danger bg-opacity-10 p-3 rounded">
                            <i class="bi bi-cash-coin text-danger" style="font-size: 2rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row mb-4">
        <!-- Registration Trend Chart -->
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light border-bottom">
                    <h5 class="mb-0">Xu Hướng Đăng Ký (7 Ngày Gần Nhất)</h5>
                </div>
                <div class="card-body">
                    <canvas id="registrationTrendChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Event Status Distribution -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light border-bottom">
                    <h5 class="mb-0">Phân Bố Trạng Thái Sự Kiện</h5>
                </div>
                <div class="card-body">
                    <canvas id="statusDistributionChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Events Table -->
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-light border-bottom d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Sự Kiện Gần Đây</h5>
                    <a asp-controller="Event" asp-action="Index" class="btn btn-sm btn-outline-primary">Xem Tất Cả</a>
                </div>
                <div class="card-body">
                    @if (Model.RecentEvents != null && Model.RecentEvents.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Tên Sự Kiện</th>
                                        <th>Thời Gian Bắt Đầu</th>
                                        <th>Trạng Thái</th>
                                        <th>Hành Động</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var evt in Model.RecentEvents)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@evt.Title</strong>
                                            </td>
                                            <td>
                                                @evt.StartTime.ToString("dd/MM/yyyy HH:mm")
                                            </td>
                                            <td>
                                                @{
                                                    string badgeClass = evt.Status switch
                                                    {
                                                        EventStatusEnum.Draft => "bg-secondary",
                                                        EventStatusEnum.Pending => "bg - warning",
                                                        EventStatusEnum.Approved => "bg-success",
                                                        EventStatusEnum.Happening => "bg-info",
                                                        EventStatusEnum.Completed => "bg-primary",
                                                        EventStatusEnum.Rejected => "bg-danger",
                                                        EventStatusEnum.Cancelled => "bg-dark",
                                                        _ => "bg-secondary"
                                                    };
                                                }
                                                <span class="badge @badgeClass">@evt.Status</span>
                                            </td>
                                            <td>
                                                <a asp-controller="Event" asp-action="Edit" asp-route-id="@evt.EventId" class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-pencil"></i> Sửa
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            <i class="bi bi-info-circle"></i> Bạn chưa có sự kiện nào.
                            <a asp-controller="Organizer" asp-action="Manage" asp-route-action="create" class="alert-link">Tạo sự kiện mới</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Registration Trend Chart (Line Chart)
        const registrationCtx = document.getElementById('registrationTrendChart').getContext('2d');
        new Chart(registrationCtx, {
            type: 'line',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RegistrationTrendLabels)),
                datasets: [{
                    label: 'Đăng Ký',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RegistrationTrendData)),
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13, 110, 253, 0.1)',
                    borderWidth: 2,
                    fill: true,
                    tension: 0.4,
                    pointBackgroundColor: '#0d6efd',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2,
                    pointRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        display: true,
                        position: 'top'
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            stepSize: 1
                        }
                    }
                }
            }
        });

        // Event Status Distribution Chart (Doughnut Chart)
        const statusCtx = document.getElementById('statusDistributionChart').getContext('2d');
        new Chart(statusCtx, {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.EventStatusDistribution.Keys.ToList())),
                datasets: [{
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.EventStatusDistribution.Values.ToList())),
                    backgroundColor: [
                        '#6c757d', // Draft
                        '#ffc107', // Pending
                        '#28a745', // Approved
                        '#17a2b8', // Happening
                        '#007bff', // Completed
                        '#dc3545', // Rejected
                        '#343a40'  // Cancelled
                    ],
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });
    </script>
}
