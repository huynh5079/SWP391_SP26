@model AEMS_Solution.Models.Organizer.OrganizerDashboardViewModel
@using DataAccess.Enum
@{
    ViewData["Title"] = "Organizer Dashboard";
    Layout = "_OrganizerLayout";
}

<div class="dashboard-header mb-4">
    <div class="d-flex justify-content-between align-items-end">
        <div>
            <div class="dashboard-overview-label">DASHBOARD OVERVIEW</div>
            <h1 class="page-title">Organizer - Dashboard</h1>
            <p class="page-subtitle">Manage events and track upcoming activities</p>
        </div>
    </div>
</div>

<!-- Navigation Tabs -->
<div class="dashboard-tabs">
    <a href="#" class="dashboard-tab active">My Events</a>
    <a href="@Url.Action("Index", "EventQuiz")" class="dashboard-tab text-decoration-none">Quiz</a>
    <a href="@Url.Action("Index", "Topic")" class="dashboard-tab text-decoration-none">Topics</a>
    <a href="@Url.Action("Index", "Location")" class="dashboard-tab text-decoration-none">Locations</a>
    <a href="@Url.Action("Manage", "Organizer", new { operation = "myeventsdelete" })" class="dashboard-tab dashboard-tab-danger text-decoration-none d-flex align-items-center gap-1">
        <i class="bi bi-trash"></i> Deleted Events
    </a>
</div>

<!-- Stat Cards -->
<div class="row g-4 mb-4">
    <!-- Total Events -->
    <div class="col-md-3">
        <div class="stat-card">
            <div>
                <div class="stat-label">TOTAL EVENTS</div>
                <div class="stat-value">@Model.Stats.TotalEvents</div>
            </div>
            <div class="stat-icon icon-purple">
                <i class="bi bi-calendar-check-fill"></i>
            </div>
        </div>
    </div>
    
    <!-- Upcoming Events -->
    <div class="col-md-3">
        <div class="stat-card">
            <div>
                <div class="stat-label">UPCOMING</div>
                <div class="stat-value">@Model.Stats.UpcomingEvents</div>
            </div>
            <div class="stat-icon icon-blue">
                <i class="bi bi-clock-history"></i>
            </div>
        </div>
    </div>

    <!-- Registrations Today -->
    <div class="col-md-3">
        <div class="stat-card">
            <div>
                <div class="stat-label">REGISTRATIONS TODAY</div>
                <div class="stat-value">@Model.RegistrationsToday</div>
            </div>
            <div class="stat-icon icon-gray">
                <i class="bi bi-person-fill"></i>
            </div>
        </div>
    </div>

    <!-- Draft Events -->
    <div class="col-md-3">
        <div class="stat-card">
            <div>
                <div class="stat-label">DRAFT</div>
                <div class="stat-value">@Model.Stats.DraftEvents</div>
            </div>
            <div class="stat-icon icon-light">
                <i class="bi bi-pencil-square"></i>
            </div>
        </div>
    </div>
</div>

<!-- Financial Row -->
<div class="row mb-4">
    <div class="col-md-8">
        <div class="revenue-card">
            <div class="revenue-label">
                <i class="bi bi-wallet2"></i> REVENUE TRACKING
            </div>
            <div class="revenue-title">Deposit Collected This Month</div>
            <div class="revenue-amount">
                @Model.DepositCollectedThisMonth.ToString("C")
                <span class="revenue-trend">
                    +0% <i class="bi bi-graph-up-arrow"></i>
                </span>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-4 mb-4">
    <!-- Registration Trend Chart -->
    <div class="col-md-8">
        <div class="chart-card">
            <div class="chart-header">
                <h5 class="chart-title">Registration Trend</h5>
                <span class="chart-subtitle">Last 7 Days</span>
            </div>
            <div style="height: 300px; position: relative;">
                <canvas id="registrationTrendChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Event Status Distribution -->
    <div class="col-md-4">
        <div class="chart-card">
            <div class="chart-header">
                <h5 class="chart-title">Event Status</h5>
            </div>
            <div class="doughnut-wrapper mt-4">
                <canvas id="statusDistributionChart"></canvas>
                <div class="doughnut-inner-text">
                    <div class="val">@Model.Stats.TotalEvents</div>
                    <div class="lbl">TOTAL</div>
                </div>
            </div>
            <ul class="status-legend" id="statusLegend">
                <!-- Legendary populated by JS -->
            </ul>
        </div>
    </div>
</div>

<!-- Recent Events Section -->
<div class="row">
    <div class="col-12">
        <div class="section-header">
            <h3 class="section-title">Recent Events</h3>
            <a href="@Url.Action("MyEvents", "Organizer")" class="view-all-link">View All <i class="bi bi-arrow-right-short fs-5"></i></a>
        </div>
        
        @if (Model.RecentEvents != null && Model.RecentEvents.Any())
        {
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4 rounded-top-start">Event Name</th>
                                    <th>Start Time</th>
                                    <th>Status</th>
                                    <th class="text-end pe-4 rounded-top-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var evt in Model.RecentEvents)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="fw-semibold text-dark">@evt.Title</div>
                                            <div class="small text-muted">@evt.Location</div>
                                        </td>
                                        <td>
                                            <div class="text-dark">@evt.StartTime.ToString("MMM dd, yyyy")</div>
                                            <div class="small text-muted">@evt.StartTime.ToString("hh:mm tt")</div>
                                        </td>
                                        <td>
                                            @{
                                                string badgeClass = evt.Status switch
                                                {
                                                    EventStatusEnum.Draft => "bg-secondary",
                                                    EventStatusEnum.Pending => "bg-warning",
                                                    EventStatusEnum.Approved => "bg-success",
                                                    EventStatusEnum.Happening => "bg-info",
                                                    EventStatusEnum.Completed => "bg-primary",
                                                    EventStatusEnum.Rejected => "bg-danger",
                                                    EventStatusEnum.Cancelled => "bg-dark",
                                                    _ => "bg-secondary"
                                                };
                                            }
                                            <span class="badge @badgeClass rounded-pill fw-normal px-2 py-1">@evt.Status</span>
                                        </td>
                                        <td class="text-end pe-4">
                                            <a asp-controller="Event" asp-action="Edit" asp-route-id="@evt.EventId" class="btn btn-sm btn-light text-primary border rounded-3 fw-medium">
                                                Manage <i class="bi bi-chevron-right ms-1 small"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="empty-state-card">
                <div class="empty-state-icon">
                    <i class="bi bi-calendar-x"></i>
                </div>
                <h3 class="empty-state-title">No active events found</h3>
                <p class="empty-state-text">You don't have any events yet. Create a new event to start managing your activities.</p>
                <a href="@Url.Action("Manage", "Organizer", new { operation = "create" })" class="btn-solid-primary d-inline-flex align-items-center gap-2 text-decoration-none">
                    Create a new event
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Use matching colors for Chart
        const primaryColor = '#4f46e5';
        const primaryLight = '#e0e7ff';

        // 1. Registration Trend Bar Chart
        const registrationCtx = document.getElementById('registrationTrendChart').getContext('2d');
        new Chart(registrationCtx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RegistrationTrendLabels)),
                datasets: [{
                    label: 'Registrations',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RegistrationTrendData)),
                    backgroundColor: primaryLight,
                    hoverBackgroundColor: primaryColor,
                    borderRadius: 4,
                    barPercentage: 0.7
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        backgroundColor: '#1e293b',
                        padding: 12,
                        cornerRadius: 8,
                        titleFont: { size: 13 },
                        bodyFont: { size: 14, weight: 'bold' }
                    }
                },
                scales: {
                    x: {
                        grid: {
                            display: false,
                            drawBorder: false
                        },
                        ticks: {
                            color: '#94a3b8',
                            font: {
                                size: 11,
                                weight: '600'
                            }
                        }
                    },
                    y: {
                        display: false, // hide y axis as requested by the minimal design
                        beginAtZero: true
                    }
                }
            }
        });

        // 2. Event Status Distribution Doughnut Chart
        const statusColors = {
            'Draft': '#4f46e5',
            'Published': '#0ea5e9',
            'Pending': '#cbd5e1',
            'Expired': '#94a3b8',
            'Completed': '#10b981',
            'Cancelled': '#ef4444',
            'Rejected': '#f59e0b'
        };

        const statusLabelsRaw = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.EventStatusDistribution.Keys.ToList()));
        const statusDataRaw = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.EventStatusDistribution.Values.ToList()));
        
        // Map colors for the specific labels present
        const chartColors = statusLabelsRaw.map(label => statusColors[label] || '#cbd5e1');

        const statusCtx = document.getElementById('statusDistributionChart').getContext('2d');
        new Chart(statusCtx, {
            type: 'doughnut',
            data: {
                labels: statusLabelsRaw,
                datasets: [{
                    data: statusDataRaw,
                    backgroundColor: chartColors,
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '75%',
                plugins: {
                    legend: {
                        display: false // We will build a custom HTML legend instead
                    },
                    tooltip: {
                        backgroundColor: '#1e293b',
                        padding: 10,
                        cornerRadius: 8
                    }
                }
            }
        });

        // 3. Build Custom Legend
        const legendContainer = document.getElementById('statusLegend');
        statusLabelsRaw.forEach((label, index) => {
            const value = statusDataRaw[index];
            const color = chartColors[index];

            const li = document.createElement('li');
            li.innerHTML = `
                <div class="status-legend-item">
                    <span class="status-dot" style="background-color: ${color}"></span>
                    <span class="status-label">${label}</span>
                </div>
                <span class="status-value">${value}</span>
            `;
            legendContainer.appendChild(li);
        });
    </script>
}
