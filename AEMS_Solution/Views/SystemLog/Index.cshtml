@model DataAccess.Entities.PaginationResult<DataAccess.Entities.SystemErrorLog>
@using DataAccess.Enum
@{
    ViewData["Title"] = "System Error Logs";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="animate-fade-in">
    @* --- Header --- *@
    <div class="page-header">
        <div>
            <h2 class="page-title"><i class="bi bi-journal-medical me-2 text-primary"></i> System Error Logs</h2>
            <p class="page-subtitle">Monitor and manage server-side exceptions and diagnostic data.</p>
        </div>
        
        <form asp-action="DeleteOldLogs" method="post" onsubmit="return confirmAction(event, 'Are you sure you want to delete all logs older than 30 days? This action cannot be undone.', 'Delete Now', 'Cancel');">
            @Html.AntiForgeryToken()
            <button type="submit" class="ex-hbtn ex-hbtn-white text-danger border-danger">
                <i class="bi bi-trash me-1"></i> Clean up old logs (>30 days)
            </button>
        </form>
    </div>

    @* --- Filter Card --- *@
    <div class="glass-card mb-4 animate-fade-in animate-delay-1">
        <div class="card-title-box">
            <div>
                <h5 class="card-title">Filter Log Data</h5>
                <p class="card-subtitle">Narrow down results by keywords or HTTP status codes.</p>
            </div>
            <i class="bi bi-funnel text-muted" style="font-size:1.2rem;"></i>
        </div>
        <form method="get" class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-bold small text-muted text-uppercase">Search Message / Source / User</label>
                <div class="search-box p-0 w-100">
                    <i class="bi bi-search"></i>
                    <input type="text" name="search" class="search-input" placeholder="Enter keywords..." value="@ViewBag.Search">
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold small text-muted text-uppercase">Status Code</label>
                <select name="statusCode" class="chart-dropdown w-100" style="padding: 9px 16px;">
                    <option value="">-- All Statuses --</option>
                    @foreach (var status in Enum.GetValues(typeof(DataAccess.Enum.SystemLogStatusEnum)))
                    {
                        var statusVal = (int)status;
                        <option value="@statusVal" selected="@(ViewBag.StatusCode == statusVal)">@statusVal (@status)</option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="ex-hbtn ex-hbtn-white w-100 justify-content-center" style="background: var(--ad-primary); color:#fff;">
                    <i class="bi bi-filter me-1"></i> Filter
                </button>
            </div>
        </form>
    </div>

    @* --- Data Table Card --- *@
    <div class="glass-card p-0 overflow-hidden animate-fade-in animate-delay-2">
        <div class="table-responsive">
            <table class="events-table">
                <thead>
                    <tr>
                        <th style="width:180px;">Time</th>
                        <th style="width:100px;">Status</th>
                        <th>Exception / Message</th>
                        <th style="width:150px;">User</th>
                        <th style="text-align:right;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Data.Any())
                    {
                        int rowIdx = 0;
                        foreach (var log in Model.Data)
                        {
                            var badgeClass = "badge bg-secondary";
                            if (log.StatusCode >= 200 && log.StatusCode < 300) { badgeClass = "badge bg-success"; }
                            else if (log.StatusCode >= 400 && log.StatusCode < 500) { badgeClass = "badge bg-warning text-dark"; }
                            else if (log.StatusCode >= 500) { badgeClass = "ex-pill-rejected"; } // Using existing premium pill class

                            <tr class="animate-fade-in" style="animation-delay: @(0.1 + (rowIdx * 0.03))s">
                                <td class="text-nowrap text-muted small">
                                    <i class="bi bi-clock me-1"></i> @log.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")
                                </td>
                                <td>
                                    <span class="@(log.StatusCode >= 500 ? "ex-pill ex-pill-rejected" : badgeClass)" style="font-size:.65rem;">
                                        @(log.StatusCode?.ToString() ?? "N/A")
                                    </span>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark" style="font-size:.85rem;">@log.ExceptionType</div>
                                    <div class="text-muted small text-truncate" style="max-width: 450px;">
                                        @log.ExceptionMessage
                                    </div>
                                </td>
                                <td>
                                    @if(!string.IsNullOrEmpty(log.UserId))
                                    {
                                         <a href="/UserManagement/Detail/@log.UserId" class="btn-link-custom" target="_blank">
                                            <i class="bi bi-person-circle"></i> @log.UserId.Substring(0, 8)...
                                         </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small italic">Anonymous</span>
                                    }
                                </td>
                                <td style="text-align:right;">
                                    <button type="button" class="btn-dot" 
                                            data-bs-toggle="modal" data-bs-target="#logDetailModal"
                                            data-ex-type="@log.ExceptionType"
                                            data-ex-msg="@log.ExceptionMessage"
                                            data-ex-source="@log.Source"
                                            data-ex-stack="@log.StackTrace"
                                            title="View Details">
                                        <i class="bi bi-eye-fill text-primary"></i>
                                    </button>
                                </td>
                            </tr>
                            rowIdx++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="ex-empty">
                                    <div class="ex-empty-icon"><i class="bi bi-check-circle"></i></div>
                                    <h4>No matching error logs found</h4>
                                    <p>Your system is currently running clean. No errors detected for this filter.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        @* Pagination *@
        <div class="px-4 py-3 border-top bg-light">
            <partial name="_Pagination" model="Model" />
        </div>
    </div>
</div>

@* --- Log Detail Modal --- *@
<div class="modal fade" id="logDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg" style="border-radius:18px;">
            <div class="modal-header bg-danger text-white border-0" style="border-radius:18px 18px 0 0;">
                <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>Error Detail</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-4">
                    <label class="fw-bold small text-muted text-uppercase mb-1 d-block">Exception Type</label>
                    <div class="p-3 bg-light rounded-3 text-danger fw-bold" id="modalExType" style="font-size:1.1rem;">Type</div>
                </div>
                <div class="mb-4">
                    <label class="fw-bold small text-muted text-uppercase mb-1 d-block">Source</label>
                    <code class="d-block p-2 bg-dark text-info rounded-2" id="modalExSource">Source</code>
                </div>
                <div class="mb-4">
                    <label class="fw-bold small text-muted text-uppercase mb-1 d-block">Message</label>
                    <div class="alert alert-secondary border-0 text-break" id="modalExMsg" style="background:#f8fafc; color:#1e293b; font-weight:500;">Message</div>
                </div>
                <div class="mb-0">
                    <label class="fw-bold small text-muted text-uppercase mb-1 d-block">Stack Trace</label>
                    <pre class="bg-dark text-light p-3 rounded-3" style="font-size: 0.8rem; max-height: 350px; overflow: auto; border: 1px solid #334155;" id="modalExStack">
                        Stack Trace...
                    </pre>
                </div>
            </div>
            <div class="modal-footer border-0 p-4 pt-0">
                <button type="button" class="ex-hbtn ex-hbtn-white" style="background:#f1f5f9; color:#475569;" data-bs-dismiss="modal">Close</button>
                <button type="button" class="ex-hbtn" style="background:var(--ad-primary); color:#fff;" onclick="copySystemLogDetails()">
                    <i class="bi bi-clipboard me-1"></i> Copy All Details
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {

    // ─── Counter animations ───────────────────────────────────────────────────
    [
        { id: 'sl-cnt-30',    target: @(ViewBag.TotalLast30Days ?? 0) },
        { id: 'sl-cnt-today', target: @(ViewBag.TodayCount ?? 0)      },
        { id: 'sl-cnt-total', target: @Model.TotalCount }
    ].forEach(function (c) {
        var el = document.getElementById(c.id);
        if (!el || c.target === 0) return;
        var cur = 0;
        var step = Math.max(1, Math.ceil(c.target / 28));
        var t = setInterval(function () {
            cur = Math.min(cur + step, c.target);
            el.textContent = cur;
            if (cur >= c.target) clearInterval(t);
        }, 38);
    });

    // ─── 30-day trend chart ───────────────────────────────────────────────────
    var trend30Dates  = @Html.Raw(ViewBag.Trend30Dates  ?? "[]");
    var trend30Counts = @Html.Raw(ViewBag.Trend30Counts ?? "[]");

    var ctxTrend = document.getElementById('sl-trend-chart');
    if (ctxTrend && trend30Dates.length > 0) {
        var ctx = ctxTrend.getContext('2d');
        var grad = ctx.createLinearGradient(0, 0, 0, 160);
        grad.addColorStop(0,   'rgba(239,68,68,.28)');
        grad.addColorStop(0.6, 'rgba(239,68,68,.08)');
        grad.addColorStop(1,   'rgba(239,68,68,0)');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: trend30Dates,
                datasets: [{
                    label: 'Errors',
                    data: trend30Counts,
                    borderColor: '#ef4444',
                    backgroundColor: grad,
                    borderWidth: 2.5,
                    pointBackgroundColor: '#ef4444',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2,
                    pointRadius: 3,
                    pointHoverRadius: 6,
                    fill: true,
                    tension: 0.42
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                animation: { duration: 1000, easing: 'easeOutQuart' },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: '#1e1b4b', padding: 11, cornerRadius: 10,
                        callbacks: {
                            label: function(ctx) { return '  ' + ctx.parsed.y + ' error(s)'; }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { color: '#94a3b8', font: { size: 9, weight: '700' }, maxTicksLimit: 10 }
                    },
                    y: { display: false, beginAtZero: true }
                },
                interaction: { mode: 'index', intersect: false }
            }
        });
    }

        function copySystemLogDetails() {
            var type = document.getElementById('modalExType').innerText;
            var source = document.getElementById('modalExSource').innerText;
            var msg = document.getElementById('modalExMsg').innerText;
            var stack = document.getElementById('modalExStack').innerText;
            
            var content = `Exception Type: ${type}\nSource: ${source}\nMessage: ${msg}\n\nStack Trace:\n${stack}`;
            
            navigator.clipboard.writeText(content).then(function() {
                toastr.success('Error details copied to clipboard!');
            }, function(err) {
                // Fallback
                var textArea = document.createElement("textarea");
                textArea.value = content;
                document.body.appendChild(textArea);
                textArea.select();
                try {
                    document.execCommand('copy');
                    toastr.success('Error details copied to clipboard!');
                } catch (err) {
                    console.error('Fallback copy failed', err);
                }
                document.body.removeChild(textArea);
            });
        }
    </script>
}

<style>
    /* Scoped additions for SystemLog */
    .ex-hbtn {
        display: inline-flex; align-items: center; gap: .35rem;
        font-size: .8rem; font-weight: 700; padding: .6rem 1.2rem;
        border-radius: 30px; border: none; text-decoration: none;
        cursor: pointer; transition: all .18s; white-space: nowrap;
    }
    .ex-hbtn-white { background: #fff; border: 1.5px solid var(--ad-border); color: var(--ad-primary); }
    .ex-hbtn-white:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(0,0,0,.1); }
</style>
