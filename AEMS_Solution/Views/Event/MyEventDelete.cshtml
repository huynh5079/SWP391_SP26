@model AEMS_Solution.Models.Organizer.MyEventsViewModel
@using DataAccess.Enum
@{
    ViewData["Title"] = "My Events";
    Layout = "_Organizerlayout";

    string StatusClass(EventStatusEnum status) => status switch
    {
        EventStatusEnum.Draft => "bg-secondary",
        EventStatusEnum.Pending => "bg-warning text-dark",
        EventStatusEnum.Approved => "bg-success",
        EventStatusEnum.Rejected => "bg-danger",
        EventStatusEnum.Published => "bg-info text-dark",
        EventStatusEnum.Upcoming => "bg-primary",
        EventStatusEnum.Happening => "bg-info text-dark",
        EventStatusEnum.Completed => "bg-success",
        EventStatusEnum.Cancelled => "bg-dark",
        _ => "bg-secondary"
    };
}

<div class="container mt-4">
    <h2 class="mb-4"> My Events Delete</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    <form class="row g-2 mb-3" method="get" asp-controller="Organizer" asp-action="MyEventsDelete">
        <div class="col-auto">
            <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search title..." />
        </div>


        <div class="col-auto">
            @{ var statuses = new[] { "Draft", "Pending", "Upcoming", "Happening", "Completed", "Cancelled" }; }
            <select name="status" class="form-select">
                <option value="">All Status</option>
                @foreach (var s in statuses)
                {
                    <option value="@s" selected="@((Model.Status?.ToString() == s) ? "selected" : null)">@s</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <button class="btn btn-primary">Filter</button>
        </div>
    </form>

    <table class="table table-bordered table-hover shadow">
        <thead class="table-dark">
            <tr>
                <th>Thumbnail</th>
                <th>Title</th>
                <th>Semester</th>
                <th>Department</th>
                <th>Location</th>
                <th>Time</th>
                <th>Capacity</th>
                <th>Status</th>
                <th>Mode</th>
                <th>Meeting Url</th>
                <th>Time State</th>
                <th>Stats</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model.Events)
            {
                <tr>
                    <td style="width:120px">
                        @if (!string.IsNullOrEmpty(e.ThumbnailUrl))
                        {
                            <img src="@e.ThumbnailUrl" class="img-fluid rounded" />
                        }
                    </td>

                    <td>
                        <strong>@e.Title</strong>
                    </td>

                    <td>@e.SemesterName</td>
                    <td>@e.DepartmentName</td>
                    <td>@e.Location</td>

                    <td class="event-time" data-start="@e.StartTime.ToString("o")" data-end="@e.EndTime.ToString("o")">
                        <span class="start">@e.StartTime.ToString("dd/MM/yyyy HH:mm")</span>
                        <br />
                        →
                        <br />
                        <span class="end">@e.EndTime.ToString("dd/MM/yyyy HH:mm")</span>
                    </td>

                    <td>
                        @e.RegisteredCount / @e.MaxCapacity
                    </td>

                    <td>
                        <span class="badge @StatusClass(e.Status)">@e.Status</span>
                    </td>

                    <td>
                        @e.Mode
                    </td>

                    <td style="max-width:200px; word-break:break-all;">
                        @if (!string.IsNullOrEmpty(e.MeetingUrl))
                        {
                            <a href="@e.MeetingUrl" target="_blank">Link</a>
                        }
                    </td>
                    <td>
                        <span class="time-badge badge bg-secondary text-dark">--</span>
                    </td>

                    <td>
                        🎟 @e.RegisteredCount <br />
                        ✅ @e.CheckedInCount <br />
                        ⏳ @e.WaitlistCount <br />
                        ⭐ @e.AvgRating.ToString("0.0")
                    </td>

                    <td>
                        <a class="btn btn-sm btn-info" asp-controller="Organizer" asp-action="Manage" asp-route-operation="detailevent" asp-route-id="@e.EventId">View</a>
                       
                        <form asp-controller="Organizer" asp-action="Manage" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="operation" value="restore" />
                            <input type="hidden" name="id" value="@e.EventId" />
                            <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Khôi phục sự kiện này?');">Restore</button>
                        </form>
                       
                        
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Pagination">
            <ul class="pagination">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="MyEventsDelete" asp-controller="Organizer" asp-route-page="@(Model.Page - 1)" asp-route-search="@Model.Search" asp-route-status="@Model.Status">Previous</a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="MyEventsDelete" asp-controller="Organizer" asp-route-page="@i" asp-route-search="@Model.Search" asp-route-status="@Model.Status">@i</a>
                    </li>
                }

                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="MyEventsDelete" asp-controller="Organizer" asp-route-page="@(Model.Page + 1)" asp-route-search="@Model.Search" asp-route-status="@Model.Status">Next</a>
                </li>
            </ul>
        </nav>
        <div class="text-muted">Page @Model.Page of @Model.TotalPages (@Model.TotalItems total items)</div>
    }
    @section Scripts {
        <script>
            (function () {
                function update() {
                    const now = new Date();

                    document.querySelectorAll('.event-time').forEach(el => {
                        const startIso = el.getAttribute('data-start');
                        const endIso = el.getAttribute('data-end');
                        if (!startIso || !endIso) return;

                        const start = new Date(startIso);
                        const end = new Date(endIso);

                        const row = el.closest('tr');
                        if (!row) return;

                        // ✅ chỉ update Time State badge
                        const timeBadge = row.querySelector('.time-badge');
                        if (!timeBadge) return;

                        if (now < start) {
                            timeBadge.textContent = 'Upcoming';
                            timeBadge.className = 'time-badge badge bg-warning text-dark';
                        } else if (now >= start && now <= end) {
                            timeBadge.textContent = 'Happening';
                            timeBadge.className = 'time-badge badge bg-info text-dark';
                        } else {
                            timeBadge.textContent = 'Completed';
                            timeBadge.className = 'time-badge badge bg-secondary text-dark';
                        }
                    });
                }

                update();
                setInterval(update, 30 * 1000);
            })();
        </script>
        <script>
            (function () {
                document.querySelectorAll('.view-detail').forEach(btn => {
                    btn.addEventListener('click', function (e) {
                        e.preventDefault();
                        var url = btn.getAttribute('data-url');
                        if (!url) return;
                        // open detail in new window/tab
                        window.location.href = url;
                    });
                });
            })();
        </script>
    }
</div>