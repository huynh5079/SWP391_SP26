@model AEMS_Solution.Models.Event.Semester.ApproverSemesterViewModel
@using DataAccess.Enum
@{
    ViewData["Title"] = Model.PageTitle;
    Layout = "_Approvallayout";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">@Model.PageTitle</h2>
            <p class="text-muted mb-0">@Model.PageDescription</p>
        </div>
        <div class="d-flex gap-2">
                @if (Model.CanCreateNextSemester)
                {
                    <form asp-controller="Approver" asp-action="AutoCreateSemester" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-magic me-1"></i> Auto Update Semester
                        </button>
                    </form>
                    <a asp-controller="Approver" asp-action="CreateSemester" class="btn btn-outline-primary">
                        <i class="bi bi-plus-circle me-1"></i> Manual
                    </a>
                }
                else
                {
                    <button type="button" class="btn btn-secondary" disabled>
                        <i class="bi bi-clock-history me-1"></i> Chờ đến kỳ tiếp theo
                    </button>
                }
        </div>
    </div>

        @if (!Model.CanCreateNextSemester)
        {
            <div class="alert alert-info">
                Đã có semester kế tiếp trong hệ thống. Khi semester đó bắt đầu, nút tạo mới sẽ tự mở lại.
            </div>
        }


    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form method="get" asp-controller="Approver" asp-action="Semester" class="row g-3 align-items-end">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Tìm kiếm</label>
                    <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Name, code..." />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Trạng thái</label>
                    <select name="status" class="form-select">
                        <option value="">-- Tất cả trạng thái --</option>
                        <option value="Upcoming" selected="@(Model.Status == "Upcoming")">Upcoming</option>
                        <option value="Active" selected="@(Model.Status == "Active")">Active</option>
                        <option value="Finished" selected="@(Model.Status == "Finished")">Finished</option>
                    </select>
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-outline-primary">Lọc</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            @if (Model.Semesters.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Code</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Status</th>
                                <th>Events</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var semester in Model.Semesters)
                            {
                                var badgeClass = semester.Status switch
                                {
                                    SemesterStatusEnum.Upcoming => "bg-info text-dark",
                                    SemesterStatusEnum.Active => "bg-success",
                                    SemesterStatusEnum.Finished => "bg-secondary",
                                    _ => "bg-secondary"
                                };

                                <tr>
                                    <td class="fw-semibold">@semester.Name</td>
                                    <td>@semester.Code</td>
                                    <td>@(semester.StartDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                                    <td>@(semester.EndDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                                    <td><span class="badge @badgeClass">@semester.Status</span></td>
                                    <td>@semester.EventCount</td>
                                    <td>
                                        <a asp-controller="Approver" asp-action="EditSemester" asp-route-id="@semester.SemesterId" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil-square me-1"></i>Edit
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">Chưa có học kỳ nào phù hợp với bộ lọc hiện tại.</div>
            }
        </div>
    </div>
</div>
