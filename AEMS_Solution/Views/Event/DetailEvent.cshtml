@model AEMS_Solution.Models.Event.EventDetailsViewModel

@{
    ViewData["Title"] = "Event Details";
    Layout = "_Organizerlayout";
    var thumbnailUrl = !string.IsNullOrWhiteSpace(Model.ThumbnailUrl)
        ? Model.ThumbnailUrl
        : "https://via.placeholder.com/640x360?text=No+Image";
    var occupancyPercent = Model.MaxCapacity > 0
        ? Math.Min(100, (int)Math.Round((double)Model.RegisteredCount / Model.MaxCapacity * 100))
        : 0;
}

<style>
    .event-detail-page .detail-card {
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.06);
    }

    .event-detail-page .hero-title {
        font-size: clamp(2rem, 3vw, 2.6rem);
        font-weight: 700;
    }

    .event-detail-page .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
    }

    .event-detail-page .info-tile,
    .event-detail-page .agenda-card {
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        background: #f8fafc;
    }

    .event-detail-page .info-tile {
        padding: 16px;
    }

    .event-detail-page .info-label,
    .event-detail-page .agenda-meta-label,
    .event-detail-page .agenda-index {
        color: #64748b;
        font-size: .8rem;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .event-detail-page .info-value {
        font-size: 1rem;
        font-weight: 600;
        color: #0f172a;
    }

    .event-detail-page .description-box {
        border-radius: 16px;
        background: #f8fafc;
        padding: 20px;
    }

    .event-detail-page .sidebar-stack {
        display: grid;
        gap: 20px;
    }

    .event-detail-page .sidebar-image {
        width: 100%;
        height: 240px;
        object-fit: cover;
        border-top-left-radius: 20px;
        border-top-right-radius: 20px;
    }

    .event-detail-page .action-list {
        display: grid;
        gap: 10px;
    }

    .event-detail-page .document-item {
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 14px;
        background: #f8fafc;
    }

    .event-detail-page .agenda-card {
        height: 100%;
        padding: 18px;
    }

    .event-detail-page .agenda-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 16px;
    }

    .event-detail-page .agenda-meta-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 12px;
        margin-bottom: 16px;
    }

    .event-detail-page .agenda-meta-item,
    .event-detail-page .agenda-desc {
        border-radius: 14px;
        padding: 14px;
        background: #fff;
        border: 1px solid #e5e7eb;
    }

    .event-detail-page .section-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
    }

    .event-detail-page .create-box {
        border: 1px dashed #cbd5e1;
        border-radius: 16px;
        padding: 16px;
        background: #f8fafc;
    }

    .event-detail-page .create-box label {
        font-weight: 600;
        margin-bottom: 6px;
    }

    .event-detail-page .create-box .form-control {
        border-radius: 12px;
    }

    .event-detail-page .room-info-box {
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 16px;
        background: #fff;
    }

    .event-detail-page .create-hint {
        color: #64748b;
        font-size: 12px;
        margin-top: 6px;
    }

    @@media (min-width: 1200px) {
        .event-detail-page .sidebar-stack {
            position: sticky;
            top: 24px;
        }
    }
</style>

<div class="container mt-4 event-detail-page">
    <a asp-controller="Organizer" asp-action="MyEvents" class="btn btn-sm btn-secondary mb-3">← Back to My Events</a>

    <div class="row g-4">
        <div class="col-xl-8">
            <div class="card detail-card h-100">
                <div class="card-body p-4 p-lg-5">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3 mb-4">
                        <div>
                            <div class="text-uppercase small text-muted fw-semibold mb-2">Event overview</div>
                            <h1 class="hero-title mb-2">@Model.Title</h1>
                            <p class="text-muted mb-0">@(Model.Location ?? Model.LocationText ?? "No location")</p>
                        </div>
                        <span class="badge rounded-pill bg-primary-subtle text-primary px-3 py-2">@Model.Status</span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.LastApprovalComment))
                    {
                        <div class="alert alert-info border-0 mb-4">
                            <div class="small text-muted mb-1">@Model.LastApprovalAction @Model.LastApprovalAt?.ToString("dd/MM/yyyy HH:mm")</div>
                            <div><strong>Approver Comment:</strong> @Model.LastApprovalComment</div>
                        </div>
                    }

                    <div class="info-grid mb-4">
                        <div class="info-tile">
                            <div class="info-label">Semester</div>
                            <div class="info-value mt-1">@(Model.SemesterName ?? "Not set")</div>
                        </div>
                        <div class="info-tile">
                            <div class="info-label">Department</div>
                            <div class="info-value mt-1">@(Model.DepartmentName ?? "Not set")</div>
                        </div>
                        <div class="info-tile">
                            <div class="info-label">Start time</div>
                            <div class="info-value mt-1">@Model.StartTime.ToString("HH:mm dd/MM/yyyy")</div>
                        </div>
                        <div class="info-tile">
                            <div class="info-label">End time</div>
                            <div class="info-value mt-1">@Model.EndTime.ToString("HH:mm dd/MM/yyyy")</div>
                        </div>
                        <div class="info-tile">
                            <div class="info-label">Mode</div>
                            <div class="info-value mt-1">@(Model.Mode?.ToString() ?? "Not set")</div>
                        </div>
                        <div class="info-tile">
                            <div class="info-label">Type</div>
                            <div class="info-value mt-1">@(Model.Type ?? "Not set")</div>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.MeetingUrl))
                    {
                        <div class="mb-4">
                            <div class="info-label mb-1">Meeting URL</div>
                            <a href="@Model.MeetingUrl" target="_blank" class="text-primary text-decoration-none fw-semibold">
                                <i class="bi bi-link-45deg"></i> @Model.MeetingUrl
                            </a>
                        </div>
                    }

                    <div class="description-box">
                        <div class="section-head mb-3">
                            <h4 class="mb-0">Description</h4>
                            <span class="badge rounded-pill bg-light text-dark border">Main content</span>
                        </div>
                        <div>@Html.Raw(Model.Description ?? "<em>No description</em>")</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="sidebar-stack">
                <div class="card detail-card overflow-hidden">
                    <img src="@thumbnailUrl" class="sidebar-image" alt="Thumbnail" />
                    <div class="card-body p-4">
                        <h5 class="mb-3">Event management</h5>

                        <div class="info-tile mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="info-label">Capacity</span>
                                <span class="info-value">@Model.RegisteredCount / @Model.MaxCapacity</span>
                            </div>
                            <div class="progress" role="progressbar" aria-valuenow="@occupancyPercent" aria-valuemin="0" aria-valuemax="100" style="height: 8px;">
                                <div class="progress-bar bg-success" style="width: @occupancyPercent%"></div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mb-3">
                            <div class="info-tile flex-fill text-center p-3">
                                <div class="info-label mb-1">Waitlist</div>
                                <div class="info-value fs-5">@Model.WaitlistCount</div>
                            </div>
                            <div class="info-tile flex-fill text-center p-3">
                                <div class="info-label mb-1">Rating</div>
                                <div class="info-value fs-5">@(Model.AvgRating > 0 ? Model.AvgRating.ToString("0.0") : "N/A")</div>
                            </div>
                        </div>

                        <div class="action-list">
                            @if (Model.CanEdit)
                            {
                                <a asp-action="Edit" asp-route-id="@Model.EventId" class="btn btn-warning w-100"><i class="fas fa-edit"></i> Chỉnh sửa</a>
                            }

                            @if (Model.CanSendForApproval)
                            {
                                <form asp-controller="Organizer" asp-action="SendForApproval" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.EventId" />
                                    <button type="submit" class="btn btn-primary w-100"><i class="fas fa-paper-plane"></i> Gửi duyệt</button>
                                </form>
                            }

                            <a asp-controller="CheckIn" asp-action="Scanner" asp-route-eventId="@Model.EventId" class="btn btn-success w-100">
                                <i class="fas fa-camera"></i> Bắt đầu Check-in
                            </a>
                        </div>
                    </div>
                </div>

                <div class="card detail-card">
                    <div class="card-body p-4">
                        <div class="section-head mb-3">
                            <div>
                                <h5 class="mb-0">Documents</h5>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#createDocumentForm" aria-expanded="false" aria-controls="createDocumentForm">
                                    + Create Document
                                </button>
                                <span class="badge rounded-pill bg-light text-dark border">@(Model.Documents?.Count ?? 0)</span>
                            </div>
                        </div>

                        <div class="collapse mb-3" id="createDocumentForm">
                            <form asp-controller="Organizer" asp-action="CreateDocumentFromDetail" method="post" class="create-box">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="EventId" value="@Model.EventId" />

                                <div class="mb-3">
                                    <label class="form-label">Document Name</label>
                                    <input name="Name" class="form-control" required />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Type</label>
                                    <input name="Type" class="form-control" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Url</label>
                                    <input name="Url" class="form-control" required />
                                </div>

                                <button type="submit" class="btn btn-primary btn-sm">Lưu document</button>
                            </form>
                        </div>

                        @if (Model.Documents == null || Model.Documents.Count == 0)
                        {
                            <p class="text-muted mb-0">No documents.</p>
                        }
                        else
                        {
                            <div class="d-grid gap-3">
                                @foreach (var d in Model.Documents)
                                {
                                    <div class="document-item">
                                        <strong>@d.FileName</strong>
                                        <div class="text-muted small mt-1">@(d.Type ?? "No type")</div>
                                        <a href="@d.Url" target="_blank" class="btn btn-link px-0 mt-2">Open document</a>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card detail-card mt-4">
        <div class="card-body p-4 p-lg-5">
            <div class="section-head mb-4">
                <div>
                    <h4 class="mb-1">Agendas</h4>
                    <div class="text-muted">Tách từng agenda thành từng mục nhỏ để dễ theo dõi và quản lí.</div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#createAgendaForm" aria-expanded="false" aria-controls="createAgendaForm">
                        + Create Agenda
                    </button>
                    <span class="badge rounded-pill bg-light text-dark border">@(Model.Agendas?.Count ?? 0) mục</span>
                </div>
            </div>

            <div class="collapse mb-4" id="createAgendaForm">
                <form asp-controller="Organizer" asp-action="CreateAgendaFromDetail" method="post" class="create-box">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="EventId" value="@Model.EventId" />
                    <input type="hidden" id="createAgendaLocation" name="Location" value="@(Model.Location ?? Model.LocationText ?? string.Empty)" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Session Name</label>
                            <input name="SessionName" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Speaker</label>
                            <input name="SpeakerName" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Start Time</label>
                            <input id="createAgendaStartTime" name="StartTime" type="datetime-local" class="form-control" value="@Model.StartTime.ToString("yyyy-MM-ddTHH:mm")" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">End Time</label>
                            <input id="createAgendaEndTime" name="EndTime" type="datetime-local" class="form-control" value="@Model.EndTime.ToString("yyyy-MM-ddTHH:mm")" required />
                        </div>

                        <div class="col-12">
                            <label class="form-label">Location</label>
                            <select id="createAgendaLocation" name="Location" class="form-select">
                                <option value="">-- Select Agenda Location --</option>
                                @if (ViewBag.Locations != null)
                                {
                                    @foreach (var loc in ViewBag.Locations)
                                    {
                                        <option value="@loc.Text">@loc.Text</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <textarea name="Description" class="form-control" rows="3"></textarea>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-sm mt-3">Lưu agenda</button>
                </form>
            </div>

            @if (Model.Agendas == null || Model.Agendas.Count == 0)
            {
                <p class="text-muted mb-0">No agendas.</p>
            }
            else
            {
                <div class="row g-3">
                    @for (int i = 0; i < Model.Agendas.Count; i++)
                    {
                        var agenda = Model.Agendas[i];

                        <div class="col-12 col-xl-6">
                            <div class="agenda-card">
                                <div class="agenda-card-header">
                                    <div>
                                        <div class="agenda-index mb-1">Agenda @(i + 1)</div>
                                        <h5 class="mb-0">@agenda.SessionName</h5>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(agenda.SpeakerName))
                                    {
                                        <span class="badge rounded-pill bg-light text-dark border">@agenda.SpeakerName</span>
                                    }
                                </div>

                                <div class="agenda-meta-grid">
                                    <div class="agenda-meta-item">
                                        <div class="agenda-meta-label mb-1">Time</div>
                                        <div class="fw-semibold">@agenda.StartTime.ToString("HH:mm dd/MM/yyyy")</div>
                                        <div class="text-muted small mt-1">→ @agenda.EndTime.ToString("HH:mm dd/MM/yyyy")</div>
                                    </div>
                                    <div class="agenda-meta-item">
                                        <div class="agenda-meta-label mb-1">Location</div>
                                        <div class="fw-semibold">@(agenda.Location ?? Model.Location ?? "No location")</div>
                                    </div>
                                </div>

                                <div class="agenda-desc">
                                    <div class="agenda-meta-label mb-2">Description</div>
                                    <div>@(!string.IsNullOrWhiteSpace(agenda.Description) ? agenda.Description : "No description.")</div>
                                </div>
                            </div>
                        </div>


                    }
                </div>
            }
        </div>
    </div>
</div>
