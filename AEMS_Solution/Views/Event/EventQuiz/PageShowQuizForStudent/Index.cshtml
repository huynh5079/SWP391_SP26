@using DocumentFormat.OpenXml.Office2010.PowerPoint
@{
    Layout = "_Layout"; // adjust if your layout has a different name
}

<!-- Student Quiz UI: replace placeholders with server-side data as needed -->
<section id="student-quiz" class="container my-5">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h4 class="mb-1">Quiz: <span id="quiz-title">Placeholder Quiz Title</span></h4>
                            <small class="text-muted">Time limit: <span id="quiz-time">--:--</span> • Questions: <span id="quiz-count">0</span></small>
                        </div>
                        <div class="text-end">
                            <div class="badge bg-primary" id="quiz-status">Ready</div>
                        </div>
                    </div>

                    <div id="quiz-area">
                        <!-- Question will be injected here by JavaScript -->
                        <div class="text-center py-5 text-muted" id="quiz-empty">Nhấn nút "Bắt đầu" để làm bài kiểm tra</div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <div>
                            <button class="btn btn-outline-secondary me-2" id="prev-btn" disabled>← Trước</button>
                            <button class="btn btn-outline-secondary" id="next-btn" disabled>Sau →</button>
                        </div>
                        <div>
                            <button class="btn btn-success" id="start-btn">Bắt đầu</button>
                            <button class="btn btn-danger d-none" id="submit-btn">Nộp bài</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm sticky-top" style="top: 90px;">
                <div class="card-body p-3">
                    <h6 class="mb-2">Thông tin bài kiểm tra</h6>
                    <ul class="list-unstyled small text-muted mb-3">
                        <li><strong>Thời lượng:</strong> <span id="info-duration">15 phút</span></li>
                        <li><strong>Số câu:</strong> <span id="info-questions">10</span></li>
                        <li><strong>Hình thức:</strong> Multiple choice</li>
                    </ul>

                    <div class="mb-3">
                        <label class="form-label small mb-1">Tiến độ</label>
                        <div class="progress" style="height: 10px;">
                            <div class="progress-bar" role="progressbar" style="width: 0%;" id="quiz-progress"></div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small mb-1">Thời gian còn lại</label>
                        <div class="h4 mb-0" id="timer">--:--</div>
                    </div>

                    <div>
                        <label class="form-label small mb-1">Danh sách câu hỏi</label>
                        <div id="question-nav" class="d-flex flex-wrap gap-2">
                            <!-- numbered pills will be inserted here -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    /* Small scoped styles for the quiz UI */
    #student-quiz .card { border-radius: 12px; }
    #student-quiz .badge { font-size: 0.85rem; padding: 0.5rem 0.7rem; }
    .question-card { border-radius: 10px; padding: 1rem; background: #fbfdff; }
    .option-btn { text-align: left; width: 100%; }
    #question-nav .btn { min-width: 40px; }
</style>

<script>
    // Simple client-side demo logic. Replace with server-driven rendering if needed.
    (function(){
        const sampleQuestions = [
            { id: 1, text: 'What is .NET?', options: ['A framework','A database','A language','An OS'], correct: 0 },
            { id: 2, text: 'C# is developed by?', options: ['Apple','Microsoft','Google','Facebook'], correct: 1 },
            { id: 3, text: 'Which one is a Razor file extension?', options: ['.cshtml','.razor','.html','.cs'], correct: 0 }
        ];

        let questions = sampleQuestions; // TODO: replace by server data insertion
        let answers = Array(questions.length).fill(null);
        let index = 0;
        let running = false;

        const quizTitle = document.getElementById('quiz-title');
        const quizCount = document.getElementById('quiz-count');
        const quizEmpty = document.getElementById('quiz-empty');
        const quizArea = document.getElementById('quiz-area');
        const prevBtn = document.getElementById('prev-btn');
        const nextBtn = document.getElementById('next-btn');
        const startBtn = document.getElementById('start-btn');
        const submitBtn = document.getElementById('submit-btn');
        const progressBar = document.getElementById('quiz-progress');
        const timerEl = document.getElementById('timer');
        const questionNav = document.getElementById('question-nav');

        function renderQuestion(i){
            const q = questions[i];
            quizArea.innerHTML = '';
            const container = document.createElement('div');
            container.className = 'question-card';
            container.innerHTML = `
                <div class="mb-2"><strong>Câu ${i+1}:</strong></div>
                <div class="mb-3">${q.text}</div>
                <div class="list-group" id="options-${q.id}"></div>
            `;
            quizArea.appendChild(container);

            const optionsEl = document.getElementById('options-' + q.id);
            q.options.forEach((opt, idx) => {
                const btn = document.createElement('button');
                btn.className = 'list-group-item list-group-item-action option-btn';
                btn.type = 'button';
                btn.innerText = opt;
                btn.onclick = () => selectOption(i, idx, btn);
                if (answers[i] === idx) btn.classList.add('active');
                optionsEl.appendChild(btn);
            });

            prevBtn.disabled = i === 0;
            nextBtn.disabled = i === questions.length - 1;
            updateProgress();
        }

        function selectOption(qIndex, optIndex, btn){
            answers[qIndex] = optIndex;
            // update button states
            const parent = btn.parentElement;
            Array.from(parent.children).forEach(c => c.classList.remove('active'));
            btn.classList.add('active');
            updateNavPill(qIndex);
        }

        function updateProgress(){
            const done = answers.filter(a => a !== null).length;
            const pct = Math.round((done / questions.length) * 100);
            progressBar.style.width = pct + '%';
            progressBar.innerText = pct + '%';
            document.getElementById('quiz-count').innerText = questions.length;
        }

        function renderNav(){
            questionNav.innerHTML = '';
            questions.forEach((q, i) => {
                const btn = document.createElement('button');
                btn.className = 'btn btn-outline-secondary btn-sm';
                if (answers[i] !== null) btn.classList.replace('btn-outline-secondary','btn-primary');
                btn.innerText = i+1;
                btn.onclick = () => { index = i; renderQuestion(i); };
                questionNav.appendChild(btn);
            });
        }

        function updateNavPill(i){
            const btn = questionNav.children[i];
            if (!btn) return;
            if (answers[i] !== null) btn.classList.replace('btn-outline-secondary','btn-primary');
            else btn.classList.replace('btn-primary','btn-outline-secondary');
        }

        prevBtn.addEventListener('click', () => { if (index>0) { index--; renderQuestion(index); } });
        nextBtn.addEventListener('click', () => { if (index<questions.length-1) { index++; renderQuestion(index); } });
        startBtn.addEventListener('click', () => startQuiz());
        submitBtn.addEventListener('click', () => submitQuiz());

        // demo timer (no server sync)
        let timerInterval = null;
        let remaining = 15 * 60; // seconds default
        function startTimer(seconds){
            remaining = seconds;
            clearInterval(timerInterval);
            timerInterval = setInterval(()=>{
                if (remaining<=0){ clearInterval(timerInterval); timerEl.innerText = '00:00'; submitQuiz(); return; }
                remaining--;
                const mm = String(Math.floor(remaining/60)).padStart(2,'0');
                const ss = String(remaining%60).padStart(2,'0');
                timerEl.innerText = `${mm}:${ss}`;
            }, 1000);
        }

        function startQuiz(){
            running = true;
            document.getElementById('quiz-status').innerText = 'In progress';
            startBtn.classList.add('d-none');
            submitBtn.classList.remove('d-none');
            quizEmpty.classList.add('d-none');
            renderNav();
            renderQuestion(0);
            startTimer(15*60); // replace with real duration
            renderNav();
        }

        function submitQuiz(){
            clearInterval(timerInterval);
            // simple scoring (only works for sampleQuestions)
            let score = 0;
            answers.forEach((a, i) => { if (a === questions[i].correct) score++; });
            quizArea.innerHTML = `<div class="text-center p-4"><h3>Kết quả</h3><p class="mb-1">Bạn được <strong>${score} / ${questions.length}</strong></p><small class="text-muted">(Demo client-side)</small></div>`;
            document.getElementById('quiz-status').innerText = 'Completed';
            submitBtn.disabled = true;
        }

        // initialize summary info
        document.getElementById('info-questions').innerText = questions.length;
        document.getElementById('info-duration').innerText = '15 phút';
        quizTitle.innerText = 'Demo Quiz - Thử nghiệm';
        quizCount.innerText = questions.length;
        timerEl.innerText = '15:00';

        // If you want to render questions from server, inject a JSON payload into a script tag and assign to `questions` variable above.
    })();
</script>