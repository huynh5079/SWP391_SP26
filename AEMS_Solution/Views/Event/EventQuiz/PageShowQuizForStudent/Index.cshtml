@{
    Layout = "_Layout"; // adjust if your layout has a different name
    var quizId = ViewData["QuizId"]?.ToString() ?? string.Empty;
    var eventId = ViewData["EventId"]?.ToString() ?? string.Empty;
}

<!-- Student Quiz UI: replace placeholders with server-side data as needed -->
<section id="student-quiz" class="container my-5" data-quiz-id="@quizId" data-event-id="@eventId">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h4 class="mb-1">Quiz: <span id="quiz-title">Placeholder Quiz Title</span></h4>
                            <small class="text-muted">Time limit: <span id="quiz-time">--:--</span> • Questions: <span id="quiz-count">0</span></small>
                        </div>
                        <div class="text-end">
                            <div class="badge bg-primary" id="quiz-status">Ready</div>
                        </div>
                    </div>

                    <div id="quiz-area">
                        <!-- Question will be injected here by JavaScript -->
                        <div class="text-center py-5 text-muted" id="quiz-empty">Nhấn nút "Bắt đầu" để làm bài kiểm tra</div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <div>
                            <button class="btn btn-outline-secondary me-2" id="prev-btn" disabled>← Trước</button>
                            <button class="btn btn-outline-secondary" id="next-btn" disabled>Sau →</button>
                        </div>
                        <div>
                            <button class="btn btn-success" id="start-btn">Bắt đầu</button>
                            <button class="btn btn-danger d-none" id="submit-btn">Nộp bài</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm sticky-top" style="top: 90px;">
                <div class="card-body p-3">
                    <h6 class="mb-2">Thông tin bài kiểm tra</h6>
                    <ul class="list-unstyled small text-muted mb-3">
                        <li><strong>Thời lượng:</strong> <span id="info-duration">15 phút</span></li>
                        <li><strong>Số câu:</strong> <span id="info-questions">10</span></li>
                        <li><strong>Hình thức:</strong> Multiple choice</li>
                        <li><strong>Số lần nộp tối đa:</strong> <span id="info-max-attempts">Không giới hạn</span></li>
                        <li><strong>Lượt nộp hiện tại:</strong> <span id="info-current-attempt">1</span></li>
                    </ul>

                    <div class="mb-3">
                        <label class="form-label small mb-1">Tiến độ</label>
                        <div class="progress" style="height: 10px;">
                            <div class="progress-bar" role="progressbar" style="width: 0%;" id="quiz-progress"></div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small mb-1">Thời gian còn lại</label>
                        <div class="h4 mb-0" id="timer">--:--</div>
                    </div>

                    <div>
                        <label class="form-label small mb-1">Danh sách câu hỏi</label>
                        <div id="question-nav" class="d-flex flex-wrap gap-2">
                            <!-- numbered pills will be inserted here -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    /* Small scoped styles for the quiz UI */
    #student-quiz .card { border-radius: 12px; }
    #student-quiz .badge { font-size: 0.85rem; padding: 0.5rem 0.7rem; }
    .question-card { border-radius: 10px; padding: 1rem; background: #fbfdff; }
    .option-btn { text-align: left; width: 100%; }
    #question-nav .btn { min-width: 40px; }
</style>

<script>
    (function () {
        const root = document.getElementById('student-quiz');
        const quizId = root?.dataset.quizId || '';
        const apiBase = '/api/v1/student-quiz';
        let session = null;
        let questions = [];
        let answers = [];
        let index = 0;
        let timerInterval = null;
        let remaining = 0;

        const quizTitle = document.getElementById('quiz-title');
        const quizCount = document.getElementById('quiz-count');
        const quizEmpty = document.getElementById('quiz-empty');
        const quizArea = document.getElementById('quiz-area');
        const prevBtn = document.getElementById('prev-btn');
        const nextBtn = document.getElementById('next-btn');
        const startBtn = document.getElementById('start-btn');
        const submitBtn = document.getElementById('submit-btn');
        const progressBar = document.getElementById('quiz-progress');
        const timerEl = document.getElementById('timer');
        const questionNav = document.getElementById('question-nav');
        const quizStatus = document.getElementById('quiz-status');

        function notify(message) { alert(message); }

        function normalizeType(typeOption) {
            const value = String(typeOption ?? '').toLowerCase();
            if (value === 'multiplechoice' || value === '2') return 'multiple';
            if (value === 'truefalse' || value === '1') return 'single';
            return 'single';
        }

        function toOptionList(options) {
            return [
                { key: 'A', text: options?.optionA },
                { key: 'B', text: options?.optionB },
                { key: 'C', text: options?.optionC },
                { key: 'D', text: options?.optionD }
            ].filter(x => x.text && x.text.trim() !== '');
        }

        function renderNav() {
            questionNav.innerHTML = '';
            questions.forEach((_, i) => {
                const btn = document.createElement('button');
                btn.className = 'btn btn-outline-secondary btn-sm';
                const hasAnswer = answers[i] && answers[i].length > 0;
                if (hasAnswer) btn.classList.replace('btn-outline-secondary', 'btn-primary');
                btn.innerText = i + 1;
                btn.onclick = () => { index = i; renderQuestion(i); };
                questionNav.appendChild(btn);
            });
        }

        function renderQuestion(i) {
            const q = questions[i];
            const type = normalizeType(q.typeOption);
            const opts = toOptionList(q.options);
            quizArea.innerHTML = '';
            const card = document.createElement('div');
            card.className = 'question-card';
            card.innerHTML = `<div class="mb-2"><strong>Câu ${i + 1}:</strong></div><div class="mb-3">${q.questionText}</div>`;
            const list = document.createElement('div');
            list.className = 'list-group';

            opts.forEach(opt => {
                const item = document.createElement('label');
                item.className = 'list-group-item list-group-item-action option-btn';
                const checked = (answers[i] || []).includes(opt.key);
                item.innerHTML = `
                    <input type="${type === 'multiple' ? 'checkbox' : 'radio'}"
                           name="q-${i}"
                           value="${opt.key}"
                           ${checked ? 'checked' : ''}
                           style="margin-right:8px;" />
                    <strong>${opt.key}.</strong> ${opt.text}
                `;
                item.querySelector('input').addEventListener('change', (e) => {
                    if (type === 'multiple') {
                        const set = new Set(answers[i] || []);
                        if (e.target.checked) set.add(opt.key); else set.delete(opt.key);
                        answers[i] = Array.from(set).sort();
                    } else {
                        answers[i] = [opt.key];
                    }
                    updateProgress();
                    renderNav();
                });
                list.appendChild(item);
            });

            card.appendChild(list);
            quizArea.appendChild(card);
            prevBtn.disabled = i === 0;
            nextBtn.disabled = i === questions.length - 1;
        }

        function updateProgress() {
            const done = answers.filter(a => a && a.length > 0).length;
            const pct = questions.length > 0 ? Math.round((done / questions.length) * 100) : 0;
            progressBar.style.width = pct + '%';
            progressBar.innerText = pct + '%';
        }

        function tick() {
            if (remaining <= 0) {
                clearInterval(timerInterval);
                timerEl.innerText = '00:00';
                submitQuiz(true);
                return;
            }
            remaining--;
            const mm = String(Math.floor(remaining / 60)).padStart(2, '0');
            const ss = String(remaining % 60).padStart(2, '0');
            timerEl.innerText = `${mm}:${ss}`;
        }

        function startTimer() {
            clearInterval(timerInterval);
            timerInterval = setInterval(tick, 1000);
            tick();
        }

        function applySession(data) {
            session = data;
            questions = data.questions || [];
            answers = Array(questions.length).fill(null).map(() => []);
            quizTitle.innerText = data.quiz?.title || 'Quiz';
            quizCount.innerText = questions.length;
            document.getElementById('info-questions').innerText = questions.length;
            document.getElementById('info-duration').innerText = `${data.limit?.timeLimitMinutes ?? 0} phút`;
            document.getElementById('info-max-attempts').innerText = data.limit?.maxAttempts > 0 ? data.limit.maxAttempts : 'Không giới hạn';
            document.getElementById('info-current-attempt').innerText = data.limit?.attemptNumber ?? 1;
            quizStatus.innerText = 'In progress';
            quizEmpty.classList.add('d-none');
            startBtn.classList.add('d-none');
            submitBtn.classList.remove('d-none');
            submitBtn.disabled = false;
            index = 0;
            renderNav();
            renderQuestion(0);
            const endsAt = data.limit?.endsAt ? new Date(data.limit.endsAt).getTime() : null;
            remaining = endsAt ? Math.max(0, Math.floor((endsAt - Date.now()) / 1000)) : (data.limit?.timeLimitMinutes || 0) * 60;
            timerEl.innerText = '--:--';
            if (remaining > 0) startTimer();
        }

        async function request(url, method, body) {
            const res = await fetch(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: body ? JSON.stringify(body) : undefined
            });
            const data = await res.json().catch(() => ({}));
            if (!res.ok) throw new Error(data.message || 'Có lỗi xảy ra.');
            return data;
        }

        async function loadCurrent() {
            if (!quizId) {
                notify('Thiếu quizId. Vui lòng quay lại trang chi tiết sự kiện và bấm Bắt đầu từ đúng quiz.');
                startBtn.disabled = true;
                return;
            }
            try {
                const current = await request(`${apiBase}/current?quizId=${encodeURIComponent(quizId)}`, 'GET');
                if (current?.session) {
                    applySession(current.session);
                } else {
                    quizStatus.innerText = 'Ready';
                    startBtn.classList.remove('d-none');
                    submitBtn.classList.add('d-none');
                }
            } catch (e) {
                notify(e.message);
                startBtn.disabled = true;
            }
        }

        async function startQuiz() {
            try {
                const result = await request(`${apiBase}/start`, 'POST', { quizId });
                applySession(result.session);
            } catch (e) {
                notify(e.message);
            }
        }

        async function submitQuiz(isAuto) {
            if (!session?.studentQuizScoreId) return;
            submitBtn.disabled = true;
            clearInterval(timerInterval);
            try {
                const payload = {
                    quizId,
                    studentQuizScoreId: session.studentQuizScoreId,
                    answers: questions.map((q, i) => ({
                        questionBankId: q.questionBankId,
                        selectedAnswer: (answers[i] || []).join(',')
                    }))
                };
                const result = await request(`${apiBase}/submit`, 'POST', payload);
                quizStatus.innerText = 'Completed';
                quizArea.innerHTML = `<div class="text-center p-4"><h3>Kết quả</h3><p class="mb-1">Bạn được <strong>${result.score} / ${questions.length}</strong></p><small class="text-muted">${isAuto ? 'Hết thời gian làm bài' : 'Đã nộp bài thành công'}</small></div>`;
                startBtn.classList.add('d-none');
                submitBtn.classList.add('d-none');
            } catch (e) {
                notify(e.message);
                submitBtn.disabled = false;
            }
        }

        prevBtn.addEventListener('click', () => { if (index > 0) { index--; renderQuestion(index); } });
        nextBtn.addEventListener('click', () => { if (index < questions.length - 1) { index++; renderQuestion(index); } });
        startBtn.addEventListener('click', startQuiz);
        submitBtn.addEventListener('click', () => submitQuiz(false));
        loadCurrent();
    })();
</script>