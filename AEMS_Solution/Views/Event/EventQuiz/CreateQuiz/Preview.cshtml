@model AEMS_Solution.Models.Event.EventQuiz.EventQuizViewModel
@{
    ViewData["Title"] = "Quiz Preview";
    bool isOrganizer = User.IsInRole("Organizer");
    Layout = isOrganizer ? "_Organizerlayout" : "~/Views/Shared/_Layout.cshtml";
    var hasQuestions = Model.Questions != null && Model.Questions.Any();
    var hasFile = !string.IsNullOrWhiteSpace(Model.Quiz?.FileQuiz);
    var filePath = hasFile ? Url.Content("~/" + Model.Quiz!.FileQuiz!.TrimStart('/')) : string.Empty;
    var fileExtension = hasFile ? System.IO.Path.GetExtension(Model.Quiz!.FileQuiz)?.ToLowerInvariant() : string.Empty;
    var canEmbedPdf = string.Equals(fileExtension, ".pdf", System.StringComparison.OrdinalIgnoreCase);

    bool HasCorrectAnswer(BusinessLogic.DTOs.Event.Quiz.ForMainRole.Contracts.QuizQuestionContract question, string option)
    {
        if (string.IsNullOrWhiteSpace(question.CorrectAnswer))
        {
            return false;
        }

        return question.CorrectAnswer
            .Split(',', System.StringSplitOptions.RemoveEmptyEntries | System.StringSplitOptions.TrimEntries)
            .Any(answer => string.Equals(answer, option, System.StringComparison.OrdinalIgnoreCase));
    }
}

<div class="container-fluid py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Quiz Detail</h1>
            <p class="text-muted small mb-0">Read-only preview of the quiz content.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            @if (isOrganizer)
            {
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Back to list</a>
                <a asp-action="Details" asp-route-quizId="@Model.Quiz?.EventQuizId" class="btn btn-sm btn-outline-primary">Manage quiz</a>
            }
            else
            {
                <a href="javascript:history.back()" class="btn btn-sm btn-outline-secondary">Go Back</a>
            }
            @if (hasFile)
            {
                <a href="@filePath" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-primary">Open file</a>
            }
        </div>
    </div>

    @if (Model.Quiz == null)
    {
        <div class="alert alert-warning">Quiz information is not available.</div>
    }
    else
    {
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
                    <div>
                        <h2 class="h4 mb-2">@Model.Quiz.Title</h2>
                        <div class="text-muted small">Event: @Model.EventTitle</div>
                        <div class="text-muted small">Topic: @(string.IsNullOrWhiteSpace(Model.TopicName) ? "-" : Model.TopicName)</div>
                    </div>
                    <div class="d-flex flex-wrap gap-2 align-content-start">
                        <span class="badge bg-secondary">@Model.Quiz.Status</span>
                        <span class="badge bg-light text-dark border">@Model.Quiz.Type</span>
                        <span class="badge bg-light text-dark border">@(Model.Quiz.PassingScore?.ToString() ?? "-") điểm</span>
                        <span class="badge bg-light text-dark border">@Model.Quiz.QuestionCount câu</span>
                    </div>
                </div>
            </div>
        </div>

        @if (canEmbedPdf)
        {
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h2 class="h6 mb-0">File Preview</h2>
                    <a href="@filePath" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary">Open in new tab</a>
                </div>
                <div class="card-body p-0">
                    <iframe src="@filePath" title="Quiz file preview" style="width:100%; min-height:900px; border:0;"></iframe>
                </div>
            </div>
        }
        else if (hasFile)
        {
            <div class="alert alert-info d-flex justify-content-between align-items-center mb-4">
                <span>This file type cannot be previewed inline. Open the quiz file in a new tab.</span>
                <a href="@filePath" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary">Open file</a>
            </div>
        }

        <div class="card shadow-sm border-0">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h2 class="h6 mb-0">Question Preview</h2>
                <span class="small text-muted">Read-only</span>
            </div>
            <div class="card-body p-4">
                @if (!hasQuestions)
                {
                    <div class="alert alert-light border mb-0">No questions found for this quiz.</div>
                }
                else
                {
                    <div class="mx-auto" style="max-width: 980px;">
                        @for (var i = 0; i < Model.Questions!.Count; i++)
                        {
                            var question = Model.Questions[i];
                            var isAnswerA = HasCorrectAnswer(question, "A");
                            var isAnswerB = HasCorrectAnswer(question, "B");
                            var isAnswerC = HasCorrectAnswer(question, "C");
                            var isAnswerD = HasCorrectAnswer(question, "D");
                            <div class="mb-4 pb-3 border-bottom">
                                <div class="fw-semibold fs-5 mb-3">
                                    @(i + 1). @question.QuestionText
                                </div>

                                <div class="row g-3 ms-1">
                                    <div class="col-md-6">
                                        <div class="@(isAnswerA ? "fw-semibold text-success" : string.Empty)">
                                            A. @question.Options.OptionA
                                            @if (isAnswerA)
                                            {
                                                <span class="badge bg-success ms-2">Correct</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="@(isAnswerB ? "fw-semibold text-success" : string.Empty)">
                                            B. @question.Options.OptionB
                                            @if (isAnswerB)
                                            {
                                                <span class="badge bg-success ms-2">Correct</span>
                                            }
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(question.Options.OptionC))
                                    {
                                        <div class="col-md-6">
                                            <div class="@(isAnswerC ? "fw-semibold text-success" : string.Empty)">
                                                C. @question.Options.OptionC
                                                @if (isAnswerC)
                                                {
                                                    <span class="badge bg-success ms-2">Correct</span>
                                                }
                                            </div>
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(question.Options.OptionD))
                                    {
                                        <div class="col-md-6">
                                            <div class="@(isAnswerD ? "fw-semibold text-success" : string.Empty)">
                                                D. @question.Options.OptionD
                                                @if (isAnswerD)
                                                {
                                                    <span class="badge bg-success ms-2">Correct</span>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>

                                @if (!string.IsNullOrWhiteSpace(question.CorrectAnswer))
                                {
                                    <div class="mt-3 small text-success fw-semibold">
                                        Correct answer: @question.CorrectAnswer
                                    </div>
                                }

                                @if (!string.IsNullOrWhiteSpace(question.Explanation))
                                {
                                    <div class="small text-muted mt-3">Explanation: @question.Explanation</div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>
