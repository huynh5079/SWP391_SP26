@model AEMS_Solution.Models.Event.EventQuiz.EventQuizViewModel
@using DataAccess.Enum
@{
    ViewData["Title"] = "Create Quiz Manually";
    Layout = "_Organizerlayout";
}

<div class="container-fluid py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Create Quiz Manually</h1>
            <p class="text-muted small mb-0">Create the quiz and enter the questions manually on this page.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Create" asp-route-mode="upload" asp-route-eventId="@Model.EventId" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-upload me-1"></i>Switch to Upload File
            </a>
            <a asp-action="Create" asp-route-mode="bank" asp-route-eventId="@Model.EventId" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-collection me-1"></i>Switch to Question Bank
            </a>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Back to list</a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <div class="alert alert-light border d-flex align-items-start gap-2 mb-4">
                <i class="bi bi-info-circle text-primary"></i>
                <div>Create the quiz and enter the questions manually in one step.</div>
            </div>

            <form asp-action="Create" asp-route-mode="manual" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="EventId" class="form-label">Event</label>
                        <select asp-for="EventId" asp-items="Model.Events" class="form-select">
                            <option value="">Select event</option>
                        </select>
                        <span asp-validation-for="EventId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="TopicId" class="form-label">Topic</label>
                        <select asp-for="TopicId" asp-items="Model.Topics" class="form-select">
                            <option value="">Select topic</option>
                        </select>
                        <span asp-validation-for="TopicId" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Quiz.Title" class="form-label">Quiz title</label>
                        <input asp-for="Quiz.Title" class="form-control" placeholder="Enter quiz title" />
                        <span asp-validation-for="Quiz.Title" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Quiz.Type" class="form-label">Type</label>
                        <select asp-for="Quiz.Type" class="form-select js-quiz-type">
                            <option value="0">Practice</option>
                            <option value="1">Exam</option>
                            <option value="2">Survey</option>
                            <option value="3">LiveQuiz</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Quiz.PassingScore" class="form-label">Passing score</label>
                        <input asp-for="Quiz.PassingScore" class="form-control" type="number" min="0" placeholder="Enter passing score" />
                        <span asp-validation-for="Quiz.PassingScore" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Quiz.MaxAttempts" class="form-label">Max Attempts</label>
                        <input asp-for="Quiz.MaxAttempts" class="form-control" type="number" min="0" placeholder="Enter max attempts (0 for unlimited)" />
                        <span asp-validation-for="Quiz.MaxAttempts" class="text-danger"></span>
                    </div>

                    <div class="col-12 d-none js-live-quiz-link-group">
                        <label asp-for="Quiz.LiveQuizLink" class="form-label">Live quiz link</label>
                        <input asp-for="Quiz.LiveQuizLink" class="form-control js-live-quiz-link-input" type="url" placeholder="https://..." />
                        <span asp-validation-for="Quiz.LiveQuizLink" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <div class="form-check form-switch mt-2">
                            <input asp-for="Quiz.AllowReview" class="form-check-input" type="checkbox" />
                            <label asp-for="Quiz.AllowReview" class="form-check-label">Cho phép học sinh xem đáp án sau khi nộp bài</label>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Quiz.SharingStatus" class="form-label">Question bank visibility</label>
                        <select asp-for="Quiz.SharingStatus" class="form-select">
                            <option value="@((int)QuizSetVisibilityEnum.Private)">Private</option>
                            <option value="@((int)QuizSetVisibilityEnum.Public)">Public (Community)</option>
                        </select>
                        <div class="form-text">`Private` chỉ dùng nội bộ. `Public (Community)` sẽ chia sẻ cho community.</div>
                    </div>
                </div>

                <div class="border-top mt-4 pt-4">
                    <div class="mb-3">
                        <h2 class="h5 mb-1">Questions</h2>
                        <p class="text-muted small mb-0">Support 3 question types: 4 Answers, True / False, and Multiple Choice.</p>
                    </div>

                    <div id="manual-questions-container" class="d-flex flex-column gap-3">
                        @for (var i = 0; i < Model.ManualQuestions.Count; i++)
                        {
                            var question = Model.ManualQuestions[i];
                            var idPrefix = $"ManualQuestions_{i}__";
                            var namePrefix = $"ManualQuestions[{i}]";
                            var currentCorrectAnswers = (question.CorrectAnswer ?? string.Empty)
                                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                            <div class="card border-0 shadow-sm manual-question-item" data-index="@i">
                                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                                    <span class="fw-semibold">Question <span class="question-number">@(i + 1)</span></span>
                                    <button type="button" class="btn btn-sm btn-outline-danger remove-question-btn @(Model.ManualQuestions.Count == 1 ? "d-none" : string.Empty)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                                <div class="card-body">
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label" for="@(idPrefix + "TypeOption")">Question type</label>
                                            <select class="form-select js-question-type" id="@(idPrefix + "TypeOption")" name="@(namePrefix + ".TypeOption")" data-current-type="@((int)question.TypeOption)">
                                                <option value="@((int)QuestionTypeOptionEnum.SingleChoice)">4 Answers</option>
                                                <option value="@((int)QuestionTypeOptionEnum.MultipleChoice)">Multiple Choice</option>
                                                <option value="@((int)QuestionTypeOptionEnum.TrueFalse)">True / False</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label" for="@(idPrefix + "Difficulty")">Difficulty</label>
                                            <select class="form-select" id="@(idPrefix + "Difficulty")" name="@(namePrefix + ".Difficulty")">
                                                @if (question.Difficulty == QuestionDifficultyEnum.Easy)
                                                {
                                                    <option value="0" selected>Easy</option>
                                                }
                                                else
                                                {
                                                    <option value="0">Easy</option>
                                                }

                                                @if (question.Difficulty == QuestionDifficultyEnum.Medium)
                                                {
                                                    <option value="1" selected>Medium</option>
                                                }
                                                else
                                                {
                                                    <option value="1">Medium</option>
                                                }

                                                @if (question.Difficulty == QuestionDifficultyEnum.Hard)
                                                {
                                                    <option value="2" selected>Hard</option>
                                                }
                                                else
                                                {
                                                    <option value="2">Hard</option>
                                                }
                                            </select>
                                        </div>
                                    </div>

                                    <div class="mt-3">
                                        <label class="form-label" for="@(idPrefix + "QuestionText")">Question</label>
                                        <textarea class="form-control" id="@(idPrefix + "QuestionText")" name="@(namePrefix + ".QuestionText")" rows="3" placeholder="Enter question content" required>@question.QuestionText</textarea>
                                    </div>

                                    <div class="mt-3">
                                        <label class="form-label" for="@(idPrefix + "Explanation")">Explanation</label>
                                        <textarea class="form-control" id="@(idPrefix + "Explanation")" name="@(namePrefix + ".Explanation")" rows="2" placeholder="Giải thích đáp án (không bắt buộc)">@question.Explanation</textarea>
                                    </div>

                                    <div class="row g-3 mt-1 js-answer-group-wrapper">
                                        <div class="col-md-6 js-option-a-group">
                                            <label class="form-label" for="@(idPrefix + "Options_OptionA")">Answer A</label>
                                            <div class="input-group">
                                                <span class="input-group-text bg-white border-end-0 js-answer-selector-wrap">
                                                    <input class="form-check-input mt-0 js-answer-selector" type="checkbox" value="A" />
                                                </span>
                                                <input class="form-control js-option-a border-start-0" id="@(idPrefix + "Options_OptionA")" name="@(namePrefix + ".Options.OptionA")" value="@question.Options.OptionA" placeholder="Enter answer A" />
                                            </div>
                                        </div>
                                        <div class="col-md-6 js-option-b-group">
                                            <label class="form-label" for="@(idPrefix + "Options_OptionB")">Answer B</label>
                                            <div class="input-group">
                                                <span class="input-group-text bg-white border-end-0 js-answer-selector-wrap">
                                                    <input class="form-check-input mt-0 js-answer-selector" type="checkbox" value="B" />
                                                </span>
                                                <input class="form-control js-option-b border-start-0" id="@(idPrefix + "Options_OptionB")" name="@(namePrefix + ".Options.OptionB")" value="@question.Options.OptionB" placeholder="Enter answer B" />
                                            </div>
                                        </div>
                                        <div class="col-md-6 js-option-c-group">
                                            <label class="form-label" for="@(idPrefix + "Options_OptionC")">Answer C</label>
                                            <div class="input-group">
                                                <span class="input-group-text bg-white border-end-0 js-answer-selector-wrap">
                                                    <input class="form-check-input mt-0 js-answer-selector" type="checkbox" value="C" />
                                                </span>
                                                <input class="form-control js-option-c border-start-0" id="@(idPrefix + "Options_OptionC")" name="@(namePrefix + ".Options.OptionC")" value="@question.Options.OptionC" placeholder="Enter answer C" />
                                            </div>
                                        </div>
                                        <div class="col-md-6 js-option-d-group">
                                            <label class="form-label" for="@(idPrefix + "Options_OptionD")">Answer D</label>
                                            <div class="input-group">
                                                <span class="input-group-text bg-white border-end-0 js-answer-selector-wrap">
                                                    <input class="form-check-input mt-0 js-answer-selector" type="checkbox" value="D" />
                                                </span>
                                                <input class="form-control js-option-d border-start-0" id="@(idPrefix + "Options_OptionD")" name="@(namePrefix + ".Options.OptionD")" value="@question.Options.OptionD" placeholder="Enter answer D" />
                                            </div>
                                        </div>
                                    </div>

                                    <input class="js-correct-answer-value" type="hidden" id="@(idPrefix + "CorrectAnswer")" name="@(namePrefix + ".CorrectAnswer")" value="@question.CorrectAnswer" />
                                    <input type="hidden" id="@(idPrefix + "ScorePoint")" name="@(namePrefix + ".ScorePoint")" value="@(question.ScorePoint > 0 ? question.ScorePoint : 1)" />
                                </div>
                            </div>
                        }
                    </div>

                    <div class="mt-3 d-flex justify-content-end">
                        <button type="button" class="btn btn-outline-primary btn-sm" id="add-question-btn">
                            <i class="bi bi-plus-circle me-1"></i>Add question
                        </button>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>Create Quiz
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const typeSelect = document.querySelector('.js-quiz-type');
            const liveLinkGroup = document.querySelector('.js-live-quiz-link-group');
            const liveLinkInput = document.querySelector('.js-live-quiz-link-input');
            const questionsContainer = document.getElementById('manual-questions-container');
            const addQuestionButton = document.getElementById('add-question-btn');

            function toggleLiveQuizLink() {
                const isLiveQuiz = typeSelect && typeSelect.value === '3';
                liveLinkGroup?.classList.toggle('d-none', !isLiveQuiz);

                if (liveLinkInput) {
                    liveLinkInput.required = isLiveQuiz;
                    if (!isLiveQuiz) {
                        liveLinkInput.value = '';
                    }
                }
            }

            function syncCorrectAnswer(card) {
                const type = card.querySelector('.js-question-type')?.value;
                const hiddenCorrectAnswer = card.querySelector('.js-correct-answer-value');
                const selectors = Array.from(card.querySelectorAll('.js-answer-selector'));
                const activeSelectors = selectors.filter(function (selector) {
                    const group = selector.closest('.col-md-6');
                    return group && !group.classList.contains('d-none') && !selector.disabled;
                });

                if (!hiddenCorrectAnswer) {
                    return;
                }

                const checkedValues = activeSelectors
                    .filter(function (selector) { return selector.checked; })
                    .map(function (selector) { return selector.value; });

                if (type === '1') {
                    hiddenCorrectAnswer.value = checkedValues.join(',');
                    return;
                }

                hiddenCorrectAnswer.value = checkedValues[0] ?? '';
            }

            function restoreSelections(card, allowMultiple) {
                const hiddenCorrectAnswer = card.querySelector('.js-correct-answer-value');
                const values = (hiddenCorrectAnswer?.value ?? '')
                    .split(',')
                    .map(function (value) { return value.trim(); })
                    .filter(Boolean);

                card.querySelectorAll('.js-answer-selector').forEach(function (selector) {
                    const group = selector.closest('.col-md-6');
                    const isVisible = group && !group.classList.contains('d-none') && !selector.disabled;
                    selector.checked = isVisible && values.includes(selector.value);
                });

                if (!allowMultiple) {
                    const checked = Array.from(card.querySelectorAll('.js-answer-selector:checked'));
                    checked.slice(1).forEach(function (selector) {
                        selector.checked = false;
                    });
                }
            }

            function updateQuestionType(card, preserveCurrentSelection) {
                const type = card.querySelector('.js-question-type')?.value;
                const optionA = card.querySelector('.js-option-a');
                const optionB = card.querySelector('.js-option-b');
                const optionC = card.querySelector('.js-option-c');
                const optionD = card.querySelector('.js-option-d');
                const optionCGroups = card.querySelectorAll('.js-option-c-group');
                const optionDGroups = card.querySelectorAll('.js-option-d-group');
                const selectors = Array.from(card.querySelectorAll('.js-answer-selector'));
                const allowMultiple = type === '1';

                if (!preserveCurrentSelection) {
                    const hiddenCorrectAnswer = card.querySelector('.js-correct-answer-value');
                    if (hiddenCorrectAnswer) {
                        hiddenCorrectAnswer.value = '';
                    }
                    selectors.forEach(function (selector) {
                        selector.checked = false;
                    });
                }

                if (type === '2') {
                    if (optionA) {
                        optionA.value = 'True';
                        optionA.readOnly = true;
                        optionA.required = true;
                    }
                    if (optionB) {
                        optionB.value = 'False';
                        optionB.readOnly = true;
                        optionB.required = true;
                    }
                    if (optionC) {
                        optionC.value = '';
                        optionC.readOnly = true;
                        optionC.required = false;
                    }
                    if (optionD) {
                        optionD.value = '';
                        optionD.readOnly = true;
                        optionD.required = false;
                    }

                    optionCGroups.forEach(function (group) { group.classList.add('d-none'); });
                    optionDGroups.forEach(function (group) { group.classList.add('d-none'); });

                    selectors.forEach(function (selector) {
                        selector.disabled = selector.value === 'C' || selector.value === 'D';
                        if (selector.disabled) {
                            selector.checked = false;
                        }
                    });
                } else {
                    if (optionA) {
                        optionA.readOnly = false;
                        optionA.required = true;
                        if (optionA.value === 'True') optionA.value = '';
                    }
                    if (optionB) {
                        optionB.readOnly = false;
                        optionB.required = true;
                        if (optionB.value === 'False') optionB.value = '';
                    }
                    if (optionC) {
                        optionC.readOnly = false;
                        optionC.required = true;
                    }
                    if (optionD) {
                        optionD.readOnly = false;
                        optionD.required = true;
                    }

                    optionCGroups.forEach(function (group) { group.classList.remove('d-none'); });
                    optionDGroups.forEach(function (group) { group.classList.remove('d-none'); });
                    selectors.forEach(function (selector) { selector.disabled = false; });
                }

                restoreSelections(card, allowMultiple);
                syncCorrectAnswer(card);
            }

            function updateQuestionNumbers() {
                const items = Array.from(questionsContainer?.querySelectorAll('.manual-question-item') ?? []);

                items.forEach(function (item, index) {
                    item.dataset.index = index.toString();
                    const number = item.querySelector('.question-number');
                    if (number) {
                        number.textContent = (index + 1).toString();
                    }

                    item.querySelectorAll('input, textarea, select').forEach(function (field) {
                        if (field.name) {
                            field.name = field.name.replace(/ManualQuestions\[\d+\]/g, `ManualQuestions[${index}]`);
                        }

                        if (field.id) {
                            field.id = field.id.replace(/ManualQuestions_\d+__/g, `ManualQuestions_${index}__`);
                        }
                    });

                    item.querySelectorAll('label').forEach(function (label) {
                        if (label.htmlFor) {
                            label.htmlFor = label.htmlFor.replace(/ManualQuestions_\d+__/g, `ManualQuestions_${index}__`);
                        }
                    });
                });

                items.forEach(function (item) {
                    const button = item.querySelector('.remove-question-btn');
                    if (button) {
                        button.classList.toggle('d-none', items.length === 1);
                    }
                });
            }

            function bindQuestionCard(card) {
                const questionTypeSelect = card.querySelector('.js-question-type');
                if (questionTypeSelect?.dataset.currentType) {
                    questionTypeSelect.value = questionTypeSelect.dataset.currentType;
                }

                card.querySelectorAll('.js-answer-selector').forEach(function (selector) {
                    selector.addEventListener('change', function () {
                        if (questionTypeSelect?.value !== '1' && selector.checked) {
                            card.querySelectorAll('.js-answer-selector').forEach(function (otherSelector) {
                                if (otherSelector !== selector) {
                                    otherSelector.checked = false;
                                }
                            });
                        }

                        syncCorrectAnswer(card);
                    });
                });

                questionTypeSelect?.addEventListener('change', function () {
                    updateQuestionType(card, false);
                });

                updateQuestionType(card, true);
            }

            function buildQuestionTemplate(index) {
                return `
                    <div class="card border-0 shadow-sm manual-question-item" data-index="${index}">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <span class="fw-semibold">Question <span class="question-number">${index + 1}</span></span>
                            <button type="button" class="btn btn-sm btn-outline-danger remove-question-btn">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label" for="ManualQuestions_${index}__TypeOption">Question type</label>
                                    <select class="form-select js-question-type" id="ManualQuestions_${index}__TypeOption" name="ManualQuestions[${index}].TypeOption">
                                        <option value="0">4 Answers</option>
                                        <option value="1">Multiple Choice</option>
                                        <option value="2">True / False</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="ManualQuestions_${index}__Difficulty">Difficulty</label>
                                    <select class="form-select" id="ManualQuestions_${index}__Difficulty" name="ManualQuestions[${index}].Difficulty">
                                        <option value="0">Easy</option>
                                        <option value="1" selected>Medium</option>
                                        <option value="2">Hard</option>
                                    </select>
                                </div>
                            </div>
                            <div class="mt-3">
                                <label class="form-label" for="ManualQuestions_${index}__QuestionText">Question</label>
                                <textarea class="form-control" id="ManualQuestions_${index}__QuestionText" name="ManualQuestions[${index}].QuestionText" rows="3" placeholder="Enter question content" required></textarea>
                            </div>
                            <div class="mt-3">
                                <label class="form-label" for="ManualQuestions_${index}__Explanation">Explanation</label>
                                <textarea class="form-control" id="ManualQuestions_${index}__Explanation" name="ManualQuestions[${index}].Explanation" rows="2" placeholder="Giải thích đáp án (không bắt buộc)"></textarea>
                            </div>
                            <div class="row g-3 mt-1 js-answer-group-wrapper">
                                <div class="col-md-6 js-option-a-group">
                                    <label class="form-label" for="ManualQuestions_${index}__Options_OptionA">Answer A</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-end-0 js-answer-selector-wrap">
                                            <input class="form-check-input mt-0 js-answer-selector" type="checkbox" value="A" />
                                        </span>
                                        <input class="form-control js-option-a border-start-0" id="ManualQuestions_${index}__Options_OptionA" name="ManualQuestions[${index}].Options.OptionA" placeholder="Enter answer A" />
                                    </div>
                                </div>
                                <div class="col-md-6 js-option-b-group">
                                    <label class="form-label" for="ManualQuestions_${index}__Options_OptionB">Answer B</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-end-0 js-answer-selector-wrap">
                                            <input class="form-check-input mt-0 js-answer-selector" type="checkbox" value="B" />
                                        </span>
                                        <input class="form-control js-option-b border-start-0" id="ManualQuestions_${index}__Options_OptionB" name="ManualQuestions[${index}].Options.OptionB" placeholder="Enter answer B" />
                                    </div>
                                </div>
                                <div class="col-md-6 js-option-c-group">
                                    <label class="form-label" for="ManualQuestions_${index}__Options_OptionC">Answer C</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-end-0 js-answer-selector-wrap">
                                            <input class="form-check-input mt-0 js-answer-selector" type="checkbox" value="C" />
                                        </span>
                                        <input class="form-control js-option-c border-start-0" id="ManualQuestions_${index}__Options_OptionC" name="ManualQuestions[${index}].Options.OptionC" placeholder="Enter answer C" />
                                    </div>
                                </div>
                                <div class="col-md-6 js-option-d-group">
                                    <label class="form-label" for="ManualQuestions_${index}__Options_OptionD">Answer D</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-end-0 js-answer-selector-wrap">
                                            <input class="form-check-input mt-0 js-answer-selector" type="checkbox" value="D" />
                                        </span>
                                        <input class="form-control js-option-d border-start-0" id="ManualQuestions_${index}__Options_OptionD" name="ManualQuestions[${index}].Options.OptionD" placeholder="Enter answer D" />
                                    </div>
                                </div>
                            </div>
                            <input class="js-correct-answer-value" type="hidden" id="ManualQuestions_${index}__CorrectAnswer" name="ManualQuestions[${index}].CorrectAnswer" value="" />
                            <input type="hidden" id="ManualQuestions_${index}__ScorePoint" name="ManualQuestions[${index}].ScorePoint" value="1" />
                        </div>
                    </div>`;
            }

            addQuestionButton?.addEventListener('click', function () {
                const nextIndex = questionsContainer?.querySelectorAll('.manual-question-item').length ?? 0;
                questionsContainer?.insertAdjacentHTML('beforeend', buildQuestionTemplate(nextIndex));
                const newCard = questionsContainer?.lastElementChild;
                if (newCard) {
                    bindQuestionCard(newCard);
                    newCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
                updateQuestionNumbers();
            });

            questionsContainer?.addEventListener('click', function (event) {
                const target = event.target;
                const removeButton = target instanceof Element ? target.closest('.remove-question-btn') : null;
                if (!removeButton) {
                    return;
                }

                removeButton.closest('.manual-question-item')?.remove();
                updateQuestionNumbers();
            });

            typeSelect?.addEventListener('change', toggleLiveQuizLink);
            toggleLiveQuizLink();
            questionsContainer?.querySelectorAll('.manual-question-item').forEach(function (card) {
                bindQuestionCard(card);
            });
            updateQuestionNumbers();
        });
    </script>
}
