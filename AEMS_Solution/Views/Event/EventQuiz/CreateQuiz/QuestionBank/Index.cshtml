@model AEMS_Solution.Models.Event.EventQuiz.EventQuizViewModel
@{
    ViewData["Title"] = "Quiz Bank";
    Layout = "_Organizerlayout";
}

<div class="container-fluid py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Quiz Bank</h1>
            <p class="text-muted small mb-0">Manage quiz question sets by semester, event, and title.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Index" asp-route-scope="myquiz" class="btn btn-sm btn-outline-secondary">My Quiz</a>
            <a asp-action="Create" asp-route-mode="bank" class="btn btn-sm btn-primary">Use Question Bank</a>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form asp-action="QuestionBank" method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label asp-for="SemesterFilter" class="form-label">Semester</label>
                    <input asp-for="SemesterFilter" class="form-control" placeholder="Filter by semester" />
                </div>
                <div class="col-md-4">
                    <label asp-for="EventTitleFilter" class="form-label">Event</label>
                    <input asp-for="EventTitleFilter" class="form-control" placeholder="Filter by event" />
                </div>
                <div class="col-md-4">
                    <label asp-for="QuizTitleFilter" class="form-label">Quiz title</label>
                    <input asp-for="QuizTitleFilter" class="form-control" placeholder="Filter by title" />
                </div>
                <div class="col-12 d-flex justify-content-end gap-2">
                    <a asp-action="QuestionBank" class="btn btn-outline-secondary">Clear</a>
                    <button type="submit" class="btn btn-primary">Apply filters</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            @if (Model.Quizzes == null || !Model.Quizzes.Any())
            {
                <div class="alert alert-info mb-0">No quiz bank records found with the current filters.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Semester</th>
                                <th>Event</th>
                                <th>Quiz title</th>
                                <th>Questions</th>
                                <th>Visibility</th>
                                <th>Updated</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var q in Model.Quizzes)
                            {
                                var visibilityLabel = q.SharingStatus == DataAccess.Enum.QuizSetVisibilityEnum.Public ? "Public (Community)" : "Private";
                                <tr>
                                    <td>@(string.IsNullOrWhiteSpace(q.SemesterName) ? "-" : q.SemesterName)</td>
                                    <td>@(string.IsNullOrWhiteSpace(q.EventTitle) ? q.EventId : q.EventTitle)</td>
                                    <td>@q.Title</td>
                                    <td>@q.QuestionCount</td>
                                    <td>@visibilityLabel</td>
                                    <td>@q.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <div class="d-flex flex-wrap gap-2">
                                            <a asp-action="Preview" asp-route-quizId="@q.EventQuizId" class="btn btn-sm btn-outline-info">View</a>
                                            <a asp-action="Details" asp-route-quizId="@q.EventQuizId" class="btn btn-sm btn-outline-secondary">Manage</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
