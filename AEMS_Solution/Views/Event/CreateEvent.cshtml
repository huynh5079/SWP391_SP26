@model AEMS_Solution.Models.Event.CreateEventViewModel
@using DataAccess.Enum
@{
    ViewData["Title"] = "Create Event";
    Layout = "_OrganizerLayout";
}

<style>
    /* Modern Create Event UI */
    :root {
        --ce-primary: #4f46e5;
        --ce-primary-hover: #4338ca;
        --ce-bg: #f8fafc;
        --ce-card-bg: #ffffff;
        --ce-border: #e2e8f0;
        --ce-text-main: #0f172a;
        --ce-text-muted: #64748b;
        --ce-radius-lg: 16px;
        --ce-radius-md: 10px;
        --ce-shadow-sm: 0 4px 14px rgba(0, 0, 0, 0.03);
        --ce-shadow-md: 0 10px 30px rgba(0, 0, 0, 0.05);
        --ce-focus-ring: 0 0 0 4px rgba(79, 70, 229, 0.15);
    }

    body {
        background-color: var(--ce-bg) !important;
    }

    .create-wrapper {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 340px;
        gap: 24px;
        align-items: start;
        margin: 0 auto;
        padding-bottom: 3rem;
        padding-top: 1rem;
    }

    @@media (max-width: 1100px) {
        .create-wrapper {
            grid-template-columns: 1fr;
        }
        .ce-sidebar {
            position: static !important;
            max-height: none !important;
            overflow-y: visible !important;
        }
    }

    /* Form Card styling */
    .ce-card {
        background: var(--ce-card-bg);
        border-radius: var(--ce-radius-lg);
        box-shadow: var(--ce-shadow-md);
        border: 1px solid rgba(255, 255, 255, 0.8);
        padding: 2.5rem;
        margin-bottom: 1.5rem;
    }

    .ce-page-title {
        font-size: 1.85rem;
        font-weight: 800;
        color: var(--ce-text-main);
        margin-bottom: 0.5rem;
        letter-spacing: -0.02em;
    }

    .ce-page-subtitle {
        color: var(--ce-text-muted);
        font-size: 0.95rem;
        margin-bottom: 2rem;
    }

    .ce-section-title {
        font-size: 1.15rem;
        font-weight: 800;
        color: var(--ce-text-main);
        margin: 2rem 0 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        border-bottom: 1px dashed var(--ce-border);
        padding-bottom: 0.75rem;
    }

    .ce-section-title i {
        color: var(--ce-primary);
        background: #e0e7ff;
        padding: 0.4rem;
        border-radius: 8px;
        font-size: 1rem;
    }

    /* Form Controls */
    .ce-label {
        font-weight: 600;
        font-size: 0.85rem;
        color: var(--ce-text-main);
        margin-bottom: 0.4rem;
        display: block;
    }

    .ce-input, .ce-select, .ce-textarea {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1px solid var(--ce-border);
        border-radius: var(--ce-radius-md);
        font-size: 0.95rem;
        color: var(--ce-text-main);
        background-color: #f8fafc;
        transition: all 0.2s ease;
    }

    .ce-textarea {
        min-height: 120px;
        resize: vertical;
    }

    .ce-input:focus, .ce-select:focus, .ce-textarea:focus {
        background-color: #fff;
        border-color: var(--ce-primary);
        box-shadow: var(--ce-focus-ring);
        outline: none;
    }

    .ce-hint {
        color: var(--ce-text-muted);
        font-size: 0.8rem;
        margin-top: 0.4rem;
        display: block;
        line-height: 1.4;
    }

    .ce-error {
        color: #ef4444;
        font-size: 0.8rem;
        font-weight: 600;
        margin-top: 0.4rem;
        display: block;
    }

    /* Buttons */
    .ce-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0.75rem 1.5rem;
        border-radius: var(--ce-radius-md);
        font-size: 0.95rem;
        font-weight: 600;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        border: none;
        cursor: pointer;
    }

    .ce-btn-primary {
        background: linear-gradient(135deg, var(--ce-primary) 0%, #6366f1 100%);
        color: #fff;
        box-shadow: 0 4px 12px rgba(79, 70, 229, 0.25);
    }
    .ce-btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(79, 70, 229, 0.35);
        color: #fff;
    }

    .ce-btn-secondary {
        background: #f1f5f9;
        color: var(--ce-text-main);
        border: 1px solid var(--ce-border);
    }
    .ce-btn-secondary:hover {
        background: #e2e8f0;
        color: var(--ce-text-main);
    }

    .ce-btn-danger {
        background: #fee2e2;
        color: #ef4444;
    }
    .ce-btn-danger:hover {
        background: #fecaca;
        color: #dc2626;
    }

    /* Nested Items (Agendas / Docs) */
    .ce-nested-item {
        background: #f8fafc;
        border: 1px solid var(--ce-border);
        border-radius: var(--ce-radius-lg);
        padding: 1.5rem;
        margin-bottom: 1.25rem;
        position: relative;
        transition: all 0.2s;
    }
    .ce-nested-item:hover {
        border-color: #cbd5e1;
        box-shadow: var(--ce-shadow-sm);
        background: #fff;
    }

    .ce-nested-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.25rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px dashed #cbd5e1;
    }

    .ce-nested-title {
        font-weight: 800;
        color: var(--ce-text-main);
        font-size: 1.05rem;
        margin: 0;
    }

    /* Sidebar Panels */
    .ce-sidebar {
        position: sticky;
        top: 24px;
        align-self: start;
        max-height: calc(100vh - 48px);
        overflow-y: auto;
        padding-right: 4px;
    }
    .ce-sidebar::-webkit-scrollbar {
        width: 6px;
    }
    .ce-sidebar::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 4px;
    }

    .ce-side-panel {
        background: #fff;
        border-radius: var(--ce-radius-lg);
        box-shadow: var(--ce-shadow-md);
        border: 1px solid rgba(255, 255, 255, 0.8);
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .ce-side-panel h4 {
        margin: 0 0 1rem;
        font-size: 1.05rem;
        font-weight: 800;
        color: var(--ce-text-main);
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .ce-side-panel h4 i {
        color: var(--ce-primary);
        font-size: 1.1rem;
    }

    .ce-side-search {
        width: 100%;
        margin-bottom: 1.25rem;
        padding: 0.65rem 1rem 0.65rem 1rem;
        border: 1px solid var(--ce-border);
        border-radius: var(--ce-radius-md);
        font-size: 0.85rem;
        background: #f8fafc;
        transition: all 0.2s;
    }
    .ce-side-search:focus {
        background-color: #fff;
        border-color: var(--ce-primary);
        box-shadow: var(--ce-focus-ring);
        outline: none;
    }

    .ce-side-list {
        list-style: none;
        margin: 0;
        padding: 0;
        max-height: 320px;
        overflow-y: auto;
    }
    .ce-side-list::-webkit-scrollbar { width: 4px; }
    .ce-side-list::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 4px; }

    .ce-side-list li {
        padding: 0.75rem 1rem;
        margin-bottom: 0.5rem;
        font-size: 0.85rem;
        color: var(--ce-text-main);
        background: #f8fafc;
        border: 1px solid transparent;
        font-weight: 500;
        border-radius: 10px;
        transition: all 0.2s;
        cursor: default;
    }
    .ce-side-list li:hover {
        background: #fff;
        border-color: var(--ce-primary);
        box-shadow: 0 2px 8px rgba(79, 70, 229, 0.1);
        color: var(--ce-primary);
        transform: translateX(3px);
    }

    .ce-side-empty {
        font-size: 0.85rem;
        color: var(--ce-text-muted);
        text-align: center;
        padding: 1.5rem 0;
        display: none;
    }

    /* Grid utilities */
    .ce-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }
    .ce-col {
        min-width: 0;
    }

    /* Checkbox */
    .ce-checkbox-wrapper {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.85rem 1.25rem;
        background: #f8fafc;
        border: 1px solid var(--ce-border);
        border-radius: var(--ce-radius-md);
        margin-bottom: 1.5rem;
        cursor: pointer;
        transition: all 0.2s;
    }
    .ce-checkbox-wrapper:hover {
        border-color: var(--ce-primary);
        background: #e0e7ff;
    }
    .ce-checkbox-wrapper input[type="checkbox"] {
        width: 1.25rem;
        height: 1.25rem;
        accent-color: var(--ce-primary);
        cursor: pointer;
        margin: 0;
    }
    .ce-checkbox-wrapper label {
        margin: 0;
        font-weight: 700;
        color: var(--ce-text-main);
        cursor: pointer;
    }

    /* Select2 UI Fixes */
    .select2-container--default .select2-selection--single {
        border-radius: var(--ce-radius-md) !important;
        height: 46px !important;
        border: 1px solid var(--ce-border) !important;
        padding: 8px 16px !important;
        background-color: #f8fafc !important;
        display: flex !important;
        align-items: center !important;
        transition: all 0.2s;
    }
    .select2-container--default.select2-container--focus .select2-selection--single,
    .select2-container--default.select2-container--open .select2-selection--single {
        background-color: #fff !important;
        border-color: var(--ce-primary) !important;
        box-shadow: var(--ce-focus-ring) !important;
    }
    .select2-container .select2-selection--single .select2-selection__rendered {
        line-height: normal !important;
        padding-left: 0 !important;
        color: var(--ce-text-main) !important;
        font-size: 0.95rem;
    }
    .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 44px !important;
        right: 12px !important;
    }
    .select2-dropdown {
        border: 1px solid var(--ce-border) !important;
        border-radius: var(--ce-radius-md) !important;
        box-shadow: var(--ce-shadow-md) !important;
        overflow: hidden !important;
    }
</style>

<div class="create-wrapper">
    <div class="ce-card">
        <h1 class="ce-page-title">Create New Event</h1>
        <p class="ce-page-subtitle">Fill in the details below to set up a new event, assign speakers, and configure capabilities.</p>

        <form asp-controller="Organizer" asp-action="Create" method="post" id="createEventForm" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(excludePropertyErrors: false, message: "", htmlAttributes: new { @class = "alert alert-danger ce-error p-3 rounded-3" })

            <h3 class="ce-section-title"><i class="bi bi-info-circle"></i> Basic Information</h3>
            
            <div class="ce-row flex-column gap-3 mb-0">
                <div class="ce-col mb-3">
                    <label asp-for="Title" class="ce-label">Event Title <span class="text-danger">*</span></label>
                    <input asp-for="Title" class="ce-input" placeholder="Enter a catchy title for your event..." />
                    <span asp-validation-for="Title" class="ce-error"></span>
                </div>

                <div class="ce-col mb-3">
                    <label asp-for="Description" class="ce-label">Description</label>
                    <textarea asp-for="Description" class="ce-textarea" placeholder="Provide a detailed description of the event..."></textarea>
                </div>
            </div>

            <h3 class="ce-section-title"><i class="bi bi-diagram-3"></i> Category & Department</h3>

            <div class="ce-row">
                <div class="ce-col">
                    <label asp-for="SemesterId" class="ce-label">Semester <span class="text-danger">*</span></label>
                    <select asp-for="SemesterId" asp-items="Model.Semesters" class="ce-select">
                        <option value="">-- Select Semester --</option>
                    </select>
                    <span asp-validation-for="SemesterId" class="ce-error"></span>
                </div>

                <div class="ce-col">
                    <label asp-for="DepartmentId" class="ce-label">Department</label>
                    <select asp-for="DepartmentId" asp-items="Model.Departments" class="ce-select">
                        <option value="">-- Select Department --</option>
                    </select>
                </div>
            </div>

            <div class="ce-row">
                <div class="ce-col">
                    <label asp-for="TopicId" class="ce-label">Event Topic</label>
                    <select asp-for="TopicId" asp-items="Model.Topics" class="ce-select" id="TopicId">
                        <option value="">-- Select Topic --</option>
                    </select>
                </div>
            </div>

            <h3 class="ce-section-title"><i class="bi bi-clock"></i> Location & Time</h3>

            <div class="ce-row">
                <div class="ce-col">
                    <label asp-for="LocationId" class="ce-label">Venue / Location <span class="text-danger">*</span></label>
                    <input type="hidden" asp-for="LocationId" id="LocationId" />
                    <div class="position-relative">
                        <input type="text" id="locationSearchInput" class="ce-input" placeholder="Search for existing locations... (e.g. Room, Hall)" autocomplete="off" value="@(Model.Locations?.FirstOrDefault(l => l.Value == Model.LocationId)?.Text)" />
                        <div id="locationSearchResults" class="position-absolute w-100 bg-white border border-gray-200 rounded-bottom shadow-lg z-3" style="display:none; max-height: 250px; overflow-y: auto;"></div>
                    </div>
                    <span asp-validation-for="LocationId" class="ce-error"></span>
                </div>
            </div>

            <div class="ce-row">
                <div class="ce-col">
                    <label asp-for="StartTime" class="ce-label">Start Time <span class="text-danger">*</span></label>
                    <input asp-for="StartTime" type="datetime-local" class="ce-input" />
                    <span asp-validation-for="StartTime" class="ce-error"></span>
                </div>
                <div class="ce-col">
                    <label asp-for="EndTime" class="ce-label">End Time <span class="text-danger">*</span></label>
                    <input asp-for="EndTime" type="datetime-local" class="ce-input" />
                    <span asp-validation-for="EndTime" class="ce-error"></span>
                </div>
            </div>

            <h3 class="ce-section-title"><i class="bi bi-gear"></i> Settings & Capacity</h3>

            <div class="ce-row">
                <div class="ce-col">
                    <label asp-for="Type" class="ce-label">Event Type</label>
                    <select asp-for="Type" asp-items="Html.GetEnumSelectList<EventTypeEnum>()" class="ce-select"></select>
                </div>
                <div class="ce-col">
                    <label asp-for="Status" class="ce-label">Initial Status</label>
                    <select asp-for="Status" class="ce-select"
                            asp-items="@(new SelectList(
                                        new[]
                                        {
                                            new { Value = (int)EventStatusEnum.Draft, Text = "Draft" },
                                            new { Value = (int)EventStatusEnum.Pending, Text = "Pending Approval" }
                                        },
                                        "Value",
                                        "Text"
                                    ))">
                    </select>
                </div>
                <div class="ce-col">
                    <label asp-for="Mode" class="ce-label">Event Format</label>
                    <select asp-for="Mode" asp-items="Html.GetEnumSelectList<DataAccess.Enum.EventModeEnum>()" class="ce-select"></select>
                </div>
            </div>

            <div class="ce-row" id="meetingRow" style="display:none;">
                <div class="ce-col">
                    <label asp-for="MeetingUrl" class="ce-label">Online Meeting URL</label>
                    <input asp-for="MeetingUrl" class="ce-input" placeholder="https://zoom.us/j/..." />
                    <span asp-validation-for="MeetingUrl" class="ce-error"></span>
                </div>
            </div>

            <div class="ce-row">
                <div class="ce-col">
                    <label asp-for="MaxCapacity" class="ce-label">Maximum Capacity <span class="text-danger">*</span></label>
                    <input asp-for="MaxCapacity" type="number" min="1" class="ce-input" />
                    <span class="ce-hint" id="locationCapacityHint">Must be less than or equal to venue's maximum capacity.</span>
                    <span asp-validation-for="MaxCapacity" class="ce-error"></span>
                </div>
                <div class="ce-col">
                    <label class="ce-label">Event Images (Slideshow)</label>
                    <input asp-for="BannerFiles" type="file" accept="image/*" multiple class="ce-input bg-white" />
                    <span class="ce-hint">Upload multiple images. The first image will be your main thumbnail.</span>
                    
                    <div class="mt-3">
                        <label class="ce-label">Or Provide External Image URLs</label>
                        <input asp-for="ThumbnailUrl" class="ce-input" placeholder="https://img.com/1.jpg | https://img.com/2.jpg" />
                        <span class="ce-hint">Separate multiple URLs with a pipe (|).</span>
                    </div>
                </div>
            </div>

            <div class="ce-checkbox-wrapper mt-3">
                <input asp-for="IsDepositRequired" id="IsDepositRequired" />
                <label for="IsDepositRequired">Require Deposit / Participation Fee</label>
            </div>

            <div class="ce-row mb-0" id="depositRow">
                <div class="ce-col">
                    <label asp-for="DepositAmount" class="ce-label">Deposit Amount (Currency)</label>
                    <input asp-for="DepositAmount" type="number" min="0" step="0.01" class="ce-input" />
                    <span asp-validation-for="DepositAmount" class="ce-error"></span>
                </div>
            </div>

            <h3 class="ce-section-title mt-5 d-flex justify-content-between align-items-center border-0 mb-0">
                <div><i class="bi bi-file-earmark-text"></i> Event Documents</div>
                <button type="button" class="ce-btn ce-btn-secondary btn-sm shadow-sm" style="border-radius: 20px; font-size: 0.8rem; padding: 0.3rem 0.8rem;" id="btnAddDocument">
                    <i class="bi bi-plus-lg"></i> Add
                </button>
            </h3>

            <div id="documentsContainer" class="mt-4">
                @for (int i = 0; i < (Model.Documents?.Count ?? 0); i++)
                {
                    <div class="ce-nested-item agenda-item" data-index="@i">
                        <div class="ce-nested-header">
                            <h4 class="ce-nested-title">Document #@(i + 1)</h4>
                            <button type="button" class="ce-btn ce-btn-danger btn-sm py-1 px-3 btnRemoveDocument" style="border-radius:20px; font-size:0.75rem;">Remove</button>
                        </div>
                        <div class="ce-row">
                            <div class="ce-col">
                                <label class="ce-label">File Name (Optional)</label>
                                <input name="Documents[@i].FileName" value="@Model.Documents[i].FileName" class="ce-input" />
                            </div>
                            <div class="ce-col">
                                <label class="ce-label">Upload File</label>
                                <input name="Documents[@i].File" type="file" class="ce-input bg-white" />
                            </div>
                        </div>
                        <div class="ce-row mb-0">
                            <div class="ce-col">
                                <label class="ce-label">Or Provide Download URL</label>
                                <input name="Documents[@i].Url" value="@Model.Documents[i].Url" class="ce-input" />
                            </div>
                        </div>
                    </div>
                }
            </div>

            <h3 class="ce-section-title mt-5 d-flex justify-content-between align-items-center border-0 mb-0">
                <div class="d-flex align-items-center flex-wrap gap-2"><i class="bi bi-view-list"></i> Event Agendas</div>
                <div class="d-flex gap-2 flex-wrap">
                    <button type="button" class="ce-btn ce-btn-secondary btn-sm shadow-sm" style="border-radius: 20px; font-size: 0.8rem; padding: 0.3rem 0.8rem;" id="btnSuggestAgenda">
                        <i class="bi bi-lightbulb-fill text-warning"></i> Suggest
                    </button>
                    <button type="button" class="ce-btn ce-btn-secondary btn-sm shadow-sm" style="border-radius: 20px; font-size: 0.8rem; padding: 0.3rem 0.8rem;" id="btnAddAgenda">
                        <i class="bi bi-plus-lg"></i> Add
                    </button>
                </div>
            </h3>
            <span class="ce-hint mb-4" id="agendaSuggestionHint">Select Event Type and click "Suggest" to load a default template.</span>

            <div id="agendaContainer">
                @for (int i = 0; i < (Model.Agendas?.Count ?? 0); i++)
                {
                    <div class="ce-nested-item agenda-item" data-index="@i">
                        <div class="ce-nested-header">
                            <h4 class="ce-nested-title">Agenda Session #@(i + 1)</h4>
                            <button type="button" class="ce-btn ce-btn-danger btn-sm py-1 px-3 btnRemoveAgenda" style="border-radius:20px; font-size:0.75rem;">Remove</button>
                        </div>

                        <div class="ce-row">
                            <div class="ce-col">
                                <label class="ce-label">Session Name <span class="text-danger">*</span></label>
                                <input name="Agendas[@i].SessionName" value="@Model.Agendas[i].SessionName" required class="ce-input" />
                                <span asp-validation-for="Agendas[i].SessionName" class="ce-error"></span>
                            </div>
                            <div class="ce-col">
                                <label class="ce-label">Speaker / Host <span class="text-danger">*</span></label>
                                <input name="Agendas[@i].SpeakerInfo" value="@Model.Agendas[i].SpeakerInfo" required class="ce-input" />
                                <span asp-validation-for="Agendas[i].SpeakerInfo" class="ce-error"></span>
                            </div>
                        </div>

                        <div class="ce-row">
                            <div class="ce-col">
                                <label class="ce-label">Session Description</label>
                                <textarea name="Agendas[@i].Description" class="ce-textarea" style="min-height:80px;">@Model.Agendas[i].Description</textarea>
                            </div>
                        </div>

                        <div class="ce-row">
                            <div class="ce-col">
                                <label class="ce-label">Start Time</label>
                                <input name="Agendas[@i].StartTime" value="@(Model.Agendas[i].StartTime?.ToString("yyyy-MM-ddTHH:mm"))" type="datetime-local" class="ce-input" />
                            </div>
                            <div class="ce-col">
                                <label class="ce-label">End Time</label>
                                <input name="Agendas[@i].EndTime" value="@(Model.Agendas[i].EndTime?.ToString("yyyy-MM-ddTHH:mm"))" type="datetime-local" class="ce-input" />
                            </div>
                        </div>

                        <div class="ce-row mb-0">
                            <div class="ce-col">
                                <label class="ce-label">Session Location</label>
                                <input type="hidden" name="Agendas[@i].Location" value="@Model.Agendas[i].Location" class="agenda-location-hidden" />
                                <div class="position-relative">
                                    <input type="text" class="ce-input agenda-location-search-input" placeholder="Leave blank if it's the same as main event..." autocomplete="off" value="@Model.Agendas[i].Location" />
                                    <div class="agenda-location-search-results position-absolute w-100 bg-white border border-gray-200 rounded-bottom shadow-lg z-3" style="display:none; max-height: 200px; overflow-y: auto;"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="d-flex gap-3 justify-content-end mt-5 pt-4 border-top">
                <button type="reset" class="ce-btn ce-btn-secondary px-4 py-2" style="border-radius:12px;">Cancel & Reset</button>
                <button type="submit" class="ce-btn ce-btn-primary px-5 py-2 shadow-lg" style="border-radius:12px;">
                    <i class="bi bi-check2-circle fs-5"></i> Publish Event
                </button>
            </div>
        </form>
    </div>

    <!-- Right Sidebar Content -->
    <aside class="ce-sidebar">
        <div class="ce-side-panel">
            <h4><i class="bi bi-tags-fill"></i> Available Topics</h4>
            <input type="text" class="ce-side-search" data-target="topicList" placeholder="Filter topics..." autocomplete="off" />
            <ul class="ce-side-list" id="topicList">
                @if (Model.Topics != null && Model.Topics.Any(x => !string.IsNullOrWhiteSpace(x.Value)))
                {
                    foreach (var topic in Model.Topics.Where(x => !string.IsNullOrWhiteSpace(x.Value)))
                    {
                        <li>@topic.Text</li>
                    }
                }
                else
                {
                    <li>No topics available.</li>
                }
            </ul>
            <div class="ce-side-empty" data-empty-for="topicList">No topics matched your search.</div>
        </div>

        <div class="ce-side-panel">
            <h4><i class="bi bi-geo-alt-fill"></i> Available Locations</h4>
            <input type="text" class="ce-side-search" data-target="locationList" placeholder="Filter locations..." autocomplete="off" />
            <ul class="ce-side-list" id="locationList">
                @if (Model.Locations != null && Model.Locations.Any(x => !string.IsNullOrWhiteSpace(x.Value)))
                {
                    foreach (var location in Model.Locations.Where(x => !string.IsNullOrWhiteSpace(x.Value)))
                    {
                        <li><i class="bi bi-building text-muted me-2"></i>@location.Text</li>
                    }
                }
                else
                {
                    <li>No locations available.</li>
                }
            </ul>
            <div class="ce-side-empty" data-empty-for="locationList">No locations matched your search.</div>
        </div>
    </aside>
</div>

<!-- JS Templates -->
<template id="agendaTemplate">
    <div class="ce-nested-item agenda-item" data-index="__i__">
        <div class="ce-nested-header">
            <h4 class="ce-nested-title">Agenda Session #__n__</h4>
            <button type="button" class="ce-btn ce-btn-danger btn-sm py-1 px-3 btnRemoveAgenda" style="border-radius:20px; font-size:0.75rem;">Remove</button>
        </div>

        <div class="ce-row">
            <div class="ce-col">
                <label class="ce-label">Session Name <span class="text-danger">*</span></label>
                <input name="Agendas[__i__].SessionName" required class="ce-input" />
            </div>
            <div class="ce-col">
                <label class="ce-label">Speaker / Host <span class="text-danger">*</span></label>
                <input name="Agendas[__i__].SpeakerInfo" required class="ce-input" />
            </div>
        </div>

        <div class="ce-row">
            <div class="ce-col">
                <label class="ce-label">Session Description</label>
                <textarea name="Agendas[__i__].Description" class="ce-textarea" style="min-height:80px;"></textarea>
            </div>
        </div>

        <div class="ce-row">
            <div class="ce-col">
                <label class="ce-label">Start Time</label>
                <input name="Agendas[__i__].StartTime" type="datetime-local" class="ce-input" />
            </div>
            <div class="ce-col">
                <label class="ce-label">End Time</label>
                <input name="Agendas[__i__].EndTime" type="datetime-local" class="ce-input" />
            </div>
        </div>

        <div class="ce-row mb-0">
            <div class="ce-col">
                <label class="ce-label">Session Location</label>
                <input type="hidden" name="Agendas[__i__].Location" class="agenda-location-hidden" />
                <div class="position-relative">
                    <input type="text" class="ce-input agenda-location-search-input" placeholder="Leave blank if it's the same as main event..." autocomplete="off" />
                    <div class="agenda-location-search-results position-absolute w-100 bg-white border border-gray-200 rounded-bottom shadow-lg z-3" style="display:none; max-height: 200px; overflow-y: auto;"></div>
                </div>
            </div>
        </div>
    </div>
</template>

<template id="documentTemplate">
    <div class="ce-nested-item agenda-item" data-index="__i__">
        <div class="ce-nested-header">
            <h4 class="ce-nested-title">Document #__n__</h4>
            <button type="button" class="ce-btn ce-btn-danger btn-sm py-1 px-3 btnRemoveDocument" style="border-radius:20px; font-size:0.75rem;">Remove</button>
        </div>

        <div class="ce-row">
            <div class="ce-col">
                <label class="ce-label">File Name (Optional)</label>
                <input name="Documents[__i__].FileName" class="ce-input" />
            </div>
            <div class="ce-col">
                <label class="ce-label">Upload File</label>
                <input name="Documents[__i__].File" type="file" class="ce-input bg-white" />
            </div>
        </div>

        <div class="ce-row mb-0">
            <div class="ce-col">
                <label class="ce-label">Or Provide Download URL</label>
                <input name="Documents[__i__].Url" class="ce-input" />
            </div>
        </div>
    </div>
</template>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Setup autocomplete for main location
            function setupLocationAutocomplete(inputId, resultsId, hiddenId, isMain = true) {
                const input = document.getElementById(inputId);
                const results = document.getElementById(resultsId);
                const hidden = document.getElementById(hiddenId);
                let timer;

                if (input && results) {
                    input.addEventListener('input', function() {
                        clearTimeout(timer);
                        const query = this.value;
                        if (query.length < 1) {
                            results.style.display = 'none';
                            if (query.length === 0) hidden.value = '';
                            return;
                        }

                        timer = setTimeout(() => {
                            fetch(`/api/v1/lookup/locations?q=${encodeURIComponent(query)}`)
                                .then(res => res.json())
                                .then(resp => {
                                    if (!resp.success || !resp.data || resp.data.length === 0) {
                                        results.innerHTML = '<div class="p-2 text-muted small">Không tìm thấy địa điểm</div>';
                                        results.style.display = 'block';
                                        return;
                                    }
                                    
                                    results.innerHTML = resp.data.map(loc => `
                                        <div class="p-2 border-bottom loc-search-item text-dark" style="cursor:pointer;" 
                                             data-id="${loc.id}" data-name="${loc.name}" data-address="${loc.address || ''}">
                                            <div class="fw-semibold small">${loc.name}</div>
                                            <div class="text-muted" style="font-size:0.75rem;">
                                                ${loc.address ? loc.address + ' - ' : ''}Sức chứa: ${loc.capacity}
                                            </div>
                                        </div>
                                    `).join('');
                                    results.style.display = 'block';
                                    
                                    const items = results.querySelectorAll('.loc-search-item');
                                    items.forEach(item => {
                                        item.addEventListener('click', function() {
                                            const locId = this.getAttribute('data-id');
                                            const locName = this.getAttribute('data-name');
                                            const locAddr = this.getAttribute('data-address');
                                            input.value = locAddr ? locAddr : locName;
                                            hidden.value = isMain ? locId : locName;
                                            results.style.display = 'none';
                                        });
                                    });
                                });
                        }, 300);
                    });

                    document.addEventListener('click', function(e) {
                        if(e.target !== input && !results.contains(e.target)) {
                            results.style.display = 'none';
                        }
                    });
                }
            }

            setupLocationAutocomplete('locationSearchInput', 'locationSearchResults', 'LocationId', true);

            // Setup autocomplete for dynamic agendas
            document.addEventListener('input', function(e) {
                if (e.target.classList.contains('agenda-location-search-input')) {
                    const input = e.target;
                    const container = input.closest('.ce-col') || input.closest('.col');
                    const results = container.querySelector('.agenda-location-search-results');
                    const hidden = container.querySelector('.agenda-location-hidden');
                    
                    clearTimeout(input.dataset.timer);
                    
                    const query = input.value;
                    if (query.length < 1) {
                        results.style.display = 'none';
                        if (query.length === 0) hidden.value = '';
                        return;
                    }

                    input.dataset.timer = setTimeout(() => {
                        fetch(`/api/v1/lookup/locations?q=${encodeURIComponent(query)}`)
                            .then(res => res.json())
                            .then(resp => {
                                if (!resp.success || !resp.data || resp.data.length === 0) {
                                    results.innerHTML = '<div class="p-2 text-muted small">Không tìm thấy địa điểm</div>';
                                    results.style.display = 'block';
                                    return;
                                }
                                
                                results.innerHTML = resp.data.map(loc => `
                                    <div class="p-2 border-bottom loc-search-item text-dark" style="cursor:pointer;" 
                                         data-name="${loc.name}" data-address="${loc.address || ''}">
                                        <div class="fw-semibold small">${loc.name}</div>
                                        <div class="text-muted" style="font-size:0.75rem;">
                                            ${loc.address ? loc.address + ' - ' : ''}Sức chứa: ${loc.capacity}
                                        </div>
                                    </div>
                                `).join('');
                                results.style.display = 'block';
                                
                                const items = results.querySelectorAll('.loc-search-item');
                                items.forEach(item => {
                                    item.addEventListener('click', function() {
                                        const locName = this.getAttribute('data-name');
                                        const locAddr = this.getAttribute('data-address');
                                        input.value = locAddr ? locAddr : locName;
                                        hidden.value = locName;
                                        results.style.display = 'none';
                                    });
                                });
                            });
                    }, 300);
                }
            });

            document.addEventListener('click', function(e) {
                if (!e.target.classList.contains('agenda-location-search-input') && !e.target.closest('.agenda-location-search-results')) {
                    document.querySelectorAll('.agenda-location-search-results').forEach(el => el.style.display = 'none');
                }
            });

            // Initialize Select2 for Topic
            $('#TopicId').select2({
                placeholder: "-- Select Topic --",
                allowClear: true,
                ajax: {
                    url: '/api/v1/lookup/topics',
                    dataType: 'json',
                    delay: 250,
                    data: function (params) {
                        return { q: params.term };
                    },
                    processResults: function (data) {
                        return {
                            results: data.data.map(item => ({
                                id: item.id,
                                text: item.name
                            }))
                        };
                    },
                    cache: true
                }
            });

            // Re-apply Select2 to newly added agenda locations if needed
            // Currently agenda locations are simple text-based or pre-loaded. 
            // If they need to be searchable too, we can initialize them here.

            // Filter for right-side topic/location lists
            document.querySelectorAll('.ce-side-search').forEach(input => {
                input.addEventListener('input', function () {
                    const targetId = this.getAttribute('data-target');
                    const list = document.getElementById(targetId);
                    if (!list) return;

                    const keyword = (this.value || '').trim().toLowerCase();
                    const items = list.querySelectorAll('li');
                    let visibleCount = 0;

                    items.forEach(li => {
                        const text = (li.textContent || '').trim().toLowerCase();
                        const match = !keyword || text.includes(keyword);
                        li.style.display = match ? '' : 'none';
                        if (match) visibleCount++;
                    });

                    const empty = document.querySelector(`.ce-side-empty[data-empty-for='${targetId}']`);
                    if (empty) {
                        empty.style.display = visibleCount === 0 ? 'block' : 'none';
                    }
                });
            });
        });

        (function () {
            const agendaContainer = document.getElementById("agendaContainer");
            const tpl = document.getElementById("agendaTemplate");
            const btnAdd = document.getElementById("btnAddAgenda");
            const btnSuggestAgenda = document.getElementById("btnSuggestAgenda");
            const agendaSuggestionHint = document.getElementById("agendaSuggestionHint");

            const isDeposit = document.getElementById("IsDepositRequired");
            const depositRow = document.getElementById("depositRow");

            function updateDepositUI() {
                depositRow.style.display = isDeposit.checked ? "grid" : "none";
                if (!isDeposit.checked) {
                    const depInput = document.querySelector("input[name='DepositAmount']");
                    if (depInput) depInput.value = 0;
                }
            }
            updateDepositUI();
            isDeposit.addEventListener("change", updateDepositUI);

            // Show/Hide meeting url when Mode is Online/Hybrid
            const modeSelect = document.querySelector("select[name='Mode']");
            const meetingRow = document.getElementById("meetingRow");
            const agendaSuggestionsByType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AgendaSuggestionsByType));

            function updateMeetingUI() {
                const val = modeSelect ? modeSelect.value : '';

                // EventModeEnum: Offline=0, Online=1, Hybrid=2
                if (val === '1' || val === '2') {
                    meetingRow.style.display = 'grid';
                } else {
                    meetingRow.style.display = 'none';
                    const m = document.querySelector("input[name='MeetingUrl']");
                    if (m) m.value = '';
                }
            }
            if (modeSelect) {
                modeSelect.addEventListener('change', updateMeetingUI);
                updateMeetingUI();
            }

            function getNextIndex() {
                return agendaContainer.querySelectorAll(".agenda-item").length;
            }

            function renumber() {
                const items = agendaContainer.querySelectorAll(".agenda-item");
                items.forEach((item, i) => {
                    item.dataset.index = i;
                    const title = item.querySelector(".ce-nested-title");
                    if (title) title.textContent = `Agenda Session #${i + 1}`;
                    item.querySelectorAll("input[name], textarea[name], select[name]").forEach(el => {
                        el.name = el.name.replace(/Agendas\[\d+\]/, `Agendas[${i}]`);
                    });
                });
            }

            function hasAgendaContent() {
                return [...agendaContainer.querySelectorAll('.agenda-item')].some(item =>
                    [...item.querySelectorAll('input[type="text"], input[type="datetime-local"], textarea, input[type="hidden"]')]
                        .some(input => input.value?.trim()));
            }

            function addAgenda(agendaData) {
                const i = getNextIndex();
                const html = tpl.innerHTML.replaceAll("__i__", i).replaceAll("__n__", i + 1);
                const wrapper = document.createElement("div");
                wrapper.innerHTML = html.trim();
                const agendaItem = wrapper.firstElementChild;
                agendaContainer.appendChild(agendaItem);

                if (agendaData) {
                    const sessionNameInput = agendaItem.querySelector("input[name$='.SessionName']");
                    const speakerNameInput = agendaItem.querySelector("input[name$='.SpeakerInfo']");
                    const descriptionInput = agendaItem.querySelector("textarea[name$='.Description']");

                    if (sessionNameInput) sessionNameInput.value = agendaData.sessionName ?? '';
                    if (speakerNameInput) speakerNameInput.value = agendaData.speakerName ?? '';
                    if (descriptionInput) descriptionInput.value = agendaData.description ?? '';
                }
                return [...agendaContainer.querySelectorAll('.agenda-item')].some(item =>
                    [...item.querySelectorAll('input[type="text"], input[type="datetime-local"], textarea, input[type="hidden"]')]
                        .some(input => input.value?.trim()));
            }

            function updateAgendaSuggestionHint() {
                const typeSelect = document.querySelector("select[name='Type']");
                const suggestions = agendaSuggestionsByType?.[typeSelect?.value] || [];

                if (!agendaSuggestionHint) return;

                agendaSuggestionHint.textContent = suggestions.length > 0
                    ? `Agenda gợi ý: ${suggestions.join(', ')}.`
                    : 'Chọn Event Type, sau đó bấm Suggest để áp dụng agenda mẫu phù hợp.';
            }

            function applySuggestedAgendas() {
                const typeSelect = document.querySelector("select[name='Type']");
                const suggestions = agendaSuggestionsByType?.[typeSelect?.value] || [];

                if (suggestions.length === 0) {
                    if (agendaSuggestionHint) {
                        agendaSuggestionHint.textContent = 'Chưa có agenda mẫu cho Event Type hiện tại.';
                    }
                    return;
                }

                if (hasAgendaContent() && !window.confirm('Agenda hiện tại sẽ được thay bằng agenda mẫu theo loại sự kiện. Tiếp tục?')) {
                    return;
                }

                agendaContainer.innerHTML = '';
                suggestions.forEach(sessionName => addAgenda({ sessionName }));
                renumber();
                updateAgendaSuggestionHint();
            }

            function removeAgenda(btn) {
                const item = btn.closest(".agenda-item");
                if (item) item.remove();
                renumber();
            }

            btnAdd.addEventListener("click", () => addAgenda());
            btnSuggestAgenda?.addEventListener("click", applySuggestedAgendas);
            agendaContainer.addEventListener("click", function (e) {
                const btn = e.target.closest(".btnRemoveAgenda");
                if (btn) removeAgenda(btn);
            });

            if (typeof existingAgendaItems !== 'undefined' && existingAgendaItems.length === 0) {
                addAgenda();
            } 
            const typeSelect = document.querySelector("select[name='Type']");
            typeSelect?.addEventListener('change', updateAgendaSuggestionHint);
            updateAgendaSuggestionHint();
            
            // Documents UI
            const docsContainer = document.getElementById("documentsContainer");
            const btnAddDoc = document.getElementById("btnAddDocument");
            const docTpl = document.getElementById("documentTemplate");

            function getNextDocIndex() { return docsContainer.querySelectorAll('.agenda-item').length; }
            function renumberDocs() {
                const items = docsContainer.querySelectorAll('.agenda-item');
                items.forEach((item, i) => {
                    item.dataset.index = i;
                    const title = item.querySelector('.ce-nested-title');
                    if (title) title.textContent = `Document #${i + 1}`;
                    item.querySelectorAll("input[name]").forEach(el => {
                        el.name = el.name.replace(/Documents\[\d+\]/, `Documents[${i}]`);
                    });
                });
            }

            function addDocument() {
                const i = getNextDocIndex();
                const html = docTpl.innerHTML.replaceAll('__i__', i).replaceAll('__n__', i+1);
                const wrapper = document.createElement('div');
                wrapper.innerHTML = html.trim();
                docsContainer.appendChild(wrapper.firstElementChild);
            }

            function removeDocument(btn) {
                const item = btn.closest('.agenda-item');
                if (item) item.remove();
                renumberDocs();
            }

            btnAddDoc.addEventListener('click', addDocument);
            docsContainer.addEventListener('click', function(e) {
                const btn = e.target.closest('.btnRemoveDocument');
                if (btn) removeDocument(btn);
            });

            if (docsContainer.querySelectorAll('.agenda-item').length === 0) {
                // don't auto-add doc by default
            }
        })();
    </script>
    <partial name="_ValidationScriptsPartial" /> 
}
