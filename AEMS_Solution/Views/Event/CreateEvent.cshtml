@model AEMS_Solution.Models.Event.CreateEventViewModel
@using DataAccess.Enum
@{
    ViewData["Title"] = "Create Event";
    Layout = "_OrganizerLayout";
}
<style>
        .create-layout {
            display: grid;
            grid-template-columns: minmax(0, 1fr) 320px;
            gap: 18px;
            align-items: start;
        }

        .create-sidebar {
            position: sticky;
            top: 14px;
            align-self: start;
            max-height: calc(100vh - 28px);
            overflow-y: auto;
            padding-right: 2px;
        }

        .card {
            max-width: 100%;
            margin: 0;
            border: 1px solid #ddd;
            border-radius: 12px;
            padding: 18px;
        }

        .side-panel {
            border: 1px solid #ddd;
            border-radius: 12px;
            background: #fff;
            padding: 14px;
            margin-bottom: 12px;
        }

        .side-panel h4 {
            margin: 0 0 10px;
            font-size: 16px;
            font-weight: 700;
        }

        .side-search {
            width: 100%;
            margin-bottom: 10px;
            padding: 8px 10px;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            font-size: 13px;
        }

        .side-empty {
            font-size: 12px;
            color: #64748b;
            margin-top: 6px;
            display: none;
        }

        .side-list {
            list-style: none;
            margin: 0;
            padding: 0;
            max-height: 280px;
            overflow: auto;
        }

        .side-list li {
            border: 1px solid #eef2f7;
            border-radius: 8px;
            padding: 8px 10px;
            margin-bottom: 8px;
            font-size: 13px;
            color: #334155;
            background: #fafafa;
        }

        @@media (max-width: 1100px) {
            .create-layout {
                grid-template-columns: 1fr;
            }

            .create-sidebar {
                position: static;
                max-height: none;
                overflow: visible;
            }
        }

        .row {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .col {
            flex: 1;
            min-width: 240px;
        }

        label {
            display: block;
            font-weight: 600;
            margin: 10px 0 6px;
        }

        input, select, textarea {
            width: 100%;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 10px;
        }

        textarea {
            min-height: 90px;
            resize: vertical;
        }

        .hint {
            color: #666;
            font-size: 12px;
            margin-top: 4px;
        }

        .error {
            color: #b00020;
            font-size: 13px;
            margin-top: 6px;
        }

        .divider {
            height: 1px;
            background: #eee;
            margin: 18px 0;
        }

        .section-box {
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 16px;
            margin: 18px 0;
            background: #fafafa;
        }

        .section-title {
            margin: 0 0 12px;
            font-size: 18px;
            font-weight: 700;
        }

        .btn {
            border: 0;
            border-radius: 10px;
            padding: 10px 14px;
            cursor: pointer;
        }

        .btn-primary {
            background: #2563eb;
            color: #fff;
        }

        .btn-secondary {
            background: #f3f4f6;
        }

        .btn-danger {
            background: #ef4444;
            color: #fff;
        }

        .agenda-item {
            border: 1px dashed #cbd5e1;
            border-radius: 12px;
            padding: 12px;
            margin-top: 12px;
        }

        .agenda-location-box {
            margin-top: 12px;
        }

        .agenda-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
        }

        .agenda-title {
            font-weight: 700;
        }

        .actions {
            display: flex;
            gap: 10px;
            margin-top: 16px;
        }

        .checkbox {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 10px;
        }

            .checkbox input {
                width: auto;
            }
    </style>

    <div class="create-layout">
        <div class="card shadow-sm border-0">
            <h2 class="mb-4">Create Event</h2>


            <form asp-controller="Organizer" asp-action="Create" method="post" id="createEventForm" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(excludePropertyErrors: false, message: "", htmlAttributes: new { @class = "text-danger" })
            <label asp-for="Title">Title *</label>
            <input asp-for="Title" />
            <span asp-validation-for="Title" class="error"></span>

            <label asp-for="Description">Description</label>
            <textarea asp-for="Description"></textarea>

            <div class="row">
                <div class="col">
                    <label asp-for="SemesterId">Semester *</label>
                    <select asp-for="SemesterId" asp-items="Model.Semesters">
                        <option value="">-- Select Semester --</option>
                    </select>
                    <span asp-validation-for="SemesterId" class="error"></span>
                </div>

                <div class="col">
                    <label asp-for="DepartmentId">Department</label>
                    <select asp-for="DepartmentId" asp-items="Model.Departments">
                        <option value="">-- Select Department --</option>
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col">
                    <label asp-for="TopicId">Topic</label>
                    <select asp-for="TopicId" asp-items="Model.Topics">
                        <option value="">-- Select Topic --</option>
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col">
                    <label asp-for="LocationId">Location *</label>
                    <input type="hidden" asp-for="LocationId" id="LocationId" />
                    <div class="position-relative">
                        <input type="text" id="locationSearchInput" class="form-control" placeholder="Tìm kiếm địa điểm (>= 1 ký tự)..." autocomplete="off" value="@(Model.Locations?.FirstOrDefault(l => l.Value == Model.LocationId)?.Text)" />
                        <div id="locationSearchResults" class="position-absolute w-100 bg-white border border-top-0 rounded-bottom shadow-sm z-3" style="display:none; max-height: 200px; overflow-y: auto;"></div>
                    </div>
                    <span asp-validation-for="LocationId" class="error text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col">
                    <label asp-for="StartTime">Start Time *</label>
                    <input asp-for="StartTime" type="datetime-local" />
                    <span asp-validation-for="StartTime" class="error"></span>
                </div>
                <div class="col">
                    <label asp-for="EndTime">End Time *</label>
                    <input asp-for="EndTime" type="datetime-local" />
                    <span asp-validation-for="EndTime" class="error"></span>
                </div>
            </div>

            <div class="row">
                <div class="col">
                    <label asp-for="MaxCapacity">Max Capacity *</label>
                    <input asp-for="MaxCapacity" type="number" min="1" />
                    <div class="hint" id="locationCapacityHint">Sức chứa phải nhỏ hơn hoặc bằng sức chứa phòng do approver cấu hình.</div>
                    <span asp-validation-for="MaxCapacity" class="error"></span>
                </div>
                <div class="col">
                    <label>Event Images (Slideshow)</label>
                    <input asp-for="BannerFiles" type="file" accept="image/*" multiple />
                    <div class="hint">Select multiple images to create a slideshow. The first image will be the primary thumbnail.</div>
                    <div class="hint" style="margin-top: 10px;">Or provide Image URLs (separating by | )</div>
                    <input asp-for="ThumbnailUrl" placeholder="https://url1.jpg|https://url2.jpg" />
                </div>
            </div>

            <div class="row">
                <div class="col">
                    <label asp-for="Type">Event Type</label>
                    <select asp-for="Type" asp-items="Html.GetEnumSelectList<EventTypeEnum>()"></select>
                </div>
                <div class="col">
                    <label asp-for="Status">Status</label>
                    <select asp-for="Status"
                            asp-items="@(new SelectList(
                                        new[]
                                        {
                                            new { Value = EventStatusEnum.Draft, Text = "Draft" },
                                            new { Value = EventStatusEnum.Pending, Text = "Pending" }
                                        },
                                        "Value",
                                        "Text"
                                    ))">
                    </select>
                </div>
                <div class="col">
                    <label asp-for="Mode">Event Mode</label>
                    <select asp-for="Mode" asp-items="Html.GetEnumSelectList<DataAccess.Enum.EventModeEnum>()"></select>
                </div>
            </div>

            <div class="row" id="meetingRow" style="display:none;">
                <div class="col">
                    <label asp-for="MeetingUrl">Meeting Url</label>
                    <input asp-for="MeetingUrl"/>
                    <span asp-validation-for="MeetingUrl" class="error"></span>
                </div>
            </div>

            <div class="checkbox">
                <input asp-for="IsDepositRequired" id="IsDepositRequired" />
                <label for="IsDepositRequired" style="margin:0;">Require Deposit</label>
            </div>

            <div class="row" id="depositRow">
                <div class="col">
                    <label asp-for="DepositAmount">Deposit Amount</label>
                    <input asp-for="DepositAmount" type="number" min="0" step="0.01" />
                    <span asp-validation-for="DepositAmount" class="error"></span>
                </div>
            </div>

            <div class="divider"></div>

            <div class="row" style="align-items:center; justify-content:space-between;">
                <h3 style="margin:0;">Event Documents</h3>
                <button type="button" class="btn btn-secondary" id="btnAddDocument">+ Add document</button>
            </div>

            <div id="documentsContainer">
                @for (int i = 0; i < (Model.Documents?.Count ?? 0); i++)
                {
                    <div class="agenda-item" data-index="@i">
                        <div class="agenda-head">
                            <div class="agenda-title">Document #@(i + 1)</div>
                            <button type="button" class="btn btn-danger btnRemoveDocument">Remove</button>
                        </div>

                        <div class="row">
                            <div class="col">
                                <label>File name</label>
                                <input name="Documents[i].FileName" value="@Model.Documents[i].FileName" />
                            </div>
                            <div class="col">
                                <label>Upload File</label>
                                <input name="Documents[i].File" type="file" />
                            </div>
                        </div>

                        <label>Or provide Url</label>
                        <input name="Documents[i].Url" value="@Model.Documents[i].Url" />
                    </div>
                }
            </div>

            <div class="row" style="align-items:center; justify-content:space-between;">
                <h3 style="margin:0;">Event Agendas</h3>
                <div style="display:flex; gap:10px;">
                    <button type="button" class="btn btn-secondary" id="btnSuggestAgenda">+ Agenda by event type</button>
                    <button type="button" class="btn btn-secondary" id="btnAddAgenda">+ Add agenda</button>
                </div>
            </div>
            <div class="hint" id="agendaSuggestionHint">Chọn `Event Type`, sau đó bấm `Agenda by event type` để áp dụng agenda mẫu phù hợp.</div>

            <div id="agendaContainer">
                @for (int i = 0; i < (Model.Agendas?.Count ?? 0); i++)
                {
                    <div class="agenda-item" data-index="@i">
                        <div class="agenda-head">
                            <div class="agenda-title">Agenda #@(i + 1)</div>
                            <button type="button" class="btn btn-danger btnRemoveAgenda">Remove</button>
                        </div>

                        <div class="row">
                            <div class="col">
                                <label>Session Name</label>
                                <input asp-for="Agendas[i].SessionName" required />
                                <span asp-validation-for="Agendas[i].SessionName" class="error"></span>
                            </div>
                            <div class="col">
                                <label>Speaker</label>
                                <input asp-for="Agendas[i].SpeakerInfo" required />
                                <span asp-validation-for="Agendas[i].SpeakerInfo" class="error"></span>
                            </div>
                        </div>

                        <label>Description</label>
                        <textarea asp-for="Agendas[i].Description"></textarea>

                        <div class="row">
                            <div class="col">
                                <label>Start</label>
                                <input asp-for="Agendas[i].StartTime" type="datetime-local" />
                            </div>
                            <div class="col">
                                <label>End</label>
                                <input asp-for="Agendas[i].EndTime" type="datetime-local" />
                            </div>
                        </div>

                        <div class="row pt-2 pb-2">
                            <div class="col">
                                <label>Location</label>
                                <input type="hidden" asp-for="Agendas[i].Location" class="agenda-location-hidden" />
                                <div class="position-relative">
                                    <input type="text" class="form-control agenda-location-search-input" placeholder="Để trống nếu giống địa điểm Event..." autocomplete="off" value="@Model.Agendas[i].Location" />
                                    <div class="agenda-location-search-results position-absolute w-100 bg-white border border-top-0 rounded-bottom shadow-sm z-3" style="display:none; max-height: 200px; overflow-y: auto;"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>


                <div class="actions">
                    <button type="submit" class="btn btn-primary">Create Event</button>
                    <button type="reset" class="btn btn-danger">Reset</button>
                </div>
            </form>
        </div>

        <aside class="create-sidebar">
            <div class="side-panel">
                <h4>Available Topics</h4>
                <input type="text" class="side-search" data-target="topicList" placeholder="Tìm topic..." autocomplete="off" />
                <ul class="side-list" id="topicList">
                    @if (Model.Topics != null && Model.Topics.Any(x => !string.IsNullOrWhiteSpace(x.Value)))
                    {
                        foreach (var topic in Model.Topics.Where(x => !string.IsNullOrWhiteSpace(x.Value)))
                        {
                            <li>@topic.Text</li>
                        }
                    }
                    else
                    {
                        <li>Chưa có topic khả dụng.</li>
                    }
                </ul>
                <div class="side-empty" data-empty-for="topicList">Không tìm thấy topic phù hợp.</div>
            </div>

            <div class="side-panel">
                <h4>Available Locations</h4>
                <input type="text" class="side-search" data-target="locationList" placeholder="Tìm location..." autocomplete="off" />
                <ul class="side-list" id="locationList">
                    @if (Model.Locations != null && Model.Locations.Any(x => !string.IsNullOrWhiteSpace(x.Value)))
                    {
                        foreach (var location in Model.Locations.Where(x => !string.IsNullOrWhiteSpace(x.Value)))
                        {
                            <li>@location.Text</li>
                        }
                    }
                    else
                    {
                        <li>Chưa có location khả dụng.</li>
                    }
                </ul>
                <div class="side-empty" data-empty-for="locationList">Không tìm thấy location phù hợp.</div>
            </div>
        </aside>
    </div>

    <template id="agendaTemplate">
        <div class="agenda-item" data-index="__i__">
            <div class="agenda-head">
                <div class="agenda-title">Agenda #__n__</div>
                <button type="button" class="btn btn-danger btnRemoveAgenda">Remove</button>
            </div>

            <div class="row">
                <div class="col">
                    <label>Session Name</label>
                    <input name="Agendas[__i__].SessionName" required />
                </div>
                <div class="col">
                    <label>Speaker</label>
                    <input name="Agendas[__i__].SpeakerInfo" required />
                </div>
            </div>

            <label>Description</label>
            <textarea name="Agendas[__i__].Description"></textarea>

            <div class="row">
                <div class="col">
                    <label>Start</label>
                    <input name="Agendas[__i__].StartTime" type="datetime-local" />
                </div>
                <div class="col">
                    <label>End</label>
                    <input name="Agendas[__i__].EndTime" type="datetime-local" />
                </div>
            </div>

            <div class="row pt-2 pb-2">
                <div class="col">
                    <label>Location</label>
                    <input type="hidden" name="Agendas[__i__].Location" class="agenda-location-hidden" />
                    <div class="position-relative">
                        <input type="text" class="form-control agenda-location-search-input" placeholder="Để trống nếu giống địa điểm Event..." autocomplete="off" />
                        <div class="agenda-location-search-results position-absolute w-100 bg-white border border-top-0 rounded-bottom shadow-sm z-3" style="display:none; max-height: 200px; overflow-y: auto;"></div>
                    </div>
                </div>
            </div>
        </div>
    </template>

    <template id="documentTemplate">
        <div class="agenda-item" data-index="__i__">
            <div class="agenda-head">
                <div class="agenda-title">Document #__n__</div>
                <button type="button" class="btn btn-danger btnRemoveDocument">Remove</button>
            </div>

            <div class="row">
                <div class="col">
                    <label>File name (Optional)</label>
                    <input name="Documents[__i__].FileName" />
                </div>
                <div class="col">
                    <label>Upload File</label>
                    <input name="Documents[__i__].File" type="file" />
                </div>
            </div>

            <label>Or provide Url</label>
            <input name="Documents[__i__].Url" />
        </div>
    </template>

    <style>
        /* Select2 bootstrap compatibility fixes */
        .select2-container--default .select2-selection--single {
            border-radius: 10px;
            height: 42px;
            border: 1px solid #ccc;
            padding: 5px;
        }
        .select2-container .select2-selection--single .select2-selection__rendered {
            line-height: 30px;
        }
        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 40px;
        }
    </style>
@section Scripts {
    <script>
        $(document).ready(function() {
            // Setup autocomplete for main location
            function setupLocationAutocomplete(inputId, resultsId, hiddenId, isMain = true) {
                const input = document.getElementById(inputId);
                const results = document.getElementById(resultsId);
                const hidden = document.getElementById(hiddenId);
                let timer;

                if (input && results) {
                    input.addEventListener('input', function() {
                        clearTimeout(timer);
                        const query = this.value;
                        if (query.length < 1) {
                            results.style.display = 'none';
                            if (query.length === 0) hidden.value = '';
                            return;
                        }

                        timer = setTimeout(() => {
                            fetch(`/api/v1/lookup/locations?q=${encodeURIComponent(query)}`)
                                .then(res => res.json())
                                .then(resp => {
                                    if (!resp.success || !resp.data || resp.data.length === 0) {
                                        results.innerHTML = '<div class="p-2 text-muted small">Không tìm thấy địa điểm</div>';
                                        results.style.display = 'block';
                                        return;
                                    }
                                    
                                    results.innerHTML = resp.data.map(loc => `
                                        <div class="p-2 border-bottom loc-search-item text-dark" style="cursor:pointer;" 
                                             data-id="${loc.id}" data-name="${loc.name}" data-address="${loc.address || ''}">
                                            <div class="fw-semibold small">${loc.name}</div>
                                            <div class="text-muted" style="font-size:0.75rem;">
                                                ${loc.address ? loc.address + ' - ' : ''}Sức chứa: ${loc.capacity}
                                            </div>
                                        </div>
                                    `).join('');
                                    results.style.display = 'block';
                                    
                                    const items = results.querySelectorAll('.loc-search-item');
                                    items.forEach(item => {
                                        item.addEventListener('click', function() {
                                            const locId = this.getAttribute('data-id');
                                            const locName = this.getAttribute('data-name');
                                            const locAddr = this.getAttribute('data-address');
                                            input.value = locAddr ? locAddr : locName;
                                            hidden.value = isMain ? locId : locName;
                                            results.style.display = 'none';
                                        });
                                    });
                                });
                        }, 300);
                    });

                    document.addEventListener('click', function(e) {
                        if(e.target !== input && !results.contains(e.target)) {
                            results.style.display = 'none';
                        }
                    });
                }
            }

            setupLocationAutocomplete('locationSearchInput', 'locationSearchResults', 'LocationId', true);

            // Setup autocomplete for dynamic agendas
            document.addEventListener('input', function(e) {
                if (e.target.classList.contains('agenda-location-search-input')) {
                    const input = e.target;
                    const container = input.closest('.col');
                    const results = container.querySelector('.agenda-location-search-results');
                    const hidden = container.querySelector('.agenda-location-hidden');
                    
                    clearTimeout(input.dataset.timer);
                    
                    const query = input.value;
                    if (query.length < 1) {
                        results.style.display = 'none';
                        if (query.length === 0) hidden.value = '';
                        return;
                    }

                    input.dataset.timer = setTimeout(() => {
                        fetch(`/api/v1/lookup/locations?q=${encodeURIComponent(query)}`)
                            .then(res => res.json())
                            .then(resp => {
                                if (!resp.success || !resp.data || resp.data.length === 0) {
                                    results.innerHTML = '<div class="p-2 text-muted small">Không tìm thấy địa điểm</div>';
                                    results.style.display = 'block';
                                    return;
                                }
                                
                                results.innerHTML = resp.data.map(loc => `
                                    <div class="p-2 border-bottom loc-search-item text-dark" style="cursor:pointer;" 
                                         data-name="${loc.name}" data-address="${loc.address || ''}">
                                        <div class="fw-semibold small">${loc.name}</div>
                                        <div class="text-muted" style="font-size:0.75rem;">
                                            ${loc.address ? loc.address + ' - ' : ''}Sức chứa: ${loc.capacity}
                                        </div>
                                    </div>
                                `).join('');
                                results.style.display = 'block';
                                
                                const items = results.querySelectorAll('.loc-search-item');
                                items.forEach(item => {
                                    item.addEventListener('click', function() {
                                        const locName = this.getAttribute('data-name');
                                        const locAddr = this.getAttribute('data-address');
                                        input.value = locAddr ? locAddr : locName;
                                        hidden.value = locName;
                                        results.style.display = 'none';
                                    });
                                });
                            });
                    }, 300);
                }
            });

            document.addEventListener('click', function(e) {
                if (!e.target.classList.contains('agenda-location-search-input') && !e.target.closest('.agenda-location-search-results')) {
                    document.querySelectorAll('.agenda-location-search-results').forEach(el => el.style.display = 'none');
                }
            });

            // Initialize Select2 for Topic
            $('#TopicId').select2({
                placeholder: "-- Select Topic --",
                allowClear: true,
                ajax: {
                    url: '/api/v1/lookup/topics',
                    dataType: 'json',
                    delay: 250,
                    data: function (params) {
                        return { q: params.term };
                    },
                    processResults: function (data) {
                        return {
                            results: data.data.map(item => ({
                                id: item.id,
                                text: item.name
                            }))
                        };
                    },
                    cache: true
                }
            });

            // Re-apply Select2 to newly added agenda locations if needed
            // Currently agenda locations are simple text-based or pre-loaded. 
            // If they need to be searchable too, we can initialize them here.

            // Filter for right-side topic/location lists
            document.querySelectorAll('.side-search').forEach(input => {
                input.addEventListener('input', function () {
                    const targetId = this.getAttribute('data-target');
                    const list = document.getElementById(targetId);
                    if (!list) return;

                    const keyword = (this.value || '').trim().toLowerCase();
                    const items = list.querySelectorAll('li');
                    let visibleCount = 0;

                    items.forEach(li => {
                        const text = (li.textContent || '').trim().toLowerCase();
                        const match = !keyword || text.includes(keyword);
                        li.style.display = match ? '' : 'none';
                        if (match) visibleCount++;
                    });

                    const empty = document.querySelector(`.side-empty[data-empty-for='${targetId}']`);
                    if (empty) {
                        empty.style.display = visibleCount === 0 ? 'block' : 'none';
                    }
                });
            });
        });

        (function () {
            const agendaContainer = document.getElementById("agendaContainer");
            const tpl = document.getElementById("agendaTemplate");
            const btnAdd = document.getElementById("btnAddAgenda");
            const btnSuggestAgenda = document.getElementById("btnSuggestAgenda");
            const agendaSuggestionHint = document.getElementById("agendaSuggestionHint");

            const isDeposit = document.getElementById("IsDepositRequired");
            const depositRow = document.getElementById("depositRow");

            function updateDepositUI() {
                depositRow.style.display = isDeposit.checked ? "flex" : "none";
                if (!isDeposit.checked) {
                    const depInput = document.querySelector("input[name='DepositAmount']");
                    if (depInput) depInput.value = 0;
                }
            }
            updateDepositUI();
            isDeposit.addEventListener("change", updateDepositUI);

            // Show/Hide meeting url when Mode is Online/Hybrid
            const modeSelect = document.querySelector("select[name='Mode']");
            const meetingRow = document.getElementById("meetingRow");
            const agendaSuggestionsByType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AgendaSuggestionsByType));

            function updateMeetingUI() {
                const val = modeSelect ? modeSelect.value : '';

                // EventModeEnum: Offline=0, Online=1, Hybrid=2
                if (val === '1' || val === '2') {
                    meetingRow.style.display = 'flex';
                } else {
                    meetingRow.style.display = 'none';
                    const m = document.querySelector("input[name='MeetingUrl']");
                    if (m) m.value = '';
                }
            }
            if (modeSelect) {
                modeSelect.addEventListener('change', updateMeetingUI);
                updateMeetingUI();
            }

            function getNextIndex() {
                return agendaContainer.querySelectorAll(".agenda-item").length;
            }

            function renumber() {
                const items = agendaContainer.querySelectorAll(".agenda-item");
                items.forEach((item, i) => {
                    item.dataset.index = i;
                    const title = item.querySelector(".agenda-title");
                    if (title) title.textContent = `Agenda #${i + 1}`;
                    item.querySelectorAll("input[name], textarea[name], select[name]").forEach(el => {
                        el.name = el.name.replace(/Agendas\[\d+\]/, `Agendas[${i}]`);
                    });
                });
            }

            function addAgenda(agendaData) {
                const i = getNextIndex();
                const html = tpl.innerHTML.replaceAll("__i__", i).replaceAll("__n__", i + 1);
                const wrapper = document.createElement("div");
                wrapper.innerHTML = html.trim();
                const agendaItem = wrapper.firstElementChild;
                agendaContainer.appendChild(agendaItem);

                if (agendaData) {
                    const sessionNameInput = agendaItem.querySelector("input[name$='.SessionName']");
                    const speakerNameInput = agendaItem.querySelector("input[name$='.SpeakerInfo']");
                    const descriptionInput = agendaItem.querySelector("textarea[name$='.Description']");

                    if (sessionNameInput) sessionNameInput.value = agendaData.sessionName ?? '';
                    if (speakerNameInput) speakerNameInput.value = agendaData.speakerName ?? '';
                    if (descriptionInput) descriptionInput.value = agendaData.description ?? '';
                }
                return [...agendaContainer.querySelectorAll('.agenda-item')].some(item =>
                    [...item.querySelectorAll('input[type="text"], input[type="datetime-local"], textarea, input[type="hidden"]')]
                        .some(input => input.value?.trim()));
            }

            function updateAgendaSuggestionHint() {
                const typeSelect = document.querySelector("select[name='Type']");
                const suggestions = agendaSuggestionsByType?.[typeSelect?.value] || [];

                if (!agendaSuggestionHint) return;

                agendaSuggestionHint.textContent = suggestions.length > 0
                    ? `Agenda gợi ý: ${suggestions.join(', ')}.`
                    : 'Chọn Event Type, sau đó bấm Agenda by event type để áp dụng agenda mẫu phù hợp.';
            }

            function applySuggestedAgendas() {
                const typeSelect = document.querySelector("select[name='Type']");
                const suggestions = agendaSuggestionsByType?.[typeSelect?.value] || [];

                if (suggestions.length === 0) {
                    if (agendaSuggestionHint) {
                        agendaSuggestionHint.textContent = 'Chưa có agenda mẫu cho Event Type hiện tại.';
                    }
                    return;
                }

                if (hasAgendaContent() && !window.confirm('Agenda hiện tại sẽ được thay bằng agenda mẫu theo loại sự kiện. Tiếp tục?')) {
                    return;
                }

                agendaContainer.innerHTML = '';
                suggestions.forEach(sessionName => addAgenda({ sessionName }));
                renumber();
                updateAgendaSuggestionHint();
            }

            function removeAgenda(btn) {
                const item = btn.closest(".agenda-item");
                if (item) item.remove();
                renumber();
            }

            btnAdd.addEventListener("click", () => addAgenda());
            btnSuggestAgenda?.addEventListener("click", applySuggestedAgendas);
            agendaContainer.addEventListener("click", function (e) {
                const btn = e.target.closest(".btnRemoveAgenda");
                if (btn) removeAgenda(btn);
            });

            if (typeof existingAgendaItems !== 'undefined' && existingAgendaItems.length === 0) {
                addAgenda();
            } 
            const typeSelect = document.querySelector("select[name='Type']");
            typeSelect?.addEventListener('change', updateAgendaSuggestionHint);
            updateAgendaSuggestionHint();
            
            // Documents UI
            const docsContainer = document.getElementById("documentsContainer");
            const btnAddDoc = document.getElementById("btnAddDocument");
            const docTpl = document.getElementById("documentTemplate");

            function getNextDocIndex() { return docsContainer.querySelectorAll('.agenda-item').length; }
            function renumberDocs() {
                const items = docsContainer.querySelectorAll('.agenda-item');
                items.forEach((item, i) => {
                    item.dataset.index = i;
                    const title = item.querySelector('.agenda-title');
                    if (title) title.textContent = `Document #${i + 1}`;
                    item.querySelectorAll("input[name]").forEach(el => {
                        el.name = el.name.replace(/Documents\[\d+\]/, `Documents[${i}]`);
                    });
                });
            }

            function addDocument() {
                const i = getNextDocIndex();
                const html = docTpl.innerHTML.replaceAll('__i__', i).replaceAll('__n__', i+1);
                const wrapper = document.createElement('div');
                wrapper.innerHTML = html.trim();
                docsContainer.appendChild(wrapper.firstElementChild);
            }

            function removeDocument(btn) {
                const item = btn.closest('.agenda-item');
                if (item) item.remove();
                renumberDocs();
            }

            btnAddDoc.addEventListener('click', addDocument);
            docsContainer.addEventListener('click', function(e) {
                const btn = e.target.closest('.btnRemoveDocument');
                if (btn) removeDocument(btn);
            });

            if (docsContainer.querySelectorAll('.agenda-item').length === 0) {
                // don't auto-add doc by default
            }
        })();
    </script>
    <partial name="_ValidationScriptsPartial" /> 
}
