@model AEMS_Solution.Models.Event.CreateEventViewModel
@using DataAccess.Enum
@{
    ViewData["Title"] = "Create Event";
    Layout = "_OrganizerLayout";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Create Event</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
        body {
            font-family: system-ui, Arial;
            margin: 24px;
        }

        .card {
            max-width: 980px;
            margin: 0 auto;
            border: 1px solid #ddd;
            border-radius: 12px;
            padding: 18px;
        }

        .row {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .col {
            flex: 1;
            min-width: 240px;
        }

        label {
            display: block;
            font-weight: 600;
            margin: 10px 0 6px;
        }

        input, select, textarea {
            width: 100%;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 10px;
        }

        textarea {
            min-height: 90px;
            resize: vertical;
        }

        .hint {
            color: #666;
            font-size: 12px;
            margin-top: 4px;
        }

        .error {
            color: #b00020;
            font-size: 13px;
            margin-top: 6px;
        }

        .divider {
            height: 1px;
            background: #eee;
            margin: 18px 0;
        }

        .section-box {
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 16px;
            margin: 18px 0;
            background: #fafafa;
        }

        .section-title {
            margin: 0 0 12px;
            font-size: 18px;
            font-weight: 700;
        }

        .btn {
            border: 0;
            border-radius: 10px;
            padding: 10px 14px;
            cursor: pointer;
        }

        .btn-primary {
            background: #2563eb;
            color: #fff;
        }

        .btn-secondary {
            background: #f3f4f6;
        }

        .btn-danger {
            background: #ef4444;
            color: #fff;
        }

        .agenda-item {
            border: 1px dashed #cbd5e1;
            border-radius: 12px;
            padding: 12px;
            margin-top: 12px;
        }

        .agenda-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
        }

        .agenda-title {
            font-weight: 700;
        }

        .actions {
            display: flex;
            gap: 10px;
            margin-top: 16px;
        }

        .checkbox {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 10px;
        }

            .checkbox input {
                width: auto;
            }
    </style>
</head>
<body>
    <div class="card">
        <h2 style="margin:0 0 6px;">Create Event</h2>

        <form asp-controller="Organizer" asp-action="Create" method="post" id="createEventForm">
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(excludePropertyErrors: false, message: "", htmlAttributes: new { @class = "text-danger" })
            <label asp-for="Title">Title *</label>
            <input asp-for="Title" />
            <span asp-validation-for="Title" class="error"></span>

            <label asp-for="Description">Description</label>
            <textarea asp-for="Description"></textarea>

            <div class="row">
                <div class="col">
                    <label asp-for="SemesterId">Semester *</label>
                    <select asp-for="SemesterId" asp-items="Model.Semesters">
                        <option value="">-- Select Semester --</option>
                    </select>
                    <span asp-validation-for="SemesterId" class="error"></span>
                </div>

                <div class="col">
                    <label asp-for="DepartmentId">Department</label>
                    <select asp-for="DepartmentId" asp-items="Model.Departments">
                        <option value="">-- Select Department --</option>
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col">
                    <label asp-for="TopicId">Topic</label>
                    <select asp-for="TopicId" asp-items="Model.Topics">
                        <option value="">-- Select Topic --</option>
                    </select>
                </div>
            </div>

            <div class="section-box">
                <h3 class="section-title">Room Information</h3>

                <div class="row">
                    <div class="col">
                        <label>University *</label>
                        <select id="universitySelect">
                            <option value="">-- Select University --</option>
                        </select>
                    </div>

                    <div class="col">
                        <label>Building *</label>
                        <select id="buildingSelect">
                            <option value="">-- Select Building --</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col">
                        <label>Floor *</label>
                        <select id="floorSelect">
                            <option value="">-- Select Floor --</option>
                        </select>
                    </div>

                    <div class="col">
                        <label>Room *</label>
                        <select id="roomSelect">
                            <option value="">-- Select Room --</option>
                        </select>
                        <input asp-for="LocationId" type="hidden" />
                        <span asp-validation-for="LocationId" class="error"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col">
                        <label>Location Type</label>
                        <input id="locationTypeDisplay" type="text" readonly placeholder="Auto from approver" />
                    </div>

                    <div class="col">
                        <label>Room Capacity</label>
                        <input id="roomCapacityDisplay" type="text" readonly placeholder="Auto from approver" />
                    </div>
                </div>

                <div class="hint" id="locationAvailabilityHint">Chọn thời gian bắt đầu và kết thúc để lọc phòng còn trống.</div>
            </div>

            <div class="row">
                <div class="col">
                    <label asp-for="StartTime">Start Time *</label>
                    <input asp-for="StartTime" type="datetime-local" />
                    <span asp-validation-for="StartTime" class="error"></span>
                </div>
                <div class="col">
                    <label asp-for="EndTime">End Time *</label>
                    <input asp-for="EndTime" type="datetime-local" />
                    <span asp-validation-for="EndTime" class="error"></span>
                </div>
            </div>

            <div class="row">
                <div class="col">
                    <label asp-for="MaxCapacity">Max Capacity *</label>
                    <input asp-for="MaxCapacity" type="number" min="1" />
                    <div class="hint" id="locationCapacityHint">Sức chứa phải nhỏ hơn hoặc bằng sức chứa phòng do approver cấu hình.</div>
                    <span asp-validation-for="MaxCapacity" class="error"></span>
                </div>
                <div class="col">
                    <label asp-for="ThumbnailUrl">Thumbnail Url</label>
                    <input asp-for="ThumbnailUrl" placeholder="https://..." />
                </div>
            </div>

            <div class="row">
                <div class="col">
                    <label asp-for="Type">Event Type</label>
                    <select asp-for="Type" asp-items="Html.GetEnumSelectList<EventTypeEnum>()"></select>
                </div>
                <div class="col">
                    <label asp-for="Status">Status</label>
                    <select asp-for="Status"
                            asp-items="@(new SelectList(
                                        new[]
                                        {
                                            new { Value = EventStatusEnum.Draft, Text = "Draft" },
                                            new { Value = EventStatusEnum.Pending, Text = "Pending" }
                                        },
                                        "Value",
                                        "Text"
                                    ))">
                    </select>
                </div>
                <div class="col">
                    <label asp-for="Mode">Event Mode</label>
                    <select asp-for="Mode" asp-items="Html.GetEnumSelectList<DataAccess.Enum.EventModeEnum>()"></select>
                </div>
            </div>

            <div class="row" id="meetingRow" style="display:none;">
                <div class="col">
                    <label asp-for="MeetingUrl">Meeting Url</label>
                    <input asp-for="MeetingUrl"/>
                    <span asp-validation-for="MeetingUrl" class="error"></span>
                </div>
            </div>

            <div class="checkbox">
                <input asp-for="IsDepositRequired" id="IsDepositRequired" />
                <label for="IsDepositRequired" style="margin:0;">Require Deposit</label>
            </div>

            <div class="row" id="depositRow">
                <div class="col">
                    <label asp-for="DepositAmount">Deposit Amount</label>
                    <input asp-for="DepositAmount" type="number" min="0" step="0.01" />
                    <span asp-validation-for="DepositAmount" class="error"></span>
                </div>
            </div>

            <div class="divider"></div>

            <div class="row" style="align-items:center; justify-content:space-between;">
                <h3 style="margin:0;">Event Documents</h3>
                <button type="button" class="btn btn-secondary" id="btnAddDocument">+ Add document</button>
            </div>

            <div id="documentsContainer">
                @for (int i = 0; i < (Model.Documents?.Count ?? 0); i++)
                {
                    <div class="agenda-item" data-index="@i">
                        <div class="agenda-head">
                            <div class="agenda-title">Document #@(i + 1)</div>
                            <button type="button" class="btn btn-danger btnRemoveDocument">Remove</button>
                        </div>

                        <div class="row">
                            <div class="col">
                                <label>File name</label>
                                <input name="Documents[@i].FileName" value="@Model.Documents[i].FileName" />
                            </div>
                            <div class="col">
                                <label>Type</label>
                                <input name="Documents[@i].Type" value="@Model.Documents[i].Type" />
                            </div>
                        </div>

                        <label>Url</label>
                        <input name="Documents[@i].Url" value="@Model.Documents[i].Url" />
                    </div>
                }
            </div>

            <div class="row" style="align-items:center; justify-content:space-between;">
                <h3 style="margin:0;">Event Agendas</h3>
                <button type="button" class="btn btn-secondary" id="btnAddAgenda">+ Add agenda</button>
            </div>

            <div id="agendaContainer">
                @for (int i = 0; i < (Model.Agendas?.Count ?? 0); i++)
                {
                    <div class="agenda-item" data-index="@i">
                        <div class="agenda-head">
                            <div class="agenda-title">Agenda #@(i + 1)</div>
                            <button type="button" class="btn btn-danger btnRemoveAgenda">Remove</button>
                        </div>

                        <div class="row">
                            <div class="col">
                                <label>Session Name</label>
                                <input asp-for="Agendas[@i].SessionName" />
                            </div>
                            <div class="col">
                                <label>Speaker</label>
                                <input asp-for="Agendas[@i].SpeakerName" />
                            </div>
                        </div>

                        <label>Description</label>
                        <textarea asp-for="Agendas[@i].Description"></textarea>

                        <div class="row">
                            <div class="col">
                                <label>Start</label>
                                <input asp-for="Agendas[@i].StartTime" type="datetime-local" />
                            </div>
                            <div class="col">
                                <label>End</label>
                                <input asp-for="Agendas[@i].EndTime" type="datetime-local" />
                            </div>
                        </div>

                        <label>Location (agenda)</label>
                        <select asp-for="Agendas[@i].Location">
                            <option value="">-- Select agenda room --</option>
                            @foreach (var location in Model.Locations)
                            {
                                <option value="@location.Text">@location.Text</option>
                            }
                        </select>
                    </div>
                }
            </div>


            <div class="actions">
                <button type="submit" class="btn btn-primary">Create Event</button>
                <button type="reset" class="btn btn-danger">Reset</button>
            </div>
        </form>
    </div>

    <template id="agendaTemplate">
        <div class="agenda-item" data-index="__i__">
            <div class="agenda-head">
                <div class="agenda-title">Agenda #__n__</div>
                <button type="button" class="btn btn-danger btnRemoveAgenda">Remove</button>
            </div>

            <div class="row">
                <div class="col">
                    <label>Session Name</label>
                    <input name="Agendas[__i__].SessionName" />
                </div>
                <div class="col">
                    <label>Speaker</label>
                    <input name="Agendas[__i__].SpeakerName" />
                </div>
            </div>

            <label>Description</label>
            <textarea name="Agendas[__i__].Description"></textarea>

            <div class="row">
                <div class="col">
                    <label>Start</label>
                    <input name="Agendas[__i__].StartTime" type="datetime-local" />
                </div>
                <div class="col">
                    <label>End</label>
                    <input name="Agendas[__i__].EndTime" type="datetime-local" />
                </div>
            </div>

            <label>Location (agenda)</label>
            <select name="Agendas[__i__].Location">
                <option value="">-- Select agenda room --</option>
                @foreach (var location in Model.Locations)
                {
                    <option value="@location.Text">@location.Text</option>
                }
            </select>
        </div>
    </template>

    <template id="documentTemplate">
        <div class="agenda-item" data-index="__i__">
            <div class="agenda-head">
                <div class="agenda-title">Document #__n__</div>
                <button type="button" class="btn btn-danger btnRemoveDocument">Remove</button>
            </div>

            <div class="row">
                <div class="col">
                    <label>File name</label>
                    <input name="Documents[__i__].FileName" />
                </div>
                <div class="col">
                    <label>Type</label>
                    <input name="Documents[__i__].Type" />
                </div>
            </div>

            <label>Url</label>
            <input name="Documents[__i__].Url" />
        </div>
    </template>

    <script>
        (function () {
            const agendaContainer = document.getElementById("agendaContainer");
            const tpl = document.getElementById("agendaTemplate");
            const btnAdd = document.getElementById("btnAddAgenda");

            const isDeposit = document.getElementById("IsDepositRequired");
            const depositRow = document.getElementById("depositRow");

            function updateDepositUI() {
                depositRow.style.display = isDeposit.checked ? "flex" : "none";
                if (!isDeposit.checked) {
                    const depInput = document.querySelector("input[name='DepositAmount']");
                    if (depInput) depInput.value = 0;
                }
            }
            updateDepositUI();
            isDeposit.addEventListener("change", updateDepositUI);

            // Show/Hide meeting url when Mode is Online/Hybrid
            const modeSelect = document.querySelector("select[name='Mode']");
            const meetingRow = document.getElementById("meetingRow");
            const startTimeInput = document.getElementById("StartTime");
            const endTimeInput = document.getElementById("EndTime");
            const locationIdInput = document.getElementById("LocationId");
            const universitySelect = document.getElementById("universitySelect");
            const buildingSelect = document.getElementById("buildingSelect");
            const floorSelect = document.getElementById("floorSelect");
            const roomSelect = document.getElementById("roomSelect");
            const locationTypeDisplay = document.getElementById("locationTypeDisplay");
            const roomCapacityDisplay = document.getElementById("roomCapacityDisplay");
            const locationHint = document.getElementById("locationAvailabilityHint");
            const maxCapacityInput = document.getElementById("MaxCapacity");
            const locationCapacityHint = document.getElementById("locationCapacityHint");
            let availableLocations = [];

            function setOptions(select, placeholder, values, selectedValue) {
                if (!select) return;

                select.innerHTML = '';
                const placeholderOption = document.createElement('option');
                placeholderOption.value = '';
                placeholderOption.textContent = placeholder;
                select.appendChild(placeholderOption);

                values.forEach(value => {
                    const option = document.createElement('option');
                    option.value = value;
                    option.textContent = value;
                    if (value === selectedValue) {
                        option.selected = true;
                    }
                    select.appendChild(option);
                });
            }

            function getDistinctValues(items, selector) {
                return [...new Set(items.map(selector).filter(Boolean))];
            }

            function syncSelectedLocation() {
                const selectedUniversity = universitySelect.value;
                const selectedBuilding = buildingSelect.value;
                const selectedFloor = floorSelect.value;
                const selectedRoom = roomSelect.value;

                const selectedLocation = availableLocations.find(x =>
                    x.name === selectedUniversity &&
                    x.building === selectedBuilding &&
                    x.floor === selectedFloor &&
                    x.room === selectedRoom);

                locationIdInput.value = selectedLocation ? selectedLocation.id : '';
                locationTypeDisplay.value = selectedLocation?.type ?? '';
                if (roomCapacityDisplay) {
                    roomCapacityDisplay.value = selectedLocation ? selectedLocation.capacity : '';
                }

                if (selectedLocation && maxCapacityInput) {
                    maxCapacityInput.max = selectedLocation.capacity;
                    if (locationCapacityHint) {
                        locationCapacityHint.textContent = `Sức chứa tối đa theo phòng đã chọn: ${selectedLocation.capacity}.`;
                    }
                } else if (maxCapacityInput) {
                    maxCapacityInput.removeAttribute('max');
                    if (locationCapacityHint) {
                        locationCapacityHint.textContent = 'Sức chứa phải nhỏ hơn hoặc bằng sức chứa phòng do approver cấu hình.';
                    }
                }
            }

            function populateRoomHierarchy(preferredLocationId) {
                const selectedLocation = availableLocations.find(x => x.id === preferredLocationId);

                const selectedUniversity = selectedLocation?.name || universitySelect.value;
                const universities = getDistinctValues(availableLocations, x => x.name);
                setOptions(universitySelect, '-- Select University --', universities, selectedUniversity);

                const filteredByUniversity = availableLocations.filter(x => x.name === universitySelect.value);
                const selectedBuilding = selectedLocation?.building || buildingSelect.value;
                const buildings = getDistinctValues(filteredByUniversity, x => x.building);
                setOptions(buildingSelect, '-- Select Building --', buildings, selectedBuilding);

                const filteredByBuilding = filteredByUniversity.filter(x => x.building === buildingSelect.value);
                const selectedFloor = selectedLocation?.floor || floorSelect.value;
                const floors = getDistinctValues(filteredByBuilding, x => x.floor);
                setOptions(floorSelect, '-- Select Floor --', floors, selectedFloor);

                const filteredByFloor = filteredByBuilding.filter(x => x.floor === floorSelect.value);
                const selectedRoom = selectedLocation?.room || roomSelect.value;
                const rooms = getDistinctValues(filteredByFloor, x => x.room);
                setOptions(roomSelect, '-- Select Room --', rooms, selectedRoom);

                syncSelectedLocation();
            }

            async function refreshAvailableLocations() {
                if (!startTimeInput || !endTimeInput || !locationIdInput) return;

                const startValue = startTimeInput.value;
                const endValue = endTimeInput.value;
                if (!startValue || !endValue) {
                    availableLocations = [];
                    populateRoomHierarchy('');
                    return;
                }

                const selectedValue = locationIdInput.value;

                try {
                    const url = `/Organizer/GetAvailableLocations?startTime=${encodeURIComponent(startValue)}&endTime=${encodeURIComponent(endValue)}`;
                    const response = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                    if (!response.ok) return;

                    availableLocations = await response.json();
                    populateRoomHierarchy(selectedValue);

                    if (locationHint) {
                        locationHint.textContent = availableLocations.length > 0
                            ? `Có ${availableLocations.length} phòng đang khả dụng trong khoảng thời gian đã chọn.`
                            : 'Không có phòng khả dụng trong khoảng thời gian đã chọn.';
                    }
                } catch {
                    if (locationHint) {
                        locationHint.textContent = 'Không thể tải danh sách phòng khả dụng.';
                    }
                }
            }

            if (startTimeInput) startTimeInput.addEventListener('change', refreshAvailableLocations);
            if (endTimeInput) endTimeInput.addEventListener('change', refreshAvailableLocations);
            if (universitySelect) universitySelect.addEventListener('change', () => populateRoomHierarchy(''));
            if (buildingSelect) buildingSelect.addEventListener('change', () => populateRoomHierarchy(''));
            if (floorSelect) floorSelect.addEventListener('change', () => populateRoomHierarchy(''));
            if (roomSelect) roomSelect.addEventListener('change', syncSelectedLocation);
            refreshAvailableLocations();

            function updateMeetingUI() {
                const val = modeSelect ? modeSelect.value : '';

                // EventModeEnum: Offline=0, Online=1, Hybrid=2
                if (val === '1' || val === '2') {
                    meetingRow.style.display = 'flex';
                } else {
                    meetingRow.style.display = 'none';
                    const m = document.querySelector("input[name='MeetingUrl']");
                    if (m) m.value = '';
                }
            }
            if (modeSelect) {
                modeSelect.addEventListener('change', updateMeetingUI);
                updateMeetingUI();
            }

            function getNextIndex() {
                return agendaContainer.querySelectorAll(".agenda-item").length;
            }

            function renumber() {
                const items = agendaContainer.querySelectorAll(".agenda-item");
                items.forEach((item, i) => {
                    item.dataset.index = i;
                    const title = item.querySelector(".agenda-title");
                    if (title) title.textContent = `Agenda #${i + 1}`;
                    item.querySelectorAll("input[name], textarea[name], select[name]").forEach(el => {
                        el.name = el.name.replace(/Agendas\[\d+\]/, `Agendas[${i}]`);
                    });
                });
            }

            function addAgenda() {
                const i = getNextIndex();
                const html = tpl.innerHTML.replaceAll("__i__", i).replaceAll("__n__", i + 1);
                const wrapper = document.createElement("div");
                wrapper.innerHTML = html.trim();
                agendaContainer.appendChild(wrapper.firstElementChild);
            }

            function removeAgenda(btn) {
                const item = btn.closest(".agenda-item");
                if (item) item.remove();
                renumber();
            }

            btnAdd.addEventListener("click", addAgenda);
            agendaContainer.addEventListener("click", function (e) {
                const btn = e.target.closest(".btnRemoveAgenda");
                if (btn) removeAgenda(btn);
            });

            if (agendaContainer.querySelectorAll(".agenda-item").length === 0) addAgenda();
            
            // Documents UI
            const docsContainer = document.getElementById("documentsContainer");
            const btnAddDoc = document.getElementById("btnAddDocument");
            const docTpl = document.getElementById("documentTemplate");

            function getNextDocIndex() { return docsContainer.querySelectorAll('.agenda-item').length; }
            function renumberDocs() {
                const items = docsContainer.querySelectorAll('.agenda-item');
                items.forEach((item, i) => {
                    item.dataset.index = i;
                    const title = item.querySelector('.agenda-title');
                    if (title) title.textContent = `Document #${i + 1}`;
                    item.querySelectorAll("input[name]").forEach(el => {
                        el.name = el.name.replace(/Documents\[\d+\]/, `Documents[${i}]`);
                    });
                });
            }

            function addDocument() {
                const i = getNextDocIndex();
                const html = docTpl.innerHTML.replaceAll('__i__', i).replaceAll('__n__', i+1);
                const wrapper = document.createElement('div');
                wrapper.innerHTML = html.trim();
                docsContainer.appendChild(wrapper.firstElementChild);
            }

            function removeDocument(btn) {
                const item = btn.closest('.agenda-item');
                if (item) item.remove();
                renumberDocs();
            }

            btnAddDoc.addEventListener('click', addDocument);
            docsContainer.addEventListener('click', function(e) {
                const btn = e.target.closest('.btnRemoveDocument');
                if (btn) removeDocument(btn);
            });

            if (docsContainer.querySelectorAll('.agenda-item').length === 0) {
                // don't auto-add doc by default
            }
        })();
    </script>

     <partial name="_ValidationScriptsPartial" /> 
</body>
</html>