@model AEMS_Solution.Models.Event.UpdateEventViewModel
@using DataAccess.Enum
@{
    ViewData["Title"] = "Edit Event";
    Layout = "_OrganizerLayout";
}
<style>
        /* Giữ nguyên Style của bản Create để đồng bộ UI */
        .card {
            max-width: 980px;
            margin: 0 auto;
            border: 1px solid #ddd;
            border-radius: 12px;
            padding: 18px;
        }

        .row {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .col {
            flex: 1;
            min-width: 240px;
        }

        label {
            display: block;
            font-weight: 600;
            margin: 10px 0 6px;
        }

        input, select, textarea {
            width: 100%;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 10px;
        }

        textarea {
            min-height: 90px;
            resize: vertical;
        }

        .error {
            color: #b00020;
            font-size: 13px;
            margin-top: 6px;
        }

        .divider {
            height: 1px;
            background: #eee;
            margin: 18px 0;
        }

        .btn {
            border: 0;
            border-radius: 10px;
            padding: 10px 14px;
            cursor: pointer;
        }

        .btn-primary {
            background: #2563eb;
            color: #fff;
        }

        .btn-secondary {
            background: #f3f4f6;
        }

        .btn-danger {
            background: #ef4444;
            color: #fff;
        }

        .agenda-item {
            border: 1px dashed #cbd5e1;
            border-radius: 12px;
            padding: 12px;
            margin-top: 12px;
            background: #f9fafb;
        }

        .agenda-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
        }

        .agenda-title {
            font-weight: 700;
        }

        .actions {
            display: flex;
            gap: 10px;
            margin-top: 16px;
        }

        .checkbox {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 10px;
        }

            .checkbox input {
                width: auto;
            }

        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            background: #e5e7eb;
            margin-bottom: 10px;
        }
    </style>
    <div class="card shadow-sm border-0">
        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
            <div>
                <h2 style="margin:0 0 6px;">Edit Event</h2>
                <div class="status-badge">Current Status: <strong>@Model.Status</strong></div>
            </div>
            <a href="@Url.Action("MyEvents", "Organizer")" class="btn btn-secondary" style="text-decoration: none; font-size: 14px;">← Back to List</a>
        </div>

        <form asp-controller="Event" asp-action="Edit" asp-route-id="@Model.EventId" method="post" id="editEventForm" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            @* Hidden EventId; Status được xử lý theo điều kiện bên dưới *@
            <input type="hidden" asp-for="EventId" />

            @Html.ValidationSummary(excludePropertyErrors: false, message: "", htmlAttributes: new { @class = "text-danger" })

            <label asp-for="Title">Title *</label>
            <input asp-for="Title" />
            <span asp-validation-for="Title" class="error"></span>

            <label asp-for="Description">Description</label>
            <textarea asp-for="Description"></textarea>

            <div class="row">
                <div class="col">
                    <label asp-for="SemesterId">Semester *</label>
                    <select asp-for="SemesterId" asp-items="Model.Semesters">
                        <option value="">-- Select Semester --</option>
                    </select>
                    <span asp-validation-for="SemesterId" class="error"></span>
                </div>

                <div class="col">
                    <label asp-for="DepartmentId">Department</label>
                    <select asp-for="DepartmentId" asp-items="Model.Departments">
                        <option value="">-- Select Department --</option>
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col">
                    <label asp-for="LocationId">Location *</label>
                    <input type="hidden" asp-for="LocationId" id="LocationId" />
                    <div class="position-relative">
                        <input type="text" id="locationSearchInput" class="form-control" placeholder="Tìm kiếm địa điểm (>= 1 ký tự)..." autocomplete="off" value="@(Model.Locations?.FirstOrDefault(l => l.Value == Model.LocationId)?.Text)" />
                        <div id="locationSearchResults" class="position-absolute w-100 bg-white border border-top-0 rounded-bottom shadow-sm z-3" style="display:none; max-height: 200px; overflow-y: auto;"></div>
                    </div>
                    <span asp-validation-for="LocationId" class="error text-danger small"></span>
                </div>

                <div class="col">
                    <label asp-for="TopicId">Topic</label>
                    <select asp-for="TopicId" asp-items="Model.Topics">
                        <option value="">-- Select Topic --</option>
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col">
                    <label asp-for="StartTime">Start Time *</label>
                    <input asp-for="StartTime" type="datetime-local" />
                    <span asp-validation-for="StartTime" class="error"></span>
                </div>
                <div class="col">
                    <label asp-for="EndTime">End Time *</label>
                    <input asp-for="EndTime" type="datetime-local" />
                    <span asp-validation-for="EndTime" class="error"></span>
                </div>
            </div>

            <div class="row">
                <div class="col">
                    <label asp-for="MaxCapacity">Max Capacity *</label>
                    <input asp-for="MaxCapacity" type="number" min="1" />
                </div>
                <div class="col">
                    <label>Event Images (Slideshow)</label>
                    <input asp-for="BannerFiles" type="file" accept="image/*" multiple />
                    <div class="hint">Select multiple images to create a slideshow. The first image will be the primary thumbnail.</div>
                    <div class="hint" style="margin-top: 10px;">Or provide Image URLs (separating by | )</div>
                    <input asp-for="ThumbnailUrl" placeholder="https://url1.jpg|https://url2.jpg" />
                </div>
            </div>

            <div class="row">
                <div class="col">
                    <label asp-for="Type">Event Type</label>
                    <select asp-for="Type" asp-items="Html.GetEnumSelectList<EventTypeEnum>()"></select>
                </div>
                <div class="col">
                    <label>Status</label>
                    @if (Model.Status == EventStatusEnum.Cancelled)
                    {
                        <select asp-for="Status" class="form-select">
                            <option value="@EventStatusEnum.Cancelled">Cancelled</option>
                            <option value="@EventStatusEnum.Draft">Draft</option>
                            <option value="@EventStatusEnum.Pending">Pending</option>
                        </select>
                    }
                    else
                    {
                        <input value="@Model.Status" disabled style="background: #f3f4f6;" />
                        <input type="hidden" asp-for="Status" />
                    }
                </div>
            </div>

            <div class="checkbox">
                <input asp-for="IsDepositRequired" id="IsDepositRequired" />
                <label for="IsDepositRequired" style="margin:0;">Require Deposit</label>
            </div>

            <div class="row" id="depositRow">
                <div class="col">
                    <label asp-for="DepositAmount">Deposit Amount</label>
                    <input asp-for="DepositAmount" type="number" min="0" step="0.01" />
                    <span asp-validation-for="DepositAmount" class="error"></span>
                </div>
            </div>

            <div class="divider"></div>

            <div class="row" style="align-items:center; justify-content:space-between;">
                <h3 style="margin:0;">Event Documents</h3>
                <button type="button" class="btn btn-secondary" id="btnAddDocument">+ Add document</button>
            </div>

            <div id="documentsContainer">
                @for (int i = 0; i < (Model.Documents?.Count ?? 0); i++)
                {
                    <div class="agenda-item" data-index="@i">
                        <div class="agenda-head">
                            <div class="agenda-title">Document #@(i + 1)</div>
                            <button type="button" class="btn btn-danger btnRemoveDocument">Remove</button>
                        </div>

                        <input type="hidden" name="Documents[@i].Id" value="@Model.Documents[i].Id" />

                        <div class="row">
                            <div class="col">
                                <label>File name</label>
                                <input name="Documents[@i].FileName" value="@Model.Documents[i].FileName" />
                            </div>
                            <div class="col">
                                <label>Upload File</label>
                                <input name="Documents[@i].File" type="file" />
                            </div>
                        </div>

                        <label>Or provide Url</label>
                        <input name="Documents[@i].Url" value="@Model.Documents[i].Url" />
                    </div>
                }
            </div>

            <div class="divider"></div>

            <div class="row" style="align-items:center; justify-content:space-between;">
                <h3 style="margin:0;">Event Agendas</h3>
                <button type="button" class="btn btn-secondary" id="btnAddAgenda">+ Add agenda</button>
            </div>

            <div id="agendaContainer">
                @for (int i = 0; i < (Model.Agendas?.Count ?? 0); i++)
                {
                    <div class="agenda-item" data-index="@i">
                        <div class="agenda-head">
                            <div class="agenda-title">Agenda #@(i + 1)</div>
                            <button type="button" class="btn btn-danger btnRemoveAgenda">Remove</button>
                        </div>

                        @* Hidden field cho ID của Agenda cũ *@
                        <input type="hidden" asp-for="Agendas[i].Id" />

                        <div class="row">
                            <div class="col">
                                <label>Session Name</label>
                                <input asp-for="Agendas[i].SessionName" />
                            </div>
                            <div class="col">
                                <label class="d-flex justify-content-between align-items-center">
                                    Speaker
                                    <span class="badge bg-light text-primary border agenda-speaker-role-badge" style="@(string.IsNullOrEmpty(Model.Agendas[i].SpeakerUserRole) ? "display:none;" : "") font-size: 0.7rem;">@Model.Agendas[i].SpeakerUserRole</span>
                                </label>
                                <input type="hidden" asp-for="Agendas[i].SpeakerUserId" class="agenda-speaker-id" />
                                <input type="hidden" asp-for="Agendas[i].SpeakerUserRole" class="agenda-speaker-role" />
                                <div class="position-relative">
                                    <input asp-for="Agendas[i].SpeakerInfo" class="form-control agenda-speaker-search-input" placeholder="Search speaker by name or email..." autocomplete="off" />
                                    <div class="agenda-speaker-search-results position-absolute w-100 bg-white border border-top-0 rounded-bottom shadow-sm z-3" style="display:none; max-height: 200px; overflow-y: auto;"></div>
                                </div>
                            </div>
                        </div>

                        <label>Description</label>
                        <textarea asp-for="Agendas[i].Description"></textarea>

                        <div class="row">
                            <div class="col">
                                <label>Start</label>
                                <input asp-for="Agendas[i].StartTime" type="datetime-local" />
                            </div>
                            <div class="col">
                                <label>End</label>
                                <input asp-for="Agendas[i].EndTime" type="datetime-local" />
                            </div>
                        </div>

                        <div class="col">
                            <label>Location (agenda)</label>
                            <input type="hidden" asp-for="Agendas[i].Location" class="agenda-location-hidden" />
                            <div class="position-relative">
                                <input type="text" class="form-control agenda-location-search-input" placeholder="Để trống nếu giống địa điểm Event..." autocomplete="off" value="@Model.Agendas[i].Location" />
                                <div class="agenda-location-search-results position-absolute w-100 bg-white border border-top-0 rounded-bottom shadow-sm z-3" style="display:none; max-height: 200px; overflow-y: auto;"></div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="actions">
                <button type="submit" class="btn btn-primary" style="padding: 12px 24px; font-weight: bold;">Update Event</button>
                <a asp-controller="Organizer" asp-action="MyEvents" class="btn btn-secondary" style="text-decoration: none; text-align: center;">Cancel</a>
            </div>
        </form>
    </div>

    @* Template cho Agenda mới (giống hệt Create nhưng thêm hidden Id rỗng) *@
    <template id="documentTemplate">
        <div class="agenda-item" data-index="__i__">
            <div class="agenda-head">
                <div class="agenda-title">Document #__n__</div>
                <button type="button" class="btn btn-danger btnRemoveDocument">Remove</button>
            </div>

            <input type="hidden" name="Documents[__i__].Id" value="" />

            <div class="row">
                <div class="col">
                    <label>File name (Optional)</label>
                    <input name="Documents[__i__].FileName" />
                </div>
                <div class="col">
                    <label>Upload File</label>
                    <input name="Documents[__i__].File" type="file" />
                </div>
            </div>

            <label>Or provide Url</label>
            <input name="Documents[__i__].Url" />
        </div>
    </template>

    <template id="agendaTemplate">
        <div class="agenda-item" data-index="__i__">
            <div class="agenda-head">
                <div class="agenda-title">Agenda #__n__</div>
                <button type="button" class="btn btn-danger btnRemoveAgenda">Remove</button>
            </div>

            <input type="hidden" name="Agendas[__i__].Id" value="" />

            <div class="row">
                <div class="col">
                    <label>Session Name</label>
                    <input name="Agendas[__i__].SessionName" />
                </div>
                <div class="col">
                    <label class="d-flex justify-content-between align-items-center">
                        Speaker
                        <span class="badge bg-light text-primary border agenda-speaker-role-badge" style="display:none; font-size: 0.7rem;"></span>
                    </label>
                    <input type="hidden" name="Agendas[__i__].SpeakerUserId" class="agenda-speaker-id" />
                    <input type="hidden" name="Agendas[__i__].SpeakerUserRole" class="agenda-speaker-role" />
                    <div class="position-relative">
                        <input name="Agendas[__i__].SpeakerInfo" class="form-control agenda-speaker-search-input" placeholder="Search speaker by name or email..." autocomplete="off" />
                        <div class="agenda-speaker-search-results position-absolute w-100 bg-white border border-top-0 rounded-bottom shadow-sm z-3" style="display:none; max-height: 200px; overflow-y: auto;"></div>
                    </div>
                </div>
            </div>

            <label>Description</label>
            <textarea name="Agendas[__i__].Description"></textarea>

            <div class="row">
                <div class="col">
                    <label>Start</label>
                    <input name="Agendas[__i__].StartTime" type="datetime-local" />
                </div>
                <div class="col">
                    <label>End</label>
                    <input name="Agendas[__i__].EndTime" type="datetime-local" />
                </div>
            </div>

            <div class="col">
                <label>Location (agenda)</label>
                <input type="hidden" name="Agendas[__i__].Location" class="agenda-location-hidden" />
                <div class="position-relative">
                    <input type="text" class="form-control agenda-location-search-input" placeholder="Để trống nếu giống địa điểm Event..." autocomplete="off" />
                    <div class="agenda-location-search-results position-absolute w-100 bg-white border border-top-0 rounded-bottom shadow-sm z-3" style="display:none; max-height: 200px; overflow-y: auto;"></div>
                </div>
            </div>
        </div>
    </template>

    <style>
        /* Select2 bootstrap compatibility fixes */
        .select2-container--default .select2-selection--single {
            border-radius: 10px;
            height: 42px;
            border: 1px solid #ccc;
            padding: 5px;
        }
        .select2-container .select2-selection--single .select2-selection__rendered {
            line-height: 30px;
        }
        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 40px;
        }
    </style>
@section Scripts {
    <script>
        $(document).ready(function() {
            // Setup autocomplete for main location
            function setupLocationAutocomplete(inputId, resultsId, hiddenId, isMain = true) {
                const input = document.getElementById(inputId);
                const results = document.getElementById(resultsId);
                const hidden = document.getElementById(hiddenId);
                let timer;

                if (input && results) {
                    input.addEventListener('input', function() {
                        clearTimeout(timer);
                        const query = this.value;
                        if (query.length < 1) {
                            results.style.display = 'none';
                            if (query.length === 0) hidden.value = '';
                            return;
                        }

                        timer = setTimeout(() => {
                            fetch(`/api/v1/lookup/locations?q=${encodeURIComponent(query)}`)
                                .then(res => res.json())
                                .then(resp => {
                                    if (!resp.success || !resp.data || resp.data.length === 0) {
                                        results.innerHTML = '<div class="p-2 text-muted small">Không tìm thấy địa điểm</div>';
                                        results.style.display = 'block';
                                        return;
                                    }
                                    
                                    results.innerHTML = resp.data.map(loc => `
                                        <div class="p-2 border-bottom loc-search-item text-dark" style="cursor:pointer;" 
                                             data-id="${loc.id}" data-name="${loc.name}" data-address="${loc.address || ''}">
                                            <div class="fw-semibold small">${loc.name}</div>
                                            <div class="text-muted" style="font-size:0.75rem;">
                                                ${loc.address ? loc.address + ' - ' : ''}Sức chứa: ${loc.capacity}
                                            </div>
                                        </div>
                                    `).join('');
                                    results.style.display = 'block';
                                    
                                    const items = results.querySelectorAll('.loc-search-item');
                                    items.forEach(item => {
                                        item.addEventListener('click', function() {
                                            const locId = this.getAttribute('data-id');
                                            const locName = this.getAttribute('data-name');
                                            const locAddr = this.getAttribute('data-address');
                                            input.value = locAddr ? locAddr : locName;
                                            hidden.value = isMain ? locId : locName;
                                            results.style.display = 'none';
                                        });
                                    });
                                });
                        }, 300);
                    });

                    document.addEventListener('click', function(e) {
                        if(e.target !== input && !results.contains(e.target)) {
                            results.style.display = 'none';
                        }
                    });
                }
            }

            setupLocationAutocomplete('locationSearchInput', 'locationSearchResults', 'LocationId', true);

            // Setup autocomplete for dynamic agendas
            document.addEventListener('input', function(e) {
                if (e.target.classList.contains('agenda-location-search-input')) {
                    const input = e.target;
                    const container = input.closest('.col');
                    const results = container.querySelector('.agenda-location-search-results');
                    const hidden = container.querySelector('.agenda-location-hidden');
                    
                    clearTimeout(input.dataset.timer);
                    
                    const query = input.value;
                    if (query.length < 1) {
                        results.style.display = 'none';
                        if (query.length === 0) hidden.value = '';
                        return;
                    }

                    input.dataset.timer = setTimeout(() => {
                        fetch(`/api/v1/lookup/locations?q=${encodeURIComponent(query)}`)
                            .then(res => res.json())
                            .then(resp => {
                                if (!resp.success || !resp.data || resp.data.length === 0) {
                                    results.innerHTML = '<div class="p-2 text-muted small">Không tìm thấy địa điểm</div>';
                                    results.style.display = 'block';
                                    return;
                                }
                                
                                results.innerHTML = resp.data.map(loc => `
                                    <div class="p-2 border-bottom loc-search-item text-dark" style="cursor:pointer;" 
                                         data-name="${loc.name}" data-address="${loc.address || ''}">
                                        <div class="fw-semibold small">${loc.name}</div>
                                        <div class="text-muted" style="font-size:0.75rem;">
                                            ${loc.address ? loc.address + ' - ' : ''}Sức chứa: ${loc.capacity}
                                        </div>
                                    </div>
                                `).join('');
                                results.style.display = 'block';
                                
                                const items = results.querySelectorAll('.loc-search-item');
                                items.forEach(item => {
                                    item.addEventListener('click', function() {
                                        const locName = this.getAttribute('data-name');
                                        const locAddr = this.getAttribute('data-address');
                                        input.value = locAddr ? locAddr : locName;
                                        hidden.value = locName;
                                        results.style.display = 'none';
                                    });
                                });
                            });
                    }, 300);
                }

                // Agenda Speaker Search
                if (e.target.classList.contains('agenda-speaker-search-input')) {
                    const input = e.target;
                    const container = input.closest('.col');
                    const results = container.querySelector('.agenda-speaker-search-results');
                    const userIdInput = container.querySelector('.agenda-speaker-id');
                    const userRoleInput = container.querySelector('.agenda-speaker-role');
                    const roleBadge = container.querySelector('.agenda-speaker-role-badge');
                    
                    clearTimeout(input.dataset.timer);
                    const query = input.value;
                    
                    if (query.length < 1) {
                        results.style.display = 'none';
                        if (query.length === 0) {
                            if (userIdInput) userIdInput.value = '';
                            if (userRoleInput) userRoleInput.value = '';
                            if (roleBadge) roleBadge.style.display = 'none';
                        }
                        return;
                    }

                    input.dataset.timer = setTimeout(() => {
                        fetch(`/api/v1/lookup/users?q=${encodeURIComponent(query)}`)
                            .then(res => res.json())
                            .then(resp => {
                                if (!resp.success || !resp.data || resp.data.length === 0) {
                                    results.innerHTML = '<div class="p-2 text-muted small">Không tìm thấy ai</div>';
                                    results.style.display = 'block';
                                    return;
                                }
                                
                                results.innerHTML = resp.data.map(user => `
                                    <div class="p-2 border-bottom agenda-search-item text-dark" style="cursor:pointer;" 
                                         data-id="${user.id}" data-role="${user.role}" data-name="${user.fullName}" data-email="${user.email}">
                                        <div class="fw-semibold small">${user.fullName}</div>
                                        <div class="text-muted" style="font-size:0.75rem;">${user.email} <span class="badge bg-light text-primary border">${user.role}</span></div>
                                    </div>
                                `).join('');
                                results.style.display = 'block';
                                
                                const items = results.querySelectorAll('.agenda-search-item');
                                items.forEach(item => {
                                    item.addEventListener('click', function() {
                                        const uid = this.getAttribute('data-id');
                                        const urole = this.getAttribute('data-role');
                                        const uname = this.getAttribute('data-name');
                                        
                                        input.value = uname;
                                        if (userIdInput) userIdInput.value = uid;
                                        if (userRoleInput) userRoleInput.value = urole;
                                        if (roleBadge) {
                                            roleBadge.textContent = urole;
                                            roleBadge.style.display = 'inline-block';
                                        }
                                        results.style.display = 'none';
                                    });
                                });
                            });
                    }, 300);
                }
            });

            document.addEventListener('click', function(e) {
                if (!e.target.classList.contains('agenda-location-search-input') && !e.target.closest('.agenda-location-search-results')) {
                    document.querySelectorAll('.agenda-location-search-results').forEach(el => el.style.display = 'none');
                }
                if (!e.target.classList.contains('agenda-speaker-search-input') && !e.target.closest('.agenda-speaker-search-results')) {
                    document.querySelectorAll('.agenda-speaker-search-results').forEach(el => el.style.display = 'none');
                }
            });

            // Initialize Select2 for Topic
            $('#TopicId').select2({
                placeholder: "-- Select Topic --",
                allowClear: true,
                ajax: {
                    url: '/api/v1/lookup/topics',
                    dataType: 'json',
                    delay: 250,
                    data: function (params) {
                        return { q: params.term };
                    },
                    processResults: function (data) {
                        return {
                            results: data.data.map(item => ({
                                id: item.id,
                                text: item.name
                            }))
                        };
                    },
                    cache: true
                }
            });
        });

        (function () {
            const agendaContainer = document.getElementById("agendaContainer");
            const tpl = document.getElementById("agendaTemplate");
            const btnAdd = document.getElementById("btnAddAgenda");
            const isDeposit = document.getElementById("IsDepositRequired");
            const depositRow = document.getElementById("depositRow");

            // 1. Xử lý ẩn/hiện tiền cọc
            function updateDepositUI() {
                if (depositRow) {
                    depositRow.style.display = isDeposit.checked ? "flex" : "none";
                }
            }
            updateDepositUI();
            isDeposit.addEventListener("change", updateDepositUI);

            // 2. Hàm đánh lại chỉ số (Index) cho các input
            function renumber() {
                const items = agendaContainer.querySelectorAll(".agenda-item");
                items.forEach((item, i) => {
                    item.dataset.index = i;
                    const title = item.querySelector(".agenda-title");
                    if (title) title.textContent = `Agenda #${i + 1}`;

                    // Cập nhật tất cả các thuộc tính name: Agendas[0] -> Agendas[i]
                    item.querySelectorAll("input, textarea, select").forEach(el => {
                        if (el.name) {
                            el.name = el.name.replace(/Agendas\[\d+\]/, `Agendas[${i}]`);
                        }
                        // Cập nhật cả ID để tránh trùng lặp nếu cần dùng label
                        if (el.id) {
                            el.id = el.id.replace(/Agendas_\d+__/, `Agendas_${i}__`);
                        }
                    });
                });
            }

            // 3. Hàm thêm mới Agenda
            function addAgenda() {
                const i = agendaContainer.querySelectorAll(".agenda-item").length;
                // Thay thế placeholder trong template
                let html = tpl.innerHTML.replace(/__i__/g, i).replace(/__n__/g, i + 1);

                const wrapper = document.createElement("div");
                wrapper.innerHTML = html.trim();
                const newNode = wrapper.firstElementChild;

                agendaContainer.appendChild(newNode);
                // Không cần gọi renumber ở đây vì index đã được set đúng lúc add
            }

            // 4. Sự kiện nút Add
            btnAdd.addEventListener("click", function(e) {
                e.preventDefault(); // Ngăn chặn submit form ngoài ý muốn
                addAgenda();
            });

            // 5. Sự kiện nút Remove (Event Delegation)
            agendaContainer.addEventListener("click", function (e) {
                if (e.target.classList.contains("btnRemoveAgenda")) {
                    e.preventDefault();
                    const item = e.target.closest(".agenda-item");
                    item.remove();
                    renumber();
                }
            });

            // 6. Tự động thêm dòng đầu tiên nếu danh sách trống
            if (agendaContainer.querySelectorAll(".agenda-item").length === 0) {
                addAgenda();
            }
            // Documents UI Logic
            const docsContainer = document.getElementById("documentsContainer");
            const btnAddDoc = document.getElementById("btnAddDocument");
            const docTpl = document.getElementById("documentTemplate");

            function renumberDocs() {
                const items = docsContainer.querySelectorAll(".agenda-item");
                items.forEach((item, i) => {
                    item.dataset.index = i;
                    const title = item.querySelector(".agenda-title");
                    if (title) title.textContent = `Document #${i + 1}`;

                    item.querySelectorAll("input").forEach(el => {
                        if (el.name) {
                            el.name = el.name.replace(/Documents\[\d+\]/, `Documents[${i}]`);
                        }
                    });
                });
            }

            function addDocument() {
                const i = docsContainer.querySelectorAll(".agenda-item").length;
                let html = docTpl.innerHTML.replace(/__i__/g, i).replace(/__n__/g, i + 1);
                const wrapper = document.createElement("div");
                wrapper.innerHTML = html.trim();
                docsContainer.appendChild(wrapper.firstElementChild);
            }

            if (btnAddDoc) {
                btnAddDoc.addEventListener("click", function (e) {
                    e.preventDefault();
                    addDocument();
                });
            }

            if (docsContainer) {
                docsContainer.addEventListener("click", function (e) {
                    if (e.target.classList.contains("btnRemoveDocument")) {
                        e.preventDefault();
                        e.target.closest(".agenda-item").remove();
                        renumberDocs();
                    }
                });
            }

        })(); // Kết thúc IIFE
    </script>

    <partial name="_ValidationScriptsPartial" />
}
