        <tbody>
            @foreach (var e in Model.Events)
            {
                <tr>
                    <td style="width:120px">
                        @if (!string.IsNullOrEmpty(e.ThumbnailUrl))
                        {
                            <img src="@e.ThumbnailUrl" class="img-fluid rounded" />
                        }
                    </td>

                    <td>
                        <strong>@e.Title</strong>
                    </td>

                    <td>@e.SemesterName</td>
                    <td>@e.DepartmentName</td>
                    <td>@e.Location</td>

                    <td class="event-time" data-start="@e.StartTime.ToString("o")" data-end="@e.EndTime.ToString("o")">
                        <span class="start">@e.StartTime.ToString("dd/MM/yyyy HH:mm")</span>
                        <br />
                        →
                        <br />
                        <span class="end">@e.EndTime.ToString("dd/MM/yyyy HH:mm")</span>
                    </td>

                    <td>
                        @e.RegisteredCount / @e.MaxCapacity
                    </td>

                    <td>
                        <span class="workflow-badge badge bg-secondary">@e.Status</span>
                    </td>
                    <td>
                        @e.Mode
                    </td>

                    <td style="max-width:200px; word-break:break-all;">
                        @if (!string.IsNullOrEmpty(e.MeetingUrl))
                        {
                            <a href="@e.MeetingUrl" target="_blank">Link</a>
                        }
                    </td>
                    <td>
                        <span class="time-badge badge bg-light text-dark">--</span>
                    </td>

                    <td>
                        🎟 @e.RegisteredCount <br />
                        ✅ @e.CheckedInCount <br />
                        ⏳ @e.WaitlistCount <br />
                        ⭐ @e.AvgRating.ToString("0.0")
                    </td>

                    <td>
                        <a href="#" data-url="@Url.Action("Manage", "Organizer", new { operation = "detailevent", id = e.EventId })" class="btn btn-sm btn-info view-detail">View</a>
                        <a class="btn btn-sm btn-secondary ms-1" asp-controller="EventWaitlist" asp-action="Index" asp-route-eventId="@e.EventId"> Waitlist </a>
                        <a asp-action="Edit" asp-route-id="@e.EventId"
                           class="btn btn-sm btn-warning">Edit</a>
                        @if (e.Status == EventStatusEnum.Draft || e.Status == EventStatusEnum.Pending || e.Status == EventStatusEnum.Rejected)
                        {
                            <form asp-controller="Organizer" asp-action="Manage" method="post" class="d-inline ms-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="operation" value="sendforapproval" />
                                <input type="hidden" name="id" value="@e.EventId" />
                                <button type="submit" class="btn btn-sm btn-primary">Send</button>
                            </form>
                        }
                        <form asp-controller="Organizer" asp-action="Manage" method="post" class="d-inline ms-1">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="operation" value="softdelete" />
                            <input type="hidden" name="id" value="@e.EventId" />
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Bạn có chắc muốn xóa sự kiện này?');">Delete</button>
                        </form>

                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Pagination">
            <ul class="pagination">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="MyEvents" asp-controller="Organizer" asp-route-page="@(Model.Page - 1)" asp-route-search="@Model.Search" asp-route-status="@Model.Status">Previous</a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="MyEvents" asp-controller="Organizer"
                           asp-route-page="@i"
                           asp-route-search="@Model.Search"
                           asp-route-status="@Model.Status"
                           asp-route-dateFrom="@(Model.DateFrom.HasValue ? Model.DateFrom.Value.ToString("yyyy-MM-dd") : "")"
                           asp-route-dateTo="@(Model.DateTo.HasValue? Model.DateTo.Value.ToString("yyyy-MM-dd") : "")">@i</a>
                    </li>
                }

                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="MyEvents" asp-controller="Organizer" asp-route-page="@(Model.Page + 1)" asp-route-search="@Model.Search" asp-route-status="@Model.Status">Next</a>
                </li>
            </ul>
        </nav>
        <div class="text-muted">Page @Model.Page of @Model.TotalPages (@Model.TotalItems total items)</div>
    }
    @section Scripts {
        <script>
            (function () {
                function update() {
                    const now = new Date();

                    document.querySelectorAll('.event-time').forEach(el => {
                        const startIso = el.getAttribute('data-start');
                        const endIso = el.getAttribute('data-end');
                        if (!startIso || !endIso) return;

                        const start = new Date(startIso);
                        const end = new Date(endIso);

                        const row = el.closest('tr');
                        if (!row) return;

                        // ✅ chỉ update Time State badge
                        const timeBadge = row.querySelector('.time-badge');
                        if (!timeBadge) return;

                        if (now < start) {
                            timeBadge.textContent = 'Upcoming';
                            timeBadge.className = 'time-badge badge bg-warning text-dark';
                        } else if (now >= start && now <= end) {
                            timeBadge.textContent = 'Happening';
                            timeBadge.className = 'time-badge badge bg-info text-dark';
                        } else {
                            timeBadge.textContent = 'Completed';
                            timeBadge.className = 'time-badge badge bg-secondary text-dark';
                        }
                    });
                }

                update();
                setInterval(update, 30 * 1000);
            })();
        </script>
        <script>
            (function () {
                document.querySelectorAll('.view-detail').forEach(btn => {
                    btn.addEventListener('click', function (e) {
                        e.preventDefault();
                        var url = btn.getAttribute('data-url');
                        if (!url) return;
                        // open detail in new window/tab
                        window.location.href = url;
                    });
                });
            })();
        </script>
        <script>
            (function () {
                const header = document.getElementById('time-header');
                const popup = document.getElementById('date-filter-popup');
                const applyBtn = document.getElementById('popup-apply');
                const clearBtn = document.getElementById('popup-clear');
                const inputFrom = document.getElementById('popup-date-from');
                const inputTo = document.getElementById('popup-date-to');

                const params = new URLSearchParams(window.location.search);
                if (params.get('dateFrom')) inputFrom.value = params.get('dateFrom');
                if (params.get('dateTo')) inputTo.value = params.get('dateTo');

                header.addEventListener('click', function (e) {
                    e.stopPropagation();
                    popup.style.display = popup.style.display === 'none' ? 'block' : 'none';
                });

                document.addEventListener('click', function () {
                    popup.style.display = 'none';
                });

                popup.addEventListener('click', function (e) {
                    e.stopPropagation();
                });

                applyBtn.addEventListener('click', function () {
                    const url = new URL(window.location.href);
                    if (inputFrom.value) url.searchParams.set('dateFrom', inputFrom.value);
                    else url.searchParams.delete('dateFrom');
                    if (inputTo.value) url.searchParams.set('dateTo', inputTo.value);
                    else url.searchParams.delete('dateTo');
                    url.searchParams.set('page', '1');
                    window.location.href = url.toString();
                });

                clearBtn.addEventListener('click', function () {
                    const url = new URL(window.location.href);
                    url.searchParams.delete('dateFrom');
                    url.searchParams.delete('dateTo');
                    url.searchParams.set('page', '1');
                    window.location.href = url.toString();
                });
            })();
        </script>
