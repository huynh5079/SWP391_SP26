@model AEMS_Solution.Models.Organizer.Manage.MyEventsViewModel
@using DataAccess.Enum
@{
    ViewData["Title"] = "My And Public Events";
    Layout = "_Organizerlayout";

    string StatusClass(EventStatusEnum status) => status switch
    {
        EventStatusEnum.Draft => "bg-secondary",
        EventStatusEnum.Pending => "bg-warning text-dark",
        EventStatusEnum.Approved => "bg-success",
        EventStatusEnum.Rejected => "bg-danger",
        EventStatusEnum.Published => "bg-info text-dark",
        EventStatusEnum.Upcoming => "bg-primary",
        EventStatusEnum.Happening => "bg-info text-dark",
        EventStatusEnum.Completed => "bg-success",
        EventStatusEnum.Cancelled => "bg-dark",
        _ => "bg-secondary"
    };
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">📅 My Events</h2>
        <a asp-controller="Organizer" asp-action="Manage" asp-route-operation="create"
            class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Create Event
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form class="row g-2 mb-3" method="get" asp-controller="Organizer" asp-action="MyEvents">
        <div class="col-auto">
            <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search title..." />
        </div>

        <div class="col-auto">
            @{
                var statuses = new[] { "Draft", "Pending", "Approved", "Rejected", "Published", "Upcoming", "Happening",
            "Completed", "Cancelled", "Expired" };
            }
            <select name="status" class="form-select">
                <option value="">All Status</option>
                @foreach (var s in statuses)
                {
                    <option value="@s" selected="@((Model.Status?.ToString() == s) ? "selected" : null)">@s</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <button class="btn btn-primary">Filter</button>
        </div>
    </form>

    <table class="table table-bordered table-hover shadow">
        <thead class="table-dark">
            <tr>
                <th>Thumbnail</th>
                <th>Title</th>
                <th>Source</th>
                <th>Location</th>
                <th>Time</th>
                <th>Status</th>
                <th class="text-center">Action</th>
                <th style="width: 200px;">Event Performance</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model.Events)
            {
                var isMatch = !string.IsNullOrEmpty(Model.Search) && e.Title.Contains(Model.Search,
                StringComparison.OrdinalIgnoreCase);
                <tr class="@(isMatch ? "table-warning" : "")">
                    <td style="width:120px">
                        @if (!string.IsNullOrEmpty(e.ThumbnailUrl))
                        {
                            <img src="@e.ThumbnailUrl" class="img-fluid rounded" />
                        }
                    </td>

                    <td>
                        <strong>@e.Title</strong>
                    </td>

                    <td>
                        @if (e.IsOwnedByCurrentUser)
                        {
                            <span class="badge bg-primary">My Event</span>
                        }
                        else
                        {
                            <span class="badge bg-info text-dark">Public</span>
                            <div class="small text-muted mt-1">@(string.IsNullOrWhiteSpace(e.OrganizerName) ? "Organizer khác" :
                        e.OrganizerName)</div>
                        }
                    </td>

                    <td>@e.Location</td>

                    <td class="event-time" data-start="@e.StartTime.ToString("o")" data-end="@e.EndTime.ToString("o")">
                        <span class="start">@e.StartTime.ToString("dd/MM/yyyy HH:mm")</span>
                        <br />
                        →
                        <br />
                        <span class="end">@e.EndTime.ToString("dd/MM/yyyy HH:mm")</span>
                    </td>

                    <td>
                        <span class="workflow-badge badge @StatusClass(e.Status)">@e.Status</span>
                    </td>

                    <td class="text-center align-middle">
                        <div class="d-flex flex-wrap gap-1 justify-content-center align-items-center"
                            style="max-width: 320px; margin: 0 auto;">
                            <style>
                                .action-pill {
                                    min-width: 90px;
                                    text-align: center;
                                }
                            </style>
                            <a class="btn btn-sm btn-info fw-semibold" asp-controller="Organizer" asp-action="Manage"
                                asp-route-operation="detailevent" asp-route-id="@e.EventId">View</a>
                            @if (e.IsOwnedByCurrentUser)
                            {
                                @if (e.CanEdit)
                                {
                                    <a asp-action="Edit" asp-route-id="@e.EventId"
                                        class="btn btn-sm btn-warning fw-semibold">Edit</a>
                                }
                                @if (e.CanPublish)
                                {
                                    <form asp-controller="Organizer" asp-action="Manage" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="operation" value="publish" />
                                        <input type="hidden" name="id" value="@e.EventId" />
                                        <button type="submit" class="btn btn-sm btn-success fw-semibold action-pill">Public</button>
                                    </form>
                                }
                                @if (e.CanSendForApproval)
                                {
                                    <form asp-controller="Organizer" asp-action="Manage" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="operation" value="sendforapproval" />
                                        <input type="hidden" name="id" value="@e.EventId" />
                                        <button type="submit" class="btn btn-sm btn-primary fw-semibold action-pill">Send</button>
                                    </form>
                                }
                                <a class="btn btn-sm btn-secondary fw-semibold action-pill" asp-controller="EventWaitlist"
                                    asp-action="Index" asp-route-eventId="@e.EventId">Waitlist</a>
                                @if (e.Status != EventStatusEnum.Cancelled && e.Status != EventStatusEnum.Completed)
                                {
                                    <a class="btn btn-sm btn-success fw-semibold action-pill" asp-controller="BudgetProposal"
                                        asp-action="Detail" asp-route-eventId="@e.EventId">
                                        <i class="bi bi-cash-stack me-1"></i>Budget
                                    </a>
                                }

                                @if (e.CanCancel)
                                {
                                    <form asp-controller="Organizer" asp-action="Manage" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="operation" value="cancel" />
                                        <input type="hidden" name="id" value="@e.EventId" />
                                        <button type="submit"
                                            class="btn btn-sm btn-outline-danger fw-semibold action-pill">Cancel</button>
                                    </form>
                                }

                                <form asp-controller="Organizer" asp-action="Manage" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="operation" value="reanalyze-sentiment" />
                                    <input type="hidden" name="id" value="@e.EventId" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary fw-semibold action-pill"
                                        title="Analyze sentiment for existing feedback">
                                        <i class="bi bi-arrow-repeat me-1"></i>Sync
                                    </button>
                                </form>
                                <form asp-controller="Organizer" asp-action="Manage" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="operation" value="softdelete" />
                                    <input type="hidden" name="id" value="@e.EventId" />
                                    <button type="submit" class="btn btn-sm btn-danger fw-semibold action-pill"
                                        onclick="return confirm('Bạn có chắc muốn xóa sự kiện này?');">Delete</button>
                                </form>
                            }

                        </div>
                    <td class="text-center align-middle">
                        <div style="height: 120px; width: 180px; margin: 0 auto;">
                                @if (e.AvgRating > 0 || e.GeneralSentimentAvg > 0 || e.TechnicalAvg > 0 || e.ContentAvg > 0 || e.InstructorAvg > 0 || e.AssessmentAvg > 0)
                                {
                                <canvas id="chart-@e.EventId"></canvas>
                                }
                                else
                                {
                                <div class="h-100 d-flex align-items-center justify-content-center">
                                    <small class="text-muted">No data</small>
                                </div>
                                }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Pagination">
            <ul class="pagination">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="MyEvents" asp-controller="Organizer" asp-route-page="@(Model.Page - 1)"
                        asp-route-search="@Model.Search" asp-route-status="@Model.Status">Previous</a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="MyEvents" asp-controller="Organizer" asp-route-page="@i"
                            asp-route-search="@Model.Search" asp-route-status="@Model.Status">@i</a>
                    </li>
                }

                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="MyEvents" asp-controller="Organizer" asp-route-page="@(Model.Page + 1)"
                        asp-route-search="@Model.Search" asp-route-status="@Model.Status">Next</a>
                </li>
            </ul>
        </nav>
        <div class="text-muted">Page @Model.Page of @Model.TotalPages (@Model.TotalItems total items)</div>
    }
    @section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
            @foreach (var e in Model.Events.Where(x => x.AvgRating > 0 || x.GeneralSentimentAvg > 0 || x.TechnicalAvg > 0 || x.ContentAvg > 0 || x.InstructorAvg > 0 || x.AssessmentAvg > 0))
            {
                <text>
                            (function() {
                                        const ctx = document.getElementById('chart-@e.EventId').getContext('2d');
                            new Chart(ctx, {
                                type: 'bar',
                            data: {
                                labels: ['Tech', 'Content', 'Inst', 'Assess', 'Gen'],
                            datasets: [{
                                label: 'Sentiment Score',
                            data: [
                    @e.TechnicalAvg.ToString("F2"),
                    @e.ContentAvg.ToString("F2"),
                    @e.InstructorAvg.ToString("F2"),
                    @e.AssessmentAvg.ToString("F2"),
                    @e.GeneralSentimentAvg.ToString("F2")
                            ],
                            backgroundColor: [
                            'rgba(255, 99, 132, 0.7)',
                            'rgba(54, 162, 235, 0.7)',
                            'rgba(255, 206, 86, 0.7)',
                            'rgba(75, 192, 192, 0.7)',
                            'rgba(153, 102, 255, 0.7)'
                            ],
                            borderRadius: 4
                                                }]
                                            },
                            options: {
                                indexAxis: 'x',
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {display: false },
                            tooltip: {enabled: true }
                                                },
                            scales: {
                                y: {
                                beginAtZero: true,
                            max: 10,
                            ticks: {display: false },
                            grid: {display: false }
                                                    },
                            x: {
                                ticks: {font: {size: 9 } },
                            grid: {display: false }
                                                    }
                                                }
                                            }
                                        });
                                    })();
                </text>
            }
                    });
        </script>
        <script>
            (function () {
                document.querySelectorAll('.view-detail').forEach(btn => {
                    btn.addEventListener('click', function (e) {
                        e.preventDefault();
                        var url = btn.getAttribute('data-url');
                        if (!url) return;
                        // open detail in new window/tab
                        window.location.href = url;
                    });
                });
            })();
        </script>
        <script>
            // Khởi tạo tooltip cho nút Budget disabled
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => {
                new bootstrap.Tooltip(el);
            });

            (function () {
                document.querySelectorAll('.view-detail').forEach(btn => {
                    btn.addEventListener('click', function (e) {
                        e.preventDefault();
                        var url = btn.getAttribute('data-url');
                        if (!url) return;
                        window.location.href = url;
                    });
                });
            })();
        </script>

    }
</div>

@functions {
    // Returns true if the event status allows creating a budget
    public bool CanCreateBudget(EventStatusEnum status)
    {
        // Example logic: allow budget creation only for Draft and Pending statuses
        return status == EventStatusEnum.Draft || status == EventStatusEnum.Pending || status == EventStatusEnum.Approved;
    }
}