<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AEMS_Solution</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AEMS_Solution.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css">
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <link rel="stylesheet" href="~/css/chatbot.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/messenger-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/organizer-dashboard.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
</head>
<<body>
    <!-- Sidebar -->
    <aside class="organizer-sidebar">
        <a href="@Url.Action("Index", "Organizer")" class="brand-wrapper">
            <div class="brand-icon-box">
                <i class="bi bi-grid-fill"></i>
            </div>
            <div class="brand-text">
                <span class="brand-title">AEMS</span>
                <span class="brand-subtitle">DIGITAL CONCIERGE</span>
            </div>
        </a>

        <ul class="sidebar-nav">
            @{
                var currentCtrl = ViewContext.RouteData.Values["Controller"]?.ToString();
                var currentAct = ViewContext.RouteData.Values["Action"]?.ToString();
                var operation = Context.Request.Query["operation"].ToString() ?? "";
            }
            <li class="nav-item">
                <a href="@Url.Action("Index", "Organizer")" class="nav-link @(currentCtrl == "Organizer" && currentAct == "Index" ? "active" : "")">
                    <i class="bi bi-grid-1x2-fill"></i>
                    Home
                </a>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("Manage", "Organizer", new { operation = "create" })" class="nav-link @(currentCtrl == "Organizer" && currentAct == "Manage" && operation == "create" ? "active" : "")">
                    <i class="bi bi-plus-circle"></i>
                    Create Event
                </a>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("Manage", "Organizer")" class="nav-link @(currentCtrl == "Event" || (currentCtrl == "Organizer" && currentAct == "Manage" && operation != "create") ? "active" : "")">
                    <i class="bi bi-calendar-check"></i>
                    Manage
                </a>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("MyEvents", "Organizer")" class="nav-link @(currentCtrl == "Organizer" && currentAct == "MyEvents" ? "active" : "")">
                    <i class="bi bi-calendar4-event"></i>
                    My Events
                </a>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("Index", "Topic")" class="nav-link @(currentCtrl == "Topic" ? "active" : "")">
                    <i class="bi bi-diagram-3"></i>
                    Topics
                </a>
            </li>
            <li class="nav-item mt-auto">
                <a href="#" class="nav-link">
                    <i class="bi bi-gear"></i>
                    Settings
                </a>
            </li>
        </ul>

        <div class="new-event-btn-wrapper">
            <a href="@Url.Action("Manage", "Organizer", new { operation = "create" })" class="btn-sidebar-primary">
                <i class="bi bi-plus"></i> New Event
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="main-wrapper">
        <!-- Top Header -->
        <header class="top-header">
            <div class="search-container">
                <i class="bi bi-search"></i>
                <input type="text" class="search-input" placeholder="Search events...">
            </div>

            <div class="header-actions">
                <i class="bi bi-bell-fill header-icon">
                    <span class="notification-badge"></span>
                </i>
                <i class="bi bi-question-circle-fill header-icon"></i>
                
                <a href="#" class="support-link">Support</a>

                <div class="user-profile dropdown" data-bs-toggle="dropdown" aria-expanded="false">
                    <div class="user-details">
                        <span class="user-name">@(User.Identity?.Name?.Split('@')[0] ?? "Alex Morgan")</span>
                        <span class="user-role">Event Manager</span>
                    </div>
                    <img src="https://ui-avatars.com/api/?name=@(User.Identity?.Name ?? "Alex+Morgan")&background=e0e7ff&color=4f46e5" alt="User" class="user-avatar">
                    
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                        <li><a class="dropdown-item" asp-controller="Profile" asp-action="Index">Profile</a></li>
                        <li><a class="dropdown-item" asp-controller="Auth" asp-action="ChangePassword">Change Password</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="dropdown-item text-danger">Logout</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <main role="main" class="page-content">
            <partial name="_Notification" />
            @RenderBody()
        </main>
    </div>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <partial name="_ChatbotBar" />
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/site.js?v=3" asp-append-version="true"></script>
    <script src="~/js/chatbot.js" asp-append-version="true"></script>
    <script src="~/js/messenger-layout.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
