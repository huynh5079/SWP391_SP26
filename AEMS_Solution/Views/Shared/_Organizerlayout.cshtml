<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AEMS_Solution</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AEMS_Solution.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css">
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <link rel="stylesheet" href="~/css/chatbot.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/messenger-layout.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
</head>
<body>
    <header>
        <nav class="aems-navbar navbar navbar-expand-lg" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); box-shadow: 0 2px 20px rgba(0,0,0,0.4); padding: 0.6rem 0;">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold text-white d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index"
                   style="font-size:1.3rem; letter-spacing:0.04em;">
                    <span style="background:linear-gradient(135deg,#6366f1,#8b5cf6); border-radius:8px; width:32px; height:32px; display:inline-flex; align-items:center; justify-content:center;">
                        <i class="bi bi-calendar-event-fill text-white" style="font-size:.85rem;"></i>
                    </span>
                    AEMS
                </a>
                <button class="navbar-toggler border-0 text-white" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <i class="bi bi-list" style="font-size:1.5rem;"></i>
                </button>
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link px-3 text-white opacity-80 fw-medium" asp-controller="Home" asp-action="Index" style="font-size:.9rem;">
                                <i class="bi bi-house-door me-1"></i>Home
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle px-3 text-white opacity-80 fw-medium" href="#" id="organizerCreateDropdown"
                               role="button" data-bs-toggle="dropdown" style="font-size:.9rem;">
                                <i class="bi bi-plus-circle me-1"></i>Create
                            </a>
                            <ul class="dropdown-menu shadow-lg border-0 mt-2 aems-dropdown" aria-labelledby="organizerCreateDropdown"
                                style="background:rgba(15,23,42,.97); backdrop-filter:blur(16px); border-radius:12px; min-width:220px; padding:.5rem;">
                                <li><a class="dropdown-item aems-dd-item" asp-controller="Organizer" asp-action="Manage" asp-route-operation="create"><i class="bi bi-calendar-plus me-2"></i>Create Event</a></li>
                                <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.1); margin:.4rem .8rem;"></li>
                                <li class="dropdown-submenu position-relative">
                                    <a class="dropdown-item aems-dd-item aems-submenu-toggle d-flex align-items-center justify-content-between" href="#">
                                        <span><i class="bi bi-patch-question me-2"></i>Create Quiz</span>
                                        <i class="bi bi-chevron-right small"></i>
                                    </a>
                                    <ul class="dropdown-menu shadow-lg border-0 aems-dropdown aems-submenu"
                                        style="background:rgba(15,23,42,.97); backdrop-filter:blur(16px); border-radius:12px; min-width:220px; padding:.5rem;">
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="EventQuiz" asp-action="Create" asp-route-mode="manual"><i class="bi bi-pencil-square me-2"></i>Manual</a></li>
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="EventQuiz" asp-action="Create" asp-route-mode="upload"><i class="bi bi-upload me-2"></i>Upload File</a></li>
                                    </ul>
                                </li>
                            </ul>
                        </li>
                        <!-- Manage Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle px-3 text-white opacity-80 fw-medium" href="#" id="organizerManageDropdown"
                               role="button" data-bs-toggle="dropdown" style="font-size:.9rem;">
                                <i class="bi bi-grid me-1"></i>Manage
                            </a>
                            <ul class="dropdown-menu shadow-lg border-0 mt-2 aems-dropdown" aria-labelledby="organizerManageDropdown"
                                style="background:rgba(15,23,42,.97); backdrop-filter:blur(16px); border-radius:12px; min-width:230px; padding:.5rem;">
                                <li><a class="dropdown-item aems-dd-item" asp-controller="Organizer" asp-action="MyEvents"><i class="bi bi-calendar-check me-2"></i>My Events</a></li>
                                <li><a class="dropdown-item aems-dd-item" asp-controller="Organizer" asp-action="Manage" asp-route-operation="myeventsdelete"><i class="bi bi-trash me-2"></i>Deleted Events</a></li>
                                <li><a class="dropdown-item aems-dd-item" asp-controller="Event" asp-action="ExpiredEvent"><i class="bi bi-clock-history me-2"></i>Expired Events</a></li>
                                <li><a class="dropdown-item aems-dd-item" asp-controller="Organizer" asp-action="MyParticipatedEvents"><i class="bi bi-person-workspace me-2"></i>S&#7921; ki&#7879;n tham gia</a></li>
                                <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.1); margin:.4rem .8rem;"></li>
                                <li><a class="dropdown-item aems-dd-item" asp-controller="EventAgenda" asp-action="MyAgenda"><i class="bi bi-list-task me-2"></i>Agenda</a></li>
                                <li><a class="dropdown-item aems-dd-item" asp-controller="Organizer" asp-action="Manage" asp-route-operation="manageticket"><i class="bi bi-ticket me-2"></i>Manage Tickets</a></li>
                                <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.1); margin:.4rem .8rem;"></li>
                                <li><a class="dropdown-item aems-dd-item" asp-controller="Topic" asp-action="Index"><i class="bi bi-tags me-2"></i>Topics</a></li>
                                <li><a class="dropdown-item aems-dd-item" asp-controller="Location" asp-action="Index"><i class="bi bi-geo-alt me-2"></i>Locations</a></li>
                                <li class="dropdown-submenu position-relative">
                                    <a class="dropdown-item aems-dd-item aems-submenu-toggle d-flex align-items-center justify-content-between" href="#">
                                        <span><i class="bi bi-question-circle me-2"></i>Quiz</span>
                                        <i class="bi bi-chevron-right small"></i>
                                    </a>
                                    <ul class="dropdown-menu shadow-lg border-0 aems-dropdown aems-submenu"
                                        style="background:rgba(15,23,42,.97); backdrop-filter:blur(16px); border-radius:12px; min-width:220px; padding:.5rem;">
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="EventQuiz" asp-action="Index" asp-route-scope="myquiz"><i class="bi bi-person-workspace me-2"></i>My Quiz</a></li>
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="EventQuiz" asp-action="Index" asp-route-scope="community"><i class="bi bi-people me-2"></i>Quiz Community</a></li>
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="EventQuiz" asp-action="QuestionBank"><i class="bi bi-collection me-2"></i>Quiz Bank</a></li>
                                    </ul>
                                </li>
                            </ul>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto d-flex flex-row align-items-center gap-1">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @try
                        {
                            @await Component.InvokeAsync("Notification")
                        }
                        catch
                        {
                            /* swallow notification errors to avoid breaking layout rendering */
                        }

                        @try
                        {
                            @await Html.PartialAsync("_ChatCustomerServiceLayout")
                        }
                        catch
                        {
                            /* swallow chat partial errors */
                        }

                        <li class="nav-item dropdown ms-1">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 px-3 py-2 text-white rounded-3"
                                   href="#" id="userProfileDropdown" role="button" data-bs-toggle="dropdown"
                                   style="background:rgba(255,255,255,.08); transition:background .2s; font-size:.875rem;">
                                    <i class="bi bi-person-circle" style="font-size:1.1rem;"></i>
                                    <span class="d-none d-lg-inline fw-semibold">@(User.Identity.Name?.Split('@')[0] ?? "User")</span>
                                    @{
                                        string orgRoleBg = "bg-secondary"; string orgRoleLabel = "User";
                                        if (User.IsInRole("Admin"))        { orgRoleBg = "bg-danger";  orgRoleLabel = "Admin"; }
                                        else if (User.IsInRole("Staff"))   { orgRoleBg = "bg-primary"; orgRoleLabel = "Staff"; }
                                        else if (User.IsInRole("Organizer")) { orgRoleBg = "bg-info text-dark"; orgRoleLabel = "Org"; }
                                    }
                                    <span class="badge @orgRoleBg" style="font-size:.65rem;">@orgRoleLabel</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 aems-dropdown mt-2"
                                    aria-labelledby="userProfileDropdown"
                                    style="background:rgba(15,23,42,.97); backdrop-filter:blur(16px); border-radius:12px; min-width:220px; padding:.5rem;">
                                    <li class="px-3 py-2">
                                        <div class="text-white fw-semibold" style="font-size:.85rem;">@(User.Identity.Name)</div>
                                        <div class="text-muted" style="font-size:.75rem;">@orgRoleLabel</div>
                                    </li>
                                    <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.1); margin:.4rem .8rem;"></li>
                                    <li><a class="dropdown-item aems-dd-item" asp-controller="Profile" asp-action="Index"><i class="bi bi-person me-2"></i>My Profile</a></li>
                                    <li><a class="dropdown-item aems-dd-item" asp-controller="Auth" asp-action="ChangePassword"><i class="bi bi-key me-2"></i>Change Password</a></li>
                                    <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.1); margin:.4rem .8rem;"></li>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</a></li>
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="UserManagement" asp-action="Index"><i class="bi bi-people me-2"></i>User Management</a></li>
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="SystemLog" asp-action="Index"><i class="bi bi-journal-text me-2"></i>System Logs</a></li>
                                    }
                                    else if (User.IsInRole("Staff") || User.IsInRole("Organizer"))
                                    {
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="Organizer" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                                    }
                                    <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.1); margin:.4rem .8rem;"></li>
                                    <li>
                                        <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item aems-dd-item text-danger">
                                                <i class="bi bi-box-arrow-right me-2"></i>Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3 text-white opacity-80" asp-controller="Auth" asp-action="Login" style="font-size:.9rem;">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
        <style>
            .aems-navbar .nav-link:hover { opacity: 1 !important; }
            .aems-dd-item { color: rgba(255,255,255,.8) !important; border-radius: 8px !important; padding: .5rem .9rem !important; font-size: .875rem !important; transition: background .15s, color .15s !important; }
            .aems-dd-item:hover { background: rgba(99,102,241,.25) !important; color: #fff !important; }
            .aems-dd-item.text-danger { color: #f87171 !important; }
            .aems-dd-item.text-danger:hover { background: rgba(239,68,68,.2) !important; }
            .dropdown-menu.aems-dropdown { animation: fadeInDown .15s ease; }
            .dropdown-submenu > .dropdown-menu { top: 0; left: 100%; margin-top: -.5rem; margin-left: .35rem; }
            .dropdown-submenu > .dropdown-menu.show { display: block; }
            @@media (max-width: 991.98px) {
                .dropdown-submenu > .dropdown-menu { left: 0; top: 100%; margin-top: .35rem; margin-left: 0; }
            }
            @@keyframes fadeInDown { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: translateY(0); } }
        </style>
    </header>

    <div class="container">

        <main role="main" class="pb-3">
            @* Legacy Alert Block - Replaced by Toastr
            @if (TempData["NotificationMessage"] != null)
            {
                var type = TempData["NotificationType"]?.ToString() == "error" ? "danger" : "success";
                <div class="alert alert-@type alert-dismissible fade show" role="alert">
                    @TempData["NotificationMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            *@
            <partial name="_Notification" />
            @RenderBody()
        </main>
    </div>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <partial name="_ChatbotBar" />
    }

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - AEMS_Solution - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/site.js?v=3" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.aems-submenu-toggle').forEach(function (toggle) {
                toggle.addEventListener('click', function (e) {
                    e.preventDefault();
                    e.stopPropagation();

                    const submenu = this.nextElementSibling;
                    const parentMenu = this.closest('.dropdown-menu');

                    parentMenu?.querySelectorAll('.aems-submenu.show').forEach(function (menu) {
                        if (menu !== submenu) {
                            menu.classList.remove('show');
                        }
                    });

                    submenu?.classList.toggle('show');
                });
            });

            document.querySelectorAll('.aems-navbar .nav-item.dropdown').forEach(function (dropdown) {
                dropdown.addEventListener('hide.bs.dropdown', function () {
                    dropdown.querySelectorAll('.aems-submenu.show').forEach(function (menu) {
                        menu.classList.remove('show');
                    });
                });
            });
        });
    </script>
    <script src="~/js/chatbot.js" asp-append-version="true"></script>
    <script src="~/js/messenger-layout.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
