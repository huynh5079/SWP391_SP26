<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AEMS_Solution</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AEMS_Solution.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css">
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <link rel="stylesheet" href="~/css/chatbot.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/messenger-layout.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
</head>
<<body>
    <!-- Sidebar -->
    <aside class="organizer-sidebar">
        <a href="@Url.Action("Index", "Organizer")" class="brand-wrapper">
            <div class="brand-icon-box">
                <i class="bi bi-grid-fill"></i>
            </div>
            <div class="brand-text">
                <span class="brand-title">AEMS</span>
                <span class="brand-subtitle">DIGITAL CONCIERGE</span>
            </div>
        </a>

        <ul class="sidebar-nav">
            @{
                var currentCtrl = ViewContext.RouteData.Values["Controller"]?.ToString();
                var currentAct = ViewContext.RouteData.Values["Action"]?.ToString();
                var operation = Context.Request.Query["operation"].ToString() ?? "";
            }
            <li class="nav-item">
                <a href="@Url.Action("Index", "Organizer")" class="nav-link @(currentCtrl == "Organizer" && currentAct == "Index" ? "active" : "")">
                    <i class="bi bi-grid-1x2-fill"></i>
                    Home
                </a>
            </li>

            <!-- Create Section -->
            <li class="nav-item">
                <a class="nav-link @(operation == "create" || (currentCtrl == "EventQuiz" && currentAct == "Create") ? "" : "collapsed")" 
                   data-bs-toggle="collapse" href="#createCollapse" role="button" 
                   aria-expanded="@(operation == "create" || (currentCtrl == "EventQuiz" && currentAct == "Create") ? "true" : "false")" 
                   aria-controls="createCollapse">
                    <i class="bi bi-plus-circle"></i>
                    Create
                    <i class="bi bi-chevron-down ms-auto" style="font-size: 0.8rem; transition: transform 0.3s; transform: rotate(@(operation == "create" || (currentCtrl == "EventQuiz" && currentAct == "Create") ? "180deg" : "0deg"));"></i>
                </a>
                <div class="collapse @(operation == "create" || (currentCtrl == "EventQuiz" && currentAct == "Create") ? "show" : "")" id="createCollapse">
                    <ul class="nav flex-column sidebar-submenu mt-1" style="padding-left: 1rem; list-style: none;">
                        <li class="nav-item mb-1">
                            <a class="nav-link py-1 px-3 fs-6 @(operation == "create" ? "active" : "")" asp-controller="Organizer" asp-action="Manage" asp-route-operation="create">
                                <i class="bi bi-calendar-plus me-2 fs-6"></i> Create Event
                            </a>
                        </li>
                        <li class="nav-item mt-2 mb-1 px-3 text-muted" style="font-size: 0.75rem; text-transform: uppercase;">Create Quiz</li>
                        <li class="nav-item mb-1">
                            <a class="nav-link py-1 px-3 fs-6 ps-4 @(currentCtrl == "EventQuiz" && currentAct == "Create" && Context.Request.Query["mode"] == "manual" ? "active" : "")" asp-controller="EventQuiz" asp-action="Create" asp-route-mode="manual">
                                <i class="bi bi-pencil-square me-2 fs-6"></i> Manual
                            </a>
                        </li>
                        <li class="nav-item mb-1">
                            <a class="nav-link py-1 px-3 fs-6 ps-4 @(currentCtrl == "EventQuiz" && currentAct == "Create" && Context.Request.Query["mode"] == "upload" ? "active" : "")" asp-controller="EventQuiz" asp-action="Create" asp-route-mode="upload">
                                <i class="bi bi-upload me-2 fs-6"></i> Upload File
                            </a>
                        </li>
                    </ul>
                </div>
            </li>

            <!-- Manage Section -->
            <li class="nav-item mt-2">
                <a class="nav-link @(currentCtrl != "Organizer" && currentCtrl != "Home" || currentAct != "Index" && operation != "create" ? "" : "collapsed")" 
                   data-bs-toggle="collapse" href="#manageCollapse" role="button" 
                   aria-expanded="@(currentCtrl != "Organizer" && currentCtrl != "Home" || currentAct != "Index" && operation != "create" ? "true" : "false")" 
                   aria-controls="manageCollapse">
                    <i class="bi bi-grid"></i>
                    Manage
                    <i class="bi bi-chevron-down ms-auto" style="font-size: 0.8rem; transition: transform 0.3s; transform: rotate(@(currentCtrl != "Organizer" && currentCtrl != "Home" || currentAct != "Index" && operation != "create" ? "180deg" : "0deg"));"></i>
                </a>
                <div class="collapse @(currentCtrl != "Organizer" && currentCtrl != "Home" || currentAct != "Index" && operation != "create" ? "show" : "")" id="manageCollapse">
                    <ul class="nav flex-column sidebar-submenu mt-1" style="padding-left: 1rem; list-style: none;">
                        <li class="nav-item mb-1">
                            <a class="nav-link py-1 px-3 fs-6 @(currentCtrl == "Organizer" && currentAct == "MyEvents" && Context.Request.Query["status"] != "Expired" ? "active" : "")" asp-controller="Organizer" asp-action="MyEvents">
                                <i class="bi bi-check-circle me-2 fs-6"></i> My Events
                            </a>
                        </li>
                        <li class="nav-item mb-1">
                            <a class="nav-link py-1 px-3 fs-6 @(operation == "myeventsdelete" ? "active" : "")" asp-controller="Organizer" asp-action="Manage" asp-route-operation="myeventsdelete">
                                <i class="bi bi-trash me-2 fs-6"></i> Deleted Events
                            </a>
                        </li>
                        <li class="nav-item mb-1">
                            <a class="nav-link py-1 px-3 fs-6 @(Context.Request.Query["status"] == "Expired" ? "active" : "")" asp-controller="Organizer" asp-action="MyEvents" asp-route-status="Expired">
                                <i class="bi bi-clock-history me-2 fs-6"></i> Expired Events
                            </a>
                        </li>
                        <li class="nav-item mb-1">
                            <a class="nav-link py-1 px-3 fs-6 @(currentAct == "MyParticipatedEvents" ? "active" : "")" asp-controller="Organizer" asp-action="MyParticipatedEvents">
                                <i class="bi bi-person-workspace me-2 fs-6"></i> Sự kiện tham gia
                            </a>
                        </li>

                        <li><hr class="dropdown-divider border-secondary my-2 opacity-25"></li>

                        <li class="nav-item mb-1">
                            <a class="nav-link py-1 px-3 fs-6 @(currentAct == "MyAgenda" ? "active" : "")" asp-controller="EventAgenda" asp-action="MyAgenda">
                                <i class="bi bi-list-task me-2 fs-6"></i> Agenda
                            </a>
                        </li>
                        <li class="nav-item mb-1">
                            <a class="nav-link py-1 px-3 fs-6 @(currentCtrl == "Ticket" ? "active" : "")" asp-controller="Ticket" asp-action="Index">
                                <i class="bi bi-ticket me-2 fs-6"></i> Manage Tickets
                            </a>
                        </li>

                        <li><hr class="dropdown-divider border-secondary my-2 opacity-25"></li>

                        <li class="nav-item mb-1">
                            <a class="nav-link py-1 px-3 fs-6 @(currentCtrl == "Topic" ? "active" : "")" asp-controller="Topic" asp-action="Index">
                                <i class="bi bi-tags me-2 fs-6"></i> Topics
                            </a>
                        </li>
                        <li class="nav-item mb-1">
                            <a class="nav-link py-1 px-3 fs-6 @(currentCtrl == "Location" ? "active" : "")" asp-controller="Location" asp-action="Index">
                                <i class="bi bi-geo-alt me-2 fs-6"></i> Locations
                            </a>
                        </li>
                        <li class="nav-item mb-1">
                            <a class="nav-link py-1 px-3 fs-6 @(currentCtrl == "EventQuiz" && currentAct != "Create" ? "" : "collapsed")" 
                               data-bs-toggle="collapse" href="#quizCollapse" role="button" 
                               aria-expanded="@(currentCtrl == "EventQuiz" && currentAct != "Create" ? "true" : "false")"
                               aria-controls="quizCollapse">
                                <i class="bi bi-question-circle me-2 fs-6"></i> Quiz
                                <i class="bi bi-chevron-down ms-auto" style="font-size: 0.7rem; transition: transform 0.3s; transform: rotate(@(currentCtrl == "EventQuiz" && currentAct != "Create" ? "180deg" : "0deg"));"></i>
                            </a>
                            <div class="collapse @(currentCtrl == "EventQuiz" && currentAct != "Create" ? "show" : "")" id="quizCollapse">
                                <ul class="nav flex-column sidebar-submenu mt-1 mb-1" style="padding-left: 1.5rem; list-style: none;">
                                    <li class="nav-item mb-1">
                                        <a class="nav-link py-1 px-3 fs-6 @(currentCtrl == "EventQuiz" && currentAct == "Index" && Context.Request.Query["scope"] != "community" ? "active" : "")" asp-controller="EventQuiz" asp-action="Index">
                                            <i class="bi bi-person-badge me-2" style="font-size: 0.9rem;"></i> My Quiz
                                        </a>
                                    </li>
                                    <li class="nav-item mb-1">
                                        <a class="nav-link py-1 px-3 fs-6 @(currentCtrl == "EventQuiz" && currentAct == "Index" && Context.Request.Query["scope"] == "community" ? "active" : "")" asp-controller="EventQuiz" asp-action="Index" asp-route-scope="community">
                                            <i class="bi bi-people me-2" style="font-size: 0.9rem;"></i> Quiz Community
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link py-1 px-3 fs-6 @(currentCtrl == "EventQuiz" && currentAct == "QuestionBank" ? "active" : "")" asp-controller="EventQuiz" asp-action="QuestionBank">
                                            <i class="bi bi-bank me-2" style="font-size: 0.9rem;"></i> Quiz Bank
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </li>
                    </ul>
                </div>
            </li>

            <li class="nav-item mt-auto">
                <a href="#" class="nav-link">
                    <i class="bi bi-gear"></i>
                    Settings
                </a>
            </li>
        </ul>

                        @try
                        {
                            @await Html.PartialAsync("_ChatCustomerServiceLayout")
                        }
                        catch
                        {
                            /* swallow chat partial errors */
                        }

                        <li class="nav-item dropdown ms-1">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 px-3 py-2 text-white rounded-3"
                                   href="#" id="userProfileDropdown" role="button" data-bs-toggle="dropdown"
                                   style="background:rgba(255,255,255,.08); transition:background .2s; font-size:.875rem;">
                                    <i class="bi bi-person-circle" style="font-size:1.1rem;"></i>
                                    <span class="d-none d-lg-inline fw-semibold">@(User.Identity.Name?.Split('@')[0] ?? "User")</span>
                                    @{
                                        string orgRoleBg = "bg-secondary"; string orgRoleLabel = "User";
                                        if (User.IsInRole("Admin"))        { orgRoleBg = "bg-danger";  orgRoleLabel = "Admin"; }
                                        else if (User.IsInRole("Staff"))   { orgRoleBg = "bg-primary"; orgRoleLabel = "Staff"; }
                                        else if (User.IsInRole("Organizer")) { orgRoleBg = "bg-info text-dark"; orgRoleLabel = "Org"; }
                                    }
                                    <span class="badge @orgRoleBg" style="font-size:.65rem;">@orgRoleLabel</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 aems-dropdown mt-2"
                                    aria-labelledby="userProfileDropdown"
                                    style="background:rgba(15,23,42,.97); backdrop-filter:blur(16px); border-radius:12px; min-width:220px; padding:.5rem;">
                                    <li class="px-3 py-2">
                                        <div class="text-white fw-semibold" style="font-size:.85rem;">@(User.Identity.Name)</div>
                                        <div class="text-muted" style="font-size:.75rem;">@orgRoleLabel</div>
                                    </li>
                                    <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.1); margin:.4rem .8rem;"></li>
                                    <li><a class="dropdown-item aems-dd-item" asp-controller="Profile" asp-action="Index"><i class="bi bi-person me-2"></i>My Profile</a></li>
                                    <li><a class="dropdown-item aems-dd-item" asp-controller="Auth" asp-action="ChangePassword"><i class="bi bi-key me-2"></i>Change Password</a></li>
                                    <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.1); margin:.4rem .8rem;"></li>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</a></li>
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="UserManagement" asp-action="Index"><i class="bi bi-people me-2"></i>User Management</a></li>
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="SystemLog" asp-action="Index"><i class="bi bi-journal-text me-2"></i>System Logs</a></li>
                                    }
                                    else if (User.IsInRole("Staff") || User.IsInRole("Organizer"))
                                    {
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="Organizer" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                                    }
                                    <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.1); margin:.4rem .8rem;"></li>
                                    <li>
                                        <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item aems-dd-item text-danger">
                                                <i class="bi bi-box-arrow-right me-2"></i>Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3 text-white opacity-80" asp-controller="Auth" asp-action="Login" style="font-size:.9rem;">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
        <style>
            .aems-navbar .nav-link:hover { opacity: 1 !important; }
            .aems-dd-item { color: rgba(255,255,255,.8) !important; border-radius: 8px !important; padding: .5rem .9rem !important; font-size: .875rem !important; transition: background .15s, color .15s !important; }
            .aems-dd-item:hover { background: rgba(99,102,241,.25) !important; color: #fff !important; }
            .aems-dd-item.text-danger { color: #f87171 !important; }
            .aems-dd-item.text-danger:hover { background: rgba(239,68,68,.2) !important; }
            .dropdown-menu.aems-dropdown { animation: fadeInDown .15s ease; }
            .dropdown-submenu > .dropdown-menu { top: 0; left: 100%; margin-top: -.5rem; margin-left: .35rem; }
            .dropdown-submenu > .dropdown-menu.show { display: block; }
            @@media (max-width: 991.98px) {
                .dropdown-submenu > .dropdown-menu { left: 0; top: 100%; margin-top: .35rem; margin-left: 0; }
            }
            @@keyframes fadeInDown { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: translateY(0); } }
        </style>
    </header>

    <div class="container">

        <main role="main" class="pb-3">
            @* Legacy Alert Block - Replaced by Toastr
            @if (TempData["NotificationMessage"] != null)
            {
                var type = TempData["NotificationType"]?.ToString() == "error" ? "danger" : "success";
                <div class="alert alert-@type alert-dismissible fade show" role="alert">
                    @TempData["NotificationMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            *@
            <partial name="_Notification" />
            @RenderBody()
        </main>
    </div>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <partial name="_ChatbotBar" />
    }

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - AEMS_Solution - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/site.js?v=3" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.aems-submenu-toggle').forEach(function (toggle) {
                toggle.addEventListener('click', function (e) {
                    e.preventDefault();
                    e.stopPropagation();

                    const submenu = this.nextElementSibling;
                    const parentMenu = this.closest('.dropdown-menu');

                    parentMenu?.querySelectorAll('.aems-submenu.show').forEach(function (menu) {
                        if (menu !== submenu) {
                            menu.classList.remove('show');
                        }
                    });

                    submenu?.classList.toggle('show');
                });
            });

            document.querySelectorAll('.aems-navbar .nav-item.dropdown').forEach(function (dropdown) {
                dropdown.addEventListener('hide.bs.dropdown', function () {
                    dropdown.querySelectorAll('.aems-submenu.show').forEach(function (menu) {
                        menu.classList.remove('show');
                    });
                });
            });
        });
    </script>
    <script src="~/js/chatbot.js" asp-append-version="true"></script>
    <script src="~/js/messenger-layout.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
