@{
    var displayName = User?.Identity?.Name ?? "User";
    var currentUserId = User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
    var currentRole = User?.IsInRole("Admin") == true ? "Admin"
        : User?.IsInRole("Staff") == true ? "Staff"
        : User?.IsInRole("Organizer") == true ? "Organizer"
        : (User?.IsInRole("Approver") == true || User?.IsInRole("Approval") == true) ? "Approver"
        : User?.IsInRole("Student") == true ? "Student"
        : "User";
    var nameParts = displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    var initials = string.Empty;

    for (var i = 0; i < nameParts.Length && i < 2; i++)
    {
        initials += char.ToUpperInvariant(nameParts[i][0]);
    }

    if (string.IsNullOrWhiteSpace(initials))
    {
        initials = "U";
    }
}

<li class="nav-item messenger-launcher" id="messengerLauncher"
    data-current-user="@displayName"
    data-current-user-id="@currentUserId"
    data-current-role="@currentRole"
    data-contacts-url="@Url.Action("Contacts", "Chat")"
    data-conversation-url="@Url.Action("Conversation", "Chat")"
    data-chat-hub-url="/hub/v1/chat">
    <button type="button" class="nav-link text-white messenger-nav-trigger" id="messengerToggle" aria-label="Open peer-to-peer chat">
        <span class="messenger-nav-icon">
            <i class="bi bi-messenger text-white"></i>
            <span class="messenger-fab-badge d-none" id="messengerFabBadge">0</span>
        </span>
        <span class="messenger-nav-text ms-1 text-white">Chat</span>
    </button>

    <section class="messenger-panel" id="messengerPanel" aria-hidden="true">
        <aside class="messenger-sidebar">
            <div class="messenger-sidebar-header">
                <div>
                    <div class="messenger-title">Messages</div>
                    <div class="messenger-subtitle">Role-based Chat</div>
                </div>
                <button type="button" class="messenger-close" id="messengerClose" aria-label="Close chat">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="messenger-search">
                <input type="text" id="messengerSearch" placeholder="Search name, role..." autocomplete="off" />
            </div>

            <div class="messenger-contact-list" id="messengerContactList"></div>
        </aside>

        <div class="messenger-main">
            <div class="messenger-main-header">
                <div class="d-flex align-items-center gap-3">
                    <div class="messenger-avatar--lg" id="messengerActiveAvatar" style="background:#4f46e5">@initials</div>
                    <div>
                        <div class="messenger-active-name" id="messengerActiveName">Select a conversation</div>
                        <div class="messenger-active-status" id="messengerActiveStatus">Loading chat list...</div>
                    </div>
                </div>
            </div>

            <div class="messenger-empty" id="messengerEmptyState">
                <div class="messenger-empty-icon"><i class="bi bi-chat-dots-fill"></i></div>
                <h5 class="mb-0">Peer-to-Peer Chat</h5>
                <div class="messenger-empty-subtitle">This interface is separate from the AI chatbot. Select a user to start real-time chat.</div>
            </div>

            <div class="messenger-thread d-none" id="messengerThread">
                <div class="messenger-messages" id="messengerMessages"></div>

                <form class="messenger-composer" id="messengerComposer" onsubmit="return false;">
                    <button type="button" class="messenger-tool-btn" title="Add attachment">
                        <i class="bi bi-plus-lg"></i>
                    </button>
                    <input type="text" id="messengerInput" placeholder="Type a message..." autocomplete="off" disabled />
                    <button type="button" class="messenger-send" id="messengerSend" aria-label="Send message">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </form>
            </div>
        </div>
    </section>
</li>
