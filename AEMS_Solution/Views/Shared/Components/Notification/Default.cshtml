@model IEnumerable<DataAccess.Entities.Notification>
@{
    int unreadCount = ViewBag.UnreadCount ?? 0;
}

<style>
.notif-bell-btn {
    position: relative;
    background: none;
    border: none;
    padding: 8px 10px;
    border-radius: 50%;
    cursor: pointer;
    transition: background 0.2s;
    color: #444;
    display: flex;
    align-items: center;
}
.notif-bell-btn:hover { background: rgba(100,100,255,0.08); }
.notif-bell-btn .bx-bell {
    font-size: 22px;
    color: #555;
}
.notif-badge {
    position: absolute;
    top: 3px;
    right: 3px;
    background: linear-gradient(135deg, #f43f5e, #e11d48);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    min-width: 18px;
    height: 18px;
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
    box-shadow: 0 2px 6px rgba(244,63,94,.4);
    animation: notif-pop 0.3s ease;
}
@@keyframes notif-pop {
    0% { transform: scale(0); }
    70% { transform: scale(1.2); }
    100% { transform: scale(1); }
}

/* Dropdown Panel */
.notif-dropdown {
    min-width: 360px;
    max-width: 360px;
    border: none;
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15);
    overflow: hidden;
    padding: 0;
}

/* Header */
.notif-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: white;
}
.notif-header-title {
    font-size: 15px;
    font-weight: 700;
    margin: 0;
    letter-spacing: 0.3px;
}
.notif-header-badge {
    background: rgba(255,255,255,0.25);
    border-radius: 20px;
    padding: 2px 10px;
    font-size: 12px;
    font-weight: 600;
}
.notif-mark-all {
    background: none;
    border: 1px solid rgba(255,255,255,0.5);
    color: white;
    font-size: 11px;
    border-radius: 10px;
    padding: 3px 10px;
    cursor: pointer;
    transition: background 0.2s;
}
.notif-mark-all:hover { background: rgba(255,255,255,0.2); }

/* List */
.notif-list {
    max-height: 320px;
    overflow-y: auto;
    scrollbar-width: thin;
}
.notif-list::-webkit-scrollbar { width: 4px; }
.notif-list::-webkit-scrollbar-thumb { background: #e0e0e0; border-radius: 4px; }

.notif-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 16px;
    border-bottom: 1px solid #f3f4f6;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
    cursor: pointer;
    position: relative;
}
.notif-item:hover { background: #f9fafb; }
.notif-item.unread { background: #f0f0ff; }
.notif-item.unread::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: linear-gradient(to bottom, #6366f1, #8b5cf6);
    border-radius: 0 3px 3px 0;
}

.notif-icon {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 17px;
    flex-shrink: 0;
}
.notif-icon.type-default { background: #ede9fe; color: #7c3aed; }
.notif-icon.type-success { background: #d1fae5; color: #059669; }
.notif-icon.type-warning { background: #fef3c7; color: #d97706; }
.notif-icon.type-danger  { background: #fee2e2; color: #dc2626; }
.notif-icon.type-info    { background: #dbeafe; color: #2563eb; }
.notif-icon.type-critical { background: #fce7f3; color: #be185d; }

.notif-body { flex: 1; min-width: 0; }
.notif-title {
    font-size: 13px;
    font-weight: 700;
    color: #1f2937;
    margin: 0 0 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.notif-msg {
    font-size: 12px;
    color: #6b7280;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.notif-time {
    font-size: 10px;
    color: #9ca3af;
    margin-top: 4px;
    display: flex;
    align-items: center;
    gap: 3px;
}

/* Empty State */
.notif-empty {
    padding: 36px 16px;
    text-align: center;
    color: #9ca3af;
}
.notif-empty i { font-size: 40px; color: #d1d5db; display: block; margin-bottom: 8px; }
.notif-empty p { margin: 0; font-size: 13px; }

/* Footer */
.notif-footer {
    padding: 12px;
    text-align: center;
    border-top: 1px solid #f3f4f6;
    background: #fafafa;
}
.notif-footer a {
    color: #6366f1;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    transition: color 0.2s;
}
.notif-footer a:hover { color: #4f46e5; }
</style>

<li class="nav-item dropdown">
    <a class="notif-bell-btn dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="text-decoration:none">
        @if (unreadCount > 0)
        {
            <span class="notif-badge alert-count">@(unreadCount > 99 ? "99+" : unreadCount.ToString())</span>
        }
        <i class='bx bx-bell'></i>
    </a>

    <div class="dropdown-menu dropdown-menu-end notif-dropdown">
        <!-- Header -->
        <div class="notif-header">
            <div class="d-flex align-items-center gap-2">
                <p class="notif-header-title">Notifications</p>
                @if (unreadCount > 0)
                {
                    <span class="notif-header-badge">@unreadCount new</span>
                }
            </div>
            @if (Model != null && Model.Any())
            {
                <button class="notif-mark-all" onclick="markAllAsReadDropdown()">Mark all read</button>
            }
        </div>

        <!-- Notification List -->
        <div class="notif-list">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    // Resolve icon style & name based on notification type
                    string iconClass = "type-default";
                    string iconName  = "bx-info-circle";

                    if (item.Type == "EventApproved" || item.Type == "EventPublished")
                    { iconClass = "type-success"; iconName = "bx-check-circle"; }
                    else if (item.Type == "EventRejected" || item.Type == "AccountBan")
                    { iconClass = "type-danger"; iconName = "bx-x-circle"; }
                    else if (item.Type == "EventChangeRequested" || item.Type == "EventOrganizeCancel")
                    { iconClass = "type-warning"; iconName = "bxs-error"; }
                    else if (item.Type == "AccountUnban" || item.Type == "StudentRegistration")
                    { iconClass = "type-success"; iconName = "bx-user-check"; }
                    else if (item.Type == "SystemBroadcast")
                    { iconClass = "type-info"; iconName = "bx-broadcast"; }
                    else if (item.Type == "EventUpdated")
                    { iconClass = "type-info"; iconName = "bx-edit"; }
                    else if (item.Type == "EventFeedback")
                    { iconClass = "type-warning"; iconName = "bx-star"; }
                    else if (item.Type == "SystemError")
                    { iconClass = "type-critical"; iconName = "bx-bug"; }

                    <a href="javascript:;" onclick="markAsReadDropdown('@item.Id', this)" class="notif-item @(item.IsRead == true ? "" : "unread")">
                        <div class="notif-icon @iconClass">
                            <i class='bx @iconName'></i>
                        </div>
                        <div class="notif-body">
                            <p class="notif-title">@item.Title</p>
                            <p class="notif-msg">@item.Message</p>
                            <span class="notif-time">
                                <i class='bx bx-time-five'></i>
                                @item.CreatedAt.ToString("dd/MM HH:mm")
                            </span>
                        </div>
                    </a>
                }
            }
            else
            {
                <div class="notif-empty">
                    <i class='bx bx-bell-off'></i>
                    <p>No notifications yet</p>
                </div>
            }
        </div>

        <!-- Footer -->
        <div class="notif-footer">
            <a href="/Notification/Index">
                View all notifications <i class='bx bx-right-arrow-alt'></i>
            </a>
        </div>
    </div>
</li>

<script>
function markAsReadDropdown(id, el) {
    var item = el.closest ? el : el.parentElement;
    $.post('/Notification/MarkAsRead', { id: id }, function () {
        item.classList.remove('unread');

        // Decrement the badge count
        var badge = document.querySelector('.notif-badge');
        if (badge) {
            var cur = parseInt(badge.innerText);
            if (!isNaN(cur) && cur > 1) {
                badge.innerText = cur - 1;
            } else {
                badge.remove();
            }
        }
    });
}

function markAllAsReadDropdown() {
    $.post('/Notification/MarkAllAsRead', function () {
        document.querySelectorAll('.notif-item.unread').forEach(n => n.classList.remove('unread'));
        var badge = document.querySelector('.notif-badge');
        if (badge) badge.remove();
        var hBadge = document.querySelector('.notif-header-badge');
        if (hBadge) hBadge.remove();
        toastr.success('All notifications marked as read');
    });
}
</script>
