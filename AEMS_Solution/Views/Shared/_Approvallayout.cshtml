<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AEMS_Solution</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AEMS_Solution.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css">
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <link rel="stylesheet" href="~/css/approval-dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/chatbot.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/messenger-layout.css" asp-append-version="true" />
</head>
<body>
    <!-- Sidebar -->
    <aside class="approver-sidebar">
        <div class="brand-wrapper">
            <a href="@Url.Action("Index", "Home")" class="brand-link">
                <div class="brand-icon-box">
                    <i class="bi bi-calendar-event-fill"></i>
                </div>
                <div class="brand-text">
                    <span class="brand-title">AEMS</span>
                    <span class="brand-subtitle">APPROVER WORKSPACE</span>
                </div>
            </a>
        </div>

        <ul class="sidebar-nav">
            @{
                var currentCtrl = ViewContext.RouteData.Values["Controller"]?.ToString();
                var currentAct = ViewContext.RouteData.Values["Action"]?.ToString();
            }
            <li class="nav-item">
                <a href="@Url.Action("Index", "Home")"
                   class="nav-link @(currentCtrl == "Home" && currentAct == "Index" ? "active" : "")">
                    <i class="bi bi-house-door-fill"></i>
                    <span>Home</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("Index", "Approver")"
                   class="nav-link @(currentCtrl == "Approver" && currentAct == "Index" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                </a>
            </li>

            <div class="menu-label">Tasks</div>
            <li class="nav-item">
                <a class="nav-link @(currentCtrl == "Approver" && currentAct == "PendingApprovals" ? "active" : "")" href="@Url.Action("PendingApprovals", "Approver")">
                    <i class="bi bi-check2-circle"></i>
                    <span>Approvals</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentCtrl == "Approver" && currentAct == "MyParticipatedEvents" ? "active" : "")" href="@Url.Action("MyParticipatedEvents", "Approver")">
                    <i class="bi bi-calendar-check"></i>
                    <span>Participated Events</span>
                </a>
            </li>

            <div class="menu-label">Manage</div>
            <li class="nav-item">
                <a class="nav-link @(currentCtrl != "Home" && currentCtrl != "Approver" ? "" : "collapsed")" data-bs-toggle="collapse" href="#manageCollapse" role="button" 
                   aria-expanded="@(currentCtrl != "Home" && currentCtrl != "Approver" ? "true" : "false")" aria-controls="manageCollapse">
                    <i class="bi bi-grid-fill"></i>
                    <span>Management</span>
                    <i class="bi bi-chevron-down ms-auto" style="font-size: 0.7rem; transition: transform 0.3s; transform: rotate(@(currentCtrl != "Home" && currentCtrl != "Approver" ? "180deg" : "0deg"));"></i>
                </a>
                <div class="collapse @(currentCtrl != "Home" && currentCtrl != "Approver" ? "show" : "")" id="manageCollapse">
                    <ul class="nav flex-column sidebar-submenu mt-1">
                        <li><a class="nav-link @(currentCtrl == "Approver" && currentAct == "AllEvents" ? "active" : "")" href="@Url.Action("AllEvents", "Approver")"><i class="bi bi-collection me-2"></i> All Events</a></li>
                        <li><a class="nav-link @(currentCtrl == "Topic" ? "active" : "")" href="@Url.Action("Index", "Topic")"><i class="bi bi-tags me-2"></i> Topics</a></li>
                        <li><a class="nav-link @(currentCtrl == "Approver" && currentAct == "Semester" ? "active" : "")" href="@Url.Action("Semester", "Approver")"><i class="bi bi-calendar3 me-2"></i> Semesters</a></li>
                        <li><a class="nav-link @(currentCtrl == "Location" ? "active" : "")" href="@Url.Action("Index", "Location")"><i class="bi bi-geo-alt me-2"></i> Locations</a></li>
                        <li><a class="nav-link @(currentCtrl == "Approver" && currentAct == "Agenda" ? "active" : "")" href="@Url.Action("Agenda", "Approver")"><i class="bi bi-list-task me-2"></i> Agenda</a></li>
                    </ul>
                </div>
            </li>

            <div class="menu-label">System</div>
            <li class="nav-item">
                <a class="nav-link" href="#">
                    <i class="bi bi-question-circle"></i>
                    <span>Support Center</span>
                </a>
            </li>
        </ul>

        <div class="sidebar-footer">
            <div class="sidebar-footer-links">
                <a href="#">Support</a>
                <a href="#">Terms</a>
                <a href="#">Privacy</a>
            </div>
            <span class="mt-2 d-block" style="font-size:.6rem; opacity:.5;">&copy; 2026 - AEMS Approver</span>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="main-wrapper">
        <header class="top-header">
            <div class="search-box animate-fade-in animate-delay-1">
                <i class="bi bi-search"></i>
                <input type="text" class="search-input" placeholder="Search events, topics...">
            </div>

            <div class="header-actions">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    @await Component.InvokeAsync("Notification")
                    <partial name="_ChatCustomerServiceLayout" />
                    
                    <div class="user-profile ms-3">
                        <div class="user-info dropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            <div class="user-details d-none d-md-block">
                                <span class="user-name">@(User.Identity.Name?.Split('@')[0] ?? "User")</span>
                                <span class="user-role d-block">Approver</span>
                            </div>
                            <img src="https://ui-avatars.com/api/?name=@(User.Identity.Name)&background=0d9488&color=fff" class="avatar ms-2" alt="Profile">
                        </div>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" style="border-radius:12px; min-width:200px; padding:8px;">
                            <li><a class="dropdown-item py-2" asp-controller="Profile" asp-action="Index"><i class="bi bi-person me-2"></i>Profile</a></li>
                            <li><a class="dropdown-item py-2" asp-controller="Auth" asp-action="ChangePassword"><i class="bi bi-key me-2"></i>Password</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-controller="Auth" asp-action="Logout" method="post">
                                    <button type="submit" class="dropdown-item py-2 text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i>Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
            </div>
        </header>

        <main role="main" class="pb-3 px-4 animate-fade-in animate-delay-2">
            <partial name="_Notification" />
            @RenderBody()
        </main>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <partial name="_ChatbotBar" />
        }
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/site.js?v=3" asp-append-version="true"></script>
    <script src="~/js/chatbot.js" asp-append-version="true"></script>
    <script src="~/js/messenger-layout.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
