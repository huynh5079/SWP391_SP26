<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Executive Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css">
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
</head>
<body>
    <!-- Sidebar -->
    <aside class="sidebar">
        <a href="@Url.Action("Index", "Admin")" class="brand-logo">
            <div class="brand-icon">
                <i class="bi bi-grid-fill"></i>
            </div>
            AEMS <span style="font-weight:400; opacity:.6; font-size:.8rem; margin-left:2px;">Admin</span>
        </a>

        <div class="menu-label">Main Menu</div>
        <ul class="nav flex-column mb-auto">
            <li class="nav-item">
                <a href="@Url.Action("Index", "Admin")"
                   class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                    <i class="bi bi-grid-1x2-fill"></i>
                    Overview
                </a>
            </li>
            <li class="nav-item dropdown">
                <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-calendar-event-fill"></i>
                    Events Data
                    <i class="bi bi-chevron-down ms-auto" style="font-size:.7rem;"></i>
                </a>
                <ul class="dropdown-menu border-0 shadow-sm">
                    <li><a class="dropdown-item" href="@Url.Action("Index", "Department")"><i class="bi bi-building me-2"></i>Departments</a></li>
                    <li><a class="dropdown-item" href="@Url.Action("Index", "Topic")"><i class="bi bi-tags me-2"></i>Topics</a></li>
                    <li><a class="dropdown-item" href="@Url.Action("Index", "Location")"><i class="bi bi-geo-alt me-2"></i>Locations</a></li>
                </ul>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("Index", "UserManagement")"
                   class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "UserManagement" ? "active" : "")">
                    <i class="bi bi-people-fill"></i>
                    Community
                </a>
            </li>
            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="bi bi-bar-chart-fill"></i>
                    Reports
                </a>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("Index", "AdminFeedback")"
                   class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "AdminFeedback" ? "active" : "")">
                    <i class="bi bi-chat-left-text-fill"></i>
                    Feedback
                </a>
            </li>
        </ul>

        <div class="menu-label">System</div>
        <ul class="nav flex-column mb-auto">
            <li class="nav-item">
                <a href="@Url.Action("Index", "SystemLog")"
                   class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "SystemLog" ? "active" : "")">
                    <i class="bi bi-journal-text"></i>
                    System Logs
                    @{
                        // Show 30-day error badge if available from Admin dashboard context
                        int errBadge = 0;
                        if (ViewBag.TotalLast30Days is int b30) { errBadge = b30; }
                        else if (ViewData["TotalLast30Days"] is int vd30) { errBadge = vd30; }
                    }
                    @if (errBadge > 0)
                    {
                        <span class="ms-auto" style="background:rgba(239,68,68,.25);border:1px solid rgba(239,68,68,.4);color:#fca5a5;font-size:.6rem;font-weight:800;padding:.1rem .4rem;border-radius:20px;line-height:1.4;">
                            @errBadge
                        </span>
                    }
                </a>
            </li>
            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="bi bi-gear-fill"></i>
                    Settings
                </a>
            </li>
            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="bi bi-shield-check"></i>
                    Security
                </a>
            </li>
        </ul>

        <div class="pro-version-card">
            <h6>Pro Analytics</h6>
            <p>Get advanced AI analytics &amp; real-time insights.</p>
            <a href="#" class="btn-pro"><i class="bi bi-lightning-charge-fill me-1"></i>Upgrade</a>
        </div>

        <div class="sidebar-footer">
            <i class="bi bi-grid-fill me-1"></i> AEMS Admin &copy; 2026
            <div class="sidebar-footer-links">
                <a href="#">Support</a>
                <a href="#">Terms</a>
                <a href="#">Privacy</a>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <!-- Top Header -->
        <header class="top-header">
            <div class="search-box">
                <i class="bi bi-search"></i>
                <input type="text" class="search-input" placeholder="Search events, users, or logs…">
            </div>

            <div class="user-profile">
                @await Component.InvokeAsync("Notification")

                @if (User.Identity?.IsAuthenticated == true)
                {
                    var userName = User.Identity.Name?.Split('@')[0] ?? "Admin";
                    var userInitial = userName.Substring(0,1).ToUpper();
                    <div class="user-info dropdown">
                        <div class="user-details" data-bs-toggle="dropdown" aria-expanded="false" style="cursor:pointer;">
                            <div class="user-name">@userName</div>
                            <div class="user-role">Admin</div>
                        </div>
                        <div style="background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.9rem;cursor:pointer;box-shadow:0 2px 10px rgba(99,102,241,.4);flex-shrink:0;"
                             data-bs-toggle="dropdown" aria-expanded="false">
                            @userInitial
                        </div>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" style="border-radius:12px;min-width:190px;padding:6px;">
                            <li class="px-3 py-2 border-bottom mb-1">
                                <div style="font-weight:700;font-size:.85rem;color:#1e1b4b;">@User.Identity.Name</div>
                                <div style="font-size:.72rem;color:#94a3b8;">System Administrator</div>
                            </li>
                            <li><a class="dropdown-item py-2" href="@Url.Action("Index","Profile")"><i class="bi bi-person me-2"></i>My Profile</a></li>
                            <li><hr class="dropdown-divider my-1"></li>
                            <li>
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="dropdown-item py-2 text-danger"><i class="bi bi-box-arrow-right me-2"></i>Logout</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
            </div>
        </header>

        <!-- Body Render -->
        <div style="padding:24px 32px; flex:1;">
            @RenderBody()
        </div>

        <footer style="text-align:center;padding:.75rem 2rem;border-top:1px solid #e0e7ff;font-size:.72rem;color:#94a3b8;">
            &copy; 2026 - AEMS Executive Dashboard
        </footer>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
