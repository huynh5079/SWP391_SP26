<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Executive Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css">
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/aems-logo.png" />
</head>
<body>
    <!-- Sidebar -->
    <aside class="admin-sidebar">
        <div class="brand-wrapper">
            <a href="@Url.Action("Index", "Admin")" class="brand-link">
                <div class="brand-icon-box" style="background: transparent; border: none; padding: 0;">
                    <img src="~/aems-logo.png" alt="AEMS Logo" style="width: 32px; height: 32px; object-fit: contain; border-radius: 6px;" />
                </div>
                <div class="brand-text">
                    <span class="brand-title">AEMS</span>
                    <span class="brand-subtitle">EXECUTIVE ADMIN</span>
                </div>
            </a>
        </div>

        <ul class="sidebar-nav">
            @{
                var currentCtrl = ViewContext.RouteData.Values["Controller"]?.ToString();
                var currentAct = ViewContext.RouteData.Values["Action"]?.ToString();
            }
            <li class="nav-item">
                <a href="@Url.Action("Index", "Admin")"
                   class="nav-link @(currentCtrl == "Admin" && currentAct == "Index" ? "active" : "")">
                    <i class="bi bi-grid-1x2-fill"></i>
                    <span>Overview</span>
                </a>
            </li>

            <div class="menu-label">Create</div>
            <li class="nav-item">
                <a class="nav-link collapsed" data-bs-toggle="collapse" href="#createCollapse" role="button" aria-expanded="false" aria-controls="createCollapse">
                    <i class="bi bi-plus-circle"></i>
                    <span>Create New</span>
                    <i class="bi bi-chevron-down ms-auto" style="font-size: 0.7rem; transition: transform 0.3s;"></i>
                </a>
                <div class="collapse" id="createCollapse">
                    <ul class="nav flex-column sidebar-submenu mt-1">
                        <li>
                            <a class="nav-link @(currentCtrl == "Department" && currentAct == "Create" ? "active" : "")" href="@Url.Action("Create", "Department")">
                                <i class="bi bi-building-add me-2"></i> Create Department
                            </a>
                        </li>
                        <li>
                            <a class="nav-link @(currentCtrl == "Topic" && currentAct == "Create" ? "active" : "")" href="@Url.Action("Create", "Topic")">
                                <i class="bi bi-tags-fill me-2"></i> Create Topic
                            </a>
                        </li>
                        <li>
                            <a class="nav-link @(currentCtrl == "Location" && currentAct == "Create" ? "active" : "")" href="@Url.Action("Create", "Location")">
                                <i class="bi bi-geo-alt-fill me-2"></i> Create Location
                            </a>
                        </li>
                    </ul>
                </div>
            </li>

            <div class="menu-label">Manage</div>
            <li class="nav-item">
                <a class="nav-link @(currentCtrl != "Admin" && currentCtrl != "SystemLog" ? "" : "collapsed")" data-bs-toggle="collapse" href="#manageCollapse" role="button" 
                   aria-expanded="@(currentCtrl != "Admin" && currentCtrl != "SystemLog" ? "true" : "false")" aria-controls="manageCollapse">
                    <i class="bi bi-grid"></i>
                    <span>Manage Data</span>
                    <i class="bi bi-chevron-down ms-auto" style="font-size: 0.7rem; transition: transform 0.3s; transform: rotate(@(currentCtrl != "Admin" && currentCtrl != "SystemLog" ? "180deg" : "0deg"));"></i>
                </a>
                <div class="collapse @(currentCtrl != "Admin" && currentCtrl != "SystemLog" ? "show" : "")" id="manageCollapse">
                    <ul class="nav flex-column sidebar-submenu mt-1">
                        <li><a class="nav-link @(currentCtrl == "Department" && currentAct != "Create" ? "active" : "")" href="@Url.Action("Index", "Department")"><i class="bi bi-building me-2"></i> Departments</a></li>
                        <li><a class="nav-link @(currentCtrl == "Topic" && currentAct != "Create" ? "active" : "")" href="@Url.Action("Index", "Topic")"><i class="bi bi-tags me-2"></i> Topics</a></li>
                        <li><a class="nav-link @(currentCtrl == "Location" && currentAct != "Create" ? "active" : "")" href="@Url.Action("Index", "Location")"><i class="bi bi-geo-alt me-2"></i> Locations</a></li>
                        <li><a class="nav-link @(currentCtrl == "UserManagement" ? "active" : "")" href="@Url.Action("Index", "UserManagement")"><i class="bi bi-people-fill me-2"></i> Users</a></li>
                        <li><a class="nav-link @(currentCtrl == "AdminFeedback" ? "active" : "")" href="@Url.Action("Index", "AdminFeedback")"><i class="bi bi-chat-left-text-fill me-2"></i> Feedback</a></li>
                    </ul>
                </div>
            </li>

            <div class="menu-label">System</div>
            <li class="nav-item">
                <a class="nav-link @(currentCtrl == "SystemLog" ? "" : "collapsed")" data-bs-toggle="collapse" href="#systemCollapse" role="button" 
                   aria-expanded="@(currentCtrl == "SystemLog" ? "true" : "false")" aria-controls="systemCollapse">
                    <i class="bi bi-cpu"></i>
                    <span>System Settings</span>
                    <i class="bi bi-chevron-down ms-auto" style="font-size: 0.7rem; transition: transform 0.3s; transform: rotate(@(currentCtrl == "SystemLog" ? "180deg" : "0deg"));"></i>
                </a>
                <div class="collapse @(currentCtrl == "SystemLog" ? "show" : "")" id="systemCollapse">
                    <ul class="nav flex-column sidebar-submenu mt-1">
                        <li><a class="nav-link @(currentCtrl == "SystemLog" ? "active" : "")" href="@Url.Action("Index", "SystemLog")"><i class="bi bi-journal-text me-2"></i> System Logs</a></li>
                        <li><a class="nav-link" href="#"><i class="bi bi-gear-fill me-2"></i> Settings</a></li>
                        <li><a class="nav-link" href="#"><i class="bi bi-shield-lock-fill me-2"></i> Security</a></li>
                    </ul>
                </div>
            </li>
        </ul>

        <div class="pro-version-card">
            <h6>Pro Analytics</h6>
            <p>Get advanced AI analytics &amp; real-time insights.</p>
            <a href="#" class="btn-pro"><i class="bi bi-lightning-charge-fill me-1"></i>Upgrade</a>
        </div>

        <div class="sidebar-footer">
            <div class="sidebar-footer-links">
                <a href="#">Support</a>
                <a href="#">Terms</a>
                <a href="#">Privacy</a>
            </div>
            <span class="mt-2 d-block" style="font-size:.6rem; opacity:.5;">&copy; 2026 - AEMS Admin</span>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <!-- Top Header -->
        <header class="top-header">
            <div class="search-box animate-fade-in animate-delay-1">
                <i class="bi bi-search"></i>
                <input type="text" class="search-input" placeholder="Search events, users, or logs…">
            </div>

            <div class="user-profile">
                @await Component.InvokeAsync("Notification")

                @if (User.Identity?.IsAuthenticated == true)
                {
                    var userName = User.Identity.Name?.Split('@')[0] ?? "Admin";
                    var userInitial = userName.Substring(0,1).ToUpper();
                    <div class="user-info dropdown">
                        <div class="user-details" data-bs-toggle="dropdown" aria-expanded="false" style="cursor:pointer;">
                            <div class="user-name">@userName</div>
                            <div class="user-role">Admin</div>
                        </div>
                        <div style="background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.9rem;cursor:pointer;box-shadow:0 2px 10px rgba(99,102,241,.4);flex-shrink:0;"
                             data-bs-toggle="dropdown" aria-expanded="false">
                            @userInitial
                        </div>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" style="border-radius:12px;min-width:190px;padding:6px;">
                            <li class="px-3 py-2 border-bottom mb-1">
                                <div style="font-weight:700;font-size:.85rem;color:#1e1b4b;">@User.Identity.Name</div>
                                <div style="font-size:.72rem;color:#94a3b8;">System Administrator</div>
                            </li>
                            <li><a class="dropdown-item py-2" href="@Url.Action("Index","Profile")"><i class="bi bi-person me-2"></i>My Profile</a></li>
                            <li><hr class="dropdown-divider my-1"></li>
                            <li>
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="dropdown-item py-2 text-danger"><i class="bi bi-box-arrow-right me-2"></i>Logout</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
            </div>
        </header>

        <!-- Body Render -->
        <div class="animate-fade-in animate-delay-2" style="padding:24px 32px; flex:1;">
            @RenderBody()
        </div>

        <footer style="text-align:center;padding:.75rem 2rem;border-top:1px solid #e0e7ff;font-size:.72rem;color:#94a3b8;">
            &copy; 2026 - AEMS Executive Dashboard
        </footer>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        // Global fix: clean up stuck Bootstrap modal backdrops on every page load
        (function () {
            document.querySelectorAll('.modal-backdrop').forEach(function (el) { el.remove(); });
            document.body.classList.remove('modal-open');
            document.body.style.overflow = '';
            document.body.style.paddingRight = '';
        })();
    </script>
</body>
</html>
