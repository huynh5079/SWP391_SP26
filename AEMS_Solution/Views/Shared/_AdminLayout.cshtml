<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Executive Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css">
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
</head>
<body>
    <!-- Sidebar -->
    <aside class="sidebar">
        <a href="@Url.Action("Index", "Admin")" class="brand-logo">
            <div class="brand-icon">
                <i class="bi bi-bank"></i>
            </div>
            AEMS
        </a>

        <div class="menu-label">Main Menu</div>
        <ul class="nav flex-column mb-auto">
            <li class="nav-item">
                <a href="@Url.Action("Index", "Admin")" class="nav-link active">
                    <i class="bi bi-grid-1x2-fill"></i>
                    Overview
                </a>
            </li>
            <li class="nav-item dropdown">
                <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-calendar-event"></i>
                    Events Data
                </a>
                <ul class="dropdown-menu border-0 shadow-sm" style="background-color: #0f172a; margin-left: 10px;">
                    <li><a class="dropdown-item text-white opacity-75" href="@Url.Action("Index", "Department")"><i class="bi bi-building me-2"></i> Departments</a></li>
                    <li><a class="dropdown-item text-white opacity-75" href="@Url.Action("Index", "Topic")"><i class="bi bi-tags me-2"></i> Topics</a></li>
                    <li><a class="dropdown-item text-white opacity-75" href="@Url.Action("Index", "Location")"><i class="bi bi-geo-alt me-2"></i> Locations</a></li>
                </ul>
            </li>
            <li class="nav-item">
                <a href="@Url.Action("Index", "UserManagement")" class="nav-link">
                    <i class="bi bi-people"></i>
                    Community
                </a>
            </li>
            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="bi bi-bar-chart"></i>
                    Reports
                </a>
            </li>
        </ul>

        <div class="menu-label">System</div>
        <ul class="nav flex-column mb-auto">
            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="bi bi-gear"></i>
                    Settings
                </a>
            </li>
            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="bi bi-shield-check"></i>
                    Security
                </a>
            </li>
        </ul>

        <div class="pro-version-card">
            <h6>Pro Version</h6>
            <p>Get advanced AI analytics & insights.</p>
            <a href="#" class="btn-pro">Upgrade</a>
        </div>

        <div class="sidebar-footer">
            <i class="bi bi-bank me-1"></i> AEMS EXECUTIVE © 2024
            <div class="sidebar-footer-links">
                <a href="#">SUPPORT</a>
                <a href="#">TERMS</a>
                <a href="#">PRIVACY</a>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <!-- Top Header -->
        <header class="top-header">
            <div class="search-box">
                <i class="bi bi-search"></i>
                <input type="text" class="search-input" placeholder="Search events, users, or logs...">
            </div>

            <div class="user-profile">
                @await Component.InvokeAsync("Notification")
                
                <div class="user-info dropdown">
                    <div class="user-details" data-bs-toggle="dropdown" aria-expanded="false" style="cursor: pointer;">
                        <div class="user-name">Alex Sterling</div>
                        <div class="user-role">Admin</div>
                    </div>
                    <img src="https://ui-avatars.com/api/?name=Alex+Sterling&background=bbf7d0&color=166534" alt="Alex Sterling" class="avatar" data-bs-toggle="dropdown" aria-expanded="false" style="cursor: pointer;">
                    
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="@Url.Action("Index", "Profile")">Profile</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="dropdown-item">Logout</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </header>

        <!-- Body Render -->
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
