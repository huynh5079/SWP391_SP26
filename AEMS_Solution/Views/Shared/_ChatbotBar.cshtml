@{
    var displayName = User?.Identity?.Name ?? "User";
    var initials = string.IsNullOrWhiteSpace(displayName) ? "U" : displayName.Trim()[0].ToString().ToUpper();
}

<div class="chatbot-launcher" id="chatbotLauncher">
    <button type="button" class="chatbot-fab" id="chatbotToggle" aria-label="Open chatbot">
        <i class="bi bi-chat-dots-fill"></i>
    </button>

    <div class="chatbot-panel shadow-lg" id="chatbotPanel" aria-hidden="true">
        <div class="chatbot-header">
            <div class="chatbot-avatar">
                <span class="avatar-initials">@initials</span>
                <span class="status-dot"></span>
            </div>
            <div class="chatbot-meta">
                <div class="title">Chatbot Assistant</div>
                <div class="subtitle">ACTIVE NOW</div>
            </div>
            <div class="chatbot-header-actions ms-auto">
                <button type="button" class="chatbot-icon-btn ghost" id="chatbotStartBtn" title="Start chat" aria-label="Start chat" style="display:none;">
                    <i class="bi bi-pencil-square"></i>
                </button>
                <button type="button" class="chatbot-icon-btn ghost" id="chatbotClose" aria-label="Close chatbot">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>

        <div class="chatbot-body">
            <div class="chatbot-date-divider"><span>TODAY</span></div>
            <div class="chatbot-log" id="chatbotLog" aria-live="polite">
                <div class="chatbot-msg bot">
                    <div class="msg-text">Hello! Ready to help you look up events, tickets, and general information.</div>
                    <div class="msg-time">@DateTime.Now.ToString("HH:mm")</div>
                </div>
            </div>
            <div class="chatbot-input-area">
                <form class="chatbot-input-wrapper" onsubmit="return false;">
                    <button type="button" class="action-btn" aria-label="Emoji">
                        <i class="bi bi-emoji-smile"></i>
                    </button>
                    <input id="chatbotInput" type="text" placeholder="Type a message..." autocomplete="off" />
                    <button type="button" id="chatbotSend" aria-label="Send question">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </form>
            </div>
            <div class="chatbot-suggestions">
                <button type="button" class="suggestion-chip" onclick="document.getElementById('chatbotInput').value=this.innerText">Register Event</button>
                <button type="button" class="suggestion-chip" onclick="document.getElementById('chatbotInput').value=this.innerText">View Schedule</button>
                <button type="button" class="suggestion-chip" onclick="document.getElementById('chatbotInput').value=this.innerText">Technical Support</button>
            </div>
        </div>
    </div>
</div>
