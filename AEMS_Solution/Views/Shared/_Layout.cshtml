@using DataAccess.Enum
@inject DataAccess.Repositories.Abstraction.IUnitOfWork UnitOfWork
@{
    DataAccess.Entities.User? lockedCurrentUser = null;

    if (User.Identity?.IsAuthenticated == true)
    {
        var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (!string.IsNullOrWhiteSpace(currentUserId))
        {
            lockedCurrentUser = await UnitOfWork.Users.GetByIdAsync(currentUserId);
        }
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AEMS_Solution</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AEMS_Solution.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css">
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <link rel="stylesheet" href="~/css/chatbot.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/messenger-layout.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="aems-navbar navbar navbar-expand-lg" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); box-shadow: 0 2px 20px rgba(0,0,0,0.4); padding: 0.6rem 0;">
            <div class="container-fluid px-4">
                <!-- Brand -->
                <a class="navbar-brand fw-bold text-white d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index"
                   style="font-size:1.3rem; letter-spacing:0.04em;">
                    <span style="background:linear-gradient(135deg,#6366f1,#8b5cf6); border-radius:8px; width:32px; height:32px; display:inline-flex; align-items:center; justify-content:center;">
                        <i class="bi bi-calendar-event-fill text-white" style="font-size:.85rem;"></i>
                    </span>
                    AEMS
                </a>

                <button class="navbar-toggler border-0 text-white" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <i class="bi bi-list" style="font-size:1.5rem;"></i>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <!-- Left links -->
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 align-items-lg-center">
                        <li class="nav-item">
                            <a class="nav-link px-3 text-white opacity-80 fw-medium" asp-controller="Home" asp-action="Index"
                               style="transition:opacity .2s; font-size:.9rem;">
                                <i class="bi bi-house-door me-1"></i>Home
                            </a>
                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <!-- Admin quick links on navbar -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle px-3 text-white opacity-80 fw-medium" href="#" id="adminNavDropdown"
                                   role="button" data-bs-toggle="dropdown" style="font-size:.9rem;">
                                    <i class="bi bi-shield-lock me-1"></i>Admin
                                </a>
                                <ul class="dropdown-menu shadow-lg border-0 mt-2 aems-dropdown" aria-labelledby="adminNavDropdown"
                                    style="background:rgba(15,23,42,.97); backdrop-filter:blur(16px); border-radius:12px; min-width:230px; padding:.5rem;">
                                    <li><a class="dropdown-item aems-dd-item" asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                                    <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.1); margin:.4rem .8rem;"></li>
                                    <li><a class="dropdown-item aems-dd-item" asp-controller="UserManagement" asp-action="Index"><i class="bi bi-people me-2"></i>Users</a></li>
                                    <li><a class="dropdown-item aems-dd-item" asp-controller="Department" asp-action="Index"><i class="bi bi-building me-2"></i>Departments</a></li>
                                    <li><a class="dropdown-item aems-dd-item" asp-controller="Topic" asp-action="Index"><i class="bi bi-tags me-2"></i>Topics</a></li>
                                    <li><a class="dropdown-item aems-dd-item" asp-controller="Location" asp-action="Index"><i class="bi bi-geo-alt me-2"></i>Locations</a></li>
                                    <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.1); margin:.4rem .8rem;"></li>
                                    <li><a class="dropdown-item aems-dd-item" asp-controller="SystemLog" asp-action="Index"><i class="bi bi-journal-text me-2"></i>System Logs</a></li>
                                    <li><a class="dropdown-item aems-dd-item" asp-controller="AdminNotification" asp-action="Create"><i class="bi bi-megaphone me-2"></i>Broadcast</a></li>
                                </ul>
                            </li>
                        }

                        @if (User.IsInRole("Organizer") || User.IsInRole("Staff"))
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3 text-white opacity-80 fw-medium" asp-controller="Organizer" asp-action="Manage" asp-route-operation="create"
                                   style="font-size:.9rem;">
                                    <i class="bi bi-plus-circle me-1"></i>Create Event
                                </a>
                            </li>

                            <!-- Manage Dropdown -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle px-3 text-white opacity-80 fw-medium" href="#" id="manageDropdown"
                                   role="button" data-bs-toggle="dropdown" style="font-size:.9rem;">
                                    <i class="bi bi-grid me-1"></i>Manage
                                </a>
                                <ul class="dropdown-menu shadow-lg border-0 mt-2 aems-dropdown" aria-labelledby="manageDropdown"
                                    style="background:rgba(15,23,42,.97); backdrop-filter:blur(16px); border-radius:12px; min-width:230px; padding:.5rem;">
                                    <li>
                                        <a class="dropdown-item aems-dd-item" asp-controller="Organizer" asp-action="MyEvents">
                                            <i class="bi bi-calendar-check me-2 text-indigo-400"></i>My Events
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item aems-dd-item" asp-controller="Organizer" asp-action="Manage" asp-route-operation="myeventsdelete">
                                            <i class="bi bi-trash me-2 text-red-400"></i>Deleted Events
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item aems-dd-item" asp-controller="Organizer" asp-action="MyParticipatedEvents">
                                            <i class="bi bi-person-workspace me-2 text-yellow-400"></i>Sự kiện tham gia
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.1); margin:.4rem .8rem;"></li>
                                    <li>
                                        <a class="dropdown-item aems-dd-item" asp-controller="EventAgenda" asp-action="MyAgenda">
                                            <i class="bi bi-list-task me-2 text-green-400"></i>Agenda
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item aems-dd-item" asp-controller="Ticket" asp-action="Index">
                                            <i class="bi bi-ticket me-2 text-blue-400"></i>Tickets
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item aems-dd-item" asp-controller="EventQuiz" asp-action="Index">
                                            <i class="bi bi-question-circle me-2 text-purple-400"></i>Quiz
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                        @if (User.IsInRole("Approver"))
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3 text-white opacity-80 fw-medium" asp-controller="Approver" asp-action="PendingApprovals"
                                   style="font-size:.9rem;">
                                    <i class="bi bi-check2-circle me-1"></i>Phê duyệt
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 text-white opacity-80 fw-medium" asp-controller="Approver" asp-action="MyParticipatedEvents"
                                   style="font-size:.9rem;">
                                    <i class="bi bi-person-workspace me-1"></i>Sự kiện tham gia
                                </a>
                            </li>
                        }

                        @if (User.IsInRole("Student"))
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3 text-white opacity-80 fw-medium" asp-controller="StudentEvent" asp-action="Index"
                                   style="font-size:.9rem;">
                                    <i class="bi bi-search me-1"></i>Khám phá
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link px-3 text-white opacity-80 fw-medium" asp-controller="StudentEvent" asp-action="MyEvents"
                                   style="font-size:.9rem;">
                                    <i class="bi bi-person-workspace me-1"></i>Của tôi
                                </a>
                            </li>
                        }
                    </ul>

                    <!-- Right: Notification + User -->
                    <ul class="navbar-nav ms-auto d-flex flex-row align-items-center gap-1">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @await Component.InvokeAsync("Notification")
                            <partial name="_ChatCustomerServiceLayout" />

                            <!-- User dropdown -->
                            <li class="nav-item dropdown ms-1">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 px-3 py-2 text-white rounded-3"
                                   href="#" id="userProfileDropdown" role="button" data-bs-toggle="dropdown"
                                   style="background:rgba(255,255,255,.08); transition:background .2s; font-size:.875rem;">
                                    <i class="bi bi-person-circle" style="font-size:1.1rem;"></i>
                                    <span class="d-none d-lg-inline fw-semibold">@(User.Identity.Name?.Split('@')[0] ?? "User")</span>
                                    @{
                                        string roleBg = "bg-secondary";
                                        string roleLabel = "User";
                                        if (User.IsInRole("Admin"))       { roleBg = "bg-danger";  roleLabel = "Admin"; }
                                        else if (User.IsInRole("Staff"))  { roleBg = "bg-primary"; roleLabel = "Staff"; }
                                        else if (User.IsInRole("Organizer")){ roleBg = "bg-indigo"; roleLabel = "Org"; }
                                        else if (User.IsInRole("Approver")){ roleBg = "bg-warning text-dark"; roleLabel = "Approver"; }
                                        else if (User.IsInRole("Student")){ roleBg = "bg-success"; roleLabel = "Student"; }
                                    }
                                    <span class="badge @roleBg" style="font-size:.65rem;">@roleLabel</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 aems-dropdown mt-2"
                                    aria-labelledby="userProfileDropdown"
                                    style="background:rgba(15,23,42,.97); backdrop-filter:blur(16px); border-radius:12px; min-width:220px; padding:.5rem;">
                                    <!-- Role banner -->
                                    <li class="px-3 py-2">
                                        <div class="text-white fw-semibold" style="font-size:.85rem;">@(User.Identity.Name)</div>
                                        <div class="text-muted" style="font-size:.75rem;">@roleLabel</div>
                                    </li>
                                    <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.1); margin:.4rem .8rem;"></li>

                                    <li><a class="dropdown-item aems-dd-item" asp-controller="Profile" asp-action="Index"><i class="bi bi-person me-2"></i>My Profile</a></li>
                                    <li><a class="dropdown-item aems-dd-item" asp-controller="Auth" asp-action="ChangePassword"><i class="bi bi-key me-2"></i>Change Password</a></li>

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.1); margin:.4rem .8rem;"></li>
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</a></li>
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="UserManagement" asp-action="Index"><i class="bi bi-people me-2"></i>User Management</a></li>
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="Department" asp-action="Index"><i class="bi bi-building me-2"></i>Departments</a></li>
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="Topic" asp-action="Index"><i class="bi bi-tags me-2"></i>Topics</a></li>
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="SystemLog" asp-action="Index"><i class="bi bi-journal-text me-2"></i>System Logs</a></li>
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="AdminNotification" asp-action="Create"><i class="bi bi-megaphone me-2"></i>Broadcast</a></li>
                                    }
                                    else if (User.IsInRole("Staff") || User.IsInRole("Organizer"))
                                    {
                                        <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.1); margin:.4rem .8rem;"></li>
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="Organizer" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                                    }
                                    else if (User.IsInRole("Approver"))
                                    {
                                        <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.1); margin:.4rem .8rem;"></li>
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="Approver" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Approver Dashboard</a></li>
                                    }
                                    else if (User.IsInRole("Student"))
                                    {
                                        <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.1); margin:.4rem .8rem;"></li>
                                        <li><a class="dropdown-item aems-dd-item" asp-controller="Student" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                                    }

                                    <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.1); margin:.4rem .8rem;"></li>
                                    <li>
                                        <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item aems-dd-item text-danger">
                                                <i class="bi bi-box-arrow-right me-2"></i>Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3 text-white opacity-80" asp-controller="Auth" asp-action="RegisterStudent" style="font-size:.9rem;">Register</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-sm ms-2 px-4 fw-semibold text-white" asp-controller="Auth" asp-action="Login"
                                   style="background:linear-gradient(135deg,#6366f1,#8b5cf6); border-radius:8px; font-size:.875rem;">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>

        <style>
            .aems-navbar .nav-link:hover  { opacity: 1 !important; }
            .aems-dd-item {
                color: rgba(255,255,255,.8) !important;
                border-radius: 8px !important;
                padding: .5rem .9rem !important;
                font-size: .875rem !important;
                transition: background .15s, color .15s !important;
            }
            .aems-dd-item:hover {
                background: rgba(99,102,241,.25) !important;
                color: #fff !important;
            }
            .aems-dd-item.text-danger { color: #f87171 !important; }
            .aems-dd-item.text-danger:hover { background: rgba(239,68,68,.2) !important; }
            .dropdown-menu.aems-dropdown { animation: fadeInDown .15s ease; }
            @@keyframes fadeInDown {
                from { opacity: 0; transform: translateY(-6px); }
                to   { opacity: 1; transform: translateY(0); }
            }
        </style>
    </header>

    <div class="container">

        <main role="main" class="pb-3">
            @* Legacy Alert Block - Replaced by Toastr
            @if (TempData["NotificationMessage"] != null)
            {
                var type = TempData["NotificationType"]?.ToString() == "error" ? "danger" : "success";
                <div class="alert alert-@type alert-dismissible fade show" role="alert">
                    @TempData["NotificationMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            *@
            <partial name="_Notification" />
            @if (lockedCurrentUser?.IsBanned == true && lockedCurrentUser.Status == UserStatusEnum.Inactive)
            {
                <div class="alert alert-warning shadow-sm mb-4" role="alert">
                    <div class="fw-bold mb-1">Tài khoản của bạn hiện đang bị khóa.</div>
                    @if (lockedCurrentUser.ReactivateAt.HasValue)
                    {
                        <div>Tài khoản sẽ tự động mở khóa lúc @lockedCurrentUser.ReactivateAt.Value.ToString("dd/MM/yyyy HH:mm").</div>
                        <div class="text-danger fw-semibold lock-countdown-global" data-reactivate-at="@lockedCurrentUser.ReactivateAt.Value.ToString("yyyy-MM-ddTHH:mm:ss")"></div>
                    }
                    else
                    {
                        <div>Đây là khóa thủ công. Vui lòng liên hệ quản trị viên để được mở khóa.</div>
                    }
                </div>
            }
            @RenderBody()
        </main>
    </div>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <partial name="_ChatbotBar" />
    }

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - AEMS_Solution - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/site.js?v=4" asp-append-version="true"></script>
    <script src="~/js/chatbot.js" asp-append-version="true"></script>
    <script src="~/js/messenger-layout.js" asp-append-version="true"></script>
    <script>
        (() => {
            const countdownElements = document.querySelectorAll('.lock-countdown-global');
            const pad = value => value.toString().padStart(2, '0');

            const updateCountdown = element => {
                const unlockAt = new Date(element.dataset.reactivateAt);
                const remaining = unlockAt.getTime() - Date.now();

                if (Number.isNaN(unlockAt.getTime())) {
                    element.textContent = '';
                    return;
                }

                if (remaining <= 0) {
                    element.textContent = 'Đang chờ hệ thống tự mở khóa...';
                    return;
                }

                const totalSeconds = Math.floor(remaining / 1000);
                const days = Math.floor(totalSeconds / 86400);
                const hours = Math.floor((totalSeconds % 86400) / 3600);
                const minutes = Math.floor((totalSeconds % 3600) / 60);
                const seconds = totalSeconds % 60;
                const dayText = days > 0 ? `${days} ngày ` : '';
                element.textContent = `Còn lại: ${dayText}${pad(hours)}:${pad(minutes)}:${pad(seconds)}`;
            };

            countdownElements.forEach(element => {
                updateCountdown(element);
                window.setInterval(() => updateCountdown(element), 1000);
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
