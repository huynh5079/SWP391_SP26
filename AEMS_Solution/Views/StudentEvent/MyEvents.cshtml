@model List<BusinessLogic.DTOs.Student.StudentEventBrowseDto>
@{
    ViewData["Title"] = "Vé của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var now = DateTime.Now;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0"><i class="bi bi-ticket-detailed me-2 text-primary"></i>Vé của tôi</h4>
            <small class="text-muted">Danh sách sự kiện bạn đã đăng ký</small>
        </div>
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-calendar-week me-1"></i> Xem tất cả sự kiện
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-ticket-detailed" style="font-size: 3rem;"></i>
            <p class="mt-2 fs-6">Bạn chưa đăng ký sự kiện nào.</p>
            <a asp-action="Index" class="btn btn-primary mt-1">
                <i class="bi bi-search me-1"></i> Khám phá sự kiện
            </a>
        </div>
    }
    else
    {
        <!-- ── Upcoming registrations ─────────────────────────────── -->
        var upcoming = Model.Where(e => e.StartTime > now).OrderBy(e => e.StartTime).ToList();
        var past     = Model.Where(e => e.StartTime <= now).OrderByDescending(e => e.StartTime).ToList();

        @if (upcoming.Any())
        {
            <h6 class="text-muted fw-bold mb-3">
                <i class="bi bi-arrow-right-circle me-1 text-success"></i>
                Sắp diễn ra (@upcoming.Count)
            </h6>
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3 mb-4">
                @foreach (var ev in upcoming)
                {
                    <div class="col">
                        @await Html.PartialAsync("_StudentEventCard", ev)
                    </div>
                }
            </div>
        }

        @if (past.Any())
        {
            <h6 class="text-muted fw-bold mb-3">
                <i class="bi bi-clock-history me-1 text-secondary"></i>
                Đã qua (@past.Count)
            </h6>
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
                @foreach (var ev in past)
                {
                    <div class="col">
                        @await Html.PartialAsync("_StudentEventCard", ev)
                    </div>
                }
            </div>
        }
    }
</div>
