@model List<BusinessLogic.DTOs.Student.StudentEventBrowseDto>
@{
    ViewData["Title"] = "Sự kiện tham gia";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var now = DateTime.Now;
    var waitlist = ViewBag.Waitlist as List<BusinessLogic.DTOs.Role.Organizer.EventWaitlistDto>
        ?? new List<BusinessLogic.DTOs.Role.Organizer.EventWaitlistDto>();
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0"><i class="bi bi-person-workspace me-2 text-primary"></i>Sự kiện tham gia</h4>
            <small class="text-muted">Danh sách sư kiện bạn đã đăng ký vé, làm ban tổ chức hoặc diễn giả</small>
        </div>
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-calendar-week me-1"></i> Xem tất cả sự kiện
        </a>
    </div>

    @* Show waitlist first if exists (always visible regardless of Model content) *@
    @if (waitlist.Any())
    {
        <h6 class="text-muted fw-bold mb-3">
            <i class="bi bi-hourglass-split me-1 text-warning"></i>
            Đăng ký chờ (@waitlist.Count)
        </h6>
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3 mb-4">
            @foreach (var w in waitlist)
            {
                <div class="col">
                    <div class="card h-100 border-warning border-2 shadow-sm">
                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center"
                             style="height: 90px;">
                            <i class="bi bi-hourglass-split text-warning" style="font-size: 2rem;"></i>
                        </div>
                        <div class="card-body pb-1">
                            <div class="d-flex justify-content-between mb-1">
                                @if (w.Status == DataAccess.Enum.EventWaitlistStatusEnum.Offered)
                                {
                                    <span class="badge bg-success"><i class="bi bi-bell me-1"></i>Được mời</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-hourglass me-1"></i>Đăng ký chờ #@w.Position</span>
                                }
                            </div>
                            <h6 class="card-title fw-bold mb-1 text-truncate" title="@w.EventTitle">@w.EventTitle</h6>
                            @if (w.EventStartTime.HasValue)
                            {
                                <div class="small text-muted">
                                    <i class="bi bi-clock me-1"></i>@w.EventStartTime.Value.ToString("dd/MM/yyyy HH:mm")
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(w.LocationName))
                            {
                                <div class="small text-muted text-truncate">
                                    <i class="bi bi-geo-alt me-1"></i>@w.LocationName
                                </div>
                            }
                            <div class="small text-muted">
                                <i class="bi bi-clock-history me-1"></i>Đăng ký chờ: @w.JoinedAt?.ToString("dd/MM/yyyy HH:mm")
                            </div>
                            @if (w.OfferedAt.HasValue)
                            {
                                <div class="small text-warning">
                                    <i class="bi bi-bell me-1"></i>Được mời: @w.OfferedAt.Value.ToString("dd/MM/yyyy HH:mm")
                                </div>
                            }
                        </div>
                        <div class="card-footer bg-transparent border-0 pt-0">
                            <a asp-action="Detail" asp-controller="StudentEvent"
                               asp-route-id="@w.EventId"
                               class="btn btn-sm btn-outline-warning w-100">
                                Xem chi tiết <i class="bi bi-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @* Events list or empty-state *@
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-calendar-x" style="font-size: 3rem;"></i>
            <p class="mt-2 fs-6">Bạn chưa tham gia vào sự kiện nào.</p>
            <a asp-action="Index" class="btn btn-primary mt-1">
                <i class="bi bi-search me-1"></i> Khám phá sự kiện
            </a>
        </div>
    }
    else
    {
        var upcoming = Model.Where(e => e.StartTime > now).OrderBy(e => e.StartTime).ToList();
        var past     = Model.Where(e => e.StartTime <= now).OrderByDescending(e => e.StartTime).ToList();

        @if (upcoming.Any())
        {
            <h6 class="text-muted fw-bold mb-3">
                <i class="bi bi-arrow-right-circle me-1 text-success"></i>
                Sắp diễn ra (@upcoming.Count)
            </h6>
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3 mb-4">
                @foreach (var ev in upcoming)
                {
                    <div class="col">
                        @await Html.PartialAsync("_StudentEventCard", ev)
                    </div>
                }
            </div>
        }

        @if (past.Any())
        {
            <h6 class="text-muted fw-bold mb-3">
                <i class="bi bi-clock-history me-1 text-secondary"></i>
                Đã qua (@past.Count)
            </h6>
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
                @foreach (var ev in past)
                {
                    <div class="col">
                        @await Html.PartialAsync("_StudentEventCard", ev)
                    </div>
                }
            </div>
        }
    }
</div>
