@model List<BusinessLogic.DTOs.Student.StudentEventBrowseDto>
@{
    ViewData["Title"] = "My Participating Events";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var now = DateTime.Now;
    var waitlist = ViewBag.Waitlist as List<BusinessLogic.DTOs.Role.Organizer.EventWaitlistDto>
        ?? new List<BusinessLogic.DTOs.Role.Organizer.EventWaitlistDto>();
}

<div class="container-fluid py-4" style="background-color: #fafbfc; min-height: 100vh;">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold mb-2" style="color: #1f2937; letter-spacing: -0.5px;">My Participating Events</h2>
            <p class="text-secondary mb-0">Track and manage your upcoming and past involvements.</p>
        </div>
        <a asp-action="Index" class="btn bg-white border rounded-3 px-4 py-2 text-dark shadow-sm" style="font-weight: 500;">
            View All Events <i class="bi bi-arrow-right ms-2"></i>
        </a>
    </div>

    @* Show waitlist first if exists *@
    @if (waitlist.Any())
    {
        <div class="d-flex align-items-center mb-4">
            <h5 class="fw-bold text-dark mb-0">Waitlist</h5>
            <span class="badge rounded-pill bg-light text-dark border ms-3 px-3 py-1">@waitlist.Count</span>
        </div>
        
        <div class="row row-cols-1 row-cols-lg-2 g-4 mb-5">
            @foreach (var w in waitlist)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden" style="background-color: #ffffff;">
                        <div class="position-relative">
                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 180px;">
                                <i class="bi bi-calendar-event text-secondary opacity-50" style="font-size: 3rem;"></i>
                                <span class="position-absolute top-0 end-0 m-3 badge rounded-pill bg-white text-dark shadow-sm px-3 py-2 text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                                    @if (w.Status == DataAccess.Enum.EventWaitlistStatusEnum.Offered)
                                    {
                                        <i class="bi bi-circle-fill text-success me-1" style="font-size: 6px; vertical-align: middle;"></i><span>OFFERED</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-circle-fill text-warning me-1" style="font-size: 6px; vertical-align: middle;"></i><span>WAITING #@w.Position</span>
                                    }
                                </span>
                            </div>
                        </div>
                        <div class="card-body p-4 d-flex flex-column">
                            <h5 class="card-title fw-bold mb-4 text-truncate" style="color: #1f2937;" title="@w.EventTitle">@w.EventTitle</h5>
                            <div class="row g-3 mb-4">
                                @if (w.EventStartTime.HasValue)
                                {
                                    <div class="col-6 d-flex align-items-center text-secondary" style="font-size: 0.9rem;">
                                        <i class="bi bi-calendar3 me-2 text-muted"></i>@w.EventStartTime.Value.ToString("MMM dd, yyyy")
                                    </div>
                                    <div class="col-6 d-flex align-items-center text-secondary" style="font-size: 0.9rem;">
                                        <i class="bi bi-clock me-2 text-muted"></i>@w.EventStartTime.Value.ToString("hh:mm tt")
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(w.LocationName))
                                {
                                    <div class="col-12 d-flex align-items-center text-secondary" style="font-size: 0.9rem;">
                                        <i class="bi bi-building me-2 text-muted"></i>
                                        <span class="text-truncate">@w.LocationName</span>
                                    </div>
                                }
                            </div>
                            <div class="mt-auto pt-3">
                                <a asp-action="Detail" asp-controller="StudentEvent" asp-route-id="@w.EventId" class="text-decoration-none fw-semibold" style="color: #4b5563; font-size: 0.95rem;">
                                    View Details <i class="bi bi-chevron-right ms-1" style="font-size: 0.8rem;"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @* Events list or empty-state *@
    @if (!Model.Any())
    {
        <div class="text-center py-5 border rounded-4 bg-white shadow-sm h-100 d-flex flex-column align-items-center justify-content-center" style="min-height: 400px; border-color: #e5e7eb !important;">
            <i class="bi bi-calendar-event text-secondary opacity-25 mb-3" style="font-size: 4rem;"></i>
            <h5 class="fw-bold text-dark mt-2">No Participating Events</h5>
            <p class="text-secondary mb-4">You haven't joined any events yet.</p>
            <a asp-action="Index" class="btn btn-dark rounded-3 px-4 py-2">
                Explore Events
            </a>
        </div>
    }
    else
    {
        var upcoming = Model.Where(e => e.StartTime > now).OrderBy(e => e.StartTime).ToList();
        var past     = Model.Where(e => e.StartTime <= now).OrderByDescending(e => e.StartTime).ToList();

        @if (upcoming.Any())
        {
            <div class="d-flex align-items-center mb-4">
                <h5 class="fw-bold text-dark mb-0">Upcoming</h5>
                <span class="badge rounded-pill" style="background-color: #e0e7ff; color: #4338ca; margin-left: 1rem; padding: 0.35rem 0.8rem; font-weight: 600;">@upcoming.Count</span>
            </div>
            <div class="row row-cols-1 row-cols-lg-2 g-4 mb-5">
                @foreach (var ev in upcoming)
                {
                    <div class="col">
                        @await Html.PartialAsync("_StudentEventCard", ev)
                    </div>
                }
            </div>
        }

        @if (past.Any())
        {
            <div class="d-flex align-items-center mb-4 mt-3">
                <h5 class="fw-bold text-dark mb-0">Past</h5>
                <span class="badge rounded-pill" style="background-color: #e2e8f0; color: #475569; margin-left: 1rem; padding: 0.35rem 0.8rem; font-weight: 600;">@past.Count</span>
            </div>
            <div class="row row-cols-1 row-cols-lg-2 g-4 mb-3">
                @foreach (var ev in past)
                {
                    <div class="col">
                        @await Html.PartialAsync("_StudentEventCard", ev)
                    </div>
                }
            </div>
        }
    }
</div>
