@model BusinessLogic.DTOs.Student.StudentEventBrowseDto
@{
    string badgeColor = "bg-white text-dark";
    string dotColor = "";
    string badgeText = Model.Status.ToString().ToUpper();
    bool showDot = false;

    if (Model.IsRegistered)
    {
        badgeColor = "text-success";
        dotColor = "text-success";
        badgeText = "REGISTERED";
        showDot = true;
    }
    else if (Model.Status == DataAccess.Enum.EventStatusEnum.Cancelled)
    {
        badgeColor = "text-secondary";
        badgeText = "CANCELLED";
    }
    else if (Model.Status == DataAccess.Enum.EventStatusEnum.Draft)
    {
        badgeColor = "text-secondary";
        badgeText = "DRAFT";
    }
    // Handle Expired or other pass through
    else if (Model.StartTime < DateTime.Now && Model.Status != DataAccess.Enum.EventStatusEnum.Happening)
    {
        badgeColor = "text-secondary";
        badgeText = "EXPIRED";
    }
    else if (Model.IsFull)
    {
        badgeColor = "text-danger";
        badgeText = "FULL";
        showDot = true;
        dotColor = "text-danger";
    }
    else
    {
        badgeColor = "text-primary";
        badgeText = Model.Status.ToString().ToUpper();
    }
}

<div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden" style="background-color: #ffffff;">
    <div class="position-relative">
        @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
        {
            <img src="@Model.ThumbnailUrl" class="card-img-top" alt="@Model.Title"
                 style="height: 180px; object-fit: cover; width: 100%;">
        }
        else
        {
            <div class="card-img-top bg-light d-flex align-items-center justify-content-center"
                 style="height: 180px;">
                <i class="bi bi-calendar-event text-secondary opacity-25" style="font-size: 3rem;"></i>
                @if (Model.Status == DataAccess.Enum.EventStatusEnum.Draft)
                {
                    <div class="position-absolute text-secondary" style="bottom: 20px; font-size: 0.85rem;">
                        Pending Poster Upload
                    </div>
                }
            </div>
        }
        
        <span class="position-absolute top-0 end-0 m-3 badge rounded-pill px-3 py-2 shadow-sm text-uppercase" 
              style="background-color: rgba(255, 255, 255, 0.95); backdrop-filter: blur(4px); font-size: 0.75rem; letter-spacing: 0.5px; @(badgeColor.Contains("text-") ? "" : "color: #475569;")">
            @if (showDot)
            {
                <i class="bi bi-circle-fill @dotColor me-1" style="font-size: 6px; vertical-align: middle;"></i>
            }
            <span class="@badgeColor">@badgeText</span>
        </span>
    </div>
    
    <div class="card-body p-4 d-flex flex-column">
        @if (!string.IsNullOrEmpty(Model.ParticipationRole))
        {
            <div class="mb-2">
                <span class="badge bg-light text-secondary border px-2 py-1">@Model.ParticipationRole</span>
            </div>
        }
        
        <h5 class="card-title fw-bold mb-4" style="color: #1f2937; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;" title="@Model.Title">
            @Model.Title
        </h5>
        
        <div class="row g-3 mb-4">
            <div class="col-6 d-flex align-items-center text-secondary" style="font-size: 0.9rem;">
                <i class="bi bi-calendar3 me-2 text-muted"></i>
                <span class="text-truncate">@Model.StartTime.ToString("MMM dd, yyyy")</span>
            </div>
            <div class="col-6 d-flex align-items-center text-secondary" style="font-size: 0.9rem;">
                <i class="bi bi-clock me-2 text-muted"></i>
                <span class="text-truncate">@Model.StartTime.ToString("hh:mm tt")</span>
            </div>
            
            <div class="col-6 d-flex align-items-center text-secondary" style="font-size: 0.9rem;">
                <i class="bi bi-building me-2 text-muted"></i>
                <span class="text-truncate" title="@Model.Location">@(string.IsNullOrEmpty(Model.Location) ? "TBA" : Model.Location)</span>
            </div>
            <div class="col-6 d-flex align-items-center text-secondary" style="font-size: 0.9rem;">
                <i class="bi bi-people me-2 text-muted"></i>
                <span class="text-truncate">
                    @Model.RegisteredCount / @Model.MaxCapacity chỗ
                    @if (!Model.IsFull)
                    {
                        <span class="text-success ms-1">(@Model.AvailableSeats trống)</span>
                    }
                </span>
            </div>
        </div>
        
        <div class="mt-auto pt-2">
            <a asp-controller="StudentEvent" asp-action="Detail" asp-route-id="@Model.EventId" 
               class="text-decoration-none fw-semibold" style="color: #4b5563; font-size: 0.95rem;">
                View Details <i class="bi bi-chevron-right ms-1" style="font-size: 0.8rem;"></i>
            </a>
        </div>
    </div>
</div>
