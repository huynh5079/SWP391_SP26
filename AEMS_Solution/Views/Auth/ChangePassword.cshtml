@model AEMS_Solution.Models.Authentication.ChangePasswordViewModel

@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<style>
/* ============================================================
   CHANGE PASSWORD — Luminous Ultra-Premium
============================================================ */
:root {
    --cp-bg: #f8fafc;
    --cp-card: #ffffff;
    --cp-text: #0f172a;
    --cp-border: #e2e8f0;
    --cp-primary: #6366f1;
    --cp-primary-hover: #4f46e5;
    --cp-shadow: 0 10px 40px rgba(15,23,42,0.06);
}

body {
    background-color: var(--cp-bg);
}

@@keyframes cp-fadeUp { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:none} }
@@keyframes cp-blob { 
    0%,100% {border-radius:60% 40% 30% 70% / 60% 30% 70% 40%; transform:rotate(0deg)} 
    50%     {border-radius:30% 60% 70% 40% / 50% 60% 30% 60%; transform:rotate(180deg)} 
}

.cp-wrapper {
    min-height: calc(100vh - 80px); /* adjust if navbar height differs */
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 2rem;
    overflow: hidden;
}

/* Background blobs */
.cp-blob-1 {
    position: absolute; top: 10%; left: 15%; width: 400px; height: 400px;
    background: #8b5cf6; filter: blur(80px); opacity: 0.2; pointer-events: none;
    animation: cp-blob 15s infinite alternate linear;
}
.cp-blob-2 {
    position: absolute; bottom: 10%; right: 15%; width: 350px; height: 350px;
    background: #ec4899; filter: blur(80px); opacity: 0.15; pointer-events: none;
    animation: cp-blob 18s infinite alternate-reverse linear;
}

.cp-card {
    background: rgba(255,255,255,0.85); /* transparent to show blob colors slightly */
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    width: 100%;
    max-width: 500px;
    border-radius: 24px;
    padding: 3rem 2.5rem;
    box-shadow: var(--cp-shadow), 0 0 0 1px rgba(255,255,255,0.5);
    border: 1px solid rgba(255,255,255,0.7);
    animation: cp-fadeUp 0.5s ease both;
    position: relative; z-index: 2;
}

.cp-icon-wrap {
    width: 64px; height: 64px; border-radius: 20px;
    background: linear-gradient(135deg, #e0e7ff, #c7d2fe);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.8rem; color: #4f46e5; margin: 0 auto 1.5rem;
    box-shadow: inset 0 2px 4px rgba(255,255,255,0.8);
}

.cp-title {
    font-size: 1.5rem; font-weight: 800; color: var(--cp-text);
    text-align: center; margin-bottom: .2rem;
}
.cp-subtitle {
    font-size: .9rem; color: #64748b; text-align: center; margin-bottom: 2rem;
}

/* Form Styles */
.cp-form-group {
    margin-bottom: 1.25rem;
    position: relative;
}
.cp-form-label {
    font-size: .8rem; font-weight: 700; color: #475569; margin-bottom: .4rem; display: block;
}
.cp-input-wrap {
    position: relative;
}
.cp-form-control {
    width: 100%; padding: .8rem 1rem; padding-right: 2.8rem;
    font-size: .95rem; border-radius: 12px; border: 1.5px solid var(--cp-border);
    transition: all .2s; outline: none; background: #fafbff;
    font-family: inherit; color: var(--cp-text); font-weight: 500;
}
.cp-form-control:focus {
    border-color: var(--cp-primary);
    box-shadow: 0 0 0 4px rgba(99,102,241,0.15);
    background: #fff;
}
.cp-toggle-pw {
    position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
    color: #94a3b8; cursor: pointer; transition: color .2s; font-size: 1.1rem;
    background: none; border: none; outline: none; padding: 0;
}
.cp-toggle-pw:hover { color: var(--cp-primary); }

/* Buttons */
.cp-actions {
    display: flex; gap: 1rem; margin-top: 2rem;
}
.cp-btn-primary {
    flex: 1; padding: .8rem; border-radius: 12px; border: none;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff; font-weight: 700; font-size: .95rem;
    transition: all .2s; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: .4rem;
    box-shadow: 0 4px 12px rgba(99,102,241,.3);
}
.cp-btn-primary:hover {
    transform: translateY(-2px); box-shadow: 0 6px 18px rgba(99,102,241,.4);
}
.cp-btn-secondary {
    padding: .8rem 1.5rem; border-radius: 12px; border: 1.5px solid var(--cp-border);
    background: #fff; color: #64748b; font-weight: 700; font-size: .95rem;
    transition: all .2s; cursor: pointer; text-decoration: none; display: flex; align-items: center; justify-content: center;
}
.cp-btn-secondary:hover {
    background: #f1f5f9; color: var(--cp-text); border-color: #cbd5e1;
}

/* Tooltip/Policy for passwords */
.cp-policy {
    background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 10px;
    padding: 1rem; margin-bottom: 1.5rem; font-size: .8rem; color: #64748b;
}
.cp-policy ul { padding-left: 1.2rem; margin-bottom: 0; margin-top: .4rem; }
.cp-policy li { margin-bottom: .2rem; }
</style>

<div class="cp-wrapper">
    <!-- Ambient Background Blobs -->
    <div class="cp-blob-1"></div>
    <div class="cp-blob-2"></div>

    <!-- Main Card -->
    <div class="cp-card">
        <div class="cp-icon-wrap">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <h2 class="cp-title">Đổi mật khẩu</h2>
        <p class="cp-subtitle">Bảo mật tài khoản của bạn bằng mật khẩu mạnh</p>

        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()

            <div class="cp-form-group">
                <label asp-for="OldPassword" class="cp-form-label">Mật khẩu hiện tại</label>
                <div class="cp-input-wrap">
                    <input asp-for="OldPassword" class="cp-form-control" placeholder="Nhập mật khẩu hiện tại" />
                    <button type="button" class="cp-toggle-pw" onclick="togglePassword(this, 'OldPassword')" tabindex="-1">
                        <i class="bi bi-eye-slash-fill"></i>
                    </button>
                </div>
                <span asp-validation-for="OldPassword" class="text-danger small mt-1 d-block fw-bold"></span>
            </div>

            <div class="cp-form-group">
                <label asp-for="NewPassword" class="cp-form-label">Mật khẩu mới</label>
                <div class="cp-input-wrap">
                    <input asp-for="NewPassword" class="cp-form-control" placeholder="Ít nhất 8 ký tự" />
                    <button type="button" class="cp-toggle-pw" onclick="togglePassword(this, 'NewPassword')" tabindex="-1">
                        <i class="bi bi-eye-slash-fill"></i>
                    </button>
                </div>
                <span asp-validation-for="NewPassword" class="text-danger small mt-1 d-block fw-bold"></span>
            </div>

            <div class="cp-form-group mb-4">
                <label asp-for="ConfirmNewPassword" class="cp-form-label">Xác nhận mật khẩu mới</label>
                <div class="cp-input-wrap">
                    <input asp-for="ConfirmNewPassword" class="cp-form-control" placeholder="Nhập lại mật khẩu mới" />
                    <button type="button" class="cp-toggle-pw" onclick="togglePassword(this, 'ConfirmNewPassword')" tabindex="-1">
                        <i class="bi bi-eye-slash-fill"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmNewPassword" class="text-danger small mt-1 d-block fw-bold"></span>
            </div>

            <!-- Optional visual hint for users, optional class if needed -->
            <div class="cp-policy">
                <i class="bi bi-info-circle-fill text-primary me-1"></i> <strong>Lưu ý bảo mật:</strong>
                <ul>
                    <li>Mật khẩu phải từ 6 ký tự trở lên.</li>
                    <li>Nên bao gồm chữ hoa, chữ thường, và số.</li>
                </ul>
            </div>

            <div class="cp-actions">
                <!-- If the user came from profile, they might want to return to profile -->
                <a href="javascript:history.back()" class="cp-btn-secondary">
                    Hủy bỏ
                </a>
                <button type="submit" class="cp-btn-primary">
                    <i class="bi bi-check2-circle"></i> Cập nhật ngay
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword(btn, inputId) {
            const input = document.getElementById(inputId);
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('bi-eye-slash-fill');
                icon.classList.add('bi-eye-fill');
            } else {
                input.type = 'password';
                icon.classList.add('bi-eye-slash-fill');
                icon.classList.remove('bi-eye-fill');
            }
        }
    </script>
}
