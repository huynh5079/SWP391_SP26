@model AEMS_Solution.Models.Approver.ApproverEventDetailVm
@{
    ViewData["Title"] = "Approval - Event Detail";
    Layout = "_Approvallayout";
}

<div class="container mt-4">
    <h2 class="mb-3">Event Detail</h2>

    <div class="card mb-3">
        <div class="card-body">
            <h4>@Model.Title</h4>
            <p>@Model.Description</p>
            <p><strong>Organizer:</strong> @Model.OrganizerName (@Model.OrganizerEmail)</p>
            <p><strong>Time:</strong> @Model.StartTime.ToString("dd/MM/yyyy HH:mm") → @Model.EndTime.ToString("dd/MM/yyyy HH:mm")</p>
            <p><strong>Location:</strong> @(Model.Location ?? "No location")</p>
            <p><strong>Capacity:</strong> @Model.MaxCapacity</p>
            <p><strong>Status:</strong> <span class="badge bg-info">@Model.Status</span></p>
        </div>
    </div>

    <div class="mb-3">
        <a asp-controller="Approver" asp-action="DescriptAction" asp-route-id="@Model.EventId" asp-route-operation="approve" class="btn btn-success">Approve</a>
        <a asp-controller="Approver" asp-action="DescriptAction" asp-route-id="@Model.EventId" asp-route-operation="reject" class="btn btn-danger ms-2">Reject</a>
        <a asp-controller="Approver" asp-action="DescriptAction" asp-route-id="@Model.EventId" asp-route-operation="requestchange" class="btn btn-warning ms-2">Request Change</a>
    </div>

    <h5>Approval Logs</h5>
    <table class="table table-sm">
        <thead>
            <tr>
                <th>Time</th>
                <th>Approver</th>
                <th>Action</th>
                <th>Comment</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var l in Model.ApprovalLogs)
            {
                <tr>
                    <td>@l.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@l.ApproverId</td>
                    <td>@l.Action</td>
                    <td>@l.Comment</td>
                </tr>
            }
        </tbody>
    </table>
</div>
