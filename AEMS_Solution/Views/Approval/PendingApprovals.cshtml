@model AEMS_Solution.Models.Approver.PendingApprovalsViewModel
@{
    ViewData["Title"] = "Approval - Pending Events";
    Layout = "_Approvallayout";
}

<div class="container mt-4">
    <h2 class="mb-4">📋 Pending Approvals</h2>

    <form class="row g-2 mb-3" method="get" asp-controller="Approver" asp-action="PendingApprovals">
        <div class="col-auto">
            <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search event or organizer..." />
        </div>

        <div class="col-auto">
            <button class="btn btn-primary">Filter</button>
        </div>
    </form>

    <table class="table table-bordered table-hover shadow">
        <thead class="table-dark">
            <tr>
                <th>Thumbnail</th>
                <th>Title</th>
                <th>Organizer</th>
                <th>Location</th>
                <th>Time</th>
                <th>Status</th>
                <th>Last Reason</th>
                <th>Action</th>
                <th>Detail Event<th/>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model.Events)
            {
                <tr>
                    <td style="width:120px">
                        @if (!string.IsNullOrEmpty(e.ThumbnailUrl))
                        {
                            var fallbackUrl = "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(e.Title ?? "Event") + "&size=128&background=f3f4f6&color=9ca3af&bold=true";
                            <img src="@e.ThumbnailUrl" class="img-fluid rounded" onerror="this.onerror=null;this.src='@fallbackUrl';" />
                        }
                    </td>
                    <td><strong>@e.Title</strong></td>
                    <td>
                        <div><strong>@(string.IsNullOrWhiteSpace(e.OrganizerName) ? "-" : e.OrganizerName)</strong></div>
                        <div class="text-muted small">@(string.IsNullOrWhiteSpace(e.OrganizerEmail) ? string.Empty : e.OrganizerEmail)</div>
                    </td>
                    <td>@e.Location</td>
                    <td>
                        @e.StartTime.ToString("dd/MM/yyyy HH:mm")<br />→<br />@e.EndTime.ToString("dd/MM/yyyy HH:mm")
                    </td>
                    <td>
                        <span class="badge bg-warning text-dark">@e.Status</span>
                    </td>
                    <td class="text-break" style="max-width:200px;">@(!string.IsNullOrWhiteSpace(e.LastApprovalComment) ? e.LastApprovalComment : "")</td>
                    <td>
                        <a asp-controller="Approver" asp-action="DescriptAction" asp-route-id="@e.EventId" asp-route-operation="approve" class="btn btn-sm btn-success">Approve</a>
                        <a asp-controller="Approver" asp-action="DescriptAction" asp-route-id="@e.EventId" asp-route-operation="reject" class="btn btn-sm btn-danger ms-1">Reject</a>
                        <a asp-controller="Approver" asp-action="DescriptAction" asp-route-id="@e.EventId" asp-route-operation="requestchange" class="btn btn-sm btn-warning ms-1">Request Change</a>
                    </td>
                    <td><a asp-action="Detail" asp-route-id="@e.EventId" class="btn btn-sm btn-info">View</a><td/>
                </tr>
            }
        </tbody>
    </table>
</div>
