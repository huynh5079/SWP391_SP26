@model AEMS_Solution.Models.Approver.Manage.ManageRoomViewModel
@using DataAccess.Enum
@{
    ViewData["Title"] = "Manage Rooms";
    Layout = "_Approvallayout";
}

<div class="container mt-4">
    <h2 class="mb-4">Manage Rooms</h2>

    <div class="card shadow-sm mb-4">
        <div class="card-header fw-bold">Create Room</div>
        <div class="card-body">
            <form asp-controller="Approver" asp-action="CreateRoom" method="post">
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(false, "", new { @class = "text-danger mb-3" })
                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="NewRoom.Name" class="form-label">Room Name</label>
                        <input asp-for="NewRoom.Name" class="form-control" />
                        <span asp-validation-for="NewRoom.Name" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="NewRoom.Building" class="form-label">Building</label>
                        <input asp-for="NewRoom.Building" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="NewRoom.Floor" class="form-label">Floor</label>
                        <input asp-for="NewRoom.Floor" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="NewRoom.Room" class="form-label">Room</label>
                        <input asp-for="NewRoom.Room" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="NewRoom.Capacity" class="form-label"></label>
                        <input asp-for="NewRoom.Capacity" type="number" min="1" class="form-control" />
                        <span asp-validation-for="NewRoom.Capacity" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="NewRoom.Type" class="form-label"></label>
                        <select asp-for="NewRoom.Type" asp-items="Html.GetEnumSelectList<LocationTypeEnum>()" class="form-select">
                            <option value="">-- Select Type --</option>
                        </select>
                        <span asp-validation-for="NewRoom.Type" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="NewRoom.Status" class="form-label"></label>
                        <select asp-for="NewRoom.Status" asp-items="Html.GetEnumSelectList<LocationStatusEnum>()" class="form-select"></select>
                    </div>
                    <div class="col-12">
                        <label asp-for="NewRoom.Description" class="form-label"></label>
                        <textarea asp-for="NewRoom.Description" rows="3" class="form-control"></textarea>
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">Create Room</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header fw-bold">Room List</div>
        <div class="card-body p-0">
            <table class="table table-bordered table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Room Name</th>
                        <th>Address</th>
                        <th>Capacity</th>
                        <th>Type</th>
                        <th>Description</th>
                        <th style="width:240px;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Rooms.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">No rooms found.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var room in Model.Rooms)
                        {
                            <tr>
                                <td>@room.Name</td>
                                <td>@room.Address</td>
                                <td>@room.Capacity</td>
                                <td>@(room.Type?.ToString() ?? "-")</td>
                                <td>@room.Description</td>
                                <td>
                                    <form asp-controller="Approver" asp-action="UpdateRoomStatus" method="post" class="d-flex gap-2 align-items-center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="LocationId" value="@room.LocationId" />
                                        <select name="Status" class="form-select form-select-sm">
                                            @foreach (LocationStatusEnum status in Enum.GetValues(typeof(LocationStatusEnum)))
                                            {
                                                <option value="@status" selected="@(room.Status == status ? "selected" : null)">@status</option>
                                            }
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-warning">Update</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />
