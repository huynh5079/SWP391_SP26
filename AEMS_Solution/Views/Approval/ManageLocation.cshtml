@model AEMS_Solution.Models.Approver.Manage.ManageRoomViewModel
@using DataAccess.Enum
@{
    ViewData["Title"] = "Manage Rooms";
    Layout = "_Approvallayout";
}

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-building me-2"></i>Manage Rooms</h2>

    <!-- Create Room Form -->
    <div class="card shadow-sm mb-4">
        <div class="card-header fw-bold">
            <i class="bi bi-plus-circle me-1"></i> Create Room
        </div>
        <div class="card-body">
            <form asp-controller="Approver" asp-action="CreateRoom" method="post">
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(false, "", new { @class = "text-danger mb-3" })
                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="NewRoom.Name" class="form-label fw-semibold">Room Name <span class="text-danger">*</span></label>
                        <input asp-for="NewRoom.Name" class="form-control" />
                        <span asp-validation-for="NewRoom.Name" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="NewRoom.Building" class="form-label fw-semibold">Building</label>
                        <input asp-for="NewRoom.Building" class="form-control" placeholder="VD: Tòa A" />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="NewRoom.Floor" class="form-label fw-semibold">Floor</label>
                        <input asp-for="NewRoom.Floor" class="form-control" placeholder="VD: 3" />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="NewRoom.Room" class="form-label fw-semibold">Room No.</label>
                        <input asp-for="NewRoom.Room" class="form-control" placeholder="VD: 301" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="NewRoom.Capacity" class="form-label fw-semibold">Capacity <span class="text-danger">*</span></label>
                        <input asp-for="NewRoom.Capacity" type="number" min="1" class="form-control" />
                        <span asp-validation-for="NewRoom.Capacity" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="NewRoom.Type" class="form-label fw-semibold">Type <span class="text-danger">*</span></label>
                        <select asp-for="NewRoom.Type" asp-items="Html.GetEnumSelectList<LocationTypeEnum>()" class="form-select">
                            <option value="">-- Select Type --</option>
                        </select>
                        <span asp-validation-for="NewRoom.Type" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="NewRoom.Status" class="form-label fw-semibold">Status</label>
                        <select asp-for="NewRoom.Status" asp-items="Html.GetEnumSelectList<LocationStatusEnum>()" class="form-select"></select>
                    </div>
                    <div class="col-12">
                        <label asp-for="NewRoom.Description" class="form-label fw-semibold">Description</label>
                        <textarea asp-for="NewRoom.Description" rows="2" class="form-control"></textarea>
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i> Create Room
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Room List -->
    <div class="card shadow-sm">
        <div class="card-header fw-bold">
            <i class="bi bi-list-ul me-1"></i> Room List
        </div>
        <div class="card-body p-0">
            <table class="table table-bordered table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Room Name</th>
                        <th>Address</th>
                        <th>Capacity</th>
                        <th>Type</th>
                        <th>Description</th>
                        <th style="width:180px;">Status</th>
                        <th style="width:80px;">Edit</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Rooms.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-3">No rooms found.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var room in Model.Rooms)
                        {
                            <tr>
                                <td><strong>@room.Name</strong></td>
                                <td>@(string.IsNullOrWhiteSpace(room.Address) ? "-" : room.Address)</td>
                                <td class="text-center">@room.Capacity</td>
                                <td>@(room.Type?.ToString() ?? "-")</td>
                                <td>@(string.IsNullOrWhiteSpace(room.Description) ? "-" : room.Description)</td>
                                <td>
                                    <form asp-controller="Approver" asp-action="UpdateRoomStatus" method="post" class="d-flex gap-2 align-items-center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="LocationId" value="@room.LocationId" />
                                        <select name="Status" class="form-select form-select-sm">
                                            @foreach (LocationStatusEnum status in Enum.GetValues(typeof(LocationStatusEnum)))
                                            {
                                                if (room.Status == status)
                                                {
                                                    <option value="@status" selected="selected">@status</option>
                                                }
                                                else
                                                {
                                                    <option value="@status">@status</option>
                                                }
                                            }
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-warning">
                                            <i class="bi bi-arrow-clockwise"></i>
                                        </button>
                                    </form>
                                </td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editRoomModal"
                                            data-id="@room.LocationId"
                                            data-name="@room.Name"
                                            data-capacity="@room.Capacity"
                                            data-type="@((int?)room.Type ?? -1)"
                                            data-status="@((int)room.Status)"
                                            data-description="@room.Description"
                                            data-address="@room.Address">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Edit Room Modal -->
<div class="modal fade" id="editRoomModal" tabindex="-1" aria-labelledby="editRoomModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editRoomModalLabel"><i class="bi bi-pencil-square me-2"></i>Edit Room</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Approver" asp-action="UpdateRoom" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="LocationId" id="editLocationId" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Room Name <span class="text-danger">*</span></label>
                            <input type="text" name="Name" id="editName" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Current Address</label>
                            <input type="text" id="editAddressDisplay" class="form-control bg-light" readonly />
                            <small class="text-muted">Điền Building/Floor/Room để ghi đè địa chỉ</small>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Building</label>
                            <input type="text" name="Building" id="editBuilding" class="form-control" placeholder="VD: Tòa A" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Floor</label>
                            <input type="text" name="Floor" id="editFloor" class="form-control" placeholder="VD: 3" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Room No.</label>
                            <input type="text" name="Room" id="editRoom" class="form-control" placeholder="VD: 301" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Capacity <span class="text-danger">*</span></label>
                            <input type="number" name="Capacity" id="editCapacity" class="form-control" min="1" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Type <span class="text-danger">*</span></label>
                            <select name="Type" id="editType" class="form-select" required>
                                <option value="">-- Select Type --</option>
                                @foreach (LocationTypeEnum t in Enum.GetValues(typeof(LocationTypeEnum)))
                                {
                                    <option value="@((int)t)">@t</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Status</label>
                            <select name="Status" id="editStatus" class="form-select">
                                @foreach (LocationStatusEnum s in Enum.GetValues(typeof(LocationStatusEnum)))
                                {
                                    <option value="@((int)s)">@s</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Description</label>
                            <textarea name="Description" id="editDescription" class="form-control" rows="3"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i> Lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />

@section Scripts {
<script>
    var editModal = document.getElementById('editRoomModal');
    editModal.addEventListener('show.bs.modal', function (event) {
        var btn = event.relatedTarget;
        document.getElementById('editLocationId').value  = btn.getAttribute('data-id');
        document.getElementById('editName').value        = btn.getAttribute('data-name');
        document.getElementById('editCapacity').value    = btn.getAttribute('data-capacity');
        document.getElementById('editDescription').value = btn.getAttribute('data-description') || '';
        document.getElementById('editAddressDisplay').value = btn.getAttribute('data-address') || '';

        // Select Type
        var typeVal = btn.getAttribute('data-type');
        var typeSelect = document.getElementById('editType');
        for (var i = 0; i < typeSelect.options.length; i++) {
            typeSelect.options[i].selected = (typeSelect.options[i].value == typeVal);
        }

        // Select Status
        var statusVal = btn.getAttribute('data-status');
        var statusSelect = document.getElementById('editStatus');
        for (var i = 0; i < statusSelect.options.length; i++) {
            statusSelect.options[i].selected = (statusSelect.options[i].value == statusVal);
        }
    });
</script>
}
