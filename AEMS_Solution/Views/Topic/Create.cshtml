@model AEMS_Solution.Models.Approver.CreateTopicViewModel
@{
    ViewData["Title"] = "Create Topic";
    Layout = "_Approvallayout";
}

<div class="container mt-4">
    <h2>Create Topic</h2>
    <form asp-controller="Topic" asp-action="Create" method="post" class="mt-3">
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(false, "", new { @class = "text-danger" })

        <div class="mb-3">
            <label asp-for="TopicName" class="form-label"></label>
            <input asp-for="TopicName" class="form-control" />
            <span asp-validation-for="TopicName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-controller="Topic" asp-action="Index" class="btn btn-secondary">Back</a>
    </form>
</div>
