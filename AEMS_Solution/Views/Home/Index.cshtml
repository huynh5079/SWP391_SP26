@{
    ViewData["Title"] = "Academic Event Management";
}


<style>
    .hero-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 5rem 2rem;
        border-radius: 1.5rem;
        margin-bottom: 3rem;
        box-shadow: 0 15px 35px rgba(118, 75, 162, 0.4);
        position: relative;
        overflow: hidden;
    }
    .hero-section::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 70%);
        transform: rotate(45deg);
        animation: shimmer 15s linear infinite;
    }
    @@keyframes shimmer {
        0% { transform: translateY(-50%) rotate(0deg); }
        100% { transform: translateY(-50%) rotate(360deg); }
    }
    .feature-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(0,0,0,0.05);
        border-radius: 1.25rem;
        padding: 2.5rem 2rem;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        height: 100%;
    }
    .feature-card:hover {
        transform: translateY(-15px);
        box-shadow: 0 20px 40px rgba(118, 75, 162, 0.2);
        border-color: rgba(118, 75, 162, 0.3);
    }
    .feature-icon {
        font-size: 3.5rem;
        margin-bottom: 1.5rem;
        background: -webkit-linear-gradient(135deg, #f68084 0%, #a6c0fe 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        transition: transform 0.3s ease;
    }
    .feature-card:hover .feature-icon {
        transform: scale(1.1);
    }
    .floating-shape {
        position: absolute;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
        animation: float 6s ease-in-out infinite;
    }
    @@keyframes float {
        0% { transform: translateY(0px) rotate(0deg); }
        50% { transform: translateY(-20px) rotate(10deg); }
        100% { transform: translateY(0px) rotate(0deg); }
    }
</style>

<div class="container py-4">
    <div class="hero-section text-center">
        <!-- Decorative elements -->
        <div class="floating-shape" style="width: 100px; height: 100px; top: 10%; left: 10%; animation-delay: 0s;"></div>
        <div class="floating-shape" style="width: 150px; height: 150px; bottom: 10%; right: 5%; animation-delay: 2s;"></div>
        <div class="floating-shape" style="width: 70px; height: 70px; top: 20%; right: 20%; animation-delay: 4s;"></div>

        <h1 class="display-3 fw-bold mb-3 position-relative" style="z-index: 1;">
            <i class="bi bi-stars text-warning"></i> Welcome to AEMS
        </h1>
        <p class="lead fs-4 mb-5 position-relative text-light" style="z-index: 1;">The ultimate platform for managing academic events effectively.</p>
        
        <div class="position-relative" style="z-index: 1;">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="card bg-white text-dark d-inline-block p-4 p-md-5 rounded-4 shadow-lg text-start mx-auto" style="max-width: 550px; border: none;">
                    <h3 class="fw-bold mb-3" style="color: #764ba2;">
                        <i class="bi bi-person-wave me-2"></i> Hello, @(User.FindFirst("Fullname")?.Value ?? User.Identity.Name)!
                    </h3>
                    <p class="fs-5 text-muted mb-4">You are logged in as <span class="badge bg-primary fs-6 px-3 py-2 rounded-pill shadow-sm">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span></p>
                    
                    <div class="mt-2 text-center">
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="Admin" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-5 shadow w-100 py-3 fw-bold"><i class="bi bi-speedometer2 me-2"></i> Quản lý hệ thống</a>
                        }
                        else if (User.IsInRole("Organizer"))
                        {
                            <a asp-controller="Organizer" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-5 shadow w-100 py-3 fw-bold"><i class="bi bi-calendar-event me-2"></i> Quản lý sự kiện</a>
                        }
                        else if (User.IsInRole("Approver"))
                        {
                            <a asp-controller="Approver" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-5 shadow w-100 py-3 fw-bold"><i class="bi bi-check-circle me-2"></i> Duyệt sự kiện</a>
                        }
                        else if (User.IsInRole("Student"))
                        {
                            <a asp-controller="StudentEvent" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-5 shadow w-100 py-3 fw-bold"><i class="bi bi-compass me-2"></i> Khám phá sự kiện</a>
                        }
                        else
                        {
                            <a href="#" class="btn btn-secondary btn-lg disabled rounded-pill px-5 w-100 py-3">Dashboard Unavailable</a>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="mt-4">
                    <p class="fs-5 mb-4 text-white-50">Please login to access event management features.</p>
                    <a asp-controller="Auth" asp-action="Login" class="btn btn-light text-primary fw-bold btn-lg rounded-pill px-5 py-3 mx-2 shadow-sm hover-lift"><i class="bi bi-box-arrow-in-right me-2"></i> Đăng nhập</a>
                    <a asp-controller="Auth" asp-action="RegisterStudent" class="btn btn-outline-light border-2 fw-bold btn-lg rounded-pill px-5 py-3 mx-2 hover-lift"><i class="bi bi-person-plus me-2"></i> Đăng ký Sinh viên</a>
                </div>
            }
        </div>
    </div>

    <!-- Features Section -->
    <div class="row g-4 mt-2">
        <div class="col-md-4">
            <div class="feature-card text-center">
                <div class="feature-icon">
                    <i class="bi bi-calendar-event"></i>
                </div>
                <h4 class="fw-bold mb-3 text-dark">Quản lý sự kiện</h4>
                <p class="text-muted">Tổ chức và theo dõi các sự kiện học thuật một cách chuyên nghiệp, sống động và cực kỳ dễ dàng.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card text-center">
                <div class="feature-icon">
                    <i class="bi bi-ticket-perforated"></i>
                </div>
                <h4 class="fw-bold mb-3 text-dark">Đăng ký tham gia</h4>
                <p class="text-muted">Hệ thống cấp vé bằng QR code tự động, giúp việc check-in nhanh như chớp và luôn an toàn.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card text-center">
                <div class="feature-icon">
                    <i class="bi bi-bell"></i>
                </div>
                <h4 class="fw-bold mb-3 text-dark">Thông báo tức thời</h4>
                <p class="text-muted">Nhận thông báo Real-time liên tục về trạng thái sự kiện, luôn nhắc nhở lịch trình kịp thời.</p>
            </div>
        </div>
    </div>
</div>
