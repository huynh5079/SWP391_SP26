@{
    ViewData["Title"] = "Luminous - Academic Event Management";
}

<style>
/* ============================================================
   HOME PAGE — Luminous Ultra-Premium
============================================================ */
:root {
    --hm-font: 'Inter', system-ui, -apple-system, sans-serif;
    --hm-bg: #0f172a;
    --hm-text: #f8fafc;
    --hm-card: rgba(30, 41, 59, 0.7);
    --hm-accent-1: #8b5cf6;
    --hm-accent-2: #3b82f6;
    --hm-accent-3: #ec4899;
    --hm-glass-border: rgba(255, 255, 255, 0.1);
    --hm-radius: 20px;
}

body {
    background-color: var(--hm-bg);
}

/* ── ANIMATIONS ── */
@@keyframes hm-fadeUp { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:none} }
@@keyframes hm-fadeScale { from{opacity:0;transform:scale(.95)} to{opacity:1;transform:none} }
@@keyframes hm-float { 
    0%,100% {transform:translateY(0)} 
    50%     {transform:translateY(-15px)} 
}
@@keyframes hm-blob { 
    0%,100% {border-radius:60% 40% 30% 70% / 60% 30% 70% 40%; transform:rotate(0deg)} 
    50%     {border-radius:30% 60% 70% 40% / 50% 60% 30% 60%; transform:rotate(180deg)} 
}
@@keyframes hm-scan {
    0% { transform:translateX(-100%); }
    100% { transform:translateX(200%); }
}

/* ── HERO ── */
.hm-hero {
    position: relative;
    padding: 7rem 2rem 5rem;
    overflow: hidden;
    min-height: 80vh;
    display: flex;
    align-items: center;
    border-radius: 0 0 40px 40px;
    background: radial-gradient(circle at 50% 100%, #1e1b4b 0%, #0f172a 70%);
}
.hm-bg-blob {
    position: absolute; filter: blur(80px); opacity: .45; z-index: 0;
    pointer-events: none; animation: hm-blob 20s infinite alternate linear;
}
.hm-blob-1 { width:500px; height:500px; background:var(--hm-accent-1); top:-100px; left:-100px; }
.hm-blob-2 { width:400px; height:400px; background:var(--hm-accent-2); bottom:-50px; right:-50px; animation-delay:-5s;}
.hm-blob-3 { width:300px; height:300px; background:var(--hm-accent-3); top:50%; left:50%; transform:translate(-50%,-50%); opacity:.2; animation:none;}

.hm-hero-content {
    position: relative; z-index: 2; width: 100%; max-width: 1200px; margin: 0 auto;
    display: flex; flex-direction: column; align-items: center; text-align: center;
}

.hm-badge {
    display: inline-flex; align-items: center; gap: .4rem;
    padding: .4rem 1.2rem; border-radius: 30px;
    background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1);
    backdrop-filter: blur(10px); color: #c4b5fd; font-size: .85rem; font-weight: 700;
    margin-bottom: 2rem; animation: hm-fadeUp .6s ease both;
}
.hm-badge i { font-size: .9rem; color: #facc15; }

.hm-title {
    font-size: clamp(2.5rem, 5vw, 4.5rem); font-weight: 900;
    line-height: 1.1; letter-spacing: -.03em; margin-bottom: 1.2rem;
    color: #fff; text-shadow: 0 10px 30px rgba(0,0,0,.5);
    animation: hm-fadeUp .6s .1s ease both;
}
.hm-title-grad {
    background: linear-gradient(to right, #a78bfa, #60a5fa, #f472b6);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.hm-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem); color: #cbd5e1; max-width: 600px;
    line-height: 1.6; margin-bottom: 2.5rem; animation: hm-fadeUp .6s .2s ease both;
}

/* ── LOGIN PANEL ── */
.hm-auth-card {
    background: rgba(255,255,255,.03);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 24px; padding: 2.5rem; width: 100%; max-width: 480px;
    box-shadow: 0 30px 60px rgba(0,0,0,.3), inset 0 1px 0 rgba(255,255,255,.1);
    animation: hm-fadeScale .6s .3s ease both; position: relative; overflow: hidden;
}
.hm-auth-card::before {
    content:''; position:absolute; top:0; left:-100%; width:50%; height:100%;
    background:linear-gradient(to right, transparent, rgba(255,255,255,.04), transparent);
    transform:skewX(-20deg); animation:hm-scan 6s linear infinite;
}

.hm-greeting { font-size: 1.4rem; font-weight: 800; color: #fff; margin-bottom: .2rem; }
.hm-role-tag {
    display: inline-block; padding: .2rem .8rem; border-radius: 6px;
    font-size: .75rem; font-weight: 800; background: rgba(99,102,241,.2);
    color: #818cf8; border: 1px solid rgba(99,102,241,.3); text-transform: uppercase;
    letter-spacing: .06em; margin-bottom: 1.5rem;
}

.hm-btn-primary {
    display: flex; align-items: center; justify-content: center; gap: .6rem;
    width: 100%; padding: 1rem 1.5rem; border-radius: 14px;
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
    color: #fff; font-size: 1rem; font-weight: 700; text-decoration: none;
    transition: all .2s; border: none; cursor: pointer;
    box-shadow: 0 10px 25px rgba(79,70,229,.3);
}
.hm-btn-primary:hover {
    transform: translateY(-2px); box-shadow: 0 15px 35px rgba(79,70,229,.4); color: #fff;
}
.hm-btn-primary i { font-size: 1.1rem; }

.hm-btn-outline {
    display: flex; align-items: center; justify-content: center; gap: .6rem;
    width: 100%; padding: 1rem 1.5rem; border-radius: 14px;
    background: transparent; border: 1.5px solid rgba(255,255,255,.15);
    color: #f8fafc; font-size: 1rem; font-weight: 700; text-decoration: none;
    transition: all .2s; margin-top: .8rem;
}
.hm-btn-outline:hover { background: rgba(255,255,255,.05); border-color: rgba(255,255,255,.3); color: #fff; }

.hm-unauth-text { color: #94a3b8; font-size: .9rem; margin-bottom: 1.5rem; }

/* ── FEATURES GRID ── */
.hm-features-sec { padding: 6rem 2rem; max-width: 1200px; margin: 0 auto; }
.hm-section-title { text-align: center; margin-bottom: 4rem; animation: hm-fadeUp 1s ease both; animation-play-state: paused; }
.hm-section-title.is-visible { animation-play-state: running; }
.hm-st-small { font-size: .8rem; font-weight: 800; color: #818cf8; text-transform: uppercase; letter-spacing: .15em; display: block; margin-bottom: .5rem; }
.hm-st-main { font-size: 2.2rem; font-weight: 900; color: #f8fafc; }

.hm-f-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
@@media(max-width:900px){ .hm-f-grid { grid-template-columns: 1fr; gap: 1.5rem; } }

.hm-f-card {
    background: rgba(30,41,59,.4); border: 1px solid rgba(255,255,255,.05);
    padding: 2.5rem 2rem; border-radius: 20px; text-align: center;
    transition: all .3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative; overflow: hidden;
}
.hm-f-card::before {
    content:''; position:absolute; top:0; left:0; width:100%; height:100%;
    background: radial-gradient(circle at 50% -20%, var(--hover-color, rgba(255,255,255,.1)), transparent 70%);
    opacity: 0; transition: opacity .3s; pointer-events: none;
}
.hm-f-card:hover { transform: translateY(-10px); border-color: rgba(255,255,255,.15); box-shadow: 0 20px 40px rgba(0,0,0,.2); }
.hm-f-card:hover::before { opacity: 1; }

.hm-f-icon-wrap {
    width: 80px; height: 80px; border-radius: 22px; margin: 0 auto 1.5rem;
    display: flex; align-items: center; justify-content: center; font-size: 2.2rem;
    background: rgba(15,23,42,.5); box-shadow: inset 0 1px 0 rgba(255,255,255,.1);
    color: #fff; transition: transform .3s; animation: hm-float 6s infinite ease-in-out;
}
.hm-f-card:nth-child(2) .hm-f-icon-wrap { animation-delay: -2s; }
.hm-f-card:nth-child(3) .hm-f-icon-wrap { animation-delay: -4s; }

.hm-f-card:hover .hm-f-icon-wrap { transform: scale(1.1); }
.hm-f-title { font-size: 1.25rem; font-weight: 800; color: #f8fafc; margin-bottom: .8rem; }
.hm-f-desc { font-size: .9rem; color: #94a3b8; line-height: 1.6; margin: 0; }

/* ── STATS SECTION ── */
.hm-stats-sec { padding: 4rem 2rem; background: rgba(15,23,42,.6); border-top: 1px solid rgba(255,255,255,.03); border-bottom: 1px solid rgba(255,255,255,.03); }
.hm-s-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 4rem; max-width: 1000px; margin: 0 auto; }
@@media(max-width:768px){ .hm-s-grid{gap:2rem;} }
.hm-s-item { text-align: center; }
.hm-s-val { font-size: 3rem; font-weight: 900; color: #fff; line-height: 1; margin-bottom: .5rem; }
.hm-s-lbl { font-size: .85rem; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: .1em; }

/* ── FOOTER ── */
.hm-footer { padding: 3rem 2rem 2rem; text-align: center; color: #64748b; font-size: .85rem; max-width: 1200px; margin: 0 auto; }
.hm-footer a { color: #818cf8; text-decoration: none; font-weight: 600; }
</style>

@* =========================================
   HERO SECTION
========================================= *@
<div class="hm-hero">
    <div class="hm-bg-blob hm-blob-1"></div>
    <div class="hm-bg-blob hm-blob-2"></div>
    <div class="hm-bg-blob hm-blob-3"></div>

    <div class="hm-hero-content">
        <div class="hm-badge">
            <i class="bi bi-stars"></i>
            <span>Giải pháp thông minh cho trường học</span>
        </div>
        
        <h1 class="hm-title">
            Academic Event <br />
            <span class="hm-title-grad">Management System</span>
        </h1>
        
        <p class="hm-subtitle">
            Nền tảng số hóa tối thượng giúp sinh viên, ban tổ chức và ban lãnh đạo quản lý mọi sự kiện học thuật một cách chuyên nghiệp, sống động và liền mạch.
        </p>

        @* LOGIN PANEL *@
        <div class="hm-auth-card">
            @if (User.Identity?.IsAuthenticated == true)
            {
                var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Unknown";
                var name = User.FindFirst("Fullname")?.Value ?? User.Identity.Name ?? "System User";

                <div class="hm-greeting">Welcome back, @name!</div>
                <div class="hm-role-tag">Bạn đang đăng nhập với vai trò: @role</div>

                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Admin" asp-action="Index" class="hm-btn-primary">
                        <i class="bi bi-speedometer2"></i> Quản Trị Hệ Thống
                    </a>
                }
                else if (User.IsInRole("Organizer"))
                {
                    <a asp-controller="Organizer" asp-action="Index" class="hm-btn-primary">
                        <i class="bi bi-diagram-3-fill"></i> Quản Lý Sự Kiện
                    </a>
                }
                else if (User.IsInRole("Approver"))
                {
                    <a asp-controller="Approver" asp-action="Index" class="hm-btn-primary">
                        <i class="bi bi-check-circle-fill"></i> Duyệt Sự Kiện
                    </a>
                }
                else if (User.IsInRole("Student"))
                {
                    <a asp-controller="StudentEvent" asp-action="Index" class="hm-btn-primary">
                        <i class="bi bi-compass-fill"></i> Khám Phá Sự Kiện
                    </a>
                }
                else
                {
                    <button class="hm-btn-primary" style="opacity:.5;cursor:not-allowed;">Dashboard Unavailable</button>
                }
                
                <form asp-controller="Auth" asp-action="Logout" method="post" style="margin-top:1rem;">
                    <button type="submit" class="hm-btn-outline" style="border:none;background:transparent;color:#fca5a5;padding:.5rem;margin:0 auto;">
                        Đăng xuất <i class="bi bi-box-arrow-right"></i>
                    </button>
                </form>
            }
            else
            {
                <div class="hm-greeting" style="margin-bottom:.5rem;">Bắt đầu hành trình</div>
                <p class="hm-unauth-text">Đăng nhập để trải nghiệm nền tảng quản lý sự kiện hiện đại và sống động nhất dành cho sinh viên.</p>

                <a asp-controller="Auth" asp-action="Login" class="hm-btn-primary">
                    Đăng nhập Hệ thống <i class="bi bi-arrow-right"></i>
                </a>
                <a asp-controller="Auth" asp-action="RegisterStudent" class="hm-btn-outline">
                    <i class="bi bi-person-plus-fill"></i> Đăng ký tài khoản Sinh viên
                </a>
            }
        </div>
    </div>
</div>

@* =========================================
   STATS SECTION
========================================= *@
<div class="hm-stats-sec">
    <div class="hm-s-grid">
        <div class="hm-s-item">
            <div class="hm-s-val cnt-stat" data-to="5000">0</div>
            <div class="hm-s-lbl">Sinh viên tham gia</div>
        </div>
        <div class="hm-s-item">
            <div class="hm-s-val cnt-stat" data-to="120">0</div>
            <div class="hm-s-lbl">Sự kiện thành công</div>
        </div>
        <div class="hm-s-item">
            <div class="hm-s-val cnt-stat" data-to="35">0</div>
            <div class="hm-s-lbl">Câu lạc bộ &amp; Phòng ban</div>
        </div>
        <div class="hm-s-item">
            <div class="hm-s-val cnt-stat" data-to="99" data-suffix="%">0</div>
            <div class="hm-s-lbl">Hài lòng</div>
        </div>
    </div>
</div>

@* =========================================
   FEATURES SECTION
========================================= *@
<div class="hm-features-sec">
    <div class="hm-section-title">
        <span class="hm-st-small">Tính năng cốt lõi</span>
        <h2 class="hm-st-main">Trải nghiệm vượt trội, quản lý toàn diện</h2>
    </div>

    <div class="hm-f-grid">
        <div class="hm-f-card" style="--hover-color: rgba(99,102,241,.15);">
            <div class="hm-f-icon-wrap" style="color: #818cf8;"><i class="bi bi-calendar-event"></i></div>
            <h4 class="hm-f-title">Tổ chức Siêu tốc</h4>
            <p class="hm-f-desc">Lên kế hoạch, xin cấp phép và triển khai sự kiện chuyên nghiệp với quy trình số hóa 100%. Không còn rườm rà giấy tờ.</p>
        </div>
        <div class="hm-f-card" style="--hover-color: rgba(16,185,129,.15);">
            <div class="hm-f-icon-wrap" style="color: #34d399;"><i class="bi bi-qr-code-scan"></i></div>
            <h4 class="hm-f-title">Check-in Điện tử</h4>
            <p class="hm-f-desc">Cấp vé QR code độc nhất cho từng người dùng, check-in bằng smartphone trong 1 giây, kiểm soát số lượng cực kỳ chính xác.</p>
        </div>
        <div class="hm-f-card" style="--hover-color: rgba(244,63,94,.15);">
            <div class="hm-f-icon-wrap" style="color: #fb7185;"><i class="bi bi-bell-fill"></i></div>
            <h4 class="hm-f-title">Kết nối &amp; Thông báo</h4>
            <p class="hm-f-desc">Tự động cập nhật trạng thái sự kiện, thông báo nhắc nhở real-time. Thu thập feedback tức thì để nâng cao chất lượng.</p>
        </div>
    </div>
</div>

<div class="hm-footer">
    <div style="width:50px;height:2px;background:rgba(255,255,255,.1);margin:0 auto 1.5rem;"></div>
    &copy; @DateTime.Now.Year — <span style="color:#e2e8f0;font-weight:700;">AEMS Luminous</span>. Thiết kế và phát triển bởi Đội ngũ AEMS. <br/>
    <a href="#">Điều khoản sử dụng</a> &middot; <a href="#">Bảo mật</a> &middot; <a href="#">Trợ giúp</a>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', () => {

    // ── Number Counter Animation ──
    const counters = document.querySelectorAll('.cnt-stat');
    const observer = new IntersectionObserver((entries, obs) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const el = entry.target;
                const target = +el.dataset.to;
                const suffix = el.dataset.suffix || '';
                let cur = 0;
                const dur = 2000;
                const fps = 60;
                const step = target / (dur / (1000/fps));
                
                const timer = setInterval(() => {
                    cur += step;
                    if (cur >= target) {
                        el.textContent = target + suffix;
                        clearInterval(timer);
                    } else {
                        el.textContent = Math.floor(cur) + suffix;
                    }
                }, 1000/fps);
                
                obs.unobserve(el);
            }
        });
    }, { threshold: 0.5 });
    
    counters.forEach(c => observer.observe(c));

    // ── Observer for Fade elements ──
    const titles = document.querySelectorAll('.hm-section-title');
    const titleObs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
            if (e.isIntersecting) {
                e.target.classList.add('is-visible');
            }
        });
    }, { threshold: 0.2 });
    titles.forEach(t => titleObs.observe(t));

});
</script>
}
