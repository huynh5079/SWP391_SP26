@{
    ViewData["Title"] = "Home Page";
}

@{
    ViewData["Title"] = "Academic Event Management";
}

<div class="text-center">
    <h1 class="display-4">Welcome to AEMS</h1>
    <p class="lead">The ultimate platform for managing academic events effectively.</p>
    
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="mt-4">
            <h3>Hello, @(User.FindFirst("Fullname")?.Value ?? User.Identity.Name)!</h3>
            <p>You are logged in as <strong>@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</strong>.</p>
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Admin" asp-action="Index" class="btn btn-primary btn-lg">Go to Dashboard</a>
            }
            else if (User.IsInRole("Organizer"))
            {
                <a asp-controller="Organizer" asp-action="Index" class="btn btn-primary btn-lg">Go to Dashboard</a>
            }
            else if (User.IsInRole("Organizer"))
            {
                <a asp-controller="Organizer" asp-action="Index" class="btn btn-primary btn-lg">Go to Dashboard</a>
            }
            else if (User.IsInRole("Student"))
            {
                <a asp-controller="Student" asp-action="Index" class="btn btn-primary btn-lg">Go to Dashboard</a>
            }
            else
            {
                 <a href="#" class="btn btn-secondary btn-lg disabled">Dasbhoard Unavailable</a>
            }
        </div>
    }
    else
    {
        <div class="mt-4">
            <p>Please login to access event management features.</p>
            <a asp-controller="Auth" asp-action="Login" class="btn btn-primary btn-lg mx-2">Login</a>
            <a asp-controller="Auth" asp-action="RegisterStudent" class="btn btn-outline-primary btn-lg mx-2">Register as Student</a>
        </div>
    }
</div>
