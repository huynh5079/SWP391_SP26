<Page x:Class="AEMS_WPF.Views.Dashboard.OverviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AEMS_WPF.Views.Dashboard"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Overview">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,40">
                <!-- Welcome Section -->
                <TextBlock x:Name="txtWelcome" Text="Hello, Staff Member!" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                <TextBlock Text="Here's what's happening with your events today." Foreground="{StaticResource TextMutedBrush}" FontSize="16" Margin="0,0,0,30"/>

                <!-- Stats Cards -->
                <Grid Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Height="140" CornerRadius="20" Background="{StaticResource PrimaryButtonGradient}" Padding="25">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Total Events" Foreground="White" Opacity="0.8" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtStatTotal" Text="0" Foreground="White" FontSize="36" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Height="140" CornerRadius="20" Background="#1e293b" BorderBrush="{StaticResource LowWhiteBrush}" BorderThickness="1" Padding="25">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Upcoming" Foreground="{StaticResource TextMutedBrush}" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtStatUpcoming" Text="0" Foreground="White" FontSize="36" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Height="140" CornerRadius="20" Background="#1e293b" BorderBrush="{StaticResource LowWhiteBrush}" BorderThickness="1" Padding="25">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Pending" Foreground="{StaticResource TextMutedBrush}" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtStatPending" Text="0" Foreground="#fbbf24" FontSize="36" FontWeight="Bold" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="6" Height="140" CornerRadius="20" Background="#1e293b" BorderBrush="{StaticResource LowWhiteBrush}" BorderThickness="1" Padding="25">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Revenue (VND)" Foreground="{StaticResource TextMutedBrush}" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtStatRevenue" Text="0" Foreground="#34d399" FontSize="24" FontWeight="Bold" Margin="0,15,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Upcoming Events Table -->
                    <Border Grid.Column="0" Background="#1e293b" CornerRadius="20" Padding="25">
                        <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="Upcoming Events" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                <Button Content="View All" HorizontalAlignment="Right" Background="Transparent" Foreground="{StaticResource IndigoAccentBrush}" BorderThickness="0" Cursor="Hand"/>
                            </Grid>
                            <ItemsControl x:Name="UpcomingList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource LowWhiteBrush}" BorderThickness="0,0,0,1" Padding="0,15">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="50" Height="50" CornerRadius="10" Background="{StaticResource LowWhiteBrush}" Margin="0,0,15,0">
                                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" FontSize="15"/>
                                                    <TextBlock Text="{Binding StartTime, StringFormat='MMM dd, yyyy'}" Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding Status}" Foreground="#fbbf24" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Feedbacks -->
                    <Border Grid.Column="2" Background="#1e293b" CornerRadius="20" Padding="25">
                        <StackPanel>
                            <TextBlock Text="Recent Feedback" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                            <ItemsControl x:Name="FeedbackList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,20">
                                            <TextBlock Text="{Binding Comment}" Foreground="{StaticResource TextMutedBrush}" FontStyle="Italic" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding EventTitle}" Foreground="White" FontSize="12" Margin="0,5,0,0"/>
                                            <TextBlock Text="⭐⭐⭐⭐⭐" Foreground="#fbbf24" FontSize="10"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="txtNoFeedback" Text="No recent feedback found." Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,20,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Admin Section: Activity and Sync Alerts -->
                <Grid x:Name="AdminSection" Margin="0,30,0,0" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1e293b" CornerRadius="20" Padding="25">
                         <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="System Activity" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="&#xEC92;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource IndigoAccentBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="18"/>
                            </Grid>
                            <ItemsControl x:Name="ActivityList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource LowWhiteBrush}" BorderThickness="0,0,0,1" Padding="0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Description}" Foreground="White" FontSize="13" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding User.FullName}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding CreatedAt, StringFormat='HH:mm'}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" VerticalAlignment="Top"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#1e293b" CornerRadius="20" Padding="25">
                        <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="Recent Alerts" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="&#xEA8F;" FontFamily="Segoe MDL2 Assets" Foreground="#fbbf24" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="18"/>
                            </Grid>
                            <ItemsControl x:Name="AlertList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                                <TextBlock Text="{Binding Message}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" MaxHeight="40" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
