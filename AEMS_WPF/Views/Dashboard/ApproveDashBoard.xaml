<Page x:Class="AEMS_WPF.Views.Dashboard.ApproveDashBoard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AEMS_WPF.Views.Dashboard"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="ApproveDashBoard">

    <Page.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuButtonStyleActive" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Page.Resources>

    <Grid Margin="24" Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Approver Dashboard" FontSize="28" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,4"/>
                    <TextBlock Text="Manage event approvals, review requests, and track key statistics seamlessly." Foreground="#64748B"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Approvals" Style="{StaticResource MenuButtonStyleActive}"/>
                    <Button Content="Topics" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Locations" Style="{StaticResource MenuButtonStyle}"/>
                    <Button Content="Agenda" Style="{StaticResource MenuButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,20">
            <Border Background="White" CornerRadius="12" Margin="0,0,12,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="TOTAL PENDING" FontSize="11" FontWeight="Bold" Foreground="#94A3B8"/>
                    <TextBlock x:Name="tbTotalPending" Text="1" FontSize="28" FontWeight="Bold" Foreground="#1E293B" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="12" Margin="0,0,12,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="APPROVED" FontSize="11" FontWeight="Bold" Foreground="#94A3B8"/>
                    <TextBlock x:Name="tbApproved" Text="0" FontSize="28" FontWeight="Bold" Foreground="#1E293B" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="12" Margin="0,0,12,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="REJECTED" FontSize="11" FontWeight="Bold" Foreground="#94A3B8"/>
                    <TextBlock x:Name="tbRejected" Text="0" FontSize="28" FontWeight="Bold" Foreground="#1E293B" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="ACTION REQUIRED" FontSize="11" FontWeight="Bold" Foreground="#94A3B8"/>
                    <TextBlock x:Name="tbActionRequired" Text="1" FontSize="28" FontWeight="Bold" Foreground="#1E293B" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="Recent Pending Events" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                    <Button Content="View All →" Background="Transparent" BorderThickness="0" Foreground="#4F46E5" Margin="10,0,0,0" Cursor="Hand"/>
                </StackPanel>

                <DataGrid x:Name="dgPendingApprovals" Grid.Row="1" AutoGenerateColumns="False" 
                          CanUserAddRows="False" GridLinesVisibility="None" Background="Transparent" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Event" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="10,5">
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" Foreground="#1E293B"/>
                                        <TextBlock Text="{Binding LocationName}" FontSize="11" Foreground="#94A3B8"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Organizer" Binding="{Binding OrganizerName}" Width="*"/>
                        <DataGridTextColumn Header="Start Time" Width="*">
                            <DataGridTextColumn.Binding>
                                <Binding Path="StartTime" StringFormat="{}{0:dd MMM yyyy, HH:mm}" />
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Status" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#FFF7ED" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left">
                                        <TextBlock Text="Pending" Foreground="#92560B" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Actions" Width="320">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0">
                                        <Button Content="View" 
                        Background="#F1F5F9" Foreground="#475569" 
                        Width="60" Height="30" Margin="2"
                        Cursor="Hand" Click="BtnView_Click">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="6"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>

                                        <Button Content="Approve" 
                        Background="#10B981" Foreground="White" 
                        Width="75" Height="30" Margin="2"
                        Cursor="Hand" Click="BtnApprove_Click">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="6"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>

                                        <Button Content="Change" 
                        Background="#F59E0B" Foreground="White" 
                        Width="75" Height="30" Margin="2"
                        Cursor="Hand" Click="BtnRequestChange_Click">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="6"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>

                                        <Button Content="Reject" 
                        Background="#EF4444" Foreground="White" 
                        Width="70" Height="30" Margin="2"
                        Cursor="Hand" Click="BtnReject_Click">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="6"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>