<Page x:Class="AEMS_WPF.Views.Approver.LocationManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AEMS_WPF.Views.Approver"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1100" Background="#F1F5F9"
      Title="LocationManagementPage">

    <Page.Resources>
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
        </Style>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#6366F1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,25">
            <StackPanel Orientation="Horizontal">
                <Button Content="← Back" Click="BtnBack_Click" Margin="0,0,16,0"
                        Background="Transparent" Foreground="#6366F1" BorderThickness="0"
                        FontSize="14" FontWeight="SemiBold" Cursor="Hand" VerticalAlignment="Center"/>
                <Border Background="#6366F1" CornerRadius="12" Width="48" Height="48">
                    <TextBlock Text="📍" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                <StackPanel Margin="16,0">
                    <TextBlock Text="Manage Locations" FontSize="28" FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock Text="Browse and manage all venue locations." Foreground="#64748B" FontSize="14"/>
                </StackPanel>
            </StackPanel>
            <Button x:Name="btnAddToggle" Content="+ Add Location" HorizontalAlignment="Right"
                    Style="{StaticResource RoundedButtonStyle}" Click="BtnAdd_Click"/>
        </Grid>

        <!-- Stats -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,25">
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="TOTAL" FontSize="11" Foreground="#94A3B8" FontWeight="Bold"/>
                    <TextBlock x:Name="txtTotalCount" Text="0" FontSize="26" FontWeight="Bold" Foreground="#1E293B" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="AVAILABLE" FontSize="11" Foreground="#10B981" FontWeight="Bold"/>
                    <TextBlock x:Name="txtAvailableCount" Text="0" FontSize="26" FontWeight="Bold" Foreground="#1E293B" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="MAINTENANCE" FontSize="11" Foreground="#3B82F6" FontWeight="Bold"/>
                    <TextBlock x:Name="txtMaintenanceCount" Text="0" FontSize="26" FontWeight="Bold" Foreground="#1E293B" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="TOTAL CAPACITY" FontSize="11" Foreground="#94A3B8" FontWeight="Bold"/>
                    <TextBlock x:Name="txtTotalCapacity" Text="0" FontSize="26" FontWeight="Bold" Foreground="#1E293B" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Inline Form (ẩn mặc định) -->
        <Border x:Name="FormPanel" Grid.Row="2" Background="White" CornerRadius="12" 
                Padding="24" Margin="0,0,0,20" Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="txtFormTitle" Text="Add New Location" FontSize="16" 
                           FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,16"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Name -->
                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,12,12">
                        <TextBlock Text="Name *" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="frmName" Style="{StaticResource InputStyle}"/>
                    </StackPanel>

                    <!-- Address -->
                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,12,12">
                        <TextBlock Text="Address *" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="frmAddress" Style="{StaticResource InputStyle}"/>
                    </StackPanel>

                    <!-- Capacity -->
                    <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Capacity *" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="frmCapacity" Style="{StaticResource InputStyle}"/>
                    </StackPanel>

                    <!-- Status -->
                    <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,12,12">
                        <TextBlock Text="Status *" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="frmStatus" Style="{StaticResource ComboStyle}"/>
                    </StackPanel>

                    <!-- Type -->
                    <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,12,12">
                        <TextBlock Text="Type" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="frmType" Style="{StaticResource ComboStyle}"/>
                    </StackPanel>

                    <!-- Description -->
                    <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,0,0,12">
                        <TextBlock Text="Description" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="frmDescription" Style="{StaticResource InputStyle}"/>
                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Grid.Column="2" Grid.Row="2" Orientation="Horizontal" 
                                HorizontalAlignment="Right">
                        <Button Content="Cancel" Click="BtnFormCancel_Click" Cursor="Hand"
                                Background="#E2E8F0" Foreground="#475569" Padding="16,8"
                                Margin="0,0,10,0" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          Margin="{TemplateBinding Padding}"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="btnFormSave" Content="Save" Click="BtnFormSave_Click"
                                Style="{StaticResource RoundedButtonStyle}" Padding="16,8"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Search Bar -->
        <Border Grid.Row="3" Background="White" CornerRadius="25" Padding="20,5" Margin="0,0,0,25">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtSearch" BorderThickness="0" VerticalContentAlignment="Center"
                         FontSize="14" Foreground="#1E293B"/>
                <Button Grid.Column="1" Content="Search" Width="100" Margin="10,5"
                        Style="{StaticResource RoundedButtonStyle}" Click="BtnSearch_Click"/>
                <Button Grid.Column="2" Content="Clear" Background="Transparent" Foreground="#64748B"
                        BorderThickness="0" Click="BtnClear_Click" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- List -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="icLocations">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="12" Margin="0,0,0,12" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="2.5*"/>
                                    <ColumnDefinition Width="2.5*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="#EEF2FF" CornerRadius="10"
                                        Width="44" Height="44" HorizontalAlignment="Left">
                                    <TextBlock Text="🏢" HorizontalAlignment="Center"
                                               VerticalAlignment="Center" FontSize="18"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" Foreground="#1E293B"/>
                                    <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#94A3B8" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="📍" Foreground="#6366F1" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Address}" Foreground="#64748B" FontSize="13" TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="20,0">
                                    <TextBlock FontWeight="SemiBold" Foreground="#1E293B">
                                        <Run Text="{Binding Capacity}"/>
                                        <Run Text=" seats" FontSize="11" Foreground="#94A3B8"/>
                                    </TextBlock>
                                    <ProgressBar Value="{Binding Capacity}" Maximum="200" Height="4"
                                                 Margin="0,6,0,0" Foreground="#6366F1"
                                                 Background="#F1F5F9" BorderThickness="0"/>
                                </StackPanel>

                                <Border Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Left"
                                        Padding="10,4" CornerRadius="15" Background="#F1F5F9">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6" Height="6" Fill="#6366F1" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Bold" Foreground="#6366F1"/>
                                    </StackPanel>
                                </Border>

                                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="✏️" Background="Transparent" BorderThickness="0"
                                            Margin="0,0,10,0" Click="BtnEdit_Click" Tag="{Binding}" Cursor="Hand"/>
                                    <Button Content="🗑️" Background="Transparent" BorderThickness="0"
                                            Click="BtnDelete_Click" Tag="{Binding}" Cursor="Hand"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>