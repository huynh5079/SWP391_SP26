<Page x:Class="AEMS_WPF.Views.Approver.TopicManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AEMS_WPF.Views.Approver"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1100" Background="#F1F5F9"
      Title="Topic Management">

    <Page.Resources>
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#6366F1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,25">
            <StackPanel Orientation="Horizontal">
                <Button Content="← Back" Click="BtnBack_Click" Margin="0,0,16,0"
                        Background="Transparent" Foreground="#6366F1" BorderThickness="0"
                        FontSize="14" FontWeight="SemiBold" Cursor="Hand" VerticalAlignment="Center"/>
                <Border Background="#6366F1" CornerRadius="12" Width="48" Height="48">
                    <TextBlock Text="📌" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                <StackPanel Margin="16,0">
                    <TextBlock Text="Topic Management" FontSize="28" FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock Text="Create, update or remove event categories." Foreground="#64748B" FontSize="14"/>
                </StackPanel>
            </StackPanel>
            <Button Content="+ Add New Topic" HorizontalAlignment="Right" Style="{StaticResource RoundedButtonStyle}" Click="BtnAdd_Click"/>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,25">
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="TOTAL TOPICS" FontSize="11" Foreground="#94A3B8" FontWeight="Bold"/>
                    <TextBlock x:Name="txtTotalCount" Text="0" FontSize="26" FontWeight="Bold" Foreground="#1E293B" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="THIS MONTH" FontSize="11" Foreground="#6366F1" FontWeight="Bold"/>
                    <TextBlock x:Name="txtThisMonthCount" Text="0" FontSize="26" FontWeight="Bold" Foreground="#1E293B" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="RECENT UPDATES" FontSize="11" Foreground="#10B981" FontWeight="Bold"/>
                    <TextBlock x:Name="txtRecentlyUpdated" Text="0" FontSize="26" FontWeight="Bold" Foreground="#1E293B" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="15,5" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtSearch" BorderThickness="0" VerticalContentAlignment="Center" FontSize="14" 
                         Foreground="#1E293B" Padding="10" Tag="Search topic name..."/>
                <Button Grid.Column="1" Content="Search" Width="100" Margin="10,5" Style="{StaticResource RoundedButtonStyle}" Click="BtnSearch_Click"/>
                <Button Grid.Column="2" Content="Clear" Background="Transparent" Foreground="#64748B" BorderThickness="0" Click="BtnClear_Click" Cursor="Hand" Margin="10,0"/>
            </Grid>
        </Border>

        <Border x:Name="EditorPanel" Grid.Row="3" Visibility="Collapsed" 
                Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,20"
                BorderBrush="#6366F1" BorderThickness="1.5">
            <StackPanel>
                <TextBlock x:Name="lblEditorTitle" Text="Add New Topic" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Topic Name" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                        <TextBox x:Name="inputName" Padding="12,10" Background="#F8FAFC" BorderBrush="#E2E8F0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,20,0">
                        <TextBlock Text="Description" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                        <TextBox x:Name="inputDescription" Padding="12,10" Background="#F8FAFC" BorderBrush="#E2E8F0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button Content="Save Changes" Style="{StaticResource RoundedButtonStyle}" Click="BtnSave_Click" Width="130"/>
                        <Button Content="Cancel" Margin="10,0,0,0" Background="Transparent" Foreground="#EF4444" 
                                BorderThickness="0" Click="BtnCancel_Click" Cursor="Hand" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="icTopics">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="12" Margin="0,0,0,12" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="#EEF2FF" CornerRadius="10" Width="44" Height="44" HorizontalAlignment="Left">
                                    <TextBlock Text="📌" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                    <TextBlock Text="{Binding TopicName}" FontWeight="Bold" FontSize="15" Foreground="#1E293B"/>
                                    <TextBlock Text="{Binding TopicId}" FontSize="11" Foreground="#CBD5E1"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="{Binding Description}" Foreground="#64748B" 
                                           VerticalAlignment="Center" TextWrapping="Wrap" Margin="10,0"/>

                                <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="20,0">
                                    <TextBlock FontSize="11" Foreground="#94A3B8">
                                        <Run Text="Updated: "/>
                                        <Run Text="{Binding UpdatedAt, StringFormat={}{0:dd/MM/yyyy}}" Foreground="#1E293B" FontWeight="SemiBold"/>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="✏️" Background="Transparent" BorderThickness="0" Margin="0,0,10,0" 
                                            Click="BtnEdit_Click" Tag="{Binding}" Cursor="Hand" FontSize="16"/>
                                    <Button Content="🗑️" Background="Transparent" BorderThickness="0" 
                                            Click="BtnDelete_Click" Tag="{Binding}" Cursor="Hand" FontSize="16"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>