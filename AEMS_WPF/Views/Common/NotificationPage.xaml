<Page x:Class="AEMS_WPF.Views.Common.NotificationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AEMS_WPF.Views.Common"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Notifications">

    <Grid>
        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="System Notifications" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
            <TextBlock Text="Stay updated with the latest event activities and system alerts." Foreground="{StaticResource TextMutedBrush}" FontSize="14" Margin="0,0,0,30"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="500">
                <ItemsControl x:Name="NotificationList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource LowWhiteBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,12" BorderBrush="{StaticResource LowWhiteBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Border Width="45" Height="45" CornerRadius="22.5" Background="{StaticResource PrimaryButtonGradient}" Margin="0,0,15,0">
                                        <TextBlock Text="&#xEA8F;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold" FontSize="15" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding Message}" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" FontSize="13"/>
                                    </StackPanel>
                                    
                                    <TextBlock Grid.Column="2" Text="{Binding CreatedAt, StringFormat='dd/MM/yyyy HH:mm'}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" VerticalAlignment="Top"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</Page>
