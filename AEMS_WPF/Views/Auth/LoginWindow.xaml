<Window x:Class="AEMS_WPF.Views.Auth.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AEMS_WPF.Views.Auth"
        mc:Ignorable="d"
        Title="AEMS - Staff Login" Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource NavbarGradient}"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True">

    <Border CornerRadius="20" Background="{StaticResource NavbarGradient}" BorderBrush="{StaticResource LowWhiteBrush}" BorderThickness="1">
        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo Area -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,30">
                <Border Width="60" Height="60" CornerRadius="15" Background="{StaticResource PrimaryButtonGradient}" Margin="0,0,0,15">
                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="30" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="AEMS STAFF" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Advanced Event Management" FontSize="12" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Input Fields -->
            <StackPanel Grid.Row="1">
                <TextBlock Text="Email Address" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8" FontSize="13"/>
                <TextBox x:Name="txtEmail" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,20" Text="staff@aems.com"/>

                <TextBlock Text="Password" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8" FontSize="13"/>
                <PasswordBox x:Name="txtPassword" Style="{StaticResource ModernPasswordBoxStyle}" Margin="0,0,0,30"/>

                <Button Content="Login to Dashboard" Style="{StaticResource PrimaryButtonStyle}" Height="45" Click="BtnLogin_Click"/>
            </StackPanel>

            <!-- Footer -->
            <StackPanel Grid.Row="3" Margin="0,20,0,0">
                <TextBlock x:Name="lblError" Foreground="#f87171" HorizontalAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,10" Visibility="Collapsed"/>
                <Button Content="Exit Application" Foreground="{StaticResource TextMutedBrush}" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center" Click="BtnExit_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
