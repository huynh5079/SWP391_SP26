<Page x:Class="AEMS_WPF.Views.Organizer.AttendanceMonitorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AEMS_WPF.Views.Organizer"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Attendance Monitor">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,30">
            <StackPanel>
                <TextBlock x:Name="txtEventTitle" Text="Attendance Monitor" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                <TextBlock Text="Live monitoring of event check-ins and attendance statistics." Foreground="{StaticResource TextMutedBrush}" FontSize="14"/>
            </StackPanel>
            <Button Content="Back" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" Foreground="{StaticResource TextMutedBrush}" BorderThickness="0" Click="BtnBack_Click"/>
        </Grid>

        <!-- Stats Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource LowWhiteBrush}" CornerRadius="12" Padding="20" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Total Registered" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                    <TextBlock x:Name="txtTotalRegistered" Text="0" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource LowWhiteBrush}" CornerRadius="12" Padding="20" Margin="10,0,10,0">
                <StackPanel>
                    <TextBlock Text="Checked In" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                    <TextBlock x:Name="txtCheckedIn" Text="0" Foreground="#34d399" FontSize="32" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource LowWhiteBrush}" CornerRadius="12" Padding="20" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="Percentage" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                    <TextBlock x:Name="txtPercentage" Text="0%" Foreground="{StaticResource IndigoAccentBrush}" FontSize="32" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Live Feed / Manual Entry -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- Recent Activity List -->
            <Border Grid.Column="0" Background="{StaticResource LowWhiteBrush}" CornerRadius="15" Padding="20" Margin="0,0,20,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="LIVE CHECK-IN FEED" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>
                    
                    <ListView Grid.Row="1" x:Name="lvFeed" Background="Transparent" BorderThickness="0" Foreground="White">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource LowWhiteBrush}" CornerRadius="10" Padding="15" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="{StaticResource IndigoAccentBrush}" Margin="0,0,15,0">
                                            <TextBlock Text="{Binding Initials}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                        </Border>
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FullName}" Foreground="White" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding StudentCode}" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                                        </StackPanel>
                                        
                                        <TextBlock Grid.Column="2" Text="{Binding Timestamp, StringFormat='HH:mm:ss'}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Manual Control / QR Simulation -->
            <StackPanel Grid.Column="1">
                <Border Background="{StaticResource LowWhiteBrush}" CornerRadius="15" Padding="20" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="MANUAL CHECK-IN" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>
                        <TextBox x:Name="txtManualCode" Style="{StaticResource ModernTextBoxStyle}" Tag="Enter Student ID or Ticket Code" Margin="0,0,0,15"/>
                        <Button x:Name="BtnManualCheckIn" Content="Submit Check-in" Style="{StaticResource PrimaryButtonStyle}" Click="BtnManualCheckIn_Click"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource LowWhiteBrush}" CornerRadius="15" Padding="20">
                    <StackPanel>
                        <TextBlock Text="QR SCANNER SIMULATION" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>
                        <TextBlock Text="In a real production environment, this would integrate with a webcam or hardware scanner." Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,15"/>
                        <Button x:Name="BtnSimulateScan" Content="Simulate QR Scan" Background="Transparent" BorderThickness="1" BorderBrush="{StaticResource TextMutedBrush}" Foreground="White" Padding="10" Click="BtnSimulateScan_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
