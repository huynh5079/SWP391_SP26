<Page x:Class="AEMS_WPF.Views.Organizer.EventListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AEMS_WPF.Views.Organizer"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1000"
      Title="My Events">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,30">
            <StackPanel>
                <TextBlock Text="My Managed Events" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                <TextBlock Text="Overview of all events you are organizing and their current status." Foreground="{StaticResource TextMutedBrush}" FontSize="14"/>
            </StackPanel>
            <Button Content="+ Create New Event" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="20,10" Click="BtnCreate_Click"/>
        </Grid>

        <!-- Stats / Quick Info (Warp Panel for premium look) -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,30">
            <Border Width="200" Height="100" Background="{StaticResource LowWhiteBrush}" CornerRadius="15" Margin="0,0,20,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="Total Events" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                    <TextBlock x:Name="txtTotalEvents" Text="0" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            <Border Width="200" Height="100" Background="{StaticResource LowWhiteBrush}" CornerRadius="15" Margin="0,0,20,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="Pending Approval" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                    <TextBlock x:Name="txtPendingEvents" Text="0" Foreground="#fbbf24" FontSize="32" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            <Border Width="200" Height="100" Background="{StaticResource LowWhiteBrush}" CornerRadius="15" Padding="20">
                <StackPanel>
                    <TextBlock Text="Active Events" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                    <TextBlock x:Name="txtActiveEvents" Text="0" Foreground="#34d399" FontSize="32" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Event Table -->
        <Border Grid.Row="2" Background="{StaticResource LowWhiteBrush}" CornerRadius="15" Padding="10">
            <DataGrid x:Name="dgEvents" AutoGenerateColumns="False" 
                      Background="Transparent" BorderThickness="0" 
                      Foreground="White" GridLinesVisibility="None"
                      CanUserAddRows="False" IsReadOnly="True"
                      RowBackground="Transparent" Selector.IsSelected="False">
                 <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="15,10"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="{StaticResource LowWhiteBrush}"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Event Title" Binding="{Binding Title}" Width="*"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding StartTime, StringFormat='dd/MM/yyyy'}" Width="120"/>
                    <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="150"/>
                    <DataGridTemplateColumn Header="Status" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource LowWhiteBrush}" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Status}" FontSize="12" Foreground="White"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Actions" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                    <WrapPanel Orientation="Horizontal">
                                        <Button Content="Details" Background="Transparent" Foreground="{StaticResource IndigoAccentBrush}" BorderThickness="0" Cursor="Hand" Click="BtnDetails_Click" Margin="0,0,10,0"/>
                                        <Button Content="Participants" Background="Transparent" Foreground="{StaticResource PurpleAccentBrush}" BorderThickness="0" Cursor="Hand" Click="BtnParticipants_Click" Margin="0,0,10,0"/>
                                        <Button Content="Teams" Background="Transparent" Foreground="#34d399" BorderThickness="0" Cursor="Hand" Click="BtnTeams_Click" Margin="0,0,10,0"/>
                                        <Button Content="Expenses" Background="Transparent" Foreground="#fbbf24" BorderThickness="0" Cursor="Hand" Click="BtnExpenses_Click" Margin="0,0,10,0"/>
                                        <Button Content="Quiz" Background="Transparent" Foreground="#f87171" BorderThickness="0" Cursor="Hand" Click="BtnQuiz_Click"/>
                                    </WrapPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
