<Window x:Class="AEMS_WPF.Views.Organizer.ParticipantSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Select Participant" Height="450" Width="400"
        WindowStartupLocation="CenterOwner" Background="{StaticResource PrimaryBlueBrush}"
        WindowStyle="None" AllowsTransparency="True">
    <Border BorderBrush="{StaticResource LowWhiteBrush}" BorderThickness="1" CornerRadius="15" Background="{StaticResource PrimaryBlueBrush}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Select Member" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
            <TextBox Grid.Row="1" x:Name="txtSearch" Style="{StaticResource ModernTextBoxStyle}" Tag="Search by name or ID..." Margin="0,0,0,15" TextChanged="TxtSearch_TextChanged"/>
            
            <ListBox Grid.Row="2" x:Name="lbParticipants" Background="Transparent" BorderThickness="0" Foreground="White">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource LowWhiteBrush}" CornerRadius="10" Padding="15" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="{Binding FullName}" Foreground="White" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding StudentCode}" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Cancel" Background="Transparent" Foreground="{StaticResource TextMutedBrush}" BorderThickness="0" Click="BtnCancel_Click" Margin="0,0,10,0"/>
                <Button Content="Add to Team" Style="{StaticResource PrimaryButtonStyle}" Click="BtnSelect_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
