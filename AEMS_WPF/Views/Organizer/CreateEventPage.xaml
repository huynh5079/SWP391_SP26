<Page x:Class="AEMS_WPF.Views.Organizer.CreateEventPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AEMS_WPF.Views.Organizer"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="800"
      Title="Create New Event">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,40">
                <!-- Header -->
                <Grid Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="Submit New Event" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                        <TextBlock Text="Fill in the details below to request a new event approval." Foreground="{StaticResource TextMutedBrush}" FontSize="14"/>
                    </StackPanel>
                    <Button x:Name="BtnBack" Content="Back to List" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" Foreground="{StaticResource TextMutedBrush}" BorderThickness="0" Click="BtnBack_Click"/>
                </Grid>

                <Border Background="{StaticResource LowWhiteBrush}" CornerRadius="15" Padding="30">
                    <StackPanel>
                        <!-- Basic Info -->
                        <TextBlock Text="BASIC INFORMATION" Foreground="{StaticResource IndigoAccentBrush}" FontSize="12" FontWeight="Bold" Margin="0,0,0,20"/>
                        
                        <TextBlock Text="Event Title" Foreground="White" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtTitle" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,20" Tag="Event Name..."/>

                        <TextBlock Text="Description" Foreground="White" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtDescription" Style="{StaticResource ModernTextBoxStyle}" Height="100" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Start Date &amp; Time" Foreground="White" Margin="0,0,0,8"/>
                                <DatePicker x:Name="dpStart" Margin="0,0,0,10"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="End Date &amp; Time" Foreground="White" Margin="0,0,0,8"/>
                                <DatePicker x:Name="dpEnd"/>
                            </StackPanel>
                        </Grid>

                        <!-- Relations -->
                        <TextBlock Text="RELATIONS &amp; CLASSIFICATION" Foreground="{StaticResource IndigoAccentBrush}" FontSize="12" FontWeight="Bold" Margin="0,10,0,20"/>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Semester" Foreground="White" Margin="0,0,0,8"/>
                                <ComboBox x:Name="cbSemester" DisplayMemberPath="Text" SelectedValuePath="Id"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Department" Foreground="White" Margin="0,0,0,8"/>
                                <ComboBox x:Name="cbDepartment" DisplayMemberPath="Text" SelectedValuePath="Id"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Topic" Foreground="White" Margin="0,0,0,8"/>
                                <ComboBox x:Name="cbTopic" DisplayMemberPath="Text" SelectedValuePath="Id"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Event Type" Foreground="White" Margin="0,0,0,8"/>
                                <ComboBox x:Name="cbType">
                                    <ComboBoxItem Content="Seminar" IsSelected="True"/>
                                    <ComboBoxItem Content="Competition"/>
                                    <ComboBoxItem Content="Workshop"/>
                                    <ComboBoxItem Content="Outdoor"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <!-- Logistics -->
                        <TextBlock Text="LOGISTICS &amp; CAPACITY" Foreground="{StaticResource IndigoAccentBrush}" FontSize="12" FontWeight="Bold" Margin="0,10,0,20"/>

                        <Grid Margin="0,0,0,20">
                             <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Event Mode" Foreground="White" Margin="0,0,0,8"/>
                                <ComboBox x:Name="cbMode" SelectedIndex="0">
                                    <ComboBoxItem Content="Offline"/>
                                    <ComboBoxItem Content="Online"/>
                                    <ComboBoxItem Content="Hybrid"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Location / Meeting Link" Foreground="White" Margin="0,0,0,8"/>
                                <ComboBox x:Name="cbLocation" DisplayMemberPath="Text" SelectedValuePath="Id" Margin="0,0,0,10"/>
                                <TextBox x:Name="txtMeetingUrl" Style="{StaticResource ModernTextBoxStyle}" Tag="Online Meeting Link (if any)..."/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Max Capacity" Foreground="White" Margin="0,0,0,8"/>
                                <TextBox x:Name="txtCapacity" Style="{StaticResource ModernTextBoxStyle}" Text="100"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Deposit Required" Foreground="White" Margin="0,0,0,8"/>
                                <CheckBox x:Name="chkIsDeposit" Content="Requires Deposit" Foreground="White" Margin="0,5,0,5"/>
                                <TextBox x:Name="txtDepositAmount" Style="{StaticResource ModernTextBoxStyle}" Tag="Amount (VND)..." IsEnabled="{Binding IsChecked, ElementName=chkIsDeposit}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,30">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Reg. Open Date" Foreground="White" Margin="0,0,0,8"/>
                                <DatePicker x:Name="dpRegOpen"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Reg. Close Date" Foreground="White" Margin="0,0,0,8"/>
                                <DatePicker x:Name="dpRegClose"/>
                            </StackPanel>
                        </Grid>

                        <!-- Agenda -->
                        <TextBlock Text="AGENDA &amp; SESSIONS" Foreground="{StaticResource IndigoAccentBrush}" FontSize="12" FontWeight="Bold" Margin="0,10,0,10"/>
                        <Grid Margin="0,0,0,10">
                            <Button x:Name="BtnAddSession" Content="+ Add Session" HorizontalAlignment="Right" Click="BtnAddSession_Click" Style="{StaticResource ModernButtonStyle}" Width="120" Height="30"/>
                        </Grid>
                        
                        <DataGrid x:Name="dgAgenda" AutoGenerateColumns="False" CanUserAddRows="False" 
                                  Background="Transparent" BorderThickness="0" Margin="0,0,0,20" 
                                  MinHeight="150" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Session Name" Binding="{Binding SessionName}" Width="*"/>
                                <DataGridTextColumn Header="Time" Binding="{Binding StartTime, StringFormat=HH:mm}" Width="80"/>
                                <DataGridTextColumn Header="Speaker" Binding="{Binding SpeakerInfo}" Width="150"/>
                                <DataGridTemplateColumn Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Remove" Click="BtnRemoveSession_Click" Background="Transparent" Foreground="Red" BorderThickness="0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Content="Submit for Approval" Style="{StaticResource PrimaryButtonStyle}" Height="50" Click="BtnSubmit_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
